{
  "name": "fajar-lang-playground",
  "version": "1.0.0",
  "description": "Browser-based Fajar Lang playground — write, run, share code instantly",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "wasm:build": "cd .. && wasm-pack build --target web --out-dir playground/pkg --no-typescript",
    "wasm:opt": "wasm-opt -Oz playground/pkg/fajar_lang_bg.wasm -o playground/pkg/fajar_lang_bg.wasm"
  },
  "dependencies": {
    "monaco-editor": "^0.52.0",
    "lz-string": "^1.5.0"
  },
  "devDependencies": {
    "vite": "^6.0.0"
  },
  "author": "Fajar (PrimeCore.id)",
  "license": "MIT"
}
