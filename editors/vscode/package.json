{
  "name": "fajar-lang",
  "displayName": "Fajar Lang",
  "description": "Fajar Lang (.fj) — systems programming for embedded ML & OS. Syntax highlighting, LSP (18 features), debugging (DAP), snippets. Formal verification, WASI P2, FFI v2, distributed runtime, self-hosting. 398K LOC, 7,402 tests.",
  "version": "11.0.0",
  "publisher": "primecore",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/fajarkraton/fajar-lang"
  },
  "homepage": "https://github.com/fajarkraton/fajar-lang",
  "bugs": {
    "url": "https://github.com/fajarkraton/fajar-lang/issues"
  },
  "keywords": [
    "fajar",
    "fj",
    "systems programming",
    "embedded",
    "machine learning",
    "tensor",
    "os development",
    "compiler",
    "cranelift",
    "llvm"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages", "Debuggers", "Snippets", "Linters"],
  "activationEvents": [
    "onLanguage:fajar",
    "onDebugResolve:fajar"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "fajar",
        "aliases": ["Fajar Lang", "fajar", "fj"],
        "extensions": [".fj"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "fajar",
        "scopeName": "source.fajar",
        "path": "./syntaxes/fajar-lang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "fajar",
        "path": "./snippets/fajar.json"
      }
    ],
    "breakpoints": [
      {
        "language": "fajar"
      }
    ],
    "debuggers": [
      {
        "type": "fajar",
        "label": "Fajar Lang Debug",
        "languages": ["fajar"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .fj file to debug",
                "default": "${workspaceFolder}/main.fj"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop at program entry point",
                "default": true
              },
              "fjPath": {
                "type": "string",
                "description": "Path to the fj binary",
                "default": "fj"
              },
              "args": {
                "type": "array",
                "description": "Arguments to pass to the program",
                "items": { "type": "string" },
                "default": []
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "Fajar Lang: Launch",
            "description": "Launch and debug a Fajar Lang program",
            "body": {
              "type": "fajar",
              "request": "launch",
              "name": "Debug Fajar Lang",
              "program": "^\"${1:${workspaceFolder}/main.fj}\"",
              "stopOnEntry": true
            }
          },
          {
            "label": "Fajar Lang: Launch (no stop)",
            "description": "Launch a Fajar Lang program without stopping on entry",
            "body": {
              "type": "fajar",
              "request": "launch",
              "name": "Run Fajar Lang",
              "program": "^\"${1:${workspaceFolder}/main.fj}\"",
              "stopOnEntry": false
            }
          }
        ],
        "initialConfigurations": [
          {
            "type": "fajar",
            "request": "launch",
            "name": "Debug Fajar Lang",
            "program": "${workspaceFolder}/main.fj",
            "stopOnEntry": true
          }
        ]
      }
    ],
    "problemMatchers": [
      {
        "name": "fj",
        "owner": "fajar",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^error\\[(\\w+)\\]:\\s+(.+)\\s+-->\\s+(.+):(\\d+):(\\d+)$",
          "code": 1,
          "message": 2,
          "file": 3,
          "line": 4,
          "column": 5
        }
      }
    ],
    "taskDefinitions": [
      {
        "type": "fj",
        "required": ["command"],
        "properties": {
          "command": {
            "type": "string",
            "description": "The fj command to run (build, test, run, check, fmt)"
          },
          "file": {
            "type": "string",
            "description": "Target file (optional)"
          }
        }
      }
    ],
    "keybindings": [
      {
        "command": "workbench.action.tasks.runTask",
        "key": "ctrl+shift+b",
        "when": "editorLangId == fajar",
        "args": "fj: Build"
      }
    ],
    "configuration": {
      "title": "Fajar Lang",
      "properties": {
        "fajarLang.server.path": {
          "type": "string",
          "default": "fj",
          "description": "Path to the Fajar Lang binary (fj)"
        },
        "fajarLang.debug.fjPath": {
          "type": "string",
          "default": "fj",
          "description": "Path to fj binary for debugging"
        },
        "fajarLang.debug.stopOnEntry": {
          "type": "boolean",
          "default": true,
          "description": "Stop at program entry point by default"
        }
      }
    }
  }
}
