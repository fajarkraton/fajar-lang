{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:void} {",
      "    ${0}",
      "}"
    ],
    "description": "Function definition with params and return type"
  },
  "Main Function": {
    "prefix": "main",
    "body": [
      "fn main() -> void {",
      "    ${0}",
      "}"
    ],
    "description": "Main entry point"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "    ${2:field}: ${3:type},",
      "}"
    ],
    "description": "Struct definition with fields"
  },
  "Enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "    ${2:Variant1}(${3:type}),",
      "    ${4:Variant2},",
      "}"
    ],
    "description": "Enum definition with variants"
  },
  "Match": {
    "prefix": "match",
    "body": [
      "match ${1:expr} {",
      "    ${2:pattern} => ${3:value},",
      "    _ => ${0}",
      "}"
    ],
    "description": "Match expression with arms"
  },
  "If-Else": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "    ${2}",
      "} else {",
      "    ${0}",
      "}"
    ],
    "description": "If/else expression"
  },
  "If Only": {
    "prefix": "iff",
    "body": [
      "if ${1:condition} {",
      "    ${0}",
      "}"
    ],
    "description": "If without else"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "    ${0}",
      "}"
    ],
    "description": "While loop"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:iterable} {",
      "    ${0}",
      "}"
    ],
    "description": "For..in loop"
  },
  "For Range": {
    "prefix": "forr",
    "body": [
      "for ${1:i} in ${2:0}..${3:10} {",
      "    ${0}",
      "}"
    ],
    "description": "For loop with range"
  },
  "Loop": {
    "prefix": "loop",
    "body": [
      "loop {",
      "    ${0}",
      "    break",
      "}"
    ],
    "description": "Infinite loop with break"
  },
  "Test Function": {
    "prefix": "test",
    "body": [
      "@test",
      "fn test_${1:name}() -> void {",
      "    ${0}",
      "    assert(true)",
      "}"
    ],
    "description": "@test annotated function"
  },
  "Test Should Panic": {
    "prefix": "testp",
    "body": [
      "@test",
      "@should_panic",
      "fn test_${1:name}() -> void {",
      "    ${0}",
      "    panic(\"expected panic\")",
      "}"
    ],
    "description": "@test function that should panic"
  },
  "Impl Block": {
    "prefix": "impl",
    "body": [
      "impl ${1:Type} {",
      "    fn ${2:method}(&self) -> ${3:void} {",
      "        ${0}",
      "    }",
      "}"
    ],
    "description": "Implementation block"
  },
  "Impl Trait": {
    "prefix": "implt",
    "body": [
      "impl ${1:Trait} for ${2:Type} {",
      "    fn ${3:method}(&self) -> ${4:void} {",
      "        ${0}",
      "    }",
      "}"
    ],
    "description": "Implement trait for type"
  },
  "Trait": {
    "prefix": "trait",
    "body": [
      "trait ${1:Name} {",
      "    fn ${2:method}(&self) -> ${3:void}",
      "}"
    ],
    "description": "Trait definition"
  },
  "Module Declaration": {
    "prefix": "mod",
    "body": [
      "mod ${1:name} {",
      "    ${0}",
      "}"
    ],
    "description": "Module declaration"
  },
  "Use Statement": {
    "prefix": "use",
    "body": "use ${1:module}::${2:item}",
    "description": "Use/import statement"
  },
  "Let Binding": {
    "prefix": "let",
    "body": "let ${1:name}: ${2:type} = ${0}",
    "description": "Immutable variable binding"
  },
  "Let Mut": {
    "prefix": "letm",
    "body": "let mut ${1:name}: ${2:type} = ${0}",
    "description": "Mutable variable binding"
  },
  "Const Declaration": {
    "prefix": "const",
    "body": "const ${1:NAME}: ${2:type} = ${0}",
    "description": "Constant declaration"
  },
  "Println": {
    "prefix": "println",
    "body": "println(${0})",
    "description": "Print with newline"
  },
  "Println Format": {
    "prefix": "plf",
    "body": "println(f\"${0}\")",
    "description": "Print formatted string"
  },
  "Print": {
    "prefix": "print",
    "body": "print(${0})",
    "description": "Print without newline"
  },
  "Assert": {
    "prefix": "assert",
    "body": "assert(${1:condition})",
    "description": "Assert condition is true"
  },
  "Assert Equal": {
    "prefix": "asserteq",
    "body": "assert_eq(${1:expected}, ${2:actual})",
    "description": "Assert two values are equal"
  },
  "Kernel Function": {
    "prefix": "@kernel",
    "body": [
      "@kernel fn ${1:name}(${2:params}) -> ${3:void} {",
      "    ${0}",
      "}"
    ],
    "description": "Kernel context function (OS, no heap, no tensor)"
  },
  "Device Function": {
    "prefix": "@device",
    "body": [
      "@device fn ${1:name}(${2:params}) -> ${3:Tensor} {",
      "    ${0}",
      "}"
    ],
    "description": "Device context function (ML, no raw ptr)"
  },
  "Unsafe Function": {
    "prefix": "@unsafe",
    "body": [
      "@unsafe fn ${1:name}(${2:params}) -> ${3:void} {",
      "    ${0}",
      "}"
    ],
    "description": "Unsafe context function (full access)"
  },
  "Result Ok/Err": {
    "prefix": "result",
    "body": [
      "fn ${1:name}(${2:params}) -> Result<${3:T}, ${4:str}> {",
      "    if ${5:error_condition} {",
      "        return Err(\"${6:error message}\")",
      "    }",
      "    Ok(${0})",
      "}"
    ],
    "description": "Function returning Result<T, E>"
  },
  "Option Some/None": {
    "prefix": "option",
    "body": [
      "fn ${1:name}(${2:params}) -> Option<${3:T}> {",
      "    if ${4:condition} {",
      "        return Some(${5:value})",
      "    }",
      "    None",
      "}"
    ],
    "description": "Function returning Option<T>"
  },
  "Closure": {
    "prefix": "closure",
    "body": "|${1:params}| ${0}",
    "description": "Closure expression"
  },
  "Iterator Chain": {
    "prefix": "iter",
    "body": [
      "${1:collection}",
      "    .iter()",
      "    .filter(|${2:x}| ${3:condition})",
      "    .map(|${4:x}| ${5:transform})",
      "    .collect()"
    ],
    "description": "Iterator chain with filter/map/collect"
  },
  "Tensor Zeros": {
    "prefix": "tzeros",
    "body": "let ${1:t} = zeros(${2:rows}, ${3:cols})",
    "description": "Create zero tensor"
  },
  "Tensor Xavier": {
    "prefix": "txavier",
    "body": "let ${1:weights} = xavier(${2:in_features}, ${3:out_features})",
    "description": "Xavier-initialized weight tensor"
  },
  "Dense Layer": {
    "prefix": "dense",
    "body": "let ${1:layer} = Dense(${2:in_features}, ${3:out_features})",
    "description": "Dense/fully-connected layer"
  },
  "Pub Function": {
    "prefix": "pubfn",
    "body": [
      "pub fn ${1:name}(${2:params}) -> ${3:void} {",
      "    ${0}",
      "}"
    ],
    "description": "Public function"
  },
  "Generic Function": {
    "prefix": "fng",
    "body": [
      "fn ${1:name}<${2:T}>(${3:params}: ${2:T}) -> ${4:T} {",
      "    ${0}",
      "}"
    ],
    "description": "Generic function with type parameter"
  },
  "Match Result": {
    "prefix": "matchr",
    "body": [
      "match ${1:expr} {",
      "    Ok(${2:val}) => ${3},",
      "    Err(${4:e}) => ${0},",
      "}"
    ],
    "description": "Match on Result<T, E>"
  },
  "Match Option": {
    "prefix": "matcho",
    "body": [
      "match ${1:expr} {",
      "    Some(${2:val}) => ${3},",
      "    None => ${0},",
      "}"
    ],
    "description": "Match on Option<T>"
  },
  "Pipeline": {
    "prefix": "pipe",
    "body": "${1:value} |> ${2:fn1} |> ${0}",
    "description": "Pipeline operator chain"
  },
  "Type Alias": {
    "prefix": "type",
    "body": "type ${1:Name} = ${0}",
    "description": "Type alias declaration"
  },
  "Async Function": {
    "prefix": "asyncfn",
    "body": [
      "async fn ${1:name}(${2:params}) -> ${3:void} {",
      "    ${0}",
      "}"
    ],
    "description": "Async function definition"
  },
  "F-String": {
    "prefix": "fstr",
    "body": "f\"${0}\"",
    "description": "Format string interpolation"
  },
  "Extern FFI": {
    "prefix": "extern",
    "body": [
      "extern \"C\" {",
      "    fn ${1:name}(${2:params}) -> ${3:void}",
      "}"
    ],
    "description": "External FFI function declaration"
  }
}
