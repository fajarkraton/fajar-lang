{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:void} {",
      "    ${0}",
      "}"
    ],
    "description": "Function definition"
  },
  "Main Function": {
    "prefix": "main",
    "body": [
      "fn main() -> void {",
      "    ${0}",
      "}"
    ],
    "description": "Main entry point"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "    ${2:field}: ${3:type}",
      "}"
    ],
    "description": "Struct definition"
  },
  "Enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "    ${2:Variant}(${3:type})",
      "}"
    ],
    "description": "Enum definition"
  },
  "Match": {
    "prefix": "match",
    "body": [
      "match ${1:expr} {",
      "    ${2:pattern} => ${3:value},",
      "    _ => ${0}",
      "}"
    ],
    "description": "Match expression"
  },
  "If-Else": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} {",
      "    ${2}",
      "} else {",
      "    ${0}",
      "}"
    ],
    "description": "If-else expression"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "    ${0}",
      "}"
    ],
    "description": "While loop"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} in ${2:0..10} {",
      "    ${0}",
      "}"
    ],
    "description": "For-in loop"
  },
  "Kernel Function": {
    "prefix": "@kernel",
    "body": [
      "@kernel fn ${1:name}(${2:params}) -> ${3:void} {",
      "    ${0}",
      "}"
    ],
    "description": "Kernel context function"
  },
  "Device Function": {
    "prefix": "@device",
    "body": [
      "@device fn ${1:name}(${2:params}) -> ${3:Tensor} {",
      "    ${0}",
      "}"
    ],
    "description": "Device context function (ML)"
  },
  "Let Binding": {
    "prefix": "let",
    "body": "let ${1:name}: ${2:type} = ${0}",
    "description": "Variable binding"
  },
  "Let Mut": {
    "prefix": "letm",
    "body": "let mut ${1:name}: ${2:type} = ${0}",
    "description": "Mutable variable binding"
  },
  "Println": {
    "prefix": "pl",
    "body": "println(${0})",
    "description": "Print with newline"
  },
  "Test Function": {
    "prefix": "test",
    "body": [
      "fn test_${1:name}() -> void {",
      "    ${0}",
      "    assert(true)",
      "}"
    ],
    "description": "Test function"
  },
  "Impl Block": {
    "prefix": "impl",
    "body": [
      "impl ${1:Type} {",
      "    fn ${2:method}(&self) -> ${3:void} {",
      "        ${0}",
      "    }",
      "}"
    ],
    "description": "Implementation block"
  },
  "Trait": {
    "prefix": "trait",
    "body": [
      "trait ${1:Name} {",
      "    fn ${2:method}(&self) -> ${3:void}",
      "}"
    ],
    "description": "Trait definition"
  }
}
