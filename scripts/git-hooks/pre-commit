#!/usr/bin/env bash
# Fajar Lang pre-commit hook — V26 Phase A1.2 + FJARR_LEAK Phase 1 step 18.0.4
#
# Rejects commits that introduce formatting drift OR that touch the
# `_fj_arr_new` / `_fj_arr_grow` allocator block in stdlib/codegen.fj
# without an ACCEPTED decision file.
# Bypass with --no-verify if absolutely necessary (discouraged).
#
# Source of truth: scripts/git-hooks/pre-commit
# Install via:    bash scripts/install-git-hooks.sh
#
# Three checks:
#   1. FJARR_LEAK decision-file gate — runs regardless of file types.
#      Per CLAUDE.md §6.8 R6 + FJARR_LEAK_PLAN §3 prevention layer.
#   2. cargo fmt --check          — catches drift in modular Rust files.
#   3. rustfmt --check <files>    — catches drift in staged orphan files.

set -e

# ────────────────────────────────────────────────────────────────────────
# Check 1: FJARR_LEAK decision-file gate
# ────────────────────────────────────────────────────────────────────────
# If the staged diff adds/modifies `_fj_arr_new` or `_fj_arr_grow` lines
# in stdlib/codegen.fj, require docs/decisions/2026-05-07-fjarr-leak-strategy.md
# to exist AND pass scripts/check_decision_file.sh. Detection is by content
# (grep for added lines containing the allocator names) rather than by line
# number, so the gate stays valid as the file evolves.

FJARR_TOUCHED=$(git diff --cached -- stdlib/codegen.fj 2>/dev/null \
    | grep -E '^\+.*(_fj_arr_new|_fj_arr_grow)' \
    | head -1 \
    || true)

if [ -n "$FJARR_TOUCHED" ]; then
    DECISION_FILE="docs/decisions/2026-05-07-fjarr-leak-strategy.md"
    CHECKER="scripts/check_decision_file.sh"

    if [ ! -f "$DECISION_FILE" ]; then
        echo ""
        echo "❌ Pre-commit blocked: stdlib/codegen.fj edits touch _fj_arr_new/_fj_arr_grow"
        echo "   but $DECISION_FILE is missing."
        echo ""
        echo "Per CLAUDE.md §6.8 R6 + FJARR_LEAK_PLAN §3, decisions must be committed"
        echo "files with the 7 canonical sections (see FJARR_LEAK_PLAN §1.3)."
        echo ""
        echo "Bypass (discouraged):  git commit --no-verify"
        echo ""
        exit 1
    fi

    if [ -x "$CHECKER" ] || [ -f "$CHECKER" ]; then
        if ! bash "$CHECKER" "$DECISION_FILE" >/dev/null 2>&1; then
            echo ""
            echo "❌ Pre-commit blocked: $DECISION_FILE is missing required sections."
            echo ""
            bash "$CHECKER" "$DECISION_FILE" 2>&1 || true
            echo ""
            echo "Bypass (discouraged):  git commit --no-verify"
            echo ""
            exit 1
        fi
    fi
fi

# ────────────────────────────────────────────────────────────────────────
# Checks 2 & 3 (Rust formatting): early-exit if no Rust files staged.
# ────────────────────────────────────────────────────────────────────────
RUST_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.rs$' || true)

if [ -z "$RUST_FILES" ]; then
    exit 0
fi

# Extract edition from Cargo.toml so rustfmt --check uses the same rules
# as cargo fmt. Without this, rustfmt defaults to edition 2015 which has
# different import-sort and comment-alignment rules than edition 2024.
EDITION=$(grep -E '^edition\s*=' Cargo.toml 2>/dev/null | head -1 | sed -E 's/.*"([0-9]+)".*/\1/')
EDITION=${EDITION:-2021}

LOG=/tmp/fajar-fmt-check.log
FAIL=0

# Check 1: cargo fmt --check (whole crate, modular files only)
if ! cargo fmt --check > "$LOG" 2>&1; then
    FAIL=1
fi

# Check 2: rustfmt --check on each staged .rs file (catches orphan files)
# Pass --edition explicitly so rules match cargo fmt.
ORPHAN_DRIFT=""
while IFS= read -r f; do
    [ -z "$f" ] && continue
    [ -f "$f" ] || continue  # skip deleted files
    if ! rustfmt --check --quiet --edition "$EDITION" "$f" 2>/dev/null; then
        ORPHAN_DRIFT="$ORPHAN_DRIFT  $f"$'\n'
        FAIL=1
    fi
done <<< "$RUST_FILES"

if [ "$FAIL" -eq 1 ]; then
    echo ""
    echo "❌ Pre-commit blocked: formatting drift detected."
    echo ""
    if grep -q "^Diff in" "$LOG" 2>/dev/null; then
        echo "Modular files with diffs (cargo fmt --check):"
        grep "^Diff in" "$LOG" | sed 's/^/  /'
        echo ""
    fi
    if [ -n "$ORPHAN_DRIFT" ]; then
        echo "Staged files with diffs (rustfmt --check):"
        echo -n "$ORPHAN_DRIFT"
        echo ""
    fi
    echo "Fix with:    cargo fmt"
    echo "             rustfmt <orphan_file>  # for files not in mod tree"
    echo "Then:        git add -u && git commit"
    echo ""
    echo "Bypass (discouraged):  git commit --no-verify"
    echo ""
    exit 1
fi

exit 0
