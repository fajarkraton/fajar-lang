// ═══════════════════════════════════════════════════════════════════════
// PHASE 1.A — tensor_init_with helpers
// ═══════════════════════════════════════════════════════════════════════
// Equivalent to ndarray's Array1::from_shape_fn / Array2::from_shape_fn.

/// Creates a 1D tensor of size `n` where element[i] = f(i).
/// Usage: `let t = tensor_init_with_1d(10, |i| (i as f64) * 2.0)`
@device fn tensor_init_with_1d(n: i64, f: fn(i64) -> f64) -> tensor {
    let mut data: [f64] = []
    let mut i: i64 = 0
    while i < n {
        data = data.push(f(i))
        i = i + 1
    }
    from_data(data, [n])
}

/// Creates a 2D tensor of shape [rows, cols] where element[r,c] = f(r, c).
@device fn tensor_init_with_2d(rows: i64, cols: i64, f: fn(i64, i64) -> f64) -> tensor {
    let mut data: [f64] = []
    let mut r: i64 = 0
    while r < rows {
        let mut c: i64 = 0
        while c < cols {
            data = data.push(f(r, c))
            c = c + 1
        }
        r = r + 1
    }
    from_data(data, [rows, cols])
}

// ═══════════════════════════════════════════════════════════════════════
// PHASE 2.B — hierarchical.rs port (BitSchedule + tiers)
// ═══════════════════════════════════════════════════════════════════════
//
// Source: src/hierarchical.rs lines 1-401
// Algorithm: allocates more bits to recent tokens, exponentially decaying
// to fewer bits as tokens age. 48.7% bit savings at 10K context per paper.
//
// Rust uses `Vec<(usize, u8)>` tiers cache; fj port uses parallel arrays
// of (max_age, bits) pairs for simplicity. Same semantics.

/// Computes bit-width for a token at given `age` using exponential decay.
/// `base_bits`: starting bit-width (e.g. 8); `min_bits`: floor (e.g. 2);
/// `decay`: rate constant (e.g. 0.001). Mirror of Rust `bits_for(age)`.
@device fn bits_for_age(base_bits: i64, min_bits: i64, decay: f64, age: i64) -> i64 {
    if age < 0 { return base_bits }
    let bits_f: f64 = (base_bits as f64) * exp(-decay * (age as f64))
    let bits: i64 = round(bits_f) as i64
    if bits < min_bits { return min_bits }
    if bits > base_bits { return base_bits }
    bits
}

/// Total bits used for a sequence of length `seq_len` under exponential
/// decay schedule. Equivalent to Rust BitSchedule::total_bits.
@device fn schedule_total_bits(seq_len: i64, base_bits: i64, min_bits: i64, decay: f64) -> i64 {
    let mut total: i64 = 0
    let mut age: i64 = 0
    while age < seq_len {
        total = total + bits_for_age(base_bits, min_bits, decay, age)
        age = age + 1
    }
    total
}

/// Average bits per token under hierarchical schedule.
/// Equivalent to Rust BitSchedule::avg_bits.
@device fn schedule_avg_bits(seq_len: i64, base_bits: i64, min_bits: i64, decay: f64) -> f64 {
    if seq_len <= 0 { return 0.0 }
    let total: i64 = schedule_total_bits(seq_len, base_bits, min_bits, decay)
    (total as f64) / (seq_len as f64)
}

/// Bit savings vs flat-allocation baseline (all positions at base_bits).
/// Returns saved bits. Equivalent to (baseline - actual).
@device fn schedule_bits_saved(seq_len: i64, base_bits: i64, min_bits: i64, decay: f64) -> i64 {
    let baseline: i64 = seq_len * base_bits
    let actual: i64 = schedule_total_bits(seq_len, base_bits, min_bits, decay)
    baseline - actual
}

/// Savings as percent. Returns 0..100.
@device fn schedule_savings_percent(seq_len: i64, base_bits: i64, min_bits: i64, decay: f64) -> i64 {
    let baseline: i64 = seq_len * base_bits
    if baseline <= 0 { return 0 }
    let saved: i64 = schedule_bits_saved(seq_len, base_bits, min_bits, decay)
    saved * 100 / baseline
}

// ═══════════════════════════════════════════════════════════════════════
// PHASE 2.C — cpu_kernels/scalar_baseline.rs port (~263 LOC)
// V31 Phase D ternary BitLinear scalar baseline.
// ═══════════════════════════════════════════════════════════════════════
//
// Source: src/cpu_kernels/scalar_baseline.rs
// Algorithm: 2-bit packed ternary weights ({-1, 0, +1}, code 0b11
// reserved=0) × i8 activations → i64 accumulator per output channel.
//
// Wire format: V31 packed at 2 bits/element, 4 elements/byte little-endian
// within byte. Encoding: 00=-1, 01=0, 10=+1, 11=reserved.
// Layout: row-major (out_features, in_features), in_features inner stride.
//
// Used as bit-exact reference for TL2 LUT path parity tests.

/// Decode a 2-bit ternary code into {-1, 0, +1}.
/// 0b11 (reserved) treated as 0 per spec.
@device fn decode_ternary_code(code: i64) -> i64 {
    let masked: i64 = code & 3
    if masked == 0 { return -1 }
    if masked == 1 { return 0 }
    if masked == 2 { return 1 }
    0
}

/// Decode 4 ternary weights from a packed byte.
/// Returns array [w0, w1, w2, w3] each in {-1, 0, +1}.
/// Mirrors Rust `decode_ternary_byte`.
@device fn decode_ternary_byte(b: i64) -> [i64; 4] {
    [
        decode_ternary_code(b),
        decode_ternary_code(b >> 2),
        decode_ternary_code(b >> 4),
        decode_ternary_code(b >> 6),
    ]
}

/// V31 ternary pack: encode i64 array of {-1, 0, +1} into bytes.
/// 4 weights per byte, little-endian within byte. Mirrors the
/// `pack_v31` test helper in scalar_baseline.rs.
@device fn pack_ternary_v31(weights: [i64], n_weights: i64) -> [i64] {
    let n_bytes: i64 = (n_weights + 3) / 4
    let mut packed: [i64] = []
    let mut b: i64 = 0
    while b < n_bytes {
        packed = packed.push(0)
        b = b + 1
    }
    let mut i: i64 = 0
    while i < n_weights {
        let w: i64 = weights[i]
        let mut code: i64 = 1  // 0 → 01
        if w == -1 { code = 0 }     // 00
        if w == 1 { code = 2 }      // 10
        let byte_idx: i64 = i / 4
        let lane: i64 = i % 4
        packed[byte_idx] = packed[byte_idx] | (code << (lane * 2))
        i = i + 1
    }
    packed
}

/// Compute per-output-channel i64 accumulator for one BitLinear matmul.
///   y[j] = Σ_i W[j, i] * x[i]   with ternary W (V31-packed) and i8 x.
///
/// Returns empty array on size mismatch or buffer underflow (substitutes
/// for Rust's `Option<Vec<i64>>` since fj-lang doesn't have Option).
/// Caller checks `result.len() > 0`.
///
/// Mirrors Rust `bitlinear_packed_scalar`.
@device fn bitlinear_packed_scalar(
    weights_packed: [i64],
    activations_i8: [i64],
    out_features: i64,
    in_features: i64,
) -> [i64] {
    if (activations_i8.len() as i64) != in_features { return [] }
    let total_weights: i64 = out_features * in_features
    let required_bytes: i64 = (total_weights + 3) / 4
    if (weights_packed.len() as i64) < required_bytes { return [] }

    let mut out: [i64] = []
    let mut j: i64 = 0
    while j < out_features {
        let mut accum: i64 = 0
        let row_start: i64 = j * in_features
        let mut i: i64 = 0
        while i < in_features {
            let weight_idx: i64 = row_start + i
            let byte: i64 = weights_packed[weight_idx / 4]
            let lane: i64 = weight_idx % 4
            let code: i64 = (byte >> (lane * 2)) & 3
            let w: i64 = decode_ternary_code(code)
            let x: i64 = activations_i8[i]
            accum = accum + w * x
            i = i + 1
        }
        out = out.push(accum)
        j = j + 1
    }
    out
}

/// Absmax quantize float activations to i8 ({-127..+127}).
///   gamma_x = 127.0 / max(|x|)        (1.0 if all-zero to avoid div-by-zero)
///   q[i]    = round(x[i] * gamma_x).clamp(-127, 127)
///
/// Returns concatenated [gamma_x_bits_as_f64, q[0], q[1], ...] — first
/// element is the scale, remaining are i64-extended i8 quantized values.
/// Caller splits.
///
/// Mirrors Rust `absmax_quantize_i8` (which returns (Vec<i8>, f32) tuple).
@device fn absmax_quantize_i8(activations: [f64], n: i64) -> [f64] {
    // Find max(|x|)
    let mut max_abs: f64 = 0.0
    let mut i: i64 = 0
    while i < n {
        let v: f64 = activations[i]
        let av: f64 = if v < 0.0 { -v } else { v }
        if av > max_abs { max_abs = av }
        i = i + 1
    }
    let gamma_x: f64 = if max_abs > 0.0 { 127.0 / max_abs } else { 1.0 }

    // Quantize: q[i] = round(x[i] * gamma_x).clamp(-127, 127)
    let mut result: [f64] = [gamma_x]
    i = 0
    while i < n {
        let scaled: f64 = activations[i] * gamma_x
        let mut q: i64 = round(scaled) as i64
        if q < -127 { q = -127 }
        if q > 127 { q = 127 }
        result = result.push(q as f64)
        i = i + 1
    }
    result
}

// ═══════════════════════════════════════════════════════════════════════
// PHASE 3.A — fused_attention.rs port (~320 LOC)
// Quantized KV cache codebook attention (zero-dequantize attention).
// ═══════════════════════════════════════════════════════════════════════
//
// Source: src/fused_attention.rs lines 80-152
// Innovation: compute attention scores DIRECTLY on quantized KV via
// codebook dot products. Skips dequantize buffer entirely.
// 524,288× memory reduction at 16K context per paper.
//
// Storage: codebook is [f64] of centroids (size = 2^bit_width).
// Quantized vectors are [i64] of indices into codebook.

/// Codebook dot product: score = Σ_j query[j] * codebook[k_indices[j]]
/// WITHOUT dequantizing the key vector.
/// Mirrors Rust `codebook_dot_product`.
@device fn codebook_dot_product(
    query: [f64],
    k_indices: [i64],
    codebook: [f64],
    dim: i64,
) -> f64 {
    let cb_size: i64 = codebook.len() as i64
    let mut sum: f64 = 0.0
    let mut j: i64 = 0
    while j < dim {
        let idx: i64 = k_indices[j]
        let centroid: f64 = if idx >= 0 && idx < cb_size { codebook[idx] } else { 0.0 }
        sum = sum + query[j] * centroid
        j = j + 1
    }
    sum
}

/// Codebook weighted sum: output[j] = Σ_i weights[i] * codebook[v_indices[i*dim+j]]
/// v_indices is flat layout: row i starts at i*dim. WITHOUT dequantizing values.
/// Mirrors Rust `codebook_weighted_sum`.
@device fn codebook_weighted_sum(
    weights: [f64],
    v_indices_flat: [i64],
    codebook: [f64],
    n_entries: i64,
    dim: i64,
) -> [f64] {
    let cb_size: i64 = codebook.len() as i64
    let mut output: [f64] = []
    let mut j: i64 = 0
    while j < dim {
        output = output.push(0.0)
        j = j + 1
    }
    let mut i: i64 = 0
    while i < n_entries {
        let w: f64 = weights[i]
        let row_start: i64 = i * dim
        j = 0
        while j < dim {
            let idx: i64 = v_indices_flat[row_start + j]
            let centroid: f64 = if idx >= 0 && idx < cb_size { codebook[idx] } else { 0.0 }
            output[j] = output[j] + w * centroid
            j = j + 1
        }
        i = i + 1
    }
    output
}

/// Full fused quantized attention.
/// k_indices_flat: row-major (n_entries, dim) flat array of key indices.
/// v_indices_flat: row-major (n_entries, dim) flat array of value indices.
/// codebook: shared centroid table.
/// Returns output vector of size `dim` in rotated space (caller applies Pi^T if needed).
///
/// Steps:
/// 1. scores[i] = codebook_dot_product(query, K[i,:])
/// 2. softmax (with max-subtract for numerical stability)
/// 3. output = codebook_weighted_sum(attn_weights, V)
///
/// Mirrors Rust `fused_quantized_attention`.
@device fn fused_quantized_attention(
    query_rotated: [f64],
    k_indices_flat: [i64],
    v_indices_flat: [i64],
    codebook: [f64],
    n_entries: i64,
    dim: i64,
) -> [f64] {
    if n_entries <= 0 {
        // Return zero vector
        let mut zeros: [f64] = []
        let mut j: i64 = 0
        while j < dim {
            zeros = zeros.push(0.0)
            j = j + 1
        }
        return zeros
    }

    // Step 1: scores per cache entry
    let mut scores: [f64] = []
    let mut i: i64 = 0
    while i < n_entries {
        let row_start: i64 = i * dim
        // Slice k_indices: rows [row_start..row_start+dim]
        let mut k_row: [i64] = []
        let mut j: i64 = 0
        while j < dim {
            k_row = k_row.push(k_indices_flat[row_start + j])
            j = j + 1
        }
        let s: f64 = codebook_dot_product(query_rotated, k_row, codebook, dim)
        scores = scores.push(s)
        i = i + 1
    }

    // Step 2: Softmax with max-subtract for stability.
    // max_score = max(scores)
    let mut max_score: f64 = scores[0]
    i = 1
    while i < n_entries {
        if scores[i] > max_score { max_score = scores[i] }
        i = i + 1
    }
    // exp_scores[i] = exp(scores[i] - max_score)
    let mut exp_scores: [f64] = []
    let mut sum_exp: f64 = 0.0
    i = 0
    while i < n_entries {
        let e: f64 = exp(scores[i] - max_score)
        exp_scores = exp_scores.push(e)
        sum_exp = sum_exp + e
        i = i + 1
    }
    // attn_weights[i] = exp_scores[i] / sum_exp
    let mut attn_weights: [f64] = []
    i = 0
    while i < n_entries {
        attn_weights = attn_weights.push(exp_scores[i] / sum_exp)
        i = i + 1
    }

    // Step 3: weighted sum of V via codebook
    codebook_weighted_sum(attn_weights, v_indices_flat, codebook, n_entries, dim)
}

// ═══════════════════════════════════════════════════════════════════════
// PHASE 3.B — turboquant.rs core port (~535 LOC; subset)
// LCG PRNG + Beta-distributed sampling + Lloyd-Max codebook + quant/dequant.
// ═══════════════════════════════════════════════════════════════════════
//
// Source: src/turboquant.rs lines 75-415
// R4 LCG seed reproducibility risk: VERIFIED bit-exact 10/10 outputs vs Rust
// (gating commit ships fj-lang core support for wrapping_mul/add/sub).

/// LCG step. Returns new state. Caller passes back to subsequent calls.
/// Mirrors Rust state.wrapping_mul(6364136223846793005).wrapping_add(1).
@kernel fn lcg_next_state(state: i64) -> i64 {
    let multiplier: i64 = 6364136223846793005
    wrapping_add(wrapping_mul(state, multiplier), 1)
}

/// Convert LCG state to f64 in [1e-15, 1).
/// Mirrors Rust `(state >> 11) as f64 / (1u64 << 53) as f64).max(1e-15)`.
/// fj-lang uses arithmetic shift on i64; mask to 53 bits to recover
/// the logical-shift behavior of Rust's u64 path.
@kernel fn lcg_to_f64(state: i64) -> f64 {
    let mask: i64 = 9007199254740991  // 2^53 - 1 = 0x1FFFFFFFFFFFFF
    let bits: i64 = (state >> 11) & mask
    let denom: f64 = 9007199254740992.0  // 2^53
    let val: f64 = (bits as f64) / denom
    if val < 1.0e-15 { 1.0e-15 } else { val }
}

/// Beta PDF approximation: (1 - x^2)^(alpha - 1) where alpha = (d-1)/2.
/// Unnormalized — Lloyd-Max only needs relative densities.
/// Mirrors Rust `beta_pdf`.
@device fn beta_pdf(x: f64, d: i64) -> f64 {
    let abs_x: f64 = if x < 0.0 { -x } else { x }
    if abs_x >= 1.0 { return 0.0 }
    let alpha: f64 = ((d as f64) - 1.0) / 2.0
    pow(1.0 - x * x, alpha - 1.0)
}

/// Linear search for bucket index.
/// Returns first i such that `x < boundaries[i]`, else `boundaries.len()`.
/// Mirrors Rust `find_bucket`.
@device fn find_bucket(x: f64, boundaries: [f64], n_boundaries: i64) -> i64 {
    let mut i: i64 = 0
    while i < n_boundaries {
        if x < boundaries[i] { return i }
        i = i + 1
    }
    n_boundaries
}

