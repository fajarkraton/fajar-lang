// ═══════════════════════════════════════════════
// Phase 8 — Process Demo + Interactive Features
// ═══════════════════════════════════════════════

// ── Real Process Spawning (Preemptive Scheduler) ──
// The linker's timer ISR saves/restores all 15 GPRs via push/pop.
// To spawn a new process, we set up a fake stack frame that looks like
// the timer ISR just interrupted it. When the scheduler switches to it,
// the pop sequence + IRETQ will "return" to the process entry point.
//
// Stack layout (top to bottom, grows down):
// [SS]      = 0x10 (kernel data) or 0x1B (user data)
// [RSP]     = process stack pointer
// [RFLAGS]  = 0x202 (IF=1)
// [CS]      = 0x08 (kernel code) or 0x23 (user code)
// [RIP]     = entry point
// [RAX]     = 0
// [RBX]     = 0
// ...15 GPRs...
// [R15]     = 0

@kernel fn sched_spawn_kernel(entry_addr: i64) -> i64 {
    // Find free PID
    let mut pid: i64 = -1
    let mut i: i64 = 1
    while i < 16 && pid == -1 {
        if volatile_read(0x600000 + i * 256 + 8) == 0 { pid = i }
        i = i + 1
    }
    if pid == -1 { return -1 }

    // Allocate process stack: 16KB at 0x700000 + pid*0x4000
    let stack_base = 0x700000 + pid * 0x4000
    let stack_top = stack_base + 0x3FF0
    // Map stack pages
    let mut pg: i64 = stack_base
    while pg < stack_base + 0x4000 {
        map_page(pg, pg, PAGE_PRESENT | PAGE_WRITABLE)
        frame_mark_used(pg / FRAME_SIZE)
        pg = pg + FRAME_SIZE
    }

    // Build fake interrupt frame on the stack
    // The timer ISR pushes 15 GPRs then does IRETQ.
    // We build the stack so that pop × 15 + IRETQ = jump to entry_addr
    let mut sp = stack_top

    // IRETQ frame (pushed by CPU on interrupt, popped by IRETQ)
    sp = sp - 8; volatile_write_u64(sp, 0x10)       // SS (kernel data)
    sp = sp - 8; volatile_write_u64(sp, stack_top)    // RSP
    sp = sp - 8; volatile_write_u64(sp, 0x202)       // RFLAGS (IF=1)
    sp = sp - 8; volatile_write_u64(sp, 0x08)        // CS (kernel code)
    sp = sp - 8; volatile_write_u64(sp, entry_addr)  // RIP

    // 15 GPRs (pushed by timer ISR, popped on restore)
    sp = sp - 8; volatile_write_u64(sp, 0)   // RAX
    sp = sp - 8; volatile_write_u64(sp, 0)   // RBX
    sp = sp - 8; volatile_write_u64(sp, 0)   // RCX
    sp = sp - 8; volatile_write_u64(sp, 0)   // RDX
    sp = sp - 8; volatile_write_u64(sp, 0)   // RSI
    sp = sp - 8; volatile_write_u64(sp, 0)   // RDI
    sp = sp - 8; volatile_write_u64(sp, 0)   // RBP
    sp = sp - 8; volatile_write_u64(sp, 0)   // R8
    sp = sp - 8; volatile_write_u64(sp, 0)   // R9
    sp = sp - 8; volatile_write_u64(sp, 0)   // R10
    sp = sp - 8; volatile_write_u64(sp, 0)   // R11
    sp = sp - 8; volatile_write_u64(sp, 0)   // R12
    sp = sp - 8; volatile_write_u64(sp, 0)   // R13
    sp = sp - 8; volatile_write_u64(sp, 0)   // R14
    sp = sp - 8; volatile_write_u64(sp, 0)   // R15

    // Set process table entry
    let base = 0x600000 + pid * 256
    volatile_write(base + 8, 1)      // state = READY
    volatile_write(base + 16, sp)    // saved RSP (points to R15 on stack)
    volatile_write(base + 32, 0)     // ticks = 0

    pid
}

@kernel fn cmd_spawn() {
    // spawn <name> — create a real kernel process
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: spawn <name>", YELLOW_ON_BLACK); return }

    // Check if name matches a registered program
    // For now, spawn a kernel-mode "busy loop" process that prints periodically
    // TODO: look up program registry for Ring 3 programs

    // Create a kernel process that runs a simple counter function
    let pid = sched_spawn_kernel(fn_addr("sched_test_process"))
    if pid < 0 {
        cprintln("spawn: no free PIDs", RED_ON_BLACK)
        return
    }

    // Copy name
    let base = 0x600000 + pid * 256
    let mut j: i64 = 0
    while j < 16 && j + 6 < len {
        volatile_write_u8(base + 64 + j, volatile_read_u8(0x6F800 + 6 + j))
        j = j + 1
    }
    volatile_write_u8(base + 64 + j, 0)

    cprint("Spawned PID ", GREEN_ON_BLACK)
    cprint_decimal(pid, CYAN_ON_BLACK)
    cprintln(" (preemptive)", WHITE_ON_BLACK)
}

// Simple test process: prints its PID every ~1 second
@kernel fn sched_test_process() {
    let pid = volatile_read(0x6FE00) // current PID
    let mut count: i64 = 0
    while count < 3 {
        // Busy-wait for ~3 seconds (300 ticks at 100Hz)
        let target = read_timer_ticks() + 300
        while read_timer_ticks() < target {}
        println("[PROC] background process alive")
        count = count + 1
    }
    println("[PROC] background process exiting")
    // Exit: mark self as dead
    let me = 0x600000 + volatile_read(0x6FE00) * 256
    volatile_write(me + 8, 0) // state = FREE
    // Halt (scheduler will skip this PID now)
    while 1 == 1 { hlt() }
}

@kernel fn cmd_wait() {
    // wait <pid> — wait for process (simulated)
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: wait <pid>", YELLOW_ON_BLACK); return }
    let mut pid: i64 = 0
    let mut i: i64 = 5
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { pid = pid * 10 + (ch - 48) }
        i = i + 1
    }
    let base = 0x600000 + pid * 256
    let state = volatile_read(base + 8)
    if state == 0 {
        cprint("PID ", WHITE_ON_BLACK)
        cprint_decimal(pid, CYAN_ON_BLACK)
        cprintln(" already exited", WHITE_ON_BLACK)
    } else {
        cprint("Waiting for PID ", WHITE_ON_BLACK)
        cprint_decimal(pid, CYAN_ON_BLACK)
        cprintln("...", WHITE_ON_BLACK)
        // Simulate wait (busy-wait 1 second then mark dead)
        let target = read_timer_ticks() + 100
        while read_timer_ticks() < target {}
        volatile_write(base + 8, 0)
        cprint("PID ", GREEN_ON_BLACK)
        cprint_decimal(pid, GREEN_ON_BLACK)
        cprintln(" exited (0)", GREEN_ON_BLACK)
    }
}

@kernel fn cmd_nice() {
    // nice — show/set process priority (simulated)
    cprintln("Priorities:", YELLOW_ON_BLACK)
    cprintln("  PID 0: priority 0 (kernel)", WHITE_ON_BLACK)
    let mut i: i64 = 1
    while i < 16 {
        let base = 0x600000 + i * 256
        if volatile_read(base + 8) != 0 {
            cprint("  PID ", WHITE_ON_BLACK)
            cprint_decimal(i, CYAN_ON_BLACK)
            cprintln(": priority 20 (normal)", WHITE_ON_BLACK)
        }
        i = i + 1
    }
}

@kernel fn cmd_demo() {
    // demo — run interactive OS demo
    cprintln("=== FajarOS Nova Demo ===", WHITE_ON_BLUE)
    cprintln("", WHITE_ON_BLACK)

    // 1. File operations
    cprintln("[1/5] File System Demo:", YELLOW_ON_BLACK)
    ramfs_write_file("demo.txt", "Hello from FajarOS Nova!", 24)
    cprint("  Created demo.txt: ", WHITE_ON_BLACK)
    // Read it back
    let idx = ramfs_find("demo.txt")
    if idx >= 0 {
        let addr = ramfs_entry_addr(idx)
        let size = volatile_read(addr + 32)
        let data = volatile_read(addr + 40)
        let mut i: i64 = 0
        while i < size { console_putchar(volatile_read_u8(data + i), GREEN_ON_BLACK); i = i + 1 }
        console_putchar(10, WHITE_ON_BLACK)
    }

    // 2. Process demo
    cprintln("[2/5] Process Demo:", YELLOW_ON_BLACK)
    let mut pid: i64 = 1
    while pid < 4 {
        let base = 0x600000 + pid * 256
        if volatile_read(base + 8) == 0 {
            volatile_write(base + 8, 1)
            volatile_write(base + 32, read_timer_ticks() % 1000)
        }
        pid = pid + 1
    }
    cprintln("  Spawned 3 demo processes (PID 1-3)", GREEN_ON_BLACK)

    // 3. Math demo
    cprintln("[3/5] Math Demo:", YELLOW_ON_BLACK)
    cprint("  fib(20) = ", WHITE_ON_BLACK)
    let mut a: i64 = 0
    let mut b: i64 = 1
    let mut n: i64 = 0
    while n < 20 { let tmp = a + b; a = b; b = tmp; n = n + 1 }
    cprint_decimal(b, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  factors(360) = ", WHITE_ON_BLACK)
    let mut val: i64 = 360
    let mut d: i64 = 2
    while d * d <= val {
        while val % d == 0 { cprint_decimal(d, CYAN_ON_BLACK); cprint(" ", WHITE_ON_BLACK); val = val / d }
        d = d + 1
    }
    if val > 1 { cprint_decimal(val, CYAN_ON_BLACK) }
    console_putchar(10, WHITE_ON_BLACK)

    // 4. Hardware info
    cprintln("[4/5] Hardware:", YELLOW_ON_BLACK)
    let rsdp = acpi_find_rsdp()
    if rsdp != 0 {
        cprint("  CPUs: ", WHITE_ON_BLACK)
        cprint_decimal(acpi_get_cpu_count(rsdp), CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    }
    cprint("  PCI devices: ", WHITE_ON_BLACK)
    let mut pci_count: i64 = 0
    let mut dev: i64 = 0
    while dev < 32 {
        let id = pci_read32(0, dev, 0, 0)
        if id != 0xFFFFFFFF && id != 0 { pci_count = pci_count + 1 }
        dev = dev + 1
    }
    cprint_decimal(pci_count, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    // 5. Benchmark
    cprintln("[5/5] Benchmark:", YELLOW_ON_BLACK)
    let t0 = rdtsc()
    let mut sum: i64 = 0
    let mut k: i64 = 0
    while k < 1000000 { sum = sum + k; k = k + 1 }
    let t1 = rdtsc()
    cprint("  1M loop: ", WHITE_ON_BLACK)
    cprint_decimal((t1 - t0) / 1000, CYAN_ON_BLACK)
    cprintln("K cycles", WHITE_ON_BLACK)

    cprintln("", WHITE_ON_BLACK)
    cprintln("Demo complete! Type 'help' for all commands.", GREEN_ON_BLACK)
}

@kernel fn cmd_neofetch() {
    // neofetch — system info with ASCII art
    cprintln("", WHITE_ON_BLACK)
    // Left side: ASCII logo, Right side: info
    cprint("  ####  ##   ", CYAN_ON_BLACK)
    cprintln("OS:      FajarOS Nova v0.1.0", WHITE_ON_BLACK)
    cprint("  #     # #  ", CYAN_ON_BLACK)
    cprintln("Kernel:  x86_64 bare-metal", WHITE_ON_BLACK)
    cprint("  ###  ##### ", CYAN_ON_BLACK)
    cprintln("Lang:    Fajar Lang (fj)", WHITE_ON_BLACK)
    cprint("  #    #   # ", CYAN_ON_BLACK)
    cprint("Uptime:  ", WHITE_ON_BLACK)
    let ticks = read_timer_ticks()
    cprint_decimal(ticks / 100, CYAN_ON_BLACK)
    cprintln("s", WHITE_ON_BLACK)
    cprint("  #    #   # ", CYAN_ON_BLACK)
    cprint("Shell:   fjsh (", WHITE_ON_BLACK)
    cprintln("100 commands)", WHITE_ON_BLACK)
    cprint("             ", CYAN_ON_BLACK)
    cprintln("Memory:  128 MB", WHITE_ON_BLACK)
    cprint("             ", CYAN_ON_BLACK)
    cprint("CPU:     ", WHITE_ON_BLACK)
    let rsdp = acpi_find_rsdp()
    if rsdp != 0 { cprint_decimal(acpi_get_cpu_count(rsdp), CYAN_ON_BLACK) }
    else { console_putchar(49, CYAN_ON_BLACK) }
    cprintln(" core(s)", WHITE_ON_BLACK)
    cprint("             ", CYAN_ON_BLACK)
    cprintln("Display: VGA 80x25 text", WHITE_ON_BLACK)
    cprint("             ", CYAN_ON_BLACK)
    cprintln("Timer:   PIT 100 Hz", WHITE_ON_BLACK)
    // Color blocks
    cprint("  ", WHITE_ON_BLACK)
    let mut c: i64 = 0
    while c < 8 {
        console_putchar(32, c * 16 + 15)
        console_putchar(32, c * 16 + 15)
        console_putchar(32, c * 16 + 15)
        c = c + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
    cprintln("", WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Command Dispatcher
// ═══════════════════════════════════════════════

@kernel fn buf_eq4(a: i64, b: i64, c: i64, d: i64) -> i64 {
    let r0 = volatile_read_u8(0x6F800)
    let r1 = volatile_read_u8(0x6F801)
    let r2 = volatile_read_u8(0x6F802)
    let r3 = volatile_read_u8(0x6F803)
    if r0 == a && r1 == b && r2 == c && r3 == d { 1 } else { 0 }
}

@kernel fn dispatch_command() {
    let len = cmdbuf_len()
    let mut handled: i64 = 0

    // === Original 15 commands ===
    // help (104,101,108,112)
    if len == 4 && buf_eq4(104, 101, 108, 112) == 1 { cmd_help(); handled = 1 }
    // clear (99,108,101,97,114)
    if handled == 0 && len == 5 && buf_eq4(99, 108, 101, 97) == 1 && volatile_read_u8(0x6F804) == 114 { cmd_clear(); handled = 1 }
    // uname (117,110,97,109,101)
    if handled == 0 && len == 5 && buf_eq4(117, 110, 97, 109) == 1 && volatile_read_u8(0x6F804) == 101 { cmd_uname(); handled = 1 }
    // uptime (117,112,116,105,109,101)
    if handled == 0 && len == 6 && buf_eq4(117, 112, 116, 105) == 1 { cmd_uptime(); handled = 1 }
    // cpuinfo
    if handled == 0 && len == 7 && buf_eq4(99, 112, 117, 105) == 1 { cmd_cpuinfo(); handled = 1 }
    // meminfo
    if handled == 0 && len == 7 && buf_eq4(109, 101, 109, 105) == 1 { cmd_meminfo(); handled = 1 }
    // lspci (108,115,112,99,105)
    if handled == 0 && len == 5 && buf_eq4(108, 115, 112, 99) == 1 { cmd_lspci(); handled = 1 }
    // ps (112,115)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 112 && volatile_read_u8(0x6F801) == 115 { cmd_ps(); handled = 1 }
    // reboot
    if handled == 0 && len == 6 && buf_eq4(114, 101, 98, 111) == 1 { cmd_reboot(); handled = 1 }
    // shutdown (115,104,117,116...)
    if handled == 0 && len == 8 && buf_eq4(115, 104, 117, 116) == 1 { cmd_shutdown(); handled = 1 }
    // acpi (97,99,112,105)
    if handled == 0 && len == 4 && buf_eq4(97, 99, 112, 105) == 1 { cmd_acpi(); handled = 1 }
    // tensor (116,101,110,115,111,114)
    if handled == 0 && len == 6 && buf_eq4(116, 101, 110, 115) == 1 { cmd_tensor(); handled = 1 }
    // mnist (109,110,105,115,116)
    if handled == 0 && len == 5 && buf_eq4(109, 110, 105, 115) == 1 { cmd_mnist(); handled = 1 }
    // version (118,101,114,115,105,111,110)
    if handled == 0 && len == 7 && buf_eq4(118, 101, 114, 115) == 1 { cmd_version(); handled = 1 }

    // === New 15 commands ===
    // whoami (119,104,111,97,109,105)
    if handled == 0 && len == 6 && buf_eq4(119, 104, 111, 97) == 1 { cmd_whoami(); handled = 1 }
    // hostname (104,111,115,116...)
    if handled == 0 && len == 8 && buf_eq4(104, 111, 115, 116) == 1 { cmd_hostname(); handled = 1 }
    // arch (97,114,99,104)
    if handled == 0 && len == 4 && buf_eq4(97, 114, 99, 104) == 1 { cmd_arch(); handled = 1 }
    // nproc (110,112,114,111,99)
    if handled == 0 && len == 5 && buf_eq4(110, 112, 114, 111) == 1 { cmd_nproc(); handled = 1 }
    // date (100,97,116,101)
    if handled == 0 && len == 4 && buf_eq4(100, 97, 116, 101) == 1 { cmd_date(); handled = 1 }
    // free (102,114,101,101)
    if handled == 0 && len == 4 && buf_eq4(102, 114, 101, 101) == 1 { cmd_free(); handled = 1 }
    // sysinfo (115,121,115,105...)
    if handled == 0 && len == 7 && buf_eq4(115, 121, 115, 105) == 1 { cmd_sysinfo(); handled = 1 }
    // logo (108,111,103,111)
    if handled == 0 && len == 4 && buf_eq4(108, 111, 103, 111) == 1 { cmd_logo(); handled = 1 }
    // color (99,111,108,111,114)
    if handled == 0 && len == 5 && buf_eq4(99, 111, 108, 111) == 1 { cmd_color(); handled = 1 }
    // about (97,98,111,117,116)
    if handled == 0 && len == 5 && buf_eq4(97, 98, 111, 117) == 1 { cmd_about(); handled = 1 }
    // bench (98,101,110,99,104)
    if handled == 0 && len == 5 && buf_eq4(98, 101, 110, 99) == 1 { cmd_bench(); handled = 1 }
    // tsc (116,115,99)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 116 && volatile_read_u8(0x6F801) == 115 && volatile_read_u8(0x6F802) == 99 { cmd_tsc(); handled = 1 }
    // cowsay (99,111,119,115...) — also matches "cowsay <msg>"
    if handled == 0 && len >= 6 && buf_eq4(99, 111, 119, 115) == 1 { cmd_cowsay(); handled = 1 }
    // fortune (102,111,114,116...)
    if handled == 0 && len == 7 && buf_eq4(102, 111, 114, 116) == 1 { cmd_fortune(); handled = 1 }
    // seq (115,101,113) — also matches "seq N"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 115 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 113 { cmd_seq(); handled = 1 }
    // hex (104,101,120) — "hex N"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 104 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 120 { cmd_hex(); handled = 1 }

    // === File commands (ramfs) ===
    // ls (108,115)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 108 && volatile_read_u8(0x6F801) == 115 { cmd_ls(); handled = 1 }
    // cat (99,97,116) — "cat <file>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 99 && volatile_read_u8(0x6F801) == 97 && volatile_read_u8(0x6F802) == 116 && (len == 3 || volatile_read_u8(0x6F803) == 32) { cmd_cat(); handled = 1 }
    // touch (116,111,117,99,104) — "touch <file>"
    if handled == 0 && len >= 5 && buf_eq4(116, 111, 117, 99) == 1 && volatile_read_u8(0x6F804) == 104 { cmd_touch(); handled = 1 }
    // rm (114,109) — "rm <file>"
    if handled == 0 && len >= 2 && volatile_read_u8(0x6F800) == 114 && volatile_read_u8(0x6F801) == 109 && (len == 2 || volatile_read_u8(0x6F802) == 32) { cmd_rm(); handled = 1 }
    // mkdir (109,107,100,105,114) — "mkdir <dir>"
    if handled == 0 && len >= 5 && volatile_read_u8(0x6F800) == 109 && volatile_read_u8(0x6F801) == 107 && volatile_read_u8(0x6F802) == 100 { cmd_mkdir(); handled = 1 }
    // pwd (112,119,100)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 112 && volatile_read_u8(0x6F801) == 119 && volatile_read_u8(0x6F802) == 100 { cmd_pwd(); handled = 1 }
    // write (119,114,105,116,101) — "write <file> <text>"
    if handled == 0 && len >= 5 && buf_eq4(119, 114, 105, 116) == 1 && volatile_read_u8(0x6F804) == 101 { cmd_write(); handled = 1 }
    // head (104,101,97,100) — "head <file>"
    if handled == 0 && len >= 4 && buf_eq4(104, 101, 97, 100) == 1 && (len == 4 || volatile_read_u8(0x6F804) == 32) { cmd_head(); handled = 1 }
    // wc (119,99) — "wc <file>"
    if handled == 0 && len >= 2 && volatile_read_u8(0x6F800) == 119 && volatile_read_u8(0x6F801) == 99 && (len == 2 || volatile_read_u8(0x6F802) == 32) { cmd_wc(); handled = 1 }
    // stat (115,116,97,116) — "stat <file>"
    if handled == 0 && len >= 4 && buf_eq4(115, 116, 97, 116) == 1 && (len == 4 || volatile_read_u8(0x6F804) == 32) { cmd_stat(); handled = 1 }

    // === More utility commands ===
    // kill (107,105,108,108) — "kill <pid>"
    if handled == 0 && len >= 4 && buf_eq4(107, 105, 108, 108) == 1 { cmd_kill(); handled = 1 }
    // dmesg (100,109,101,115,103)
    if handled == 0 && len == 5 && buf_eq4(100, 109, 101, 115) == 1 { cmd_dmesg(); handled = 1 }
    // cal (99,97,108)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 99 && volatile_read_u8(0x6F801) == 97 && volatile_read_u8(0x6F802) == 108 { cmd_cal(); handled = 1 }
    // sleep (115,108,101,101,112) — "sleep <N>"
    if handled == 0 && len >= 5 && buf_eq4(115, 108, 101, 101) == 1 && volatile_read_u8(0x6F804) == 112 { cmd_sleep(); handled = 1 }
    // true (116,114,117,101)
    if handled == 0 && len == 4 && buf_eq4(116, 114, 117, 101) == 1 { cmd_true(); handled = 1 }
    // false (102,97,108,115,101)
    if handled == 0 && len == 5 && buf_eq4(102, 97, 108, 115) == 1 { cmd_false(); handled = 1 }
    // id (105,100)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 105 && volatile_read_u8(0x6F801) == 100 { cmd_id(); handled = 1 }
    // dice (100,105,99,101)
    if handled == 0 && len == 4 && buf_eq4(100, 105, 99, 101) == 1 { cmd_dice(); handled = 1 }
    // rev (114,101,118) — "rev <text>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 114 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 118 && (len == 3 || volatile_read_u8(0x6F803) == 32) { cmd_rev(); handled = 1 }
    // yes (121,101,115)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 121 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 115 { cmd_yes(); handled = 1 }
    // env (101,110,118)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 101 && volatile_read_u8(0x6F801) == 110 && volatile_read_u8(0x6F802) == 118 { cmd_env(); handled = 1 }

    // === Phase 4 commands (60 total) ===
    // history (104,105,115,116,111,114,121)
    if handled == 0 && len == 7 && buf_eq4(104, 105, 115, 116) == 1 && volatile_read_u8(0x6F804) == 111 { cmd_history(); handled = 1 }
    // xxd (120,120,100) — "xxd <file>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 120 && volatile_read_u8(0x6F801) == 120 && volatile_read_u8(0x6F802) == 100 { cmd_xxd(); handled = 1 }
    // top (116,111,112)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 116 && volatile_read_u8(0x6F801) == 111 && volatile_read_u8(0x6F802) == 112 { cmd_top(); handled = 1 }
    // append (97,112,112,101,110,100) — "append <file> <text>"
    if handled == 0 && len >= 6 && buf_eq4(97, 112, 112, 101) == 1 && volatile_read_u8(0x6F804) == 110 { cmd_append(); handled = 1 }
