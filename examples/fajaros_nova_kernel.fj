@kernel fn cmd_kill() {
    // kill <pid>
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: kill <pid>", YELLOW_ON_BLACK); return }
    let mut pid: i64 = 0
    let mut i: i64 = 5
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { pid = pid * 10 + (ch - 48) }
        i = i + 1
    }
    if pid == 0 { cprintln("kill: cannot kill PID 0 (kernel)", RED_ON_BLACK); return }
    if pid >= 16 { cprintln("kill: invalid PID", RED_ON_BLACK); return }
    let base = 0x600000 + pid * 256
    let state = volatile_read(base + 8)
    if state == 0 { cprintln("kill: no such process", RED_ON_BLACK); return }
    volatile_write(base + 8, 0)  // state = dead
    cprint("Killed PID ", GREEN_ON_BLACK)
    cprint_decimal(pid, GREEN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

