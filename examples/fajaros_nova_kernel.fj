@kernel fn cmd_help() {
    cprintln("=== FajarOS Nova - 75 Commands ===", YELLOW_ON_BLACK)
    cprintln("System:", WHITE_ON_BLUE)
    cprintln("  help version about uname sysinfo", WHITE_ON_BLACK)
    cprintln("  uptime date hostname whoami arch", WHITE_ON_BLACK)
    cprintln("  dmesg env id cal history man", WHITE_ON_BLACK)
    cprintln("  which banner exit", WHITE_ON_BLACK)
    cprintln("Hardware:", WHITE_ON_BLUE)
    cprintln("  cpuinfo meminfo free nproc lspci", WHITE_ON_BLACK)
    cprintln("  acpi tsc time", WHITE_ON_BLACK)
    cprintln("Process:", WHITE_ON_BLUE)
    cprintln("  ps top kill sleep reboot shutdown", WHITE_ON_BLACK)
    cprintln("Files:", WHITE_ON_BLUE)
    cprintln("  ls cat touch rm cp mv mkdir pwd", WHITE_ON_BLACK)
    cprintln("  write append head tail wc grep", WHITE_ON_BLACK)
    cprintln("  stat xxd df du count", WHITE_ON_BLACK)
    cprintln("AI/Compute:", WHITE_ON_BLUE)
    cprintln("  tensor mnist bench fib", WHITE_ON_BLACK)
    cprintln("Math/Text:", WHITE_ON_BLUE)
    cprintln("  hex factor prime", WHITE_ON_BLACK)
    cprintln("  echo rev upcase downcase", WHITE_ON_BLACK)
    cprintln("Utility:", WHITE_ON_BLUE)
    cprintln("  clear cls seq true false yes dice", WHITE_ON_BLACK)
    cprintln("  logo color cowsay fortune", WHITE_ON_BLACK)
    cprintln("Keys: Up/Down = history", YELLOW_ON_BLACK)
}

@kernel fn cmd_version() {
    cprintln("FajarOS Nova v0.1.0 \"Nova\"", WHITE_ON_BLUE)
    cprintln("  Kernel:   x86_64 bare-metal", WHITE_ON_BLACK)
    cprintln("  Language: 100% Fajar Lang", WHITE_ON_BLACK)
    cprintln("  Compiler: Fajar Lang + Cranelift", WHITE_ON_BLACK)
    cprintln("  Boot:     Multiboot2 (GRUB2)", WHITE_ON_BLACK)
    cprintln("  Paging:   128MB identity (2MB pages)", WHITE_ON_BLACK)
    cprintln("  Timer:    PIT 100Hz preemptive", WHITE_ON_BLACK)
    cprintln("  Shell:    75 commands", WHITE_ON_BLACK)
    cprintln("  Author:   Fajar (TaxPrime/PrimeCore.id)", WHITE_ON_BLACK)
    cprintln("  Built with Claude Opus 4.6", CYAN_ON_BLACK)
}

@kernel fn cmd_uname() {
    cprintln("FajarOS Nova v0.1.0 x86_64 (Fajar Lang)", CYAN_ON_BLACK)
}

@kernel fn cmd_uptime() {
    cprint("Uptime: ", WHITE_ON_BLACK)
    let ticks = read_timer_ticks()
    cprint_decimal(ticks, CYAN_ON_BLACK)
    cprint(" ticks (", WHITE_ON_BLACK)
    cprint_decimal(ticks / 100, CYAN_ON_BLACK)
    cprintln(" seconds)", WHITE_ON_BLACK)
}

@kernel fn cmd_cpuinfo() {
    let ecx1 = cpuid_ecx(1)
    let edx1 = cpuid_edx(1)
    let ebx7 = cpuid_ebx(7)
    cprintln("CPU Features:", YELLOW_ON_BLACK)
    if (edx1 & (1 << 0)) != 0 { cprintln("  FPU", WHITE_ON_BLACK) }
    if (edx1 & (1 << 25)) != 0 { cprintln("  SSE", WHITE_ON_BLACK) }
    if (edx1 & (1 << 26)) != 0 { cprintln("  SSE2", WHITE_ON_BLACK) }
    if (ecx1 & (1 << 20)) != 0 { cprintln("  SSE4.2", WHITE_ON_BLACK) }
    if (ecx1 & (1 << 28)) != 0 { cprintln("  AVX", WHITE_ON_BLACK) }
    if (ebx7 & (1 << 5)) != 0 { cprintln("  AVX2", WHITE_ON_BLACK) }
    if (edx1 & (1 << 9)) != 0 { cprintln("  APIC", WHITE_ON_BLACK) }
}

@kernel fn cmd_meminfo() {
    cprintln("Memory:", YELLOW_ON_BLACK)
    cprintln("  Total mapped: 128 MB (identity)", WHITE_ON_BLACK)
    cprintln("  Kernel:  0x100000 (1 MB)", WHITE_ON_BLACK)
    cprintln("  Heap:    0x400000 - 0x7000000 (108 MB)", WHITE_ON_BLACK)
    cprintln("  Stack:   0x7F00000 (127 MB)", WHITE_ON_BLACK)
    cprintln("  ProcTbl: 0x600000 (4 KB)", WHITE_ON_BLACK)
}

@kernel fn cmd_lspci() {
    cprintln("PCI Devices:", YELLOW_ON_BLACK)
    let mut dev: i64 = 0
    let mut found: i64 = 0
    while dev < 32 {
        let id = pci_read32(0, dev, 0, 0)
        if id != 0xFFFFFFFF && id != 0 {
            cprint("  ", WHITE_ON_BLACK)
            cprint_hex(id & 0xFFFF, 4, CYAN_ON_BLACK)
            console_putchar(58, WHITE_ON_BLACK)
            cprint_hex((id >> 16) & 0xFFFF, 4, CYAN_ON_BLACK)
            let cl = pci_read32(0, dev, 0, 8)
            cprint(" class=", WHITE_ON_BLACK)
            cprint_hex((cl >> 24) & 0xFF, 2, YELLOW_ON_BLACK)
            cprint_hex((cl >> 16) & 0xFF, 2, YELLOW_ON_BLACK)
            console_putchar(10, WHITE_ON_BLACK)
            found = found + 1
        }
        dev = dev + 1
    }
    cprint("Total: ", GREEN_ON_BLACK)
    cprint_decimal(found, GREEN_ON_BLACK)
    cprintln(" devices", GREEN_ON_BLACK)
}

@kernel fn cmd_ps() {
    cprintln("Processes:", YELLOW_ON_BLACK)
    cprintln("  PID  STATE    TICKS", WHITE_ON_BLACK)
    let mut i: i64 = 0
    while i < 16 {
        let base = 0x600000 + i * 256
        let state = volatile_read(base + 8)
        if state != 0 {
            cprint("  ", WHITE_ON_BLACK)
            cprint_decimal(i, CYAN_ON_BLACK)
            if state == 1 { cprint("    ready    ", WHITE_ON_BLACK) }
            else if state == 2 { cprint("    running  ", GREEN_ON_BLACK) }
            else { cprint("    blocked  ", YELLOW_ON_BLACK) }
            cprint_decimal(volatile_read(base + 32), WHITE_ON_BLACK)
            console_putchar(10, WHITE_ON_BLACK)
        }
        i = i + 1
    }
}

@kernel fn cmd_clear() {
    console_init()
}

@kernel fn cmd_echo() {
    // Echo the command buffer (skip "echo " prefix = 5 chars)
    let len = cmdbuf_len()
    if len > 5 {
        let mut i: i64 = 5
        while i < len {
            console_putchar(volatile_read_u8(0x6F800 + i), WHITE_ON_BLACK)
            i = i + 1
        }
    }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_reboot() {
    cprintln("Rebooting...", RED_ON_BLACK)
    port_outb(0x64, 0xFE)  // keyboard controller reset
}

@kernel fn cmd_shutdown() {
    cprintln("Shutting down via ACPI...", YELLOW_ON_BLACK)
    acpi_shutdown()
}

@kernel fn cmd_tensor() {
    cprintln("Tensor Operations (CPU):", YELLOW_ON_BLACK)

    // Simple 3x3 matrix multiply demo using volatile memory as tensor storage
    // Matrix A (3x3) at 0x500000, Matrix B (3x3) at 0x500100, Result at 0x500200
    // A = [[1,2,3],[4,5,6],[7,8,9]]
    volatile_write(0x500000, 1); volatile_write(0x500008, 2); volatile_write(0x500010, 3)
    volatile_write(0x500018, 4); volatile_write(0x500020, 5); volatile_write(0x500028, 6)
    volatile_write(0x500030, 7); volatile_write(0x500038, 8); volatile_write(0x500040, 9)
    // B = identity [[1,0,0],[0,1,0],[0,0,1]]
    volatile_write(0x500100, 1); volatile_write(0x500108, 0); volatile_write(0x500110, 0)
    volatile_write(0x500118, 0); volatile_write(0x500120, 1); volatile_write(0x500128, 0)
    volatile_write(0x500130, 0); volatile_write(0x500138, 0); volatile_write(0x500140, 1)

    // Naive matmul: C[i][j] = sum(A[i][k] * B[k][j])
    let t0 = rdtsc()
    let mut i: i64 = 0
    while i < 3 {
        let mut j: i64 = 0
        while j < 3 {
            let mut sum: i64 = 0
            let mut k: i64 = 0
            while k < 3 {
                let a = volatile_read(0x500000 + (i * 3 + k) * 8)
                let b = volatile_read(0x500100 + (k * 3 + j) * 8)
                sum = sum + a * b
                k = k + 1
            }
            volatile_write(0x500200 + (i * 3 + j) * 8, sum)
            j = j + 1
        }
        i = i + 1
    }
    let t1 = rdtsc()

    // Print result (should be same as A since B is identity)
    cprint("  A * I = [", WHITE_ON_BLACK)
    let mut r: i64 = 0
    while r < 3 {
        let mut c: i64 = 0
        while c < 3 {
            cprint_decimal(volatile_read(0x500200 + (r * 3 + c) * 8), CYAN_ON_BLACK)
            if c < 2 { cprint(",", WHITE_ON_BLACK) }
            c = c + 1
        }
        if r < 2 { cprint("; ", WHITE_ON_BLACK) }
        r = r + 1
    }
    cprintln("]", WHITE_ON_BLACK)

    cprint("  Cycles: ", WHITE_ON_BLACK)
    cprint_decimal(t1 - t0, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    // Simple ReLU demo
    cprintln("  ReLU([-3, 0, 5]) = [0, 0, 5]", GREEN_ON_BLACK)
}

@kernel fn cmd_mnist() {
    cprintln("MNIST Inference (CPU):", YELLOW_ON_BLACK)
    cprintln("  Model: MLP 784->128->10", WHITE_ON_BLACK)
    cprintln("  Weights: not loaded (demo mode)", WHITE_ON_BLACK)

    // Simulate a forward pass timing
    let t0 = rdtsc()
    // Simulate 784*128 = 100352 multiply-adds
    let mut ops: i64 = 0
    let mut acc: i64 = 0
    while ops < 100352 {
        acc = acc + ops * 3 - ops * 2  // dummy compute
        ops = ops + 1
    }
    let t1 = rdtsc()

    cprint("  Forward pass: ", WHITE_ON_BLACK)
    cprint_decimal((t1 - t0) / 1000, CYAN_ON_BLACK)
    cprintln("K cycles", WHITE_ON_BLACK)

    // Simulated prediction
    cprintln("  Input: blank image (28x28)", WHITE_ON_BLACK)
    cprintln("  Prediction: 0 (demo)", GREEN_ON_BLACK)
    cprintln("  Note: load real weights for accuracy", YELLOW_ON_BLACK)
}

@kernel fn cmd_acpi() {
    cprintln("ACPI Info:", YELLOW_ON_BLACK)
    let rsdp = acpi_find_rsdp()
    if rsdp != 0 {
        cprint("  RSDP found at: 0x", WHITE_ON_BLACK)
        cprint_hex(rsdp, 8, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        let cpus = acpi_get_cpu_count(rsdp)
        cprint("  CPU cores: ", WHITE_ON_BLACK)
        cprint_decimal(cpus, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    } else {
        cprintln("  RSDP not found", RED_ON_BLACK)
    }
    cprint("  TSC: ", WHITE_ON_BLACK)
    let tsc = rdtsc()
    cprint_hex(tsc >> 32, 8, CYAN_ON_BLACK)
    cprint_hex(tsc & 0xFFFFFFFF, 8, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

