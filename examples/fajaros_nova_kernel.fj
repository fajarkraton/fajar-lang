@kernel fn cmd_about() {
    cprintln("FajarOS Nova v0.1.0", WHITE_ON_BLUE)
    cprintln("", WHITE_ON_BLACK)
    cprintln("  The world's first OS written 100% in a single", WHITE_ON_BLACK)
    cprintln("  language that unifies kernel (@kernel), AI", WHITE_ON_BLACK)
    cprintln("  inference (@device), and userspace (@safe).", WHITE_ON_BLACK)
    cprintln("", WHITE_ON_BLACK)
    cprintln("  Language:  Fajar Lang (fj)", CYAN_ON_BLACK)
    cprintln("  Compiler:  Cranelift native codegen", CYAN_ON_BLACK)
    cprintln("  Target:    x86_64-unknown-none", CYAN_ON_BLACK)
    cprintln("  Author:    Fajar (TaxPrime/PrimeCore.id)", CYAN_ON_BLACK)
    cprintln("  Built:     Claude Opus 4.6", CYAN_ON_BLACK)
