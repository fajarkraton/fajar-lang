    cprintln("[0.008] Process table: 16 slots at 0x600000", WHITE_ON_BLACK)
    cprintln("[0.009] Keyboard: PS/2 IRQ1 enabled", WHITE_ON_BLACK)
    cprintln("[0.010] Paging: 128MB identity (2MB pages)", WHITE_ON_BLACK)
    cprintln("[0.011] Heap: bump allocator at 0x400000", WHITE_ON_BLACK)
    cprintln("[0.012] RamFS: initialized (64 entries, 832KB)", WHITE_ON_BLACK)
