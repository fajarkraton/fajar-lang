}

@kernel fn cmd_color() {
    cprintln("Color Test:", YELLOW_ON_BLACK)
    cprint("  ", WHITE_ON_BLACK)
    cprint("WHITE ", WHITE_ON_BLACK)
    cprint("GREEN ", GREEN_ON_BLACK)
    cprint("CYAN ", CYAN_ON_BLACK)
    cprint("YELLOW ", YELLOW_ON_BLACK)
