// More Commands (Phase 4 — 60 total)
// ═══════════════════════════════════════════════

@kernel fn cmd_history() {
    let count = volatile_read(0x6FC00)
    if count == 0 { cprintln("(no history)", WHITE_ON_BLACK); return }
    let mut i: i64 = 0
    while i < count {
        cprint("  ", WHITE_ON_BLACK)
        cprint_decimal(i + 1, YELLOW_ON_BLACK)
        cprint("  ", WHITE_ON_BLACK)
        let slot = HIST_BASE + i * HIST_SLOT_SIZE
        let mut j: i64 = 0
        while volatile_read_u8(slot + j) != 0 && j < 63 {
            console_putchar(volatile_read_u8(slot + j), WHITE_ON_BLACK)
            j = j + 1
        }
        console_putchar(10, WHITE_ON_BLACK)
        i = i + 1
    }
}

@kernel fn cmd_xxd() {
    // xxd <file> — hex dump of file contents
    let len = cmdbuf_len()
    if len <= 4 { cprintln("Usage: xxd <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(4)
    if idx == -1 { cprintln("xxd: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    if size == 0 { cprintln("(empty)", WHITE_ON_BLACK); return }
    let mut off: i64 = 0
    while off < size && off < 128 {
        // Offset
        cprint_hex(off, 4, YELLOW_ON_BLACK)
        cprint(": ", WHITE_ON_BLACK)
        // Hex bytes (16 per line)
        let mut i: i64 = 0
        while i < 16 {
            if off + i < size {
                cprint_hex(volatile_read_u8(data_ptr + off + i), 2, CYAN_ON_BLACK)
                console_putchar(32, WHITE_ON_BLACK)
            } else {
                cprint("   ", WHITE_ON_BLACK)
            }
            i = i + 1
        }
        cprint(" ", WHITE_ON_BLACK)
        // ASCII
        i = 0
        while i < 16 && off + i < size {
            let ch = volatile_read_u8(data_ptr + off + i)
            if ch >= 32 && ch < 127 { console_putchar(ch, GREEN_ON_BLACK) }
            else { console_putchar(46, WHITE_ON_BLACK) }
            i = i + 1
        }
        console_putchar(10, WHITE_ON_BLACK)
        off = off + 16
    }
}

@kernel fn cmd_top() {
    cprintln("PID  STATE      TICKS    CPU", YELLOW_ON_BLACK)
    cprintln("---  ---------  -------  ---", WHITE_ON_BLACK)
    let total_ticks = read_timer_ticks()
    let mut i: i64 = 0
    while i < 16 {
        let base = 0x600000 + i * 256
        let state = volatile_read(base + 8)
        if state != 0 {
            cprint_decimal(i, CYAN_ON_BLACK)
            cprint("    ", WHITE_ON_BLACK)
            if state == 1 { cprint("ready    ", WHITE_ON_BLACK) }
            else if state == 2 { cprint("RUNNING  ", GREEN_ON_BLACK) }
            else if state == 3 { cprint("blocked  ", YELLOW_ON_BLACK) }
            else { cprint("unknown  ", RED_ON_BLACK) }
            cprint("  ", WHITE_ON_BLACK)
            let ticks = volatile_read(base + 32)
            cprint_decimal(ticks, WHITE_ON_BLACK)
            cprint("    ", WHITE_ON_BLACK)
            if total_ticks > 0 {
                cprint_decimal(ticks * 100 / (total_ticks + 1), CYAN_ON_BLACK)
                console_putchar(37, WHITE_ON_BLACK) // '%'
            }
            console_putchar(10, WHITE_ON_BLACK)
        }
        i = i + 1
    }
}

@kernel fn cmd_append() {
    // append <file> <text> — append text to existing file
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: append <file> <text>", YELLOW_ON_BLACK); return }
    // Find space after "append "
    let mut sp: i64 = 7
    while sp < len && volatile_read_u8(0x6F800 + sp) != 32 { sp = sp + 1 }
    if sp >= len - 1 { cprintln("Usage: append <file> <text>", YELLOW_ON_BLACK); return }
    let name_len = sp - 7
    // Find file
    let count = volatile_read(FS_BASE)
    let mut idx: i64 = -1
    let mut fi: i64 = 0
    while fi < count && idx == -1 {
        let addr = ramfs_entry_addr(fi)
        let mut match_ok: i64 = 1
        let mut j: i64 = 0
        while j < name_len && match_ok == 1 {
            if volatile_read_u8(addr + j) != volatile_read_u8(0x6F800 + 7 + j) { match_ok = 0 }
            j = j + 1
        }
        if match_ok == 1 && volatile_read_u8(addr + name_len) == 0 { idx = fi }
        fi = fi + 1
    }
    if idx == -1 { cprintln("append: file not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let old_size = volatile_read(addr + 32)
    let old_ptr = volatile_read(addr + 40)
    let text_start = sp + 1
    let text_len = len - text_start
    // Allocate new data area and copy old + new
    let new_ptr = volatile_read(FS_BASE + 8)
    let mut i: i64 = 0
    while i < old_size {
        volatile_write_u8(new_ptr + i, volatile_read_u8(old_ptr + i))
        i = i + 1
    }
    i = 0
    while i < text_len {
        volatile_write_u8(new_ptr + old_size + i, volatile_read_u8(0x6F800 + text_start + i))
        i = i + 1
    }
    volatile_write(addr + 32, old_size + text_len)
    volatile_write(addr + 40, new_ptr)
    volatile_write(FS_BASE + 8, new_ptr + old_size + text_len)
}

@kernel fn cmd_cp() {
    // cp <src> <dst> — copy file
    let len = cmdbuf_len()
    if len <= 3 { cprintln("Usage: cp <src> <dst>", YELLOW_ON_BLACK); return }
    // Find space between src and dst
    let mut sp: i64 = 3
    while sp < len && volatile_read_u8(0x6F800 + sp) != 32 { sp = sp + 1 }
    if sp >= len - 1 { cprintln("Usage: cp <src> <dst>", YELLOW_ON_BLACK); return }
    let src_len = sp - 3
    let dst_start = sp + 1
    let dst_len = len - dst_start
    // Find source file
    let count = volatile_read(FS_BASE)
    let mut src_idx: i64 = -1
    let mut fi: i64 = 0
    while fi < count && src_idx == -1 {
        let addr = ramfs_entry_addr(fi)
        let mut match_ok: i64 = 1
        let mut j: i64 = 0
        while j < src_len && match_ok == 1 {
            if volatile_read_u8(addr + j) != volatile_read_u8(0x6F800 + 3 + j) { match_ok = 0 }
            j = j + 1
        }
        if match_ok == 1 && volatile_read_u8(addr + src_len) == 0 { src_idx = fi }
        fi = fi + 1
    }
    if src_idx == -1 { cprintln("cp: source not found", RED_ON_BLACK); return }
    // Create destination
    if count >= FS_MAX_FILES { cprintln("cp: filesystem full", RED_ON_BLACK); return }
    let src_addr = ramfs_entry_addr(src_idx)
    let src_size = volatile_read(src_addr + 32)
    let src_data = volatile_read(src_addr + 40)
    let dst_idx = count
    let dst_addr = ramfs_entry_addr(dst_idx)
    // Copy name
    let mut i: i64 = 0
    while i < dst_len && i < 31 {
        volatile_write_u8(dst_addr + i, volatile_read_u8(0x6F800 + dst_start + i))
        i = i + 1
    }
    volatile_write_u8(dst_addr + i, 0)
    // Copy data
    let new_ptr = volatile_read(FS_BASE + 8)
    i = 0
    while i < src_size {
        volatile_write_u8(new_ptr + i, volatile_read_u8(src_data + i))
        i = i + 1
    }
    volatile_write(dst_addr + 32, src_size)
    volatile_write(dst_addr + 40, new_ptr)
    volatile_write(dst_addr + 48, 1) // file
    volatile_write(FS_BASE, count + 1)
    volatile_write(FS_BASE + 8, new_ptr + src_size)
}

@kernel fn cmd_time() {
    // time — run a benchmark and show elapsed
    cprint("Timing 100K loop... ", WHITE_ON_BLACK)
    let t0 = rdtsc()
    let mut i: i64 = 0
    let mut acc: i64 = 0
    while i < 100000 { acc = acc + i; i = i + 1 }
    let t1 = rdtsc()
    let cycles = t1 - t0
    cprint_decimal(cycles, CYAN_ON_BLACK)
    cprint(" cycles (", WHITE_ON_BLACK)
    cprint_decimal(cycles / 1000, CYAN_ON_BLACK)
    cprintln("K)", WHITE_ON_BLACK)
}

@kernel fn cmd_factor() {
    // factor <N> — factorize a number
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: factor <N>", YELLOW_ON_BLACK); return }
    let mut n: i64 = 0
    let mut i: i64 = 7
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48) }
        i = i + 1
    }
    if n <= 1 { cprintln("factor: need N > 1", YELLOW_ON_BLACK); return }
    cprint_decimal(n, WHITE_ON_BLACK)
    cprint(": ", WHITE_ON_BLACK)
    let mut d: i64 = 2
    let mut val = n
    while d * d <= val {
        while val % d == 0 {
            cprint_decimal(d, CYAN_ON_BLACK)
            console_putchar(32, WHITE_ON_BLACK)
            val = val / d
        }
        d = d + 1
    }
    if val > 1 { cprint_decimal(val, CYAN_ON_BLACK) }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_prime() {
    // prime <N> — check if N is prime
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: prime <N>", YELLOW_ON_BLACK); return }
    let mut n: i64 = 0
    let mut i: i64 = 6
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48) }
        i = i + 1
    }
    if n <= 1 { cprintln("Not prime", RED_ON_BLACK); return }
    let mut is_prime: i64 = 1
    let mut d: i64 = 2
    while d * d <= n {
        if n % d == 0 { is_prime = 0 }
        d = d + 1
    }
    cprint_decimal(n, WHITE_ON_BLACK)
    if is_prime == 1 { cprintln(" is PRIME", GREEN_ON_BLACK) }
    else { cprintln(" is not prime", RED_ON_BLACK) }
}

// ═══════════════════════════════════════════════
// Phase 5 Commands — 75+ total
// ═══════════════════════════════════════════════

@kernel fn cmd_mv() {
    // mv <src> <dst> — rename/move file
    let len = cmdbuf_len()
    if len <= 3 { cprintln("Usage: mv <src> <dst>", YELLOW_ON_BLACK); return }
    let mut sp: i64 = 3
    while sp < len && volatile_read_u8(0x6F800 + sp) != 32 { sp = sp + 1 }
    if sp >= len - 1 { cprintln("Usage: mv <src> <dst>", YELLOW_ON_BLACK); return }
    let src_len = sp - 3
    let dst_start = sp + 1
    let dst_len = len - dst_start
    // Find source
    let count = volatile_read(FS_BASE)
    let mut idx: i64 = -1
    let mut fi: i64 = 0
    while fi < count && idx == -1 {
        let addr = ramfs_entry_addr(fi)
        let mut ok: i64 = 1
        let mut j: i64 = 0
        while j < src_len && ok == 1 {
            if volatile_read_u8(addr + j) != volatile_read_u8(0x6F800 + 3 + j) { ok = 0 }
            j = j + 1
        }
        if ok == 1 && volatile_read_u8(addr + src_len) == 0 { idx = fi }
        fi = fi + 1
    }
    if idx == -1 { cprintln("mv: source not found", RED_ON_BLACK); return }
    // Rename: overwrite name
    let addr = ramfs_entry_addr(idx)
    let mut i: i64 = 0
    while i < dst_len && i < 31 {
        volatile_write_u8(addr + i, volatile_read_u8(0x6F800 + dst_start + i))
        i = i + 1
    }
    volatile_write_u8(addr + i, 0)
    // Clear remaining name bytes
    while i < 32 { volatile_write_u8(addr + i, 0); i = i + 1 }
}

@kernel fn cmd_tail() {
    // tail <file> — show last 5 lines
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: tail <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(5)
    if idx == -1 { cprintln("tail: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    if size == 0 { return }
    // Count total lines
    let mut total_lines: i64 = 0
    let mut i: i64 = 0
    while i < size { if volatile_read_u8(data_ptr + i) == 10 { total_lines = total_lines + 1 }; i = i + 1 }
    // Find start of last 5 lines
    let skip = total_lines - 5
    let mut line_num: i64 = 0
    let mut start: i64 = 0
    if skip > 0 {
        i = 0
        while i < size && line_num < skip {
            if volatile_read_u8(data_ptr + i) == 10 { line_num = line_num + 1 }
            i = i + 1
        }
        start = i
    }
    // Print from start
    i = start
    while i < size { console_putchar(volatile_read_u8(data_ptr + i), WHITE_ON_BLACK); i = i + 1 }
    if size > 0 && volatile_read_u8(data_ptr + size - 1) != 10 { console_putchar(10, WHITE_ON_BLACK) }
}

@kernel fn cmd_grep() {
    // grep <pattern> <file> — search for pattern in file
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: grep <pattern> <file>", YELLOW_ON_BLACK); return }
    // Find first space (after "grep ")
    let mut sp: i64 = 5
    while sp < len && volatile_read_u8(0x6F800 + sp) != 32 { sp = sp + 1 }
    if sp >= len - 1 { cprintln("Usage: grep <pattern> <file>", YELLOW_ON_BLACK); return }
    let pat_start: i64 = 5
    let pat_len = sp - 5
    let file_start = sp + 1
    let file_len = len - file_start
    // Find file
    let count = volatile_read(FS_BASE)
    let mut idx: i64 = -1
    let mut fi: i64 = 0
    while fi < count && idx == -1 {
        let addr = ramfs_entry_addr(fi)
        let mut ok: i64 = 1
        let mut j: i64 = 0
        while j < file_len && ok == 1 {
            if volatile_read_u8(addr + j) != volatile_read_u8(0x6F800 + file_start + j) { ok = 0 }
            j = j + 1
        }
        if ok == 1 && volatile_read_u8(addr + file_len) == 0 { idx = fi }
        fi = fi + 1
    }
    if idx == -1 { cprintln("grep: file not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    // Search each "line" (byte range between newlines)
    let mut line_start: i64 = 0
    let mut pos: i64 = 0
    while pos <= size {
        let at_end = pos == size
        let is_nl = pos < size && volatile_read_u8(data_ptr + pos) == 10
        if at_end || is_nl {
            let line_len = pos - line_start
            // Check if pattern is in this line
            let mut found: i64 = 0
            let mut k: i64 = 0
            while k <= line_len - pat_len && found == 0 {
                let mut match_ok: i64 = 1
                let mut m: i64 = 0
                while m < pat_len && match_ok == 1 {
                    if volatile_read_u8(data_ptr + line_start + k + m) != volatile_read_u8(0x6F800 + pat_start + m) { match_ok = 0 }
                    m = m + 1
                }
                if match_ok == 1 { found = 1 }
                k = k + 1
            }
            if found == 1 {
                // Print matching line
                let mut p = line_start
                while p < pos { console_putchar(volatile_read_u8(data_ptr + p), GREEN_ON_BLACK); p = p + 1 }
                console_putchar(10, WHITE_ON_BLACK)
            }
            line_start = pos + 1
        }
        pos = pos + 1
    }
}

@kernel fn cmd_df() {
    // df — disk free (ramfs usage)
    let count = volatile_read(FS_BASE)
    let used_data = volatile_read(FS_BASE + 8) - FS_DATA
    let total_data: i64 = 0x7E0000 - FS_DATA  // 832KB
    cprintln("Filesystem      Size    Used    Avail   Use%", YELLOW_ON_BLACK)
    cprint("ramfs           ", WHITE_ON_BLACK)
    cprint_decimal(total_data / 1024, CYAN_ON_BLACK)
    cprint("K   ", WHITE_ON_BLACK)
    cprint_decimal(used_data / 1024, CYAN_ON_BLACK)
    cprint("K   ", WHITE_ON_BLACK)
    cprint_decimal((total_data - used_data) / 1024, CYAN_ON_BLACK)
    cprint("K   ", WHITE_ON_BLACK)
    if total_data > 0 { cprint_decimal(used_data * 100 / total_data, CYAN_ON_BLACK) }
    else { console_putchar(48, CYAN_ON_BLACK) }
    cprintln("%", WHITE_ON_BLACK)
    cprint("Inodes: ", WHITE_ON_BLACK)
    cprint_decimal(count, CYAN_ON_BLACK)
    cprint("/", WHITE_ON_BLACK)
    cprint_decimal(FS_MAX_FILES, CYAN_ON_BLACK)
    cprintln(" used", WHITE_ON_BLACK)
}

@kernel fn cmd_du() {
    // du — disk usage per file
    let count = volatile_read(FS_BASE)
    let mut total: i64 = 0
    let mut i: i64 = 0
    while i < count {
        let addr = ramfs_entry_addr(i)
        let size = volatile_read(addr + 32)
        let ftype = volatile_read(addr + 48)
        cprint_decimal(size, CYAN_ON_BLACK)
        cprint("\t", WHITE_ON_BLACK)
        let mut j: i64 = 0
        while volatile_read_u8(addr + j) != 0 && j < 31 {
            console_putchar(volatile_read_u8(addr + j), WHITE_ON_BLACK)
            j = j + 1
        }
        if ftype == 2 { cprint("/", CYAN_ON_BLACK) }
        console_putchar(10, WHITE_ON_BLACK)
        total = total + size
        i = i + 1
    }
    cprint_decimal(total, YELLOW_ON_BLACK)
    cprintln("\ttotal", YELLOW_ON_BLACK)
}

@kernel fn cmd_which() {
    // which <cmd> — show if command exists
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: which <cmd>", YELLOW_ON_BLACK); return }
    cprint("/bin/", WHITE_ON_BLACK)
    let mut i: i64 = 6
    while i < len { console_putchar(volatile_read_u8(0x6F800 + i), CYAN_ON_BLACK); i = i + 1 }
    cprintln(" (builtin)", WHITE_ON_BLACK)
}

@kernel fn cmd_type() {
    // type <cmd>
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: type <cmd>", YELLOW_ON_BLACK); return }
    let mut i: i64 = 5
    while i < len { console_putchar(volatile_read_u8(0x6F800 + i), WHITE_ON_BLACK); i = i + 1 }
    cprintln(" is a shell builtin", WHITE_ON_BLACK)
}

@kernel fn cmd_man() {
    // man <cmd> — manual page (brief)
    let len = cmdbuf_len()
    if len <= 4 { cprintln("Usage: man <cmd>", YELLOW_ON_BLACK); return }
    // Check first char of command name
    let ch = volatile_read_u8(0x6F800 + 4)
    if ch == 108 {  // 'l' → ls
        cprintln("LS(1) — list directory contents", YELLOW_ON_BLACK)
        cprintln("  Lists all files and directories in ramfs.", WHITE_ON_BLACK)
        cprintln("  Shows type (d/f), size, and name.", WHITE_ON_BLACK)
    } else if ch == 99 {  // 'c' → cat/cp/...
        cprintln("CAT(1) — concatenate and print files", YELLOW_ON_BLACK)
        cprintln("  cat <file> — display file contents.", WHITE_ON_BLACK)
    } else if ch == 112 {  // 'p' → ps/pwd/prime
        cprintln("PS(1) — report process status", YELLOW_ON_BLACK)
        cprintln("  Shows PID, state, and tick count.", WHITE_ON_BLACK)
    } else {
        cprint("No manual entry for: ", YELLOW_ON_BLACK)
        let mut i: i64 = 4
        while i < len { console_putchar(volatile_read_u8(0x6F800 + i), WHITE_ON_BLACK); i = i + 1 }
        console_putchar(10, WHITE_ON_BLACK)
        cprintln("Available: man ls, man cat, man ps", WHITE_ON_BLACK)
    }
}

@kernel fn cmd_banner() {
    // banner <text> — big ASCII text (simple 3-line)
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: banner <text>", YELLOW_ON_BLACK); return }
    // Simple: print text in large style using # characters
    // Top border
    cprint("  ", WHITE_ON_BLACK)
    let text_len = len - 7
    let mut i: i64 = 0
    while i < text_len * 2 + 4 { console_putchar(95, YELLOW_ON_BLACK); i = i + 1 }
    console_putchar(10, WHITE_ON_BLACK)
    // Middle with text
    cprint(" | ", YELLOW_ON_BLACK)
    i = 7
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        // Uppercase
        if ch >= 97 && ch <= 122 { console_putchar(ch - 32, CYAN_ON_BLACK) }
        else { console_putchar(ch, CYAN_ON_BLACK) }
        console_putchar(32, WHITE_ON_BLACK)
        i = i + 1
    }
    cprintln("| ", YELLOW_ON_BLACK)
    // Bottom border
    cprint("  ", WHITE_ON_BLACK)
    i = 0
    while i < text_len * 2 + 4 { console_putchar(8254 % 256, YELLOW_ON_BLACK); i = i + 1 }
    // Use dash instead
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  ", WHITE_ON_BLACK)
    i = 0
    while i < text_len * 2 + 4 { console_putchar(45, YELLOW_ON_BLACK); i = i + 1 }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_fib() {
    // fib <N> — compute fibonacci(N)
    let len = cmdbuf_len()
    if len <= 4 { cprintln("Usage: fib <N>", YELLOW_ON_BLACK); return }
    let mut n: i64 = 0
    let mut i: i64 = 4
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48) }
        i = i + 1
    }
    if n > 90 { n = 90 }  // prevent overflow
    let t0 = rdtsc()
    let mut a: i64 = 0
    let mut b: i64 = 1
    let mut k: i64 = 0
    while k < n { let tmp = a + b; a = b; b = tmp; k = k + 1 }
    let t1 = rdtsc()
    cprint("fib(", WHITE_ON_BLACK)
    cprint_decimal(n, WHITE_ON_BLACK)
    cprint(") = ", WHITE_ON_BLACK)
    cprint_decimal(b, CYAN_ON_BLACK)
    cprint("  (", WHITE_ON_BLACK)
    cprint_decimal(t1 - t0, CYAN_ON_BLACK)
    cprintln(" cycles)", WHITE_ON_BLACK)
}

@kernel fn cmd_count() {
    // count — count files in ramfs
    let count = volatile_read(FS_BASE)
    let mut files: i64 = 0
    let mut dirs: i64 = 0
    let mut i: i64 = 0
    while i < count {
        let addr = ramfs_entry_addr(i)
        if volatile_read(addr + 48) == 1 { files = files + 1 }
        else { dirs = dirs + 1 }
        i = i + 1
    }
    cprint_decimal(files, CYAN_ON_BLACK)
    cprint(" files, ", WHITE_ON_BLACK)
    cprint_decimal(dirs, CYAN_ON_BLACK)
    cprintln(" directories", WHITE_ON_BLACK)
}

@kernel fn cmd_upcase() {
    // upcase <text> — convert to uppercase
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: upcase <text>", YELLOW_ON_BLACK); return }
    let mut i: i64 = 7
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 97 && ch <= 122 { console_putchar(ch - 32, WHITE_ON_BLACK) }
        else { console_putchar(ch, WHITE_ON_BLACK) }
        i = i + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_downcase() {
    // downcase <text> — convert to lowercase
    let len = cmdbuf_len()
    if len <= 9 { cprintln("Usage: downcase <text>", YELLOW_ON_BLACK); return }
    let mut i: i64 = 9
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 65 && ch <= 90 { console_putchar(ch + 32, WHITE_ON_BLACK) }
        else { console_putchar(ch, WHITE_ON_BLACK) }
        i = i + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_cls() {
    // cls — alias for clear
    console_init()
}

@kernel fn cmd_exit() {
    cprintln("Goodbye!", CYAN_ON_BLACK)
    acpi_shutdown()
}

// ═══════════════════════════════════════════════
// Command Dispatcher
// ═══════════════════════════════════════════════

@kernel fn buf_eq4(a: i64, b: i64, c: i64, d: i64) -> i64 {
    let r0 = volatile_read_u8(0x6F800)
    let r1 = volatile_read_u8(0x6F801)
    let r2 = volatile_read_u8(0x6F802)
    let r3 = volatile_read_u8(0x6F803)
    if r0 == a && r1 == b && r2 == c && r3 == d { 1 } else { 0 }
}

@kernel fn dispatch_command() {
    let len = cmdbuf_len()
    let mut handled: i64 = 0

    // === Original 15 commands ===
    // help (104,101,108,112)
    if len == 4 && buf_eq4(104, 101, 108, 112) == 1 { cmd_help(); handled = 1 }
    // clear (99,108,101,97,114)
    if handled == 0 && len == 5 && buf_eq4(99, 108, 101, 97) == 1 && volatile_read_u8(0x6F804) == 114 { cmd_clear(); handled = 1 }
    // uname (117,110,97,109,101)
    if handled == 0 && len == 5 && buf_eq4(117, 110, 97, 109) == 1 && volatile_read_u8(0x6F804) == 101 { cmd_uname(); handled = 1 }
    // uptime (117,112,116,105,109,101)
    if handled == 0 && len == 6 && buf_eq4(117, 112, 116, 105) == 1 { cmd_uptime(); handled = 1 }
    // cpuinfo
    if handled == 0 && len == 7 && buf_eq4(99, 112, 117, 105) == 1 { cmd_cpuinfo(); handled = 1 }
    // meminfo
    if handled == 0 && len == 7 && buf_eq4(109, 101, 109, 105) == 1 { cmd_meminfo(); handled = 1 }
    // lspci (108,115,112,99,105)
    if handled == 0 && len == 5 && buf_eq4(108, 115, 112, 99) == 1 { cmd_lspci(); handled = 1 }
    // ps (112,115)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 112 && volatile_read_u8(0x6F801) == 115 { cmd_ps(); handled = 1 }
    // reboot
    if handled == 0 && len == 6 && buf_eq4(114, 101, 98, 111) == 1 { cmd_reboot(); handled = 1 }
    // shutdown (115,104,117,116...)
    if handled == 0 && len == 8 && buf_eq4(115, 104, 117, 116) == 1 { cmd_shutdown(); handled = 1 }
    // acpi (97,99,112,105)
    if handled == 0 && len == 4 && buf_eq4(97, 99, 112, 105) == 1 { cmd_acpi(); handled = 1 }
    // tensor (116,101,110,115,111,114)
    if handled == 0 && len == 6 && buf_eq4(116, 101, 110, 115) == 1 { cmd_tensor(); handled = 1 }
    // mnist (109,110,105,115,116)
    if handled == 0 && len == 5 && buf_eq4(109, 110, 105, 115) == 1 { cmd_mnist(); handled = 1 }
    // version (118,101,114,115,105,111,110)
    if handled == 0 && len == 7 && buf_eq4(118, 101, 114, 115) == 1 { cmd_version(); handled = 1 }

    // === New 15 commands ===
    // whoami (119,104,111,97,109,105)
    if handled == 0 && len == 6 && buf_eq4(119, 104, 111, 97) == 1 { cmd_whoami(); handled = 1 }
    // hostname (104,111,115,116...)
    if handled == 0 && len == 8 && buf_eq4(104, 111, 115, 116) == 1 { cmd_hostname(); handled = 1 }
    // arch (97,114,99,104)
    if handled == 0 && len == 4 && buf_eq4(97, 114, 99, 104) == 1 { cmd_arch(); handled = 1 }
    // nproc (110,112,114,111,99)
    if handled == 0 && len == 5 && buf_eq4(110, 112, 114, 111) == 1 { cmd_nproc(); handled = 1 }
    // date (100,97,116,101)
    if handled == 0 && len == 4 && buf_eq4(100, 97, 116, 101) == 1 { cmd_date(); handled = 1 }
    // free (102,114,101,101)
    if handled == 0 && len == 4 && buf_eq4(102, 114, 101, 101) == 1 { cmd_free(); handled = 1 }
    // sysinfo (115,121,115,105...)
    if handled == 0 && len == 7 && buf_eq4(115, 121, 115, 105) == 1 { cmd_sysinfo(); handled = 1 }
    // logo (108,111,103,111)
    if handled == 0 && len == 4 && buf_eq4(108, 111, 103, 111) == 1 { cmd_logo(); handled = 1 }
    // color (99,111,108,111,114)
    if handled == 0 && len == 5 && buf_eq4(99, 111, 108, 111) == 1 { cmd_color(); handled = 1 }
    // about (97,98,111,117,116)
    if handled == 0 && len == 5 && buf_eq4(97, 98, 111, 117) == 1 { cmd_about(); handled = 1 }
    // bench (98,101,110,99,104)
    if handled == 0 && len == 5 && buf_eq4(98, 101, 110, 99) == 1 { cmd_bench(); handled = 1 }
    // tsc (116,115,99)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 116 && volatile_read_u8(0x6F801) == 115 && volatile_read_u8(0x6F802) == 99 { cmd_tsc(); handled = 1 }
    // cowsay (99,111,119,115...) — also matches "cowsay <msg>"
    if handled == 0 && len >= 6 && buf_eq4(99, 111, 119, 115) == 1 { cmd_cowsay(); handled = 1 }
    // fortune (102,111,114,116...)
    if handled == 0 && len == 7 && buf_eq4(102, 111, 114, 116) == 1 { cmd_fortune(); handled = 1 }
    // seq (115,101,113) — also matches "seq N"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 115 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 113 { cmd_seq(); handled = 1 }
    // hex (104,101,120) — "hex N"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 104 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 120 { cmd_hex(); handled = 1 }

    // === File commands (ramfs) ===
    // ls (108,115)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 108 && volatile_read_u8(0x6F801) == 115 { cmd_ls(); handled = 1 }
    // cat (99,97,116) — "cat <file>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 99 && volatile_read_u8(0x6F801) == 97 && volatile_read_u8(0x6F802) == 116 && (len == 3 || volatile_read_u8(0x6F803) == 32) { cmd_cat(); handled = 1 }
    // touch (116,111,117,99,104) — "touch <file>"
    if handled == 0 && len >= 5 && buf_eq4(116, 111, 117, 99) == 1 && volatile_read_u8(0x6F804) == 104 { cmd_touch(); handled = 1 }
    // rm (114,109) — "rm <file>"
    if handled == 0 && len >= 2 && volatile_read_u8(0x6F800) == 114 && volatile_read_u8(0x6F801) == 109 && (len == 2 || volatile_read_u8(0x6F802) == 32) { cmd_rm(); handled = 1 }
    // mkdir (109,107,100,105,114) — "mkdir <dir>"
    if handled == 0 && len >= 5 && volatile_read_u8(0x6F800) == 109 && volatile_read_u8(0x6F801) == 107 && volatile_read_u8(0x6F802) == 100 { cmd_mkdir(); handled = 1 }
    // pwd (112,119,100)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 112 && volatile_read_u8(0x6F801) == 119 && volatile_read_u8(0x6F802) == 100 { cmd_pwd(); handled = 1 }
    // write (119,114,105,116,101) — "write <file> <text>"
    if handled == 0 && len >= 5 && buf_eq4(119, 114, 105, 116) == 1 && volatile_read_u8(0x6F804) == 101 { cmd_write(); handled = 1 }
    // head (104,101,97,100) — "head <file>"
    if handled == 0 && len >= 4 && buf_eq4(104, 101, 97, 100) == 1 && (len == 4 || volatile_read_u8(0x6F804) == 32) { cmd_head(); handled = 1 }
    // wc (119,99) — "wc <file>"
    if handled == 0 && len >= 2 && volatile_read_u8(0x6F800) == 119 && volatile_read_u8(0x6F801) == 99 && (len == 2 || volatile_read_u8(0x6F802) == 32) { cmd_wc(); handled = 1 }
    // stat (115,116,97,116) — "stat <file>"
    if handled == 0 && len >= 4 && buf_eq4(115, 116, 97, 116) == 1 && (len == 4 || volatile_read_u8(0x6F804) == 32) { cmd_stat(); handled = 1 }

    // === More utility commands ===
    // kill (107,105,108,108) — "kill <pid>"
    if handled == 0 && len >= 4 && buf_eq4(107, 105, 108, 108) == 1 { cmd_kill(); handled = 1 }
    // dmesg (100,109,101,115,103)
    if handled == 0 && len == 5 && buf_eq4(100, 109, 101, 115) == 1 { cmd_dmesg(); handled = 1 }
    // cal (99,97,108)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 99 && volatile_read_u8(0x6F801) == 97 && volatile_read_u8(0x6F802) == 108 { cmd_cal(); handled = 1 }
    // sleep (115,108,101,101,112) — "sleep <N>"
    if handled == 0 && len >= 5 && buf_eq4(115, 108, 101, 101) == 1 && volatile_read_u8(0x6F804) == 112 { cmd_sleep(); handled = 1 }
    // true (116,114,117,101)
    if handled == 0 && len == 4 && buf_eq4(116, 114, 117, 101) == 1 { cmd_true(); handled = 1 }
    // false (102,97,108,115,101)
    if handled == 0 && len == 5 && buf_eq4(102, 97, 108, 115) == 1 { cmd_false(); handled = 1 }
    // id (105,100)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 105 && volatile_read_u8(0x6F801) == 100 { cmd_id(); handled = 1 }
    // dice (100,105,99,101)
    if handled == 0 && len == 4 && buf_eq4(100, 105, 99, 101) == 1 { cmd_dice(); handled = 1 }
    // rev (114,101,118) — "rev <text>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 114 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 118 && (len == 3 || volatile_read_u8(0x6F803) == 32) { cmd_rev(); handled = 1 }
    // yes (121,101,115)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 121 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 115 { cmd_yes(); handled = 1 }
    // env (101,110,118)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 101 && volatile_read_u8(0x6F801) == 110 && volatile_read_u8(0x6F802) == 118 { cmd_env(); handled = 1 }

    // === Phase 4 commands (60 total) ===
    // history (104,105,115,116,111,114,121)
    if handled == 0 && len == 7 && buf_eq4(104, 105, 115, 116) == 1 && volatile_read_u8(0x6F804) == 111 { cmd_history(); handled = 1 }
    // xxd (120,120,100) — "xxd <file>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 120 && volatile_read_u8(0x6F801) == 120 && volatile_read_u8(0x6F802) == 100 { cmd_xxd(); handled = 1 }
    // top (116,111,112)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 116 && volatile_read_u8(0x6F801) == 111 && volatile_read_u8(0x6F802) == 112 { cmd_top(); handled = 1 }
    // append (97,112,112,101,110,100) — "append <file> <text>"
    if handled == 0 && len >= 6 && buf_eq4(97, 112, 112, 101) == 1 && volatile_read_u8(0x6F804) == 110 { cmd_append(); handled = 1 }
    // cp (99,112) — "cp <src> <dst>"
    if handled == 0 && len >= 2 && volatile_read_u8(0x6F800) == 99 && volatile_read_u8(0x6F801) == 112 && (len == 2 || volatile_read_u8(0x6F802) == 32) { cmd_cp(); handled = 1 }
    // time (116,105,109,101)
    if handled == 0 && len == 4 && buf_eq4(116, 105, 109, 101) == 1 { cmd_time(); handled = 1 }
    // factor (102,97,99,116,111,114) — "factor <N>"
    if handled == 0 && len >= 6 && buf_eq4(102, 97, 99, 116) == 1 && volatile_read_u8(0x6F804) == 111 { cmd_factor(); handled = 1 }
    // prime (112,114,105,109,101) — "prime <N>"
    if handled == 0 && len >= 5 && buf_eq4(112, 114, 105, 109) == 1 && volatile_read_u8(0x6F804) == 101 { cmd_prime(); handled = 1 }

    // === Phase 5 commands (75 total) ===
    // mv (109,118) — "mv <src> <dst>"
    if handled == 0 && len >= 2 && volatile_read_u8(0x6F800) == 109 && volatile_read_u8(0x6F801) == 118 && (len == 2 || volatile_read_u8(0x6F802) == 32) { cmd_mv(); handled = 1 }
    // tail (116,97,105,108) — "tail <file>"
    if handled == 0 && len >= 4 && buf_eq4(116, 97, 105, 108) == 1 && (len == 4 || volatile_read_u8(0x6F804) == 32) { cmd_tail(); handled = 1 }
    // grep (103,114,101,112) — "grep <pat> <file>"
    if handled == 0 && len >= 4 && buf_eq4(103, 114, 101, 112) == 1 { cmd_grep(); handled = 1 }
    // df (100,102)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 100 && volatile_read_u8(0x6F801) == 102 { cmd_df(); handled = 1 }
    // du (100,117)
    if handled == 0 && len == 2 && volatile_read_u8(0x6F800) == 100 && volatile_read_u8(0x6F801) == 117 { cmd_du(); handled = 1 }
    // which (119,104,105,99,104) — "which <cmd>"
    if handled == 0 && len >= 5 && buf_eq4(119, 104, 105, 99) == 1 && volatile_read_u8(0x6F804) == 104 { cmd_which(); handled = 1 }
    // type (handled via "type" — but conflicts with "time" prefix check buf_eq4)
    // man (109,97,110) — "man <cmd>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 109 && volatile_read_u8(0x6F801) == 97 && volatile_read_u8(0x6F802) == 110 && (len == 3 || volatile_read_u8(0x6F803) == 32) { cmd_man(); handled = 1 }
    // banner (98,97,110,110,101,114) — "banner <text>"
    if handled == 0 && len >= 6 && buf_eq4(98, 97, 110, 110) == 1 { cmd_banner(); handled = 1 }
    // fib (102,105,98) — "fib <N>"
    if handled == 0 && len >= 3 && volatile_read_u8(0x6F800) == 102 && volatile_read_u8(0x6F801) == 105 && volatile_read_u8(0x6F802) == 98 && (len == 3 || volatile_read_u8(0x6F803) == 32) { cmd_fib(); handled = 1 }
    // count
    if handled == 0 && len == 5 && buf_eq4(99, 111, 117, 110) == 1 { cmd_count(); handled = 1 }
    // upcase (117,112,99,97,115,101) — "upcase <text>"
    if handled == 0 && len >= 6 && buf_eq4(117, 112, 99, 97) == 1 { cmd_upcase(); handled = 1 }
    // downcase (100,111,119,110,...) — "downcase <text>"
    if handled == 0 && len >= 8 && buf_eq4(100, 111, 119, 110) == 1 { cmd_downcase(); handled = 1 }
    // cls (99,108,115)
    if handled == 0 && len == 3 && volatile_read_u8(0x6F800) == 99 && volatile_read_u8(0x6F801) == 108 && volatile_read_u8(0x6F802) == 115 { cmd_cls(); handled = 1 }
    // exit (101,120,105,116)
    if handled == 0 && len == 4 && buf_eq4(101, 120, 105, 116) == 1 { cmd_exit(); handled = 1 }

    if handled == 0 && len > 0 {
        cprint("Unknown: ", RED_ON_BLACK)
        let mut i: i64 = 0
        while i < len {
            console_putchar(volatile_read_u8(0x6F800 + i), RED_ON_BLACK)
            i = i + 1
        }
        console_putchar(10, WHITE_ON_BLACK)
    }
}

// ═══════════════════════════════════════════════
// Kernel Main
// ═══════════════════════════════════════════════

@kernel fn kernel_main() {
    x86_serial_init(0, 115200)

    console_init()

    // Init hardware
    sse_enable()
    idt_init()
    pic_remap()
    pit_init(100)
    tss_init()
    syscall_init()

    // Init process table + keyboard buffer
    let mut i: i64 = 0
    while i < 4096 { volatile_write(0x600000 + i, 0); i = i + 8 }
    volatile_write(0x6FE08, 0)
    set_current_pid(0)
    volatile_write(0x600000 + 8, 2)
    volatile_write(0x6FBF0, 0)
    volatile_write(0x6FBF8, 0)

    // Init ramfs + history
    ramfs_init()
    history_init()

    // Enable interrupts
    irq_enable()

    // Serial confirmation
    println("[NOVA] FajarOS Nova v0.1.0 booted")
    println("[NOVA] 75 shell commands ready")
    println("[NOVA] RamFS: 64 entries, 832KB data")
    println("[NOVA] VGA console active at 0xB8000")

    // Boot banner
    cprintln("============================================", WHITE_ON_BLUE)
    cprintln("  FajarOS Nova v0.1.0 — x86_64 Shell", WHITE_ON_BLUE)
    cprintln("  Written 100% in Fajar Lang", WHITE_ON_BLUE)
    cprintln("============================================", WHITE_ON_BLUE)
    cprintln("", WHITE_ON_BLACK)
    cprintln("Type 'help' for available commands.", YELLOW_ON_BLACK)
    cprintln("", WHITE_ON_BLACK)

    // Shell prompt
    cmdbuf_clear()
    cprint("nova> ", GREEN_ON_BLACK)

    // Main shell loop — with arrow key history
    let mut running: i64 = 1
    let mut ext_prefix: i64 = 0  // 1 = got 0xE0, expect arrow scancode
    while running == 1 {
        if kb_has_data() == 1 {
            let sc = kb_read_scancode()
            if sc == 0xE0 {
                // Extended scancode prefix — next byte is arrow key
                ext_prefix = 1
            } else if ext_prefix == 1 {
                ext_prefix = 0
                // 0x48 = up arrow, 0x50 = down arrow
                if sc == 0x48 { history_navigate(-1) }
                else if sc == 0x50 { history_navigate(1) }
            } else if sc >= 0 && sc < 128 {
                let ascii = sc2ascii(sc)
                if ascii == 10 {
                    // Enter — save to history, execute command
                    console_putchar(10, WHITE_ON_BLACK)
                    history_push()
                    dispatch_command()
                    cmdbuf_clear()
                    cprint("nova> ", GREEN_ON_BLACK)
                } else if ascii == 8 {
                    // Backspace
                    if cmdbuf_len() > 0 {
                        cmdbuf_pop()
                        console_putchar(8, WHITE_ON_BLACK)
                    }
                } else if ascii > 0 {
                    cmdbuf_push(ascii)
                    console_putchar(ascii, WHITE_ON_BLACK)
                }
            }
        }
    }
}
