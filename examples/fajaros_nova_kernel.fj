    cprint("  caps:   ", WHITE_ON_BLACK)
    if volatile_read(0x6FBE8) == 1 { cprintln("ON", GREEN_ON_BLACK) }
    else { cprintln("off", WHITE_ON_BLACK) }
    cprint("  hist:   ", WHITE_ON_BLACK)
