@kernel fn cmd_history() {
    let count = volatile_read(0x6FC00)
    if count == 0 { cprintln("(no history)", WHITE_ON_BLACK); return }
    let mut i: i64 = 0
    while i < count {
        cprint("  ", WHITE_ON_BLACK)
        cprint_decimal(i + 1, YELLOW_ON_BLACK)
        cprint("  ", WHITE_ON_BLACK)
        let slot = HIST_BASE + i * HIST_SLOT_SIZE
        let mut j: i64 = 0
        while volatile_read_u8(slot + j) != 0 && j < 63 {
            console_putchar(volatile_read_u8(slot + j), WHITE_ON_BLACK)
            j = j + 1
        }
        console_putchar(10, WHITE_ON_BLACK)
        i = i + 1
    }
}

@kernel fn cmd_xxd() {
    // xxd <file> — hex dump of file contents
    let len = cmdbuf_len()
    if len <= 4 { cprintln("Usage: xxd <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(4)
    if idx == -1 { cprintln("xxd: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    if size == 0 { cprintln("(empty)", WHITE_ON_BLACK); return }
    let mut off: i64 = 0
    while off < size && off < 128 {
        // Offset
        cprint_hex(off, 4, YELLOW_ON_BLACK)
        cprint(": ", WHITE_ON_BLACK)
        // Hex bytes (16 per line)
        let mut i: i64 = 0
        while i < 16 {
            if off + i < size {
                cprint_hex(volatile_read_u8(data_ptr + off + i), 2, CYAN_ON_BLACK)
                console_putchar(32, WHITE_ON_BLACK)
            } else {
                cprint("   ", WHITE_ON_BLACK)
            }
            i = i + 1
        }
        cprint(" ", WHITE_ON_BLACK)
        // ASCII
        i = 0
        while i < 16 && off + i < size {
            let ch = volatile_read_u8(data_ptr + off + i)
            if ch >= 32 && ch < 127 { console_putchar(ch, GREEN_ON_BLACK) }
            else { console_putchar(46, WHITE_ON_BLACK) }
            i = i + 1
        }
        console_putchar(10, WHITE_ON_BLACK)
        off = off + 16
    }
}

@kernel fn cmd_top() {
    cprintln("PID  STATE      TICKS    CPU", YELLOW_ON_BLACK)
    cprintln("---  ---------  -------  ---", WHITE_ON_BLACK)
    let total_ticks = read_timer_ticks()
    let mut i: i64 = 0
    while i < 16 {
        let base = 0x600000 + i * 256
        let state = volatile_read(base + 8)
        if state != 0 {
            cprint_decimal(i, CYAN_ON_BLACK)
            cprint("    ", WHITE_ON_BLACK)
            if state == 1 { cprint("ready    ", WHITE_ON_BLACK) }
            else if state == 2 { cprint("RUNNING  ", GREEN_ON_BLACK) }
            else if state == 3 { cprint("blocked  ", YELLOW_ON_BLACK) }
            else { cprint("unknown  ", RED_ON_BLACK) }
            cprint("  ", WHITE_ON_BLACK)
            let ticks = volatile_read(base + 32)
            cprint_decimal(ticks, WHITE_ON_BLACK)
            cprint("    ", WHITE_ON_BLACK)
            if total_ticks > 0 {
                cprint_decimal(ticks * 100 / (total_ticks + 1), CYAN_ON_BLACK)
                console_putchar(37, WHITE_ON_BLACK) // '%'
            }
            console_putchar(10, WHITE_ON_BLACK)
        }
        i = i + 1
    }
}

@kernel fn cmd_append() {
    // append <file> <text> — append text to existing file
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: append <file> <text>", YELLOW_ON_BLACK); return }
    // Find space after "append "
    let mut sp: i64 = 7
    while sp < len && volatile_read_u8(0x6F800 + sp) != 32 { sp = sp + 1 }
    if sp >= len - 1 { cprintln("Usage: append <file> <text>", YELLOW_ON_BLACK); return }
    let name_len = sp - 7
    // Find file
    let count = volatile_read(FS_BASE)
    let mut idx: i64 = -1
    let mut fi: i64 = 0
    while fi < count && idx == -1 {
        let addr = ramfs_entry_addr(fi)
        let mut match_ok: i64 = 1
        let mut j: i64 = 0
        while j < name_len && match_ok == 1 {
            if volatile_read_u8(addr + j) != volatile_read_u8(0x6F800 + 7 + j) { match_ok = 0 }
            j = j + 1
        }
        if match_ok == 1 && volatile_read_u8(addr + name_len) == 0 { idx = fi }
        fi = fi + 1
    }
    if idx == -1 { cprintln("append: file not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let old_size = volatile_read(addr + 32)
    let old_ptr = volatile_read(addr + 40)
    let text_start = sp + 1
    let text_len = len - text_start
    // Allocate new data area and copy old + new
    let new_ptr = volatile_read(FS_BASE + 8)
    let mut i: i64 = 0
    while i < old_size {
        volatile_write_u8(new_ptr + i, volatile_read_u8(old_ptr + i))
        i = i + 1
    }
    i = 0
    while i < text_len {
        volatile_write_u8(new_ptr + old_size + i, volatile_read_u8(0x6F800 + text_start + i))
        i = i + 1
    }
    volatile_write(addr + 32, old_size + text_len)
    volatile_write(addr + 40, new_ptr)
    volatile_write(FS_BASE + 8, new_ptr + old_size + text_len)
}

@kernel fn cmd_cp() {
    // cp <src> <dst> — copy file
    let len = cmdbuf_len()
    if len <= 3 { cprintln("Usage: cp <src> <dst>", YELLOW_ON_BLACK); return }
    // Find space between src and dst
    let mut sp: i64 = 3
    while sp < len && volatile_read_u8(0x6F800 + sp) != 32 { sp = sp + 1 }
    if sp >= len - 1 { cprintln("Usage: cp <src> <dst>", YELLOW_ON_BLACK); return }
    let src_len = sp - 3
    let dst_start = sp + 1
    let dst_len = len - dst_start
    // Find source file
    let count = volatile_read(FS_BASE)
    let mut src_idx: i64 = -1
    let mut fi: i64 = 0
    while fi < count && src_idx == -1 {
        let addr = ramfs_entry_addr(fi)
        let mut match_ok: i64 = 1
        let mut j: i64 = 0
        while j < src_len && match_ok == 1 {
            if volatile_read_u8(addr + j) != volatile_read_u8(0x6F800 + 3 + j) { match_ok = 0 }
            j = j + 1
        }
        if match_ok == 1 && volatile_read_u8(addr + src_len) == 0 { src_idx = fi }
        fi = fi + 1
    }
    if src_idx == -1 { cprintln("cp: source not found", RED_ON_BLACK); return }
    // Create destination
    if count >= FS_MAX_FILES { cprintln("cp: filesystem full", RED_ON_BLACK); return }
    let src_addr = ramfs_entry_addr(src_idx)
    let src_size = volatile_read(src_addr + 32)
    let src_data = volatile_read(src_addr + 40)
    let dst_idx = count
    let dst_addr = ramfs_entry_addr(dst_idx)
    // Copy name
    let mut i: i64 = 0
    while i < dst_len && i < 31 {
        volatile_write_u8(dst_addr + i, volatile_read_u8(0x6F800 + dst_start + i))
        i = i + 1
    }
    volatile_write_u8(dst_addr + i, 0)
    // Copy data
    let new_ptr = volatile_read(FS_BASE + 8)
    i = 0
    while i < src_size {
        volatile_write_u8(new_ptr + i, volatile_read_u8(src_data + i))
        i = i + 1
    }
    volatile_write(dst_addr + 32, src_size)
    volatile_write(dst_addr + 40, new_ptr)
    volatile_write(dst_addr + 48, 1) // file
    volatile_write(FS_BASE, count + 1)
    volatile_write(FS_BASE + 8, new_ptr + src_size)
}

@kernel fn cmd_time() {
    // time — run a benchmark and show elapsed
    cprint("Timing 100K loop... ", WHITE_ON_BLACK)
    let t0 = rdtsc()
    let mut i: i64 = 0
    let mut acc: i64 = 0
    while i < 100000 { acc = acc + i; i = i + 1 }
    let t1 = rdtsc()
    let cycles = t1 - t0
    cprint_decimal(cycles, CYAN_ON_BLACK)
    cprint(" cycles (", WHITE_ON_BLACK)
    cprint_decimal(cycles / 1000, CYAN_ON_BLACK)
    cprintln("K)", WHITE_ON_BLACK)
}

@kernel fn cmd_factor() {
    // factor <N> — factorize a number
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: factor <N>", YELLOW_ON_BLACK); return }
    let mut n: i64 = 0
    let mut i: i64 = 7
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48) }
        i = i + 1
    }
    if n <= 1 { cprintln("factor: need N > 1", YELLOW_ON_BLACK); return }
    cprint_decimal(n, WHITE_ON_BLACK)
    cprint(": ", WHITE_ON_BLACK)
    let mut d: i64 = 2
    let mut val = n
    while d * d <= val {
        while val % d == 0 {
            cprint_decimal(d, CYAN_ON_BLACK)
            console_putchar(32, WHITE_ON_BLACK)
            val = val / d
        }
        d = d + 1
    }
    if val > 1 { cprint_decimal(val, CYAN_ON_BLACK) }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_prime() {
    // prime <N> — check if N is prime
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: prime <N>", YELLOW_ON_BLACK); return }
    let mut n: i64 = 0
    let mut i: i64 = 6
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48) }
        i = i + 1
    }
    if n <= 1 { cprintln("Not prime", RED_ON_BLACK); return }
    let mut is_prime: i64 = 1
    let mut d: i64 = 2
    while d * d <= n {
        if n % d == 0 { is_prime = 0 }
        d = d + 1
    }
    cprint_decimal(n, WHITE_ON_BLACK)
    if is_prime == 1 { cprintln(" is PRIME", GREEN_ON_BLACK) }
    else { cprintln(" is not prime", RED_ON_BLACK) }
}

// ═══════════════════════════════════════════════
// Phase 5 Commands — 75+ total
// ═══════════════════════════════════════════════

@kernel fn cmd_mv() {
    // mv <src> <dst> — rename/move file
    let len = cmdbuf_len()
    if len <= 3 { cprintln("Usage: mv <src> <dst>", YELLOW_ON_BLACK); return }
    let mut sp: i64 = 3
    while sp < len && volatile_read_u8(0x6F800 + sp) != 32 { sp = sp + 1 }
    if sp >= len - 1 { cprintln("Usage: mv <src> <dst>", YELLOW_ON_BLACK); return }
    let src_len = sp - 3
    let dst_start = sp + 1
    let dst_len = len - dst_start
    // Find source
    let count = volatile_read(FS_BASE)
    let mut idx: i64 = -1
    let mut fi: i64 = 0
    while fi < count && idx == -1 {
        let addr = ramfs_entry_addr(fi)
        let mut ok: i64 = 1
        let mut j: i64 = 0
        while j < src_len && ok == 1 {
            if volatile_read_u8(addr + j) != volatile_read_u8(0x6F800 + 3 + j) { ok = 0 }
            j = j + 1
        }
        if ok == 1 && volatile_read_u8(addr + src_len) == 0 { idx = fi }
        fi = fi + 1
    }
    if idx == -1 { cprintln("mv: source not found", RED_ON_BLACK); return }
    // Rename: overwrite name
    let addr = ramfs_entry_addr(idx)
    let mut i: i64 = 0
    while i < dst_len && i < 31 {
        volatile_write_u8(addr + i, volatile_read_u8(0x6F800 + dst_start + i))
        i = i + 1
    }
    volatile_write_u8(addr + i, 0)
    // Clear remaining name bytes
    while i < 32 { volatile_write_u8(addr + i, 0); i = i + 1 }
}

@kernel fn cmd_tail() {
    // tail <file> — show last 5 lines
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: tail <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(5)
    if idx == -1 { cprintln("tail: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    if size == 0 { return }
    // Count total lines
    let mut total_lines: i64 = 0
    let mut i: i64 = 0
    while i < size { if volatile_read_u8(data_ptr + i) == 10 { total_lines = total_lines + 1 }; i = i + 1 }
    // Find start of last 5 lines
    let skip = total_lines - 5
    let mut line_num: i64 = 0
    let mut start: i64 = 0
    if skip > 0 {
        i = 0
        while i < size && line_num < skip {
            if volatile_read_u8(data_ptr + i) == 10 { line_num = line_num + 1 }
            i = i + 1
        }
        start = i
    }
    // Print from start
    i = start
    while i < size { console_putchar(volatile_read_u8(data_ptr + i), WHITE_ON_BLACK); i = i + 1 }
    if size > 0 && volatile_read_u8(data_ptr + size - 1) != 10 { console_putchar(10, WHITE_ON_BLACK) }
}

@kernel fn cmd_grep() {
    // grep <pattern> <file> — search for pattern in file
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: grep <pattern> <file>", YELLOW_ON_BLACK); return }
    // Find first space (after "grep ")
    let mut sp: i64 = 5
    while sp < len && volatile_read_u8(0x6F800 + sp) != 32 { sp = sp + 1 }
    if sp >= len - 1 { cprintln("Usage: grep <pattern> <file>", YELLOW_ON_BLACK); return }
    let pat_start: i64 = 5
    let pat_len = sp - 5
    let file_start = sp + 1
    let file_len = len - file_start
    // Find file
    let count = volatile_read(FS_BASE)
    let mut idx: i64 = -1
    let mut fi: i64 = 0
    while fi < count && idx == -1 {
        let addr = ramfs_entry_addr(fi)
        let mut ok: i64 = 1
        let mut j: i64 = 0
        while j < file_len && ok == 1 {
            if volatile_read_u8(addr + j) != volatile_read_u8(0x6F800 + file_start + j) { ok = 0 }
            j = j + 1
        }
        if ok == 1 && volatile_read_u8(addr + file_len) == 0 { idx = fi }
        fi = fi + 1
    }
    if idx == -1 { cprintln("grep: file not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    // Search each "line" (byte range between newlines)
    let mut line_start: i64 = 0
    let mut pos: i64 = 0
    while pos <= size {
        let at_end = pos == size
        let is_nl = pos < size && volatile_read_u8(data_ptr + pos) == 10
        if at_end || is_nl {
            let line_len = pos - line_start
            // Check if pattern is in this line
            let mut found: i64 = 0
            let mut k: i64 = 0
            while k <= line_len - pat_len && found == 0 {
                let mut match_ok: i64 = 1
                let mut m: i64 = 0
                while m < pat_len && match_ok == 1 {
                    if volatile_read_u8(data_ptr + line_start + k + m) != volatile_read_u8(0x6F800 + pat_start + m) { match_ok = 0 }
                    m = m + 1
                }
                if match_ok == 1 { found = 1 }
                k = k + 1
            }
            if found == 1 {
                // Print matching line
                let mut p = line_start
                while p < pos { console_putchar(volatile_read_u8(data_ptr + p), GREEN_ON_BLACK); p = p + 1 }
                console_putchar(10, WHITE_ON_BLACK)
            }
            line_start = pos + 1
        }
        pos = pos + 1
    }
}

@kernel fn cmd_df() {
    // df — disk free (ramfs usage)
    let count = volatile_read(FS_BASE)
    let used_data = volatile_read(FS_BASE + 8) - FS_DATA
    let total_data: i64 = 0x7E0000 - FS_DATA  // 832KB
    cprintln("Filesystem      Size    Used    Avail   Use%", YELLOW_ON_BLACK)
    cprint("ramfs           ", WHITE_ON_BLACK)
    cprint_decimal(total_data / 1024, CYAN_ON_BLACK)
    cprint("K   ", WHITE_ON_BLACK)
    cprint_decimal(used_data / 1024, CYAN_ON_BLACK)
    cprint("K   ", WHITE_ON_BLACK)
    cprint_decimal((total_data - used_data) / 1024, CYAN_ON_BLACK)
    cprint("K   ", WHITE_ON_BLACK)
    if total_data > 0 { cprint_decimal(used_data * 100 / total_data, CYAN_ON_BLACK) }
    else { console_putchar(48, CYAN_ON_BLACK) }
    cprintln("%", WHITE_ON_BLACK)
    cprint("Inodes: ", WHITE_ON_BLACK)
    cprint_decimal(count, CYAN_ON_BLACK)
    cprint("/", WHITE_ON_BLACK)
    cprint_decimal(FS_MAX_FILES, CYAN_ON_BLACK)
    cprintln(" used", WHITE_ON_BLACK)
}

@kernel fn cmd_du() {
    // du — disk usage per file
    let count = volatile_read(FS_BASE)
    let mut total: i64 = 0
    let mut i: i64 = 0
    while i < count {
        let addr = ramfs_entry_addr(i)
        let size = volatile_read(addr + 32)
        let ftype = volatile_read(addr + 48)
        cprint_decimal(size, CYAN_ON_BLACK)
        cprint("\t", WHITE_ON_BLACK)
        let mut j: i64 = 0
        while volatile_read_u8(addr + j) != 0 && j < 31 {
            console_putchar(volatile_read_u8(addr + j), WHITE_ON_BLACK)
            j = j + 1
        }
        if ftype == 2 { cprint("/", CYAN_ON_BLACK) }
        console_putchar(10, WHITE_ON_BLACK)
        total = total + size
        i = i + 1
    }
    cprint_decimal(total, YELLOW_ON_BLACK)
    cprintln("\ttotal", YELLOW_ON_BLACK)
}

@kernel fn cmd_which() {
    // which <cmd> — show if command exists
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: which <cmd>", YELLOW_ON_BLACK); return }
    cprint("/bin/", WHITE_ON_BLACK)
    let mut i: i64 = 6
    while i < len { console_putchar(volatile_read_u8(0x6F800 + i), CYAN_ON_BLACK); i = i + 1 }
    cprintln(" (builtin)", WHITE_ON_BLACK)
}

@kernel fn cmd_type() {
    // type <cmd>
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: type <cmd>", YELLOW_ON_BLACK); return }
    let mut i: i64 = 5
    while i < len { console_putchar(volatile_read_u8(0x6F800 + i), WHITE_ON_BLACK); i = i + 1 }
    cprintln(" is a shell builtin", WHITE_ON_BLACK)
}

@kernel fn cmd_man() {
    // man <cmd> — manual page (brief)
    let len = cmdbuf_len()
    if len <= 4 { cprintln("Usage: man <cmd>", YELLOW_ON_BLACK); return }
    // Check first char of command name
    let ch = volatile_read_u8(0x6F800 + 4)
    if ch == 108 {  // 'l' → ls
        cprintln("LS(1) — list directory contents", YELLOW_ON_BLACK)
        cprintln("  Lists all files and directories in ramfs.", WHITE_ON_BLACK)
        cprintln("  Shows type (d/f), size, and name.", WHITE_ON_BLACK)
    } else if ch == 99 {  // 'c' → cat/cp/...
        cprintln("CAT(1) — concatenate and print files", YELLOW_ON_BLACK)
        cprintln("  cat <file> — display file contents.", WHITE_ON_BLACK)
    } else if ch == 112 {  // 'p' → ps/pwd/prime
        cprintln("PS(1) — report process status", YELLOW_ON_BLACK)
        cprintln("  Shows PID, state, and tick count.", WHITE_ON_BLACK)
    } else {
        cprint("No manual entry for: ", YELLOW_ON_BLACK)
        let mut i: i64 = 4
        while i < len { console_putchar(volatile_read_u8(0x6F800 + i), WHITE_ON_BLACK); i = i + 1 }
        console_putchar(10, WHITE_ON_BLACK)
        cprintln("Available: man ls, man cat, man ps", WHITE_ON_BLACK)
    }
}

@kernel fn cmd_banner() {
    // banner <text> — big ASCII text (simple 3-line)
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: banner <text>", YELLOW_ON_BLACK); return }
    // Simple: print text in large style using # characters
    // Top border
    cprint("  ", WHITE_ON_BLACK)
    let text_len = len - 7
    let mut i: i64 = 0
    while i < text_len * 2 + 4 { console_putchar(95, YELLOW_ON_BLACK); i = i + 1 }
    console_putchar(10, WHITE_ON_BLACK)
    // Middle with text
    cprint(" | ", YELLOW_ON_BLACK)
    i = 7
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        // Uppercase
        if ch >= 97 && ch <= 122 { console_putchar(ch - 32, CYAN_ON_BLACK) }
        else { console_putchar(ch, CYAN_ON_BLACK) }
        console_putchar(32, WHITE_ON_BLACK)
        i = i + 1
    }
    cprintln("| ", YELLOW_ON_BLACK)
    // Bottom border
    cprint("  ", WHITE_ON_BLACK)
    i = 0
    while i < text_len * 2 + 4 { console_putchar(8254 % 256, YELLOW_ON_BLACK); i = i + 1 }
    // Use dash instead
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  ", WHITE_ON_BLACK)
    i = 0
    while i < text_len * 2 + 4 { console_putchar(45, YELLOW_ON_BLACK); i = i + 1 }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_fib() {
    // fib <N> — compute fibonacci(N)
    let len = cmdbuf_len()
    if len <= 4 { cprintln("Usage: fib <N>", YELLOW_ON_BLACK); return }
    let mut n: i64 = 0
    let mut i: i64 = 4
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48) }
        i = i + 1
    }
    if n > 90 { n = 90 }  // prevent overflow
    let t0 = rdtsc()
    let mut a: i64 = 0
    let mut b: i64 = 1
    let mut k: i64 = 0
    while k < n { let tmp = a + b; a = b; b = tmp; k = k + 1 }
    let t1 = rdtsc()
    cprint("fib(", WHITE_ON_BLACK)
    cprint_decimal(n, WHITE_ON_BLACK)
    cprint(") = ", WHITE_ON_BLACK)
    cprint_decimal(b, CYAN_ON_BLACK)
    cprint("  (", WHITE_ON_BLACK)
    cprint_decimal(t1 - t0, CYAN_ON_BLACK)
    cprintln(" cycles)", WHITE_ON_BLACK)
}

@kernel fn cmd_count() {
    // count — count files in ramfs
    let count = volatile_read(FS_BASE)
    let mut files: i64 = 0
    let mut dirs: i64 = 0
    let mut i: i64 = 0
    while i < count {
        let addr = ramfs_entry_addr(i)
        if volatile_read(addr + 48) == 1 { files = files + 1 }
        else { dirs = dirs + 1 }
        i = i + 1
    }
    cprint_decimal(files, CYAN_ON_BLACK)
    cprint(" files, ", WHITE_ON_BLACK)
    cprint_decimal(dirs, CYAN_ON_BLACK)
    cprintln(" directories", WHITE_ON_BLACK)
}

@kernel fn cmd_upcase() {
    // upcase <text> — convert to uppercase
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: upcase <text>", YELLOW_ON_BLACK); return }
    let mut i: i64 = 7
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 97 && ch <= 122 { console_putchar(ch - 32, WHITE_ON_BLACK) }
        else { console_putchar(ch, WHITE_ON_BLACK) }
        i = i + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_downcase() {
    // downcase <text> — convert to lowercase
    let len = cmdbuf_len()
    if len <= 9 { cprintln("Usage: downcase <text>", YELLOW_ON_BLACK); return }
    let mut i: i64 = 9
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 65 && ch <= 90 { console_putchar(ch + 32, WHITE_ON_BLACK) }
        else { console_putchar(ch, WHITE_ON_BLACK) }
        i = i + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_cls() {
    // cls — alias for clear
    console_init()
}

@kernel fn cmd_exit() {
    cprintln("Goodbye!", CYAN_ON_BLACK)
    acpi_shutdown()
}

// ═══════════════════════════════════════════════
// Phase 6 — Interactive Commands
// ═══════════════════════════════════════════════

@kernel fn cmd_calc() {
    // calc <a> <op> <b> — simple calculator
    // e.g., "calc 42 + 13" → "55"
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: calc <a> <op> <b>", YELLOW_ON_BLACK); return }
    // Parse first number
    let mut a: i64 = 0
    let mut i: i64 = 5
    let mut neg_a: i64 = 0
    if i < len && volatile_read_u8(0x6F800 + i) == 45 { neg_a = 1; i = i + 1 }
    while i < len && volatile_read_u8(0x6F800 + i) != 32 {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { a = a * 10 + (ch - 48) }
        i = i + 1
    }
    if neg_a == 1 { a = 0 - a }
    // Skip space
    while i < len && volatile_read_u8(0x6F800 + i) == 32 { i = i + 1 }
    // Read operator
    let op = volatile_read_u8(0x6F800 + i)
    i = i + 1
    // Skip space
    while i < len && volatile_read_u8(0x6F800 + i) == 32 { i = i + 1 }
    // Parse second number
    let mut b: i64 = 0
    let mut neg_b: i64 = 0
    if i < len && volatile_read_u8(0x6F800 + i) == 45 { neg_b = 1; i = i + 1 }
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { b = b * 10 + (ch - 48) }
        i = i + 1
    }
    if neg_b == 1 { b = 0 - b }
    // Compute
    let mut result: i64 = 0
    if op == 43 { result = a + b }       // +
    else if op == 45 { result = a - b }  // -
    else if op == 42 { result = a * b }  // *
    else if op == 47 {                   // /
        if b == 0 { cprintln("Error: division by zero", RED_ON_BLACK); return }
        result = a / b
    }
    else if op == 37 {                   // %
        if b == 0 { cprintln("Error: division by zero", RED_ON_BLACK); return }
        result = a % b
    }
    else { cprintln("Operators: + - * / %", YELLOW_ON_BLACK); return }
    // Print result
    if result < 0 {
        console_putchar(45, CYAN_ON_BLACK)
        cprint_decimal(0 - result, CYAN_ON_BLACK)
    } else {
        cprint_decimal(result, CYAN_ON_BLACK)
    }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_base() {
    // base <N> <from> <to> — base conversion
    // e.g., "base 255 10 16" → FF
    // Simplified: base <N> 16 → hex output, base <N> 2 → binary output
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: base <N> <radix>", YELLOW_ON_BLACK); return }
    let mut n: i64 = 0
    let mut i: i64 = 5
    while i < len && volatile_read_u8(0x6F800 + i) != 32 {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48) }
        i = i + 1
    }
    while i < len && volatile_read_u8(0x6F800 + i) == 32 { i = i + 1 }
    let mut radix: i64 = 0
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { radix = radix * 10 + (ch - 48) }
        i = i + 1
    }
    if radix == 2 {
        // Binary output
        cprint("0b", WHITE_ON_BLACK)
        let mut bit: i64 = 63
        let mut started: i64 = 0
        while bit >= 0 {
            let b = (n >> bit) & 1
            if b == 1 { started = 1 }
            if started == 1 { cprint_decimal(b, CYAN_ON_BLACK) }
            bit = bit - 1
        }
        if started == 0 { console_putchar(48, CYAN_ON_BLACK) }
        console_putchar(10, WHITE_ON_BLACK)
    } else if radix == 8 {
        cprint("0o", WHITE_ON_BLACK)
        cprint_decimal(n, CYAN_ON_BLACK)  // simplified
        cprintln(" (octal TBD)", WHITE_ON_BLACK)
    } else if radix == 16 {
        cprint("0x", WHITE_ON_BLACK)
        cprint_hex(n, 8, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    } else {
        cprintln("Supported: base <N> 2|8|16", YELLOW_ON_BLACK)
    }
}

@kernel fn cmd_nl() {
    // nl <file> — number lines
    let len = cmdbuf_len()
    if len <= 3 { cprintln("Usage: nl <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(3)
    if idx == -1 { cprintln("nl: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    if size == 0 { return }
    let mut line_num: i64 = 1
    cprint_decimal(line_num, YELLOW_ON_BLACK)
    cprint("  ", WHITE_ON_BLACK)
    let mut i: i64 = 0
    while i < size {
        let ch = volatile_read_u8(data_ptr + i)
        console_putchar(ch, WHITE_ON_BLACK)
        if ch == 10 && i + 1 < size {
            line_num = line_num + 1
            cprint_decimal(line_num, YELLOW_ON_BLACK)
            cprint("  ", WHITE_ON_BLACK)
        }
        i = i + 1
    }
    if volatile_read_u8(data_ptr + size - 1) != 10 { console_putchar(10, WHITE_ON_BLACK) }
}

@kernel fn cmd_strings() {
    // strings <file> — print printable strings from file (>= 4 chars)
    let len = cmdbuf_len()
    if len <= 8 { cprintln("Usage: strings <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(8)
    if idx == -1 { cprintln("strings: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    let mut run: i64 = 0
    let mut i: i64 = 0
    while i < size {
        let ch = volatile_read_u8(data_ptr + i)
        if ch >= 32 && ch < 127 {
            run = run + 1
        } else {
            if run >= 4 {
                // Print the string
                let mut j = i - run
                while j < i { console_putchar(volatile_read_u8(data_ptr + j), GREEN_ON_BLACK); j = j + 1 }
                console_putchar(10, WHITE_ON_BLACK)
            }
            run = 0
        }
        i = i + 1
    }
    if run >= 4 {
        let mut j = i - run
        while j < i { console_putchar(volatile_read_u8(data_ptr + j), GREEN_ON_BLACK); j = j + 1 }
        console_putchar(10, WHITE_ON_BLACK)
    }
}

@kernel fn cmd_len() {
    // len <text> — print length of text
    let len = cmdbuf_len()
    if len <= 4 { cprintln("0", WHITE_ON_BLACK); return }
    cprint_decimal(len - 4, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Phase 7 — 100 commands target
// ═══════════════════════════════════════════════

@kernel fn cmd_sort() {
    // sort <file> — bubble sort file lines by first char
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: sort <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(5)
    if idx == -1 { cprintln("sort: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    if size == 0 { return }
    // Collect line starts and lengths (max 32 lines)
    let line_base: i64 = 0x580000  // temp storage
    let mut line_count: i64 = 0
    let mut start: i64 = 0
    let mut i: i64 = 0
    while i <= size && line_count < 32 {
        if i == size || volatile_read_u8(data_ptr + i) == 10 {
            volatile_write(line_base + line_count * 16, start)
            volatile_write(line_base + line_count * 16 + 8, i - start)
            line_count = line_count + 1
            start = i + 1
        }
        i = i + 1
    }
    // Bubble sort by first character
    let mut swapped: i64 = 1
    while swapped == 1 {
        swapped = 0
        let mut j: i64 = 0
        while j < line_count - 1 {
            let s1 = volatile_read(line_base + j * 16)
            let s2 = volatile_read(line_base + (j + 1) * 16)
            let c1 = volatile_read_u8(data_ptr + s1)
            let c2 = volatile_read_u8(data_ptr + s2)
            if c1 > c2 {
                // Swap
                let tmp_s = volatile_read(line_base + j * 16)
                let tmp_l = volatile_read(line_base + j * 16 + 8)
                volatile_write(line_base + j * 16, volatile_read(line_base + (j+1) * 16))
                volatile_write(line_base + j * 16 + 8, volatile_read(line_base + (j+1) * 16 + 8))
                volatile_write(line_base + (j+1) * 16, tmp_s)
                volatile_write(line_base + (j+1) * 16 + 8, tmp_l)
                swapped = 1
            }
            j = j + 1
        }
    }
    // Print sorted
    let mut k: i64 = 0
    while k < line_count {
        let s = volatile_read(line_base + k * 16)
        let l = volatile_read(line_base + k * 16 + 8)
        let mut p: i64 = 0
        while p < l { console_putchar(volatile_read_u8(data_ptr + s + p), WHITE_ON_BLACK); p = p + 1 }
        console_putchar(10, WHITE_ON_BLACK)
        k = k + 1
    }
}

@kernel fn cmd_uniq() {
    // uniq <file> — suppress adjacent duplicate lines
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: uniq <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(5)
    if idx == -1 { cprintln("uniq: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    if size == 0 { return }
    let mut prev_start: i64 = -1
    let mut prev_len: i64 = 0
    let mut start: i64 = 0
    let mut i: i64 = 0
    while i <= size {
        if i == size || volatile_read_u8(data_ptr + i) == 10 {
            let cur_len = i - start
            // Compare with previous line
            let mut same: i64 = 0
            if prev_start >= 0 && cur_len == prev_len {
                same = 1
                let mut j: i64 = 0
                while j < cur_len && same == 1 {
                    if volatile_read_u8(data_ptr + start + j) != volatile_read_u8(data_ptr + prev_start + j) { same = 0 }
                    j = j + 1
                }
            }
            if same == 0 {
                let mut p = start
                while p < i { console_putchar(volatile_read_u8(data_ptr + p), WHITE_ON_BLACK); p = p + 1 }
                console_putchar(10, WHITE_ON_BLACK)
            }
            prev_start = start
            prev_len = cur_len
            start = i + 1
        }
        i = i + 1
    }
}

@kernel fn cmd_tr() {
    // tr <a> <b> — replace char a with b in stdin (echo-like)
    // Usage: tr a b (replaces 'a' with 'b' in remaining text)
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: tr <from> <to>", YELLOW_ON_BLACK); return }
    let from_ch = volatile_read_u8(0x6F800 + 3)
    let to_ch = volatile_read_u8(0x6F800 + 5)
    // If there's more text after "tr X Y ", print it with replacements
    if len > 7 {
        let mut i: i64 = 7
        while i < len {
            let ch = volatile_read_u8(0x6F800 + i)
            if ch == from_ch { console_putchar(to_ch, WHITE_ON_BLACK) }
            else { console_putchar(ch, WHITE_ON_BLACK) }
            i = i + 1
        }
        console_putchar(10, WHITE_ON_BLACK)
    }
}

@kernel fn cmd_cut() {
    // cut <n> <file> — print first n chars of each line
    let len = cmdbuf_len()
    if len <= 4 { cprintln("Usage: cut <n> <file>", YELLOW_ON_BLACK); return }
    // Parse n
    let mut n: i64 = 0
    let mut i: i64 = 4
    while i < len && volatile_read_u8(0x6F800 + i) != 32 {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48) }
        i = i + 1
    }
    i = i + 1  // skip space
    if n == 0 { n = 10 }
    let file_start = i
    // Find file
    let count = volatile_read(FS_BASE)
    let file_len = len - file_start
    let mut idx: i64 = -1
    let mut fi: i64 = 0
    while fi < count && idx == -1 {
        let faddr = ramfs_entry_addr(fi)
        let mut ok: i64 = 1
        let mut j: i64 = 0
        while j < file_len && ok == 1 {
            if volatile_read_u8(faddr + j) != volatile_read_u8(0x6F800 + file_start + j) { ok = 0 }
            j = j + 1
        }
        if ok == 1 && volatile_read_u8(faddr + file_len) == 0 { idx = fi }
        fi = fi + 1
    }
    if idx == -1 { cprintln("cut: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    let mut col: i64 = 0
    let mut p: i64 = 0
    while p < size {
        let ch = volatile_read_u8(data_ptr + p)
        if ch == 10 { console_putchar(10, WHITE_ON_BLACK); col = 0 }
        else if col < n { console_putchar(ch, WHITE_ON_BLACK); col = col + 1 }
        p = p + 1
    }
    if size > 0 && volatile_read_u8(data_ptr + size - 1) != 10 { console_putchar(10, WHITE_ON_BLACK) }
}

@kernel fn cmd_rmdir() {
    // rmdir <dir> — remove directory (must be empty)
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: rmdir <dir>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(6)
    if idx == -1 { cprintln("rmdir: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    if volatile_read(addr + 48) != 2 { cprintln("rmdir: not a directory", RED_ON_BLACK); return }
    // Remove by shifting
    let count = volatile_read(FS_BASE)
    let mut i = idx
    while i < count - 1 {
        let src = ramfs_entry_addr(i + 1)
        let dst = ramfs_entry_addr(i)
        let mut j: i64 = 0
        while j < FS_ENTRY_SIZE { volatile_write_u8(dst + j, volatile_read_u8(src + j)); j = j + 1 }
        i = i + 1
    }
    volatile_write(FS_BASE, count - 1)
    cprintln("removed", GREEN_ON_BLACK)
}

@kernel fn cmd_printenv() {
    // printenv <VAR> — print specific env var
    let len = cmdbuf_len()
    if len <= 9 { cmd_env(); return }
    let ch = volatile_read_u8(0x6F800 + 9)
    if ch == 72 { cprintln("/", WHITE_ON_BLACK) }           // HOME
    else if ch == 85 { cprintln("root", WHITE_ON_BLACK) }   // USER
    else if ch == 83 { cprintln("/bin/fjsh", WHITE_ON_BLACK) } // SHELL
    else if ch == 65 { cprintln("x86_64", WHITE_ON_BLACK) } // ARCH
    else { cprintln("(undefined)", YELLOW_ON_BLACK) }
}

