@kernel fn cmd_sleep() {
    // sleep <seconds> — busy wait
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: sleep <seconds>", YELLOW_ON_BLACK); return }
    let mut secs: i64 = 0
    let mut i: i64 = 6
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { secs = secs * 10 + (ch - 48) }
        i = i + 1
    }
    if secs > 30 { secs = 30 } // max 30 seconds
    let target = read_timer_ticks() + secs * 100
    while read_timer_ticks() < target {}
}

