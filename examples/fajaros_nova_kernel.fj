@kernel fn cmd_date() {
    let ticks = read_timer_ticks()
    let total_secs = ticks / 100
    let hours = total_secs / 3600
    let mins = (total_secs % 3600) / 60
    let secs = total_secs % 60
    cprint("Up ", WHITE_ON_BLACK)
    cprint_decimal(hours, CYAN_ON_BLACK)
    console_putchar(58, WHITE_ON_BLACK)  // ':'
    if mins < 10 { console_putchar(48, CYAN_ON_BLACK) }
    cprint_decimal(mins, CYAN_ON_BLACK)
    console_putchar(58, WHITE_ON_BLACK)
    if secs < 10 { console_putchar(48, CYAN_ON_BLACK) }
    cprint_decimal(secs, CYAN_ON_BLACK)
    cprintln(" (since boot)", WHITE_ON_BLACK)
}

