    let roll = (ticks % 6) + 1
    cprint("You rolled: ", WHITE_ON_BLACK)
    cprint_decimal(roll, CYAN_ON_BLACK)
    cprintln(" 🎲", WHITE_ON_BLACK)
}

@kernel fn cmd_rev() {
    // rev — reverse echo args (after "rev " = 4 chars)
    let len = cmdbuf_len()
    if len <= 4 { cprintln("Usage: rev <text>", YELLOW_ON_BLACK); return }
    let mut i = len - 1
    while i >= 4 {
        console_putchar(volatile_read_u8(0x6F800 + i), WHITE_ON_BLACK)
        i = i - 1
    }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_yes() {
    let mut i: i64 = 0
    while i < 20 {
        cprintln("y", WHITE_ON_BLACK)
        i = i + 1
    }
}

@kernel fn cmd_wc() {
    // wc <file> — count bytes/lines/words
    let len = cmdbuf_len()
    if len <= 3 { cprintln("Usage: wc <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(3)
    if idx == -1 { cprintln("wc: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    let mut lines: i64 = 0
    let mut words: i64 = 0
    let mut in_word: i64 = 0
    let mut i: i64 = 0
    while i < size {
        let ch = volatile_read_u8(data_ptr + i)
        if ch == 10 { lines = lines + 1 }
        if ch == 32 || ch == 10 || ch == 9 {
            in_word = 0
        } else {
            if in_word == 0 { words = words + 1 }
            in_word = 1
        }
        i = i + 1
    }
    cprint("  ", WHITE_ON_BLACK)
    cprint_decimal(lines, CYAN_ON_BLACK)
    cprint("  ", WHITE_ON_BLACK)
    cprint_decimal(words, CYAN_ON_BLACK)
    cprint("  ", WHITE_ON_BLACK)
    cprint_decimal(size, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_env() {
    cprintln("SHELL=/bin/fjsh", WHITE_ON_BLACK)
    cprintln("HOME=/", WHITE_ON_BLACK)
    cprintln("USER=root", WHITE_ON_BLACK)
    cprintln("HOSTNAME=fajaros-nova", WHITE_ON_BLACK)
    cprintln("ARCH=x86_64", WHITE_ON_BLACK)
    cprintln("LANG=Fajar Lang", WHITE_ON_BLACK)
    cprintln("TERM=vga", WHITE_ON_BLACK)
}

@kernel fn cmd_stat() {
    // stat <file>
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: stat <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(5)
    if idx == -1 { cprintln("stat: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let ftype = volatile_read(addr + 48)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    cprint("  File: ", WHITE_ON_BLACK)
    let mut j: i64 = 0
    while volatile_read_u8(addr + j) != 0 && j < 31 {
        console_putchar(volatile_read_u8(addr + j), CYAN_ON_BLACK)
        j = j + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Type: ", WHITE_ON_BLACK)
    if ftype == 1 { cprintln("regular file", WHITE_ON_BLACK) }
    else { cprintln("directory", CYAN_ON_BLACK) }
    cprint("  Size: ", WHITE_ON_BLACK)
    cprint_decimal(size, CYAN_ON_BLACK)
    cprintln(" bytes", WHITE_ON_BLACK)
    cprint("  Data: 0x", WHITE_ON_BLACK)
    cprint_hex(data_ptr, 8, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Idx:  ", WHITE_ON_BLACK)
    cprint_decimal(idx, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

