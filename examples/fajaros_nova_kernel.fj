    cprintln("  █       █ █    █ ██ █  █   █  █   █", CYAN_ON_BLACK)
    cprintln("  ████   █████   █    █  █████  ████", CYAN_ON_BLACK)
    cprintln("  █      █   █   █    █  █   █  █  █", CYAN_ON_BLACK)
    cprintln("  █      █   █ █ █    █  █   █  █   █", CYAN_ON_BLACK)
    cprintln("        FajarOS Nova — x86_64", YELLOW_ON_BLACK)
