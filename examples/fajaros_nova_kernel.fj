}

@kernel fn cmd_dd() {
    // dd — show disk/memory info (simplified)
    cprintln("Device    Blocks   Used    Free    Mount", YELLOW_ON_BLACK)
    let count = volatile_read(FS_BASE)
    let used = volatile_read(FS_BASE + 8) - FS_DATA
    let total: i64 = 0x7E0000 - FS_DATA
    cprint("ramfs     ", WHITE_ON_BLACK)
    cprint_decimal(total / 4096, CYAN_ON_BLACK)
    cprint("      ", WHITE_ON_BLACK)
    cprint_decimal(used / 4096, CYAN_ON_BLACK)
    cprint("       ", WHITE_ON_BLACK)
    cprint_decimal((total - used) / 4096, CYAN_ON_BLACK)
    cprintln("    /", WHITE_ON_BLACK)
}

@kernel fn cmd_md5() {
    // md5 <file> — simple checksum (not real MD5, just sum of bytes)
    let len = cmdbuf_len()
    if len <= 4 { cprintln("Usage: md5 <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(4)
    if idx == -1 { cprintln("md5: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    let mut hash: i64 = 0x12345678
    let mut i: i64 = 0
    while i < size {
        let b = volatile_read_u8(data_ptr + i)
        hash = hash ^ (b * 31 + i * 17)
        hash = (hash << 5) | ((hash >> 59) & 0x1F)
        i = i + 1
    }
    cprint_hex(hash >> 32, 8, CYAN_ON_BLACK)
    cprint_hex(hash & 0xFFFFFFFF, 8, CYAN_ON_BLACK)
    cprint("  ", WHITE_ON_BLACK)
    // Print filename
    let mut j: i64 = 4
    while j < len { console_putchar(volatile_read_u8(0x6F800 + j), WHITE_ON_BLACK); j = j + 1 }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_yes_arg() {
    // Handle "yes <text>" — repeat text 20 times
    let len = cmdbuf_len()
    if len <= 4 {
        let mut i: i64 = 0
        while i < 20 { cprintln("y", WHITE_ON_BLACK); i = i + 1 }
        return
    }
    let mut r: i64 = 0
    while r < 20 {
        let mut i: i64 = 4
        while i < len { console_putchar(volatile_read_u8(0x6F800 + i), WHITE_ON_BLACK); i = i + 1 }
        console_putchar(10, WHITE_ON_BLACK)
        r = r + 1
    }
}

@kernel fn cmd_repeat() {
    // repeat <n> <text> — repeat text n times
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: repeat <n> <text>", YELLOW_ON_BLACK); return }
    let mut n: i64 = 0
    let mut i: i64 = 7
    while i < len && volatile_read_u8(0x6F800 + i) != 32 {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48) }
        i = i + 1
    }
    i = i + 1  // skip space
    if n > 100 { n = 100 }
    let mut r: i64 = 0
    while r < n {
        let mut j = i
        while j < len { console_putchar(volatile_read_u8(0x6F800 + j), WHITE_ON_BLACK); j = j + 1 }
        console_putchar(10, WHITE_ON_BLACK)
        r = r + 1
    }
}

