    // run <name> — "run " (114,117,110,32) with space = name lookup
    if handled == 0 && len >= 5 && volatile_read_u8(0x6F800) == 114 && volatile_read_u8(0x6F801) == 117 && volatile_read_u8(0x6F802) == 110 && volatile_read_u8(0x6F803) == 32 { cmd_run(); handled = 1 }
    // ring3test — "ring3test" (114,105,110,103,51,116,101,115,116)
    if handled == 0 && len == 9 && buf_eq4(114, 105, 110, 103) == 1 && volatile_read_u8(0x6F804) == 51 { cmd_test_ring3(); handled = 1 }
    // sync — "sync" (115,121,110,99)
    if handled == 0 && len == 4 && buf_eq4(115, 121, 110, 99) == 1 { cmd_sync(); handled = 1 }
    // wget — "wget" (119,103,101,116)
    if handled == 0 && len == 4 && buf_eq4(119, 103, 101, 116) == 1 { cmd_wget(); handled = 1 }
    // nslookup — "nslookup" (110,115,108,111) — starts with "nslo"
    if handled == 0 && len >= 9 && buf_eq4(110, 115, 108, 111) == 1 { cmd_nslookup(); handled = 1 }
    // netdemo — "netdemo" (110,101,116,100,101,109,111)
    if handled == 0 && len == 7 && buf_eq4(110, 101, 116, 100) == 1 { cmd_netdemo(); handled = 1 }
    // persist — "persist" (112,101,114,115,105,115,116) — persistence test
    if handled == 0 && len == 7 && buf_eq4(112, 101, 114, 115) == 1 && volatile_read_u8(0x6F804) == 105 { cmd_persist_test(); handled = 1 }
    // syscalltest — "syscalltest"
    if handled == 0 && len == 11 && volatile_read_u8(0x6F800) == 115 && volatile_read_u8(0x6F801) == 121 && volatile_read_u8(0x6F802) == 115 && volatile_read_u8(0x6F803) == 99 { cmd_syscall_test(); handled = 1 }
    // login — "login" (108,111,103,105,110)
    if handled == 0 && len == 5 && volatile_read_u8(0x6F800) == 108 && volatile_read_u8(0x6F801) == 111 && volatile_read_u8(0x6F802) == 103 { cmd_login(); handled = 1 }
    // neofetch — "neofetch" (110,101,111,102)
    if handled == 0 && len == 8 && volatile_read_u8(0x6F800) == 110 && volatile_read_u8(0x6F801) == 101 && volatile_read_u8(0x6F802) == 111 && volatile_read_u8(0x6F803) == 102 { cmd_neofetch_v2(); handled = 1 }

    if handled == 0 && len > 0 {
        cprint("Unknown: ", RED_ON_BLACK)
        let mut i: i64 = 0
        while i < len {
            console_putchar(volatile_read_u8(0x6F800 + i), RED_ON_BLACK)
            i = i + 1
        }
        console_putchar(10, WHITE_ON_BLACK)
    }
}

// ═══════════════════════════════════════════════
// Kernel Main
// ═══════════════════════════════════════════════

@kernel fn kernel_main() {
    x86_serial_init(0, 115200)

    console_init()

    // Init hardware
    sse_enable()
    idt_init()
    pic_remap()
    pit_init(100)
    tss_init()
    syscall_init()
    syscall_register_dispatch()  // v0.7: store fn_addr for linker indirect call

    // Init process table + keyboard buffer
    let mut i: i64 = 0
    while i < 4096 { volatile_write(0x600000 + i, 0); i = i + 8 }
    volatile_write(0x6FE08, 0)
    set_current_pid(0)
    volatile_write(0x600000 + 8, 2)       // PID 0 state = running
    volatile_write(0x600000 + 40, PML4_BASE) // PID 0 CR3 = kernel PML4
    volatile_write(0x6FBF0, 0)
    volatile_write(0x6FBF8, 0)

    // Enable NX bit (EFER.NXE, MSR 0xC0000080 bit 11)
    let efer = read_msr(0xC0000080)
    write_msr(0xC0000080, efer | (1 << 11))

    // Parse Multiboot2 info (pointer saved at 0x6FF00 by trampoline)
    let mb2_ptr = volatile_read(0x6FF00)
    if mb2_ptr > 0x1000 && mb2_ptr < 0x8000000 {
        volatile_write(0x6FF10, mb2_ptr)
        let mb2_size = volatile_read_u32(mb2_ptr)
        if mb2_size > 8 && mb2_size < 0x100000 {
            volatile_write(0x6FF18, mb2_size)
            let mut offset: i64 = 8
            while offset + 8 < mb2_size {
                let tag_type = volatile_read_u32(mb2_ptr + offset)
                let tag_size = volatile_read_u32(mb2_ptr + offset + 4)
                if tag_type == 0 || tag_size < 8 { offset = mb2_size }
                else {
                    if tag_type == 6 {
                        volatile_write(0x6FF20, mb2_ptr + offset)
                        volatile_write(0x6FF28, tag_size)
                    }
                    if tag_type == 8 { volatile_write(0x6FF30, mb2_ptr + offset) }
                    let aligned = (tag_size + 7) / 8 * 8
                    offset = offset + aligned
                }
            }
        }
    }

    // Note: SMEP (CR4 bit 20) NOT enabled — our identity-mapped 2MB pages
    // use P|RW|PS flags without explicit Supervisor-only marking.
    // On real CPUs with SMEP, the U/S bit in page tables must be 0 for
    // kernel pages. Our 32-bit trampoline sets PD entries with just P|RW|PS
    // (no User bit), so SMEP *should* work, but some QEMU -cpu host configs
    // expose SMEP before we can verify page table correctness.
    // TODO: Enable SMEP after verifying all kernel pages have U/S=0.

    // Stack guard page: unmap bottom of stack to catch overflow
    unmap_page(0x7F0000 - 4096)  // guard page below stack bottom

    // Init memory + SMP + IPC + ramfs + history + ML
    smp_init_per_cpu()
    frames_init()
    heap_init()
    slab_init()
    ipc_init()
    ramfs_init()
    mnist_init_weights()

    // Map LAPIC + IOAPIC MMIO pages (beyond 128MB identity region)
    map_page(0xFEE00000, 0xFEE00000, PAGE_PRESENT | PAGE_WRITABLE)  // LAPIC
    map_page(0xFEC00000, 0xFEC00000, PAGE_PRESENT | PAGE_WRITABLE)  // IOAPIC

    // Initialize LAPIC
    let apic_present = cpuid_edx(1) & (1 << 9)
    if apic_present != 0 {
        // Set spurious interrupt vector to 0xFF, enable APIC (bit 8)
        let svr = volatile_read_u32(0xFEE000F0)
        volatile_write_u32(0xFEE000F0, svr | 0x1FF)  // vector 0xFF + enable
    }
    history_init()

    // Initialize NVMe block device (or ramdisk fallback)
    nvme_full_init()

    // Initialize VFS (mounts /, /dev, /proc, /mnt if FAT32 available)
    vfs_init()
    println("[VFS] Initialized")

    // Initialize network stack
    net_init()
    println("[NET] Initialized")

    // Auto-detect + init USB XHCI
    let xhci_dev = usb_find_xhci()
    if xhci_dev >= 0 {
        println("[USB] XHCI controller detected, initializing...")
        cmd_usb_init()
    }

    // Initialize syscall dispatch table
    syscall_init()
    println("[ELF] Syscall table ready")

    // Initialize process table v2 + keyboard buffer
    proc_v2_init()
    kb_init()
    fd_init(0) // FDs for kernel process (legacy)
    fd_v2_init(0) // FDs v2 at 0x8D0000 for syscall dispatch
    // Initialize CWD for PID 0 to "/"
    volatile_write_u8(PROC_TABLE + PROC_OFF_CWD, 47) // '/'
    volatile_write_u8(PROC_TABLE + PROC_OFF_CWD + 1, 0)
    sig_init(0) // Initialize signal table for PID 0
    volatile_write(CTRL_STATE_ADDR, 0) // Ctrl key not pressed
    set_fg_pgid(0) // Shell is foreground
    // Clear job table
    let mut ji: i64 = 0
    while ji < JOB_MAX * JOB_ENTRY_SIZE { volatile_write_u8(JOB_TABLE + ji, 0); ji = ji + 1 }
    // Initialize ENV_TABLE and last exit code
    let mut ei: i64 = 0
    while ei < ENV_MAX * ENV_ENTRY_SIZE { volatile_write_u8(ENV_TABLE + ei, 0); ei = ei + 1 }
    volatile_write_u64(LAST_EXIT_CODE, 0)
    script_state_init() // Initialize shell control flow state
    cow_init() // Initialize CoW page refcount table
    // Register cow_handle_fault fn pointer at 0x950040 for linker page fault handler
    volatile_write_u64(0x950040, fn_addr("cow_handle_fault"))
    volatile_write_u64(COW_FAULT_COUNT, 0) // Reset CoW fault counter
    user_init() // Initialize user table with root account
    volatile_write_u64(LOGIN_HIST_IDX, 0) // Clear login history
    volatile_write_u64(SESSION_TIMEOUT, 0) // Session timeout disabled by default
    journal_init() // Initialize filesystem journal
    socket_init() // Initialize socket table
    journal_replay() // Replay any uncommitted journal entries
    volatile_write_u64(SESSION_LAST_INPUT, 0)
    println("[PROC] Process table v2 ready")
    println("[KB] Keyboard buffer ready")

    // Configure SYSCALL/SYSRET for Ring 3
    syscall_setup()
    println("[SYSCALL] Entry stub + MSRs configured")

    // Ring 3 user program is pre-installed but NOT auto-run
    // Use 'runhello' command to test Ring 3 execution
    // (Auto-running Ring 3 halts the kernel because SYS_EXIT does hlt)
    // Install user programs
    prog_install_all()
    println("[RING3] 5 user programs installed (hello, goodbye, fajar, counter, fib)")

    // Network: DHCP + ARP + ping
    if net_state_read(56) != 0 {
        // Try DHCP first
        let dhcp_result = dhcp_do()
        if dhcp_result == 0 {
            println("[NET] DHCP successful!")
        } else {
            println("[NET] DHCP failed, using static IP 10.0.2.15")
        }
        let gw = net_state_read(24)
        delay_us(500000) // let device settle

        // Send ARP request
        println("[NET] Sending ARP request...")
        let arp_len = arp_build_request(gw)
        let bcast: i64 = NET_PKT_BUF + 3072
        let mut bj: i64 = 0
        while bj < 6 { volatile_write_u8(bcast + bj, 0xFF); bj = bj + 1 }
        let arp_frame = eth_build_frame(bcast, 0x0806, NET_PKT_BUF, arp_len)
        net_send_frame(NET_TX_BUF, arp_frame)

        // Wait for reply, then scan ALL 16 RX buffers for ARP ethertype
        delay_us(500000) // 500ms for ARP reply

        let mut found_arp: i64 = 0
        let mut buf_idx: i64 = 0
        while buf_idx < 16 && found_arp == 0 {
            let buf = VQ_RX_BUFS + buf_idx * 2048
            // Scan for 0x08 0x06 (ARP ethertype) in first 30 bytes
            let mut off: i64 = 0
            while off < 30 && found_arp == 0 {
                if volatile_read_u8(buf + off) == 0x08 && volatile_read_u8(buf + off + 1) == 0x06 {
                    found_arp = 1
                    println("[NET] ARP reply found!")
                    // Extract gateway MAC: sender hardware addr at ARP offset
                    // ARP header starts 14 bytes after ethertype position - 12
                    // ethertype at off means eth header starts at off - 12
                    // ARP sender MAC at eth+14+8 = off - 12 + 14 + 8 = off + 10
                    let gw_mac_off = buf + off + 10
                    arp_cache_add(gw, gw_mac_off)

                    // Now send ICMP ping with real gateway MAC
                    println("[NET] Sending ICMP ping...")
                    let icmp_len = icmp_build_echo_request(1)
                    let ip_len = ip_build_header(gw, 1, icmp_len)
                    let pkt: i64 = NET_PKT_BUF + 2048
                    let mut ci: i64 = 0
                    while ci < ip_len { volatile_write_u8(pkt + ci, volatile_read_u8(NET_PKT_BUF + 512 + ci)); ci = ci + 1 }
                    ci = 0
                    while ci < icmp_len { volatile_write_u8(pkt + ip_len + ci, volatile_read_u8(NET_PKT_BUF + 1024 + ci)); ci = ci + 1 }
                    let gw_mac = arp_cache_lookup(gw)
                    if gw_mac >= 0 {
                        let flen = eth_build_frame(gw_mac, 0x0800, pkt, ip_len + icmp_len)
                        net_send_frame(NET_TX_BUF, flen)
                        println("[NET] ICMP ping sent!")
                        // Check for reply after 500ms
                        delay_us(500000)
                        let mut buf2: i64 = 0
                        let mut found_icmp: i64 = 0
                        while buf2 < 16 && found_icmp == 0 {
                            let rb = VQ_RX_BUFS + buf2 * 2048
                            let mut o2: i64 = 0
                            while o2 < 50 && found_icmp == 0 {
                                // Look for ICMP type 0 (echo reply) after IP header
                                // IP protocol=1 (ICMP) at IP+9
                                if volatile_read_u8(rb + o2) == 0x45 { // IP version+IHL
                                    if volatile_read_u8(rb + o2 + 9) == 1 { // protocol=ICMP
                                        let icmp_off = o2 + 20
                                        if volatile_read_u8(rb + icmp_off) == 0 { // type=Echo Reply
                                            found_icmp = 1
                                            println("[NET] PING REPLY RECEIVED! NETWORK IS LIVE!")
                                        }
                                    }
                                }
                                o2 = o2 + 1
                            }
                            buf2 = buf2 + 1
                        }
                        if found_icmp == 0 {
                            println("[NET] Ping sent (reply not found in buffers)")
                        }
                    }
                }
                off = off + 1
            }
            buf_idx = buf_idx + 1
        }
        if found_arp == 0 {
            // Debug: verify RX descriptor 0 is intact
            let d0_addr = volatile_read_u64(VQ_RX_BASE)
            let d0_len = volatile_read_u32(VQ_RX_BASE + 8)
            let d0_flags = volatile_read_u16(VQ_RX_BASE + 12)
            if d0_addr == VQ_RX_BUFS && d0_len == 2048 && d0_flags == 2 {
                println("[NET] Desc OK but no data — device not using our queue")
                // Possible fix: the RX queue PFN was set for 256 entries but
                // our descriptors are only 16. The device may read desc[16+] which are empty.
                // Check: is the avail ring idx set to 16?
                let avail = vq_avail_offset(VQ_RX_BASE)
                let avail_idx = volatile_read_u16(avail + 2)
                if avail_idx == 16 {
                    println("[NET] Avail idx=16 (only 16 of 256 slots filled)")
                }
            } else {
                println("[NET] Desc 0 modified — device DID write to queue!")
            }
            println("[NET] ARP not found in buffers")
        }
    }

    // Spawn init process (PID 1) — monitors system health
    let init_pid = sched_spawn_kernel(fn_addr("init_process"))
    if init_pid > 0 {
        println("[INIT] Init process (PID 1) started — preemptive scheduling active")
    }

    println("[SEC] Security commands ready")
    println("[INIT] Script engine ready")

    // Enable interrupts
    irq_enable()

    // Serial confirmation
    println("[NOVA] FajarOS Nova v1.1.0 Ascension booted")
    println("[NOVA] 12000+ LOC | 165 commands | Preemptive | 100% Fajar Lang")
    println("[NOVA] Frame allocator: 32768 frames (128MB)")
    println("[NOVA] RamFS: 64 entries, 832KB data")
    println("[NOVA] VGA console active at 0xB8000")

    // Boot banner
    cprintln("============================================", WHITE_ON_BLUE)
    cprintln("  FajarOS Nova v1.1.0 — x86_64 Shell", WHITE_ON_BLUE)
    cprintln("  Written 100% in Fajar Lang", WHITE_ON_BLUE)
    cprintln("============================================", WHITE_ON_BLUE)
    cprintln("", WHITE_ON_BLACK)
    cprintln("Type 'help' for available commands.", YELLOW_ON_BLACK)
    cprintln("", WHITE_ON_BLACK)

    // Shell prompt
    cmdbuf_clear()
    cprint("nova> ", GREEN_ON_BLACK)

    // Init shift/caps state
    volatile_write(0x6FBE0, 0)  // shift = 0
    volatile_write(0x6FBE8, 0)  // caps = 0

    // Main shell loop — shift, caps lock, arrow history
    let mut running: i64 = 1
    let mut ext_prefix: i64 = 0
    while running == 1 {
        if kb_has_data() == 1 {
            let sc = kb_read_scancode()

            // Extended scancode prefix (arrows, etc.)
            if sc == 0xE0 {
                ext_prefix = 1
            }
            // Shift make/break
            else if sc == 0x2A || sc == 0x36 {
                volatile_write(0x6FBE0, 1)  // shift pressed
            }
            else if sc == 0xAA || sc == 0xB6 {
                volatile_write(0x6FBE0, 0)  // shift released
            }
            // Ctrl make/break (I2.2/I2.3)
            else if sc == 0x1D {
                volatile_write(CTRL_STATE_ADDR, 1)  // ctrl pressed
            }
            else if sc == 0x9D {
                volatile_write(CTRL_STATE_ADDR, 0)  // ctrl released
            }
            // Caps Lock toggle (make only)
            else if sc == 0x3A {
                let caps = volatile_read(0x6FBE8)
                volatile_write(0x6FBE8, 1 - caps)
            }
            // Arrow keys (after E0 prefix)
            else if ext_prefix == 1 {
                ext_prefix = 0
                if sc == 0x48 { history_navigate(-1) }       // Up
                else if sc == 0x50 { history_navigate(1) }   // Down
            }
            // Break codes (key release, >= 0x80) — ignore
            else if sc >= 0x80 {
                // Ignore break codes
            }
            // Normal key press
            else if sc > 0 && sc < 128 {
                let ctrl_held = volatile_read(CTRL_STATE_ADDR)
                // I2.2: Ctrl+C (scancode 0x2E = 'C') → SIGINT
                if ctrl_held == 1 && sc == 0x2E {
                    cprintln("^C", WHITE_ON_BLACK)
                    signal_fg_group(SIGINT)
                    cmdbuf_clear()
                    cprint("nova> ", GREEN_ON_BLACK)
                }
                // I2.3: Ctrl+Z (scancode 0x2C = 'Z') → SIGTSTP
                else if ctrl_held == 1 && sc == 0x2C {
                    cprintln("^Z", WHITE_ON_BLACK)
                    signal_fg_group(SIGTSTP)
                    cmdbuf_clear()
                    cprint("nova> ", GREEN_ON_BLACK)
                }
                else {
                let ascii = sc2ascii(sc)
                if ascii == 10 {
                    console_putchar(10, WHITE_ON_BLACK)
                    // I2.9: Check for completed background jobs
                    job_check_notifications()
                    history_push()
                    // I2.4: Check for background '&' operator
                    let bg_pos = shell_has_background()
                    if bg_pos > 0 {
                        // Remove '&' from cmdbuf and run in background
                        volatile_write_u8(0x6F800 + bg_pos, 0)
                        volatile_write(0x6F880, bg_pos)
                        // Spawn as background kernel process
                        shell_execute()
                    } else {
                    shell_execute_v2()  // v0.7: var expansion + pipes + redirects
                    }
                    // Check for deferred user program run
                    if volatile_read_u64(RUN_PENDING) == 1 {
                        volatile_write_u64(RUN_PENDING, 0)
                        let run_code = volatile_read_u64(RUN_PENDING + 8)
                        let run_stack = volatile_read_u64(RUN_PENDING + 16)
                        volatile_write_u64(0x6FC04, 0x7F0000) // TSS RSP0
                        iretq_to_user(run_code, run_stack, 0x202)
                        // SYS_EXIT returns here via RSP restore
                    }
                    cmdbuf_clear()
                    cprint("nova> ", GREEN_ON_BLACK)
                } else if ascii == 8 {
                    if cmdbuf_len() > 0 {
                        cmdbuf_pop()
                        console_putchar(8, WHITE_ON_BLACK)
                    }
                } else if ascii == 9 {
                    // Tab → 4 spaces
                    let mut t: i64 = 0
                    while t < 4 { cmdbuf_push(32); console_putchar(32, WHITE_ON_BLACK); t = t + 1 }
                } else if ascii > 0 {
                    cmdbuf_push(ascii)
                    console_putchar(ascii, WHITE_ON_BLACK)
                }
                } // close else (non-ctrl key)
            }
        }
    }
}
