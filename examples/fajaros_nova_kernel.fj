// FajarOS Nova v1.2.0 "Nexus" — x86_64 Bare-Metal OS
// 142 commands, Ring 3 "Hello Ring 3!", NVMe + FAT32 + VFS + SMP + Net
// Written 100% in Fajar Lang — 8,800+ lines
// Milestone: User program calls SYSCALL from Ring 3 and prints to serial

const VGA_BASE: i64 = 0xB8000
const VGA_COLS: i64 = 80
const VGA_ROWS: i64 = 25
const WHITE_ON_BLACK: i64 = 0x0F
const WHITE_ON_BLUE: i64 = 0x1F
const GREEN_ON_BLACK: i64 = 0x0A
const CYAN_ON_BLACK: i64 = 0x0B
const YELLOW_ON_BLACK: i64 = 0x0E
const RED_ON_BLACK: i64 = 0x0C

// ═══════════════════════════════════════════════
// Bitmap Frame Allocator (Phase 2)
// 128MB = 32768 × 4KB frames
// Bitmap at 0x580000 (4096 bytes = 32768 bits)
// ═══════════════════════════════════════════════

const FRAME_SIZE: i64 = 4096
const TOTAL_FRAMES: i64 = 32768
const BITMAP_BASE: i64 = 0x580000
const BITMAP_SIZE: i64 = 4096

@kernel fn frames_init() {
    // Clear bitmap (all free)
    let mut i: i64 = 0
    while i < BITMAP_SIZE {
        volatile_write_u8(BITMAP_BASE + i, 0)
        i = i + 1
    }
    // Mark frames 0-0x7F as used (first 512KB: IVT, BDA, VGA, BIOS)
    let mut f: i64 = 0
    while f < 128 { frame_mark_used(f); f = f + 1 }
    // Mark kernel frames (0x100000 - 0x120000 = frames 256-288)
    f = 256
    while f < 288 { frame_mark_used(f); f = f + 1 }
    // Mark page tables (0x70000 - 0x73000 = frames 112-115)
    f = 112
    while f < 116 { frame_mark_used(f); f = f + 1 }
    // Mark heap area (0x400000 - 0x580000 = frames 1024-1408)
    f = 1024
    while f < 1408 { frame_mark_used(f); f = f + 1 }
    // Mark bitmap itself (0x580000 - 0x581000 = frame 1408)
    frame_mark_used(1408)
    // Mark process table + cmdbuf region (0x600000 - 0x700000 = frames 1536-1792)
    f = 1536
    while f < 1792 { frame_mark_used(f); f = f + 1 }
    // Mark ramfs (0x700000 - 0x7E0000 = frames 1792-2016)
    f = 1792
    while f < 2016 { frame_mark_used(f); f = f + 1 }
    // Mark stack (0x7F0000 - 0x800000 = frames 2032-2048)
    f = 2032
    while f < 2048 { frame_mark_used(f); f = f + 1 }
}

@kernel fn frame_mark_used(frame: i64) {
    let byte_idx = frame / 8
    let bit_idx = frame % 8
    let old = volatile_read_u8(BITMAP_BASE + byte_idx)
    volatile_write_u8(BITMAP_BASE + byte_idx, old | (1 << bit_idx))
}

@kernel fn frame_mark_free(frame: i64) {
    let byte_idx = frame / 8
    let bit_idx = frame % 8
    let old = volatile_read_u8(BITMAP_BASE + byte_idx)
    volatile_write_u8(BITMAP_BASE + byte_idx, old & (255 - (1 << bit_idx)))
}

@kernel fn frame_is_used(frame: i64) -> i64 {
    let byte_idx = frame / 8
    let bit_idx = frame % 8
    let val = volatile_read_u8(BITMAP_BASE + byte_idx)
    if (val & (1 << bit_idx)) != 0 { 1 } else { 0 }
}

@kernel fn frame_alloc() -> i64 {
    // Find first free frame, returns physical address or -1
    let mut f: i64 = 0
    while f < TOTAL_FRAMES {
        if frame_is_used(f) == 0 {
            frame_mark_used(f)
            return f * FRAME_SIZE
        }
        f = f + 1
    }
    -1  // OOM
}

@kernel fn frame_free(addr: i64) {
    let frame = addr / FRAME_SIZE
    if frame >= 0 && frame < TOTAL_FRAMES {
        frame_mark_free(frame)
    }
}

@kernel fn frame_alloc_contiguous(count: i64) -> i64 {
    // Find 'count' contiguous free frames, returns base physical address or -1
    let mut start: i64 = 2048  // Start after reserved area
    while start + count <= TOTAL_FRAMES {
        let mut ok: i64 = 1
        let mut i: i64 = 0
        while i < count && ok == 1 {
            if frame_is_used(start + i) == 1 { ok = 0 }
            i = i + 1
        }
        if ok == 1 {
            i = 0
            while i < count { frame_mark_used(start + i); i = i + 1 }
            return start * FRAME_SIZE
        }
        start = start + 1
    }
    -1
}

@kernel fn frame_stats_total() -> i64 { TOTAL_FRAMES }

@kernel fn frame_stats_used() -> i64 {
    let mut count: i64 = 0
    let mut f: i64 = 0
    while f < TOTAL_FRAMES {
        if frame_is_used(f) == 1 { count = count + 1 }
        f = f + 1
    }
    count
}

@kernel fn frame_stats_free() -> i64 {
    TOTAL_FRAMES - frame_stats_used()
}

// ═══════════════════════════════════════════════
// Page Table Management (Phase 2)
// PML4 at 0x70000, PDPT at 0x71000, PD at 0x72000
// Currently: 64 × 2MB huge pages = 128MB identity
// New: support 4KB page mapping via PT entries
// ═══════════════════════════════════════════════

const PML4_BASE: i64 = 0x70000
const PAGE_PRESENT: i64 = 1
const PAGE_WRITABLE: i64 = 2
const PAGE_USER: i64 = 4
const PAGE_HUGE: i64 = 128
const PAGE_NX: i64 = 0  // Would be bit 63, needs EFER.NXE

@kernel fn page_table_entry(table_base: i64, index: i64) -> i64 {
    volatile_read(table_base + index * 8)
}

@kernel fn page_table_set(table_base: i64, index: i64, value: i64) {
    volatile_write(table_base + index * 8, value)
}

@kernel fn map_page(virt: i64, phys: i64, flags: i64) {
    // Map a 4KB page: virt → phys with given flags
    // Walk PML4 → PDPT → PD → PT, allocating tables as needed
    let pml4_idx = (virt >> 39) & 0x1FF
    let pdpt_idx = (virt >> 30) & 0x1FF
    let pd_idx = (virt >> 21) & 0x1FF
    let pt_idx = (virt >> 12) & 0x1FF

    // Propagate USER flag to intermediate entries if requested
    let user_flag = flags & PAGE_USER

    // Get or create PDPT
    let mut pdpt_addr: i64 = 0
    let pml4_entry = page_table_entry(PML4_BASE, pml4_idx)
    if (pml4_entry & PAGE_PRESENT) != 0 {
        pdpt_addr = pml4_entry & 0xFFFFF000
        // Add USER flag to existing entry if needed
        if user_flag != 0 && (pml4_entry & PAGE_USER) == 0 {
            page_table_set(PML4_BASE, pml4_idx, pml4_entry | PAGE_USER)
        }
    } else {
        pdpt_addr = frame_alloc()
        if pdpt_addr == -1 { return }
        let mut i: i64 = 0
        while i < 4096 { volatile_write_u8(pdpt_addr + i, 0); i = i + 1 }
        page_table_set(PML4_BASE, pml4_idx, pdpt_addr | PAGE_PRESENT | PAGE_WRITABLE | user_flag)
    }

    // Get or create PD
    let mut pd_addr: i64 = 0
    let pdpt_entry = page_table_entry(pdpt_addr, pdpt_idx)
    if (pdpt_entry & PAGE_PRESENT) != 0 {
        pd_addr = pdpt_entry & 0xFFFFF000
        if user_flag != 0 && (pdpt_entry & PAGE_USER) == 0 {
            page_table_set(pdpt_addr, pdpt_idx, pdpt_entry | PAGE_USER)
        }
    } else {
        pd_addr = frame_alloc()
        if pd_addr == -1 { return }
        let mut i: i64 = 0
        while i < 4096 { volatile_write_u8(pd_addr + i, 0); i = i + 1 }
        page_table_set(pdpt_addr, pdpt_idx, pd_addr | PAGE_PRESENT | PAGE_WRITABLE | user_flag)
    }

    // Check if PD entry is a 2MB huge page
    let pd_entry = page_table_entry(pd_addr, pd_idx)
    if (pd_entry & PAGE_HUGE) != 0 {
        // Add USER flag to existing huge page if needed
        if user_flag != 0 && (pd_entry & PAGE_USER) == 0 {
            page_table_set(pd_addr, pd_idx, pd_entry | PAGE_USER)
        }
        return
    }

    // Get or create PT (4KB page table)
    let mut pt_addr: i64 = 0
    if (pd_entry & PAGE_PRESENT) != 0 {
        pt_addr = pd_entry & 0xFFFFF000
    } else {
        pt_addr = frame_alloc()
        if pt_addr == -1 { return }
        let mut i: i64 = 0
        while i < 4096 { volatile_write_u8(pt_addr + i, 0); i = i + 1 }
        page_table_set(pd_addr, pd_idx, pt_addr | PAGE_PRESENT | PAGE_WRITABLE)
    }

    // Set the PT entry
    page_table_set(pt_addr, pt_idx, phys | flags)
}

@kernel fn unmap_page(virt: i64) {
    // Unmap a 4KB page
    let pml4_idx = (virt >> 39) & 0x1FF
    let pdpt_idx = (virt >> 30) & 0x1FF
    let pd_idx = (virt >> 21) & 0x1FF
    let pt_idx = (virt >> 12) & 0x1FF

    let pml4_entry = page_table_entry(PML4_BASE, pml4_idx)
    if (pml4_entry & PAGE_PRESENT) == 0 { return }
    let pdpt_addr = pml4_entry & 0xFFFFF000

    let pdpt_entry = page_table_entry(pdpt_addr, pdpt_idx)
    if (pdpt_entry & PAGE_PRESENT) == 0 { return }
    let pd_addr = pdpt_entry & 0xFFFFF000

    let pd_entry = page_table_entry(pd_addr, pd_idx)
    if (pd_entry & PAGE_PRESENT) == 0 || (pd_entry & PAGE_HUGE) != 0 { return }
    let pt_addr = pd_entry & 0xFFFFF000

    // Clear PT entry and flush TLB
    page_table_set(pt_addr, pt_idx, 0)
    invlpg(virt)
}

// ── Per-Process Page Tables (Phase 3) ──

@kernel fn clone_kernel_pml4() -> i64 {
    // Allocate a new PML4 page and copy kernel entries from the shared PML4
    let new_pml4 = frame_alloc()
    if new_pml4 == -1 { return -1 }

    // Zero the new PML4
    let mut i: i64 = 0
    while i < 4096 { volatile_write_u8(new_pml4 + i, 0); i = i + 1 }

    // Copy all entries from kernel PML4 (identity map + kernel pages)
    // PML4 has 512 entries × 8 bytes = 4096 bytes
    i = 0
    while i < 512 {
        let entry = page_table_entry(PML4_BASE, i)
        if entry != 0 {
            page_table_set(new_pml4, i, entry)
        }
        i = i + 1
    }

    new_pml4
}

@kernel fn sched_spawn_user(code_addr: i64, stack_addr: i64) -> i64 {
    // Spawn a Ring 3 process with its own page table
    let mut pid: i64 = -1
    let mut i: i64 = 1
    while i < 16 && pid == -1 {
        if volatile_read(0x600000 + i * 256 + 8) == 0 { pid = i }
        i = i + 1
    }
    if pid == -1 { return -1 }

    // Clone kernel page tables for this process
    let pml4 = clone_kernel_pml4()
    if pml4 == -1 { return -2 }

    // Allocate process kernel stack
    let kstack_base = 0x700000 + pid * 0x4000
    let kstack_top = kstack_base + 0x3FF0
    let mut pg: i64 = kstack_base
    while pg < kstack_base + 0x4000 {
        map_page(pg, pg, PAGE_PRESENT | PAGE_WRITABLE)
        frame_mark_used(pg / FRAME_SIZE)
        pg = pg + FRAME_SIZE
    }

    // Build fake interrupt frame for Ring 3 process
    let mut sp = kstack_top

    // IRETQ frame: Ring 3
    sp = sp - 8; volatile_write_u64(sp, 0x1B)         // SS = user data (0x18 | RPL=3)
    sp = sp - 8; volatile_write_u64(sp, stack_addr)    // RSP = user stack
    sp = sp - 8; volatile_write_u64(sp, 0x202)        // RFLAGS (IF=1)
    sp = sp - 8; volatile_write_u64(sp, 0x23)         // CS = user code (0x20 | RPL=3)
    sp = sp - 8; volatile_write_u64(sp, code_addr)    // RIP = user entry

    // 15 GPRs (zeroed)
    let mut r: i64 = 0
    while r < 15 { sp = sp - 8; volatile_write_u64(sp, 0); r = r + 1 }

    // Set process table entry
    let base = 0x600000 + pid * 256
    volatile_write(base + 8, 1)      // state = READY
    volatile_write(base + 16, sp)    // saved RSP
    volatile_write(base + 32, 0)     // ticks = 0
    volatile_write(base + 40, pml4)  // CR3 = per-process page table

    pid
}

// ═══════════════════════════════════════════════
// Memory Commands
// ═══════════════════════════════════════════════

@kernel fn cmd_frames() {
    let used = frame_stats_used()
    let free = frame_stats_free()
    let total = frame_stats_total()
    cprintln("Frame Allocator:", YELLOW_ON_BLACK)
    cprint("  Total:  ", WHITE_ON_BLACK)
    cprint_decimal(total, CYAN_ON_BLACK)
    cprint(" frames (", WHITE_ON_BLACK)
    cprint_decimal(total * 4 / 1024, CYAN_ON_BLACK)
    cprintln(" MB)", WHITE_ON_BLACK)
    cprint("  Used:   ", WHITE_ON_BLACK)
    cprint_decimal(used, CYAN_ON_BLACK)
    cprint(" frames (", WHITE_ON_BLACK)
    cprint_decimal(used * 4, CYAN_ON_BLACK)
    cprintln(" KB)", WHITE_ON_BLACK)
    cprint("  Free:   ", WHITE_ON_BLACK)
    cprint_decimal(free, CYAN_ON_BLACK)
    cprint(" frames (", WHITE_ON_BLACK)
    cprint_decimal(free * 4 / 1024, CYAN_ON_BLACK)
    cprintln(" MB)", WHITE_ON_BLACK)
    cprint("  Usage:  ", WHITE_ON_BLACK)
    cprint_decimal(used * 100 / total, CYAN_ON_BLACK)
    cprintln("%", WHITE_ON_BLACK)
}

@kernel fn cmd_mmap() {
    // mmap — show memory map
    cprintln("Memory Map:", YELLOW_ON_BLACK)
    cprintln("  0x000000-0x07FFFF  512K  Low memory (IVT+BDA)", WHITE_ON_BLACK)
    cprintln("  0x0B8000-0x0B8FA0  4K    VGA text buffer", CYAN_ON_BLACK)
    cprintln("  0x0E0000-0x0FFFFF  128K  BIOS/ACPI", WHITE_ON_BLACK)
    cprintln("  0x100000-0x120000  128K  Kernel .text+.rodata", GREEN_ON_BLACK)
    cprintln("  0x400000-0x580000  1.5M  Heap (bump)", WHITE_ON_BLACK)
    cprintln("  0x580000-0x581000  4K    Frame bitmap", CYAN_ON_BLACK)
    cprintln("  0x600000-0x601000  4K    Process table", WHITE_ON_BLACK)
    cprintln("  0x6F8000-0x6FD000  20K   Shell state", WHITE_ON_BLACK)
    cprintln("  0x700000-0x7E0000  896K  RamFS", CYAN_ON_BLACK)
    cprintln("  0x7F0000-0x800000  64K   Stack", WHITE_ON_BLACK)
    cprintln("  0x800000-0x7FFFFFF 120M  Free frames", GREEN_ON_BLACK)
}

@kernel fn cmd_alloc() {
    // alloc <N> — allocate N frames and show addresses
    let len = cmdbuf_len()
    let mut n: i64 = 1
    if len > 6 {
        n = 0
        let mut i: i64 = 6
        while i < len {
            let ch = volatile_read_u8(0x6F800 + i)
            if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48) }
            i = i + 1
        }
    }
    if n > 16 { n = 16 }  // max 16 at a time
    let mut i: i64 = 0
    while i < n {
        let addr = frame_alloc()
        if addr == -1 {
            cprintln("OOM: no free frames", RED_ON_BLACK)
            return
        }
        cprint("  Allocated frame at 0x", WHITE_ON_BLACK)
        cprint_hex(addr, 8, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        i = i + 1
    }
}

@kernel fn cmd_dealloc() {
    // dealloc <addr> — free frame at address
    let len = cmdbuf_len()
    if len <= 8 { cprintln("Usage: dealloc <hex_addr>", YELLOW_ON_BLACK); return }
    // Parse hex address after "dealloc "
    let mut addr: i64 = 0
    let mut i: i64 = 8
    // Skip "0x" prefix if present
    if i + 1 < len && volatile_read_u8(0x6F800 + i) == 48 && volatile_read_u8(0x6F800 + i + 1) == 120 {
        i = i + 2
    }
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        addr = addr * 16
        if ch >= 48 && ch <= 57 { addr = addr + (ch - 48) }
        else if ch >= 97 && ch <= 102 { addr = addr + (ch - 87) }
        else if ch >= 65 && ch <= 70 { addr = addr + (ch - 55) }
        i = i + 1
    }
    frame_free(addr)
    cprint("  Freed frame at 0x", GREEN_ON_BLACK)
    cprint_hex(addr, 8, GREEN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Freelist Heap Allocator (Phase 2 Sprint 6)
// Heap region: 0x400000 - 0x580000 (1.5MB)
// Free list: linked list of (size, next_ptr) blocks
// Header: 16 bytes (size: i64, next: i64)
// Magic: 0xABCD1234 at offset -8 for double-free detect
// ═══════════════════════════════════════════════

const HEAP_START: i64 = 0x400000
const HEAP_END: i64 = 0x580000
const HEAP_HDR: i64 = 16
const HEAP_MAGIC: i64 = 0xABCD1234

@kernel fn heap_init() {
    // Initialize free list: one big free block
    volatile_write(HEAP_START, HEAP_END - HEAP_START - HEAP_HDR)  // size of free block
    volatile_write(HEAP_START + 8, 0)  // next = null
    // Stats at 0x581010
    volatile_write(0x581010, 0)              // total allocated bytes
    volatile_write(0x581018, HEAP_END - HEAP_START) // total heap size
    volatile_write(0x581020, 0)              // allocation count
}

@kernel fn kmalloc(size: i64) -> i64 {
    // First-fit allocation from free list
    let aligned_size = ((size + 7) / 8) * 8  // 8-byte align
    let mut prev: i64 = 0
    let mut curr = HEAP_START
    while curr != 0 {
        let blk_size = volatile_read(curr)
        if blk_size >= aligned_size {
            // Found a block! Split if large enough
            if blk_size >= aligned_size + HEAP_HDR + 16 {
                // Split: create new free block after allocation
                let new_free = curr + HEAP_HDR + aligned_size
                volatile_write(new_free, blk_size - aligned_size - HEAP_HDR)
                volatile_write(new_free + 8, volatile_read(curr + 8))
                // Update current to allocated size
                volatile_write(curr, aligned_size)
                // Link previous to new free
                if prev != 0 { volatile_write(prev + 8, new_free) }
                else {
                    // curr was head — update head to new_free
                    // Store free list head at 0x581008
                    volatile_write(0x581008, new_free)
                }
            } else {
                // Use entire block
                if prev != 0 { volatile_write(prev + 8, volatile_read(curr + 8)) }
                else { volatile_write(0x581008, volatile_read(curr + 8)) }
            }
            // Write magic for double-free detection
            volatile_write(curr + 8, HEAP_MAGIC)
            // Update stats
            volatile_write(0x581010, volatile_read(0x581010) + aligned_size)
            volatile_write(0x581020, volatile_read(0x581020) + 1)
            return curr + HEAP_HDR  // return pointer past header
        }
        prev = curr
        curr = volatile_read(curr + 8)
    }
    -1  // OOM
}

@kernel fn kfree(ptr: i64) {
    if ptr <= HEAP_START || ptr >= HEAP_END { return }
    let hdr = ptr - HEAP_HDR
    let magic = volatile_read(hdr + 8)
    if magic != HEAP_MAGIC {
        cprintln("PANIC: double-free or corruption detected!", RED_ON_BLACK)
        return
    }
    let size = volatile_read(hdr)
    // Clear magic
    volatile_write(hdr + 8, 0)
    // Add to front of free list
    let old_head = volatile_read(0x581008)
    volatile_write(hdr + 8, old_head)
    volatile_write(0x581008, hdr)
    // Update stats
    volatile_write(0x581010, volatile_read(0x581010) - size)
    volatile_write(0x581020, volatile_read(0x581020) - 1)
}

@kernel fn cmd_heap() {
    let used = volatile_read(0x581010)
    let total = volatile_read(0x581018)
    let count = volatile_read(0x581020)
    cprintln("Heap Allocator (freelist):", YELLOW_ON_BLACK)
    cprint("  Total:   ", WHITE_ON_BLACK)
    cprint_decimal(total / 1024, CYAN_ON_BLACK)
    cprintln(" KB", WHITE_ON_BLACK)
    cprint("  Used:    ", WHITE_ON_BLACK)
    cprint_decimal(used, CYAN_ON_BLACK)
    cprintln(" bytes", WHITE_ON_BLACK)
    cprint("  Free:    ", WHITE_ON_BLACK)
    cprint_decimal((total - used) / 1024, CYAN_ON_BLACK)
    cprintln(" KB", WHITE_ON_BLACK)
    cprint("  Allocs:  ", WHITE_ON_BLACK)
    cprint_decimal(count, CYAN_ON_BLACK)
    cprintln(" active", WHITE_ON_BLACK)
    cprint("  Usage:   ", WHITE_ON_BLACK)
    if total > 0 { cprint_decimal(used * 100 / total, CYAN_ON_BLACK) }
    else { console_putchar(48, CYAN_ON_BLACK) }
    cprintln("%", WHITE_ON_BLACK)
    // Walk free list
    cprint("  Blocks:  ", WHITE_ON_BLACK)
    let mut blk_count: i64 = 0
    let mut curr = volatile_read(0x581008)
    while curr != 0 && blk_count < 20 {
        blk_count = blk_count + 1
        curr = volatile_read(curr + 8)
    }
    cprint_decimal(blk_count, CYAN_ON_BLACK)
    cprintln(" free blocks", WHITE_ON_BLACK)
}

@kernel fn cmd_kmalloc() {
    // kmalloc <size> — allocate from heap
    let len = cmdbuf_len()
    if len <= 8 { cprintln("Usage: kmalloc <size>", YELLOW_ON_BLACK); return }
    let mut size: i64 = 0
    let mut i: i64 = 8
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { size = size * 10 + (ch - 48) }
        i = i + 1
    }
    if size <= 0 || size > 65536 { cprintln("kmalloc: size 1-65536", YELLOW_ON_BLACK); return }
    let ptr = kmalloc(size)
    if ptr == -1 {
        cprintln("kmalloc: OOM", RED_ON_BLACK)
    } else {
        cprint("  Allocated ", GREEN_ON_BLACK)
        cprint_decimal(size, CYAN_ON_BLACK)
        cprint(" bytes at 0x", WHITE_ON_BLACK)
        cprint_hex(ptr, 8, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    }
}

@kernel fn cmd_kfree() {
    // kfree <addr> — free heap allocation
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: kfree <hex_addr>", YELLOW_ON_BLACK); return }
    let mut addr: i64 = 0
    let mut i: i64 = 6
    if i + 1 < len && volatile_read_u8(0x6F800 + i) == 48 && volatile_read_u8(0x6F800 + i + 1) == 120 { i = i + 2 }
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        addr = addr * 16
        if ch >= 48 && ch <= 57 { addr = addr + (ch - 48) }
        else if ch >= 97 && ch <= 102 { addr = addr + (ch - 87) }
        else if ch >= 65 && ch <= 70 { addr = addr + (ch - 55) }
        i = i + 1
    }
    kfree(addr)
    cprint("  Freed at 0x", GREEN_ON_BLACK)
    cprint_hex(addr, 8, GREEN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// IPC Message Queue (Phase 5 Sprint 15)
// Per-process message queue: 4 messages × 64 bytes
// Queue at 0x640000 + pid * 512
// Header: head(i64), tail(i64), count(i64)
// Messages: 4 × (sender_pid(i64) + data[56 bytes])
// ═══════════════════════════════════════════════

const IPC_BASE: i64 = 0x640000
const IPC_MSG_SIZE: i64 = 64
const IPC_QUEUE_SIZE: i64 = 4

@kernel fn ipc_init() {
    // Zero all IPC queues
    let mut i: i64 = 0
    while i < 16 * 512 { volatile_write_u8(IPC_BASE + i, 0); i = i + 1 }
}

@kernel fn ipc_send(dst_pid: i64, msg_val: i64) -> i64 {
    if dst_pid < 0 || dst_pid >= 16 { return -1 }
    let base = IPC_BASE + dst_pid * 512
    let count = volatile_read(base + 16)
    if count >= IPC_QUEUE_SIZE { return -2 } // queue full
    let tail = volatile_read(base + 8)
    let msg_addr = base + 24 + tail * IPC_MSG_SIZE
    let src_pid = volatile_read(0x6FE00)  // current pid
    volatile_write(msg_addr, src_pid)
    volatile_write(msg_addr + 8, msg_val)
    volatile_write(base + 8, (tail + 1) % IPC_QUEUE_SIZE)
    volatile_write(base + 16, count + 1)
    0
}

@kernel fn ipc_recv(pid: i64) -> i64 {
    let base = IPC_BASE + pid * 512
    let count = volatile_read(base + 16)
    if count == 0 { return -1 } // no messages
    let head = volatile_read(base)
    let msg_addr = base + 24 + head * IPC_MSG_SIZE
    let val = volatile_read(msg_addr + 8)
    volatile_write(base, (head + 1) % IPC_QUEUE_SIZE)
    volatile_write(base + 16, count - 1)
    val
}

@kernel fn cmd_ipc_send() {
    // send <pid> <value>
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: send <pid> <value>", YELLOW_ON_BLACK); return }
    let mut pid: i64 = 0
    let mut i: i64 = 5
    while i < len && volatile_read_u8(0x6F800 + i) != 32 {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { pid = pid * 10 + (ch - 48) }
        i = i + 1
    }
    i = i + 1  // skip space
    let mut val: i64 = 0
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { val = val * 10 + (ch - 48) }
        i = i + 1
    }
    let result = ipc_send(pid, val)
    if result == 0 {
        cprint("Sent ", GREEN_ON_BLACK)
        cprint_decimal(val, CYAN_ON_BLACK)
        cprint(" to PID ", WHITE_ON_BLACK)
        cprint_decimal(pid, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    } else if result == -2 {
        cprintln("send: queue full", RED_ON_BLACK)
    } else {
        cprintln("send: invalid PID", RED_ON_BLACK)
    }
}

@kernel fn cmd_ipc_recv() {
    // recv — receive message for current process (PID 0)
    let pid = volatile_read(0x6FE00)
    let val = ipc_recv(pid)
    if val == -1 {
        cprintln("recv: no messages", YELLOW_ON_BLACK)
    } else {
        cprint("Received: ", GREEN_ON_BLACK)
        cprint_decimal(val, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    }
}

@kernel fn cmd_ipc() {
    // ipc — show IPC queue status for all processes
    cprintln("IPC Queues:", YELLOW_ON_BLACK)
    let mut pid: i64 = 0
    while pid < 16 {
        let base = IPC_BASE + pid * 512
        let count = volatile_read(base + 16)
        if count > 0 || volatile_read(0x600000 + pid * 256 + 8) != 0 {
            cprint("  PID ", WHITE_ON_BLACK)
            cprint_decimal(pid, CYAN_ON_BLACK)
            cprint(": ", WHITE_ON_BLACK)
            cprint_decimal(count, CYAN_ON_BLACK)
            cprint("/", WHITE_ON_BLACK)
            cprint_decimal(IPC_QUEUE_SIZE, WHITE_ON_BLACK)
            cprintln(" messages", WHITE_ON_BLACK)
        }
        pid = pid + 1
    }
}

// ═══════════════════════════════════════════════
// Security Features (Phase 8 Sprint 24)
// ═══════════════════════════════════════════════

@kernel fn cmd_fpu() {
    // FPU/SSE state save/restore demo
    cprintln("FPU/SSE State:", YELLOW_ON_BLACK)
    // Save current FPU state to PID 0's area (0x650000)
    let fpu_area: i64 = 0x650000
    fxsave(fpu_area)
    cprintln("  fxsave: 512 bytes saved to 0x650000", GREEN_ON_BLACK)
    // Show first 16 bytes of FPU state
    cprint("  State: ", WHITE_ON_BLACK)
    let mut i: i64 = 0
    while i < 16 {
        cprint_hex(volatile_read_u8(fpu_area + i), 2, CYAN_ON_BLACK)
        console_putchar(32, WHITE_ON_BLACK)
        i = i + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
    // Restore
    fxrstor(fpu_area)
    cprintln("  fxrstor: restored OK", GREEN_ON_BLACK)
}

@kernel fn cmd_ring3() {
    // Ring 3 demo — show Ring 3 infrastructure status
    cprintln("Ring 3 User Mode:", YELLOW_ON_BLACK)
    cprintln("  GDT User CS: 0x23 (0x20 | RPL=3)", WHITE_ON_BLACK)
    cprintln("  GDT User SS: 0x1B (0x18 | RPL=3)", WHITE_ON_BLACK)
    cprint("  TSS RSP0:    0x", WHITE_ON_BLACK)
    cprint_hex(0x7F00000, 8, CYAN_ON_BLACK)
    cprintln(" (kernel stack)", WHITE_ON_BLACK)
    cprintln("  SYSCALL:     IA32_STAR + IA32_LSTAR configured", GREEN_ON_BLACK)
    cprintln("  Syscalls:    EXIT(0), WRITE(1), READ(2), GETPID(9), YIELD(10)", WHITE_ON_BLACK)
    cprintln("  iretq_to_user: builtin available", GREEN_ON_BLACK)
    cprintln("  map_page(USER): PAGE_USER flag (bit 2) supported", GREEN_ON_BLACK)
    cprintln("", WHITE_ON_BLACK)
    cprintln("  To run Ring 3 code:", YELLOW_ON_BLACK)
    cprintln("  1. Map user pages with PAGE_USER flag", WHITE_ON_BLACK)
    cprintln("  2. Copy user code to user pages", WHITE_ON_BLACK)
    cprintln("  3. Call iretq_to_user(rip, rsp, 0x202)", WHITE_ON_BLACK)
    cprintln("  4. User code uses SYSCALL to return to kernel", WHITE_ON_BLACK)
}

@kernel fn cmd_random() {
    // rdrand — hardware random number
    let r = rdrand()
    cprint("Random: ", WHITE_ON_BLACK)
    cprint_hex(r, 16, CYAN_ON_BLACK)
    cprint(" (", WHITE_ON_BLACK)
    cprint_decimal(r % 1000000, CYAN_ON_BLACK)
    cprintln(")", WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// SMP Infrastructure (Phase 8 Sprint 23)
// ═══════════════════════════════════════════════

const AP_COUNTER: i64 = 0x8100  // AP boot counter
const PER_CPU_BASE: i64 = 0x652000  // 16 CPUs × 64 bytes

@kernel fn smp_init_per_cpu() {
    // Zero per-CPU data
    let mut i: i64 = 0
    while i < 16 * 64 { volatile_write_u8(PER_CPU_BASE + i, 0); i = i + 1 }
    // BSP = CPU 0
    volatile_write(PER_CPU_BASE, 0)  // LAPIC ID
    volatile_write(PER_CPU_BASE + 8, 1)  // online = true
    volatile_write(AP_COUNTER, 0)
}

@kernel fn smp_send_init_sipi(apic_id: i64) {
    // Send INIT IPI
    volatile_write_u32(LAPIC_BASE + LAPIC_ICR_HI, apic_id << 24)
    volatile_write_u32(LAPIC_BASE + LAPIC_ICR_LO, 0x00004500)  // INIT
    sleep_ms(10)
    // Send SIPI #1 (vector = 0x08 → trampoline at 0x8000)
    volatile_write_u32(LAPIC_BASE + LAPIC_ICR_HI, apic_id << 24)
    volatile_write_u32(LAPIC_BASE + LAPIC_ICR_LO, 0x00004608)  // SIPI vec=8
    delay_us(200)
    // Send SIPI #2
    volatile_write_u32(LAPIC_BASE + LAPIC_ICR_HI, apic_id << 24)
    volatile_write_u32(LAPIC_BASE + LAPIC_ICR_LO, 0x00004608)
}

@kernel fn cmd_smp() {
    cprintln("SMP Status:", YELLOW_ON_BLACK)
    let rsdp = acpi_find_rsdp()
    let cpus = if rsdp != 0 { acpi_get_cpu_count(rsdp) } else { 1 }
    cprint("  CPUs detected (MADT):  ", WHITE_ON_BLACK)
    cprint_decimal(cpus, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  BSP LAPIC ID:          ", WHITE_ON_BLACK)
    let bsp_id = volatile_read_u32(LAPIC_BASE + LAPIC_ID) >> 24
    cprint_decimal(bsp_id, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  APs booted:            ", WHITE_ON_BLACK)
    cprint_decimal(volatile_read(AP_COUNTER), CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprintln("  Scheduler:             round-robin (BSP only)", WHITE_ON_BLACK)
    cprintln("  Spinlock:              available", GREEN_ON_BLACK)
    cprintln("  Per-CPU data:          at 0x652000 (16×64B)", WHITE_ON_BLACK)
    cprintln("  AP trampoline:         0x8000 (installed)", GREEN_ON_BLACK)
    cprintln("  INIT-SIPI-SIPI:        smp_send_init_sipi() ready", GREEN_ON_BLACK)
    // Show per-CPU online status
    let mut cpu: i64 = 0
    while cpu < 16 {
        let online = volatile_read(PER_CPU_BASE + cpu * 64 + 8)
        if online != 0 {
            cprint("  CPU ", WHITE_ON_BLACK)
            cprint_decimal(cpu, CYAN_ON_BLACK)
            cprintln(": ONLINE", GREEN_ON_BLACK)
        }
        cpu = cpu + 1
    }
}

// ── AP Trampoline (16-bit real mode → 64-bit long mode) ──
// Installed at physical address 0x8000 (page 8)
// The SIPI vector 0x08 means APs start at 0x8000 in real mode.
// Trampoline: set up GDT, enable PAE+PGE, load CR3, enable long mode, jump to AP entry

@kernel fn smp_install_trampoline() {
    // AP trampoline machine code at 0x8000
    // This is a minimal 16-bit → 64-bit transition:
    //   cli; load GDT; enable PE; load CR3 from 0x70000; enable PAE+PGE;
    //   set EFER.LME; enable PG; far jump to 64-bit AP entry

    let base: i64 = 0x8000

    // Phase 1: 16-bit real mode setup
    // cli
    volatile_write_u8(base + 0, 0xFA)
    // xor ax, ax ; mov ds, ax (zero segments)
    volatile_write_u8(base + 1, 0x31)
    volatile_write_u8(base + 2, 0xC0)
    volatile_write_u8(base + 3, 0x8E)
    volatile_write_u8(base + 4, 0xD8)
    // lgdt [0x8080] — GDT pointer at offset 0x80
    volatile_write_u8(base + 5, 0x0F)
    volatile_write_u8(base + 6, 0x01)
    volatile_write_u8(base + 7, 0x16)
    volatile_write_u8(base + 8, 0x80)
    volatile_write_u8(base + 9, 0x80)

    // Phase 2: Enter protected mode
    // mov eax, cr0; or al, 1; mov cr0, eax
    volatile_write_u8(base + 10, 0x0F)
    volatile_write_u8(base + 11, 0x20)
    volatile_write_u8(base + 12, 0xC0)
    volatile_write_u8(base + 13, 0x0C)
    volatile_write_u8(base + 14, 0x01)
    volatile_write_u8(base + 15, 0x0F)
    volatile_write_u8(base + 16, 0x22)
    volatile_write_u8(base + 17, 0xC0)

    // jmp 0x08:0x8020 (far jump to 32-bit code at offset 0x20)
    volatile_write_u8(base + 18, 0x66)
    volatile_write_u8(base + 19, 0xEA)
    volatile_write_u32(base + 20, 0x8020) // offset
    volatile_write_u16(base + 24, 0x08)   // code segment

    // NOP padding to offset 0x20
    volatile_write_u8(base + 26, 0x90)
    volatile_write_u8(base + 27, 0x90)
    volatile_write_u8(base + 28, 0x90)
    volatile_write_u8(base + 29, 0x90)
    volatile_write_u8(base + 30, 0x90)
    volatile_write_u8(base + 31, 0x90)

    // Phase 3: 32-bit protected mode — enable PAE, load CR3, enable long mode
    // At offset 0x20 (32-bit code):
    let p32: i64 = base + 0x20
    // mov ax, 0x10; mov ds, ax; mov es, ax; mov ss, ax
    volatile_write_u8(p32, 0x66)
    volatile_write_u8(p32 + 1, 0xB8)
    volatile_write_u16(p32 + 2, 0x10)
    volatile_write_u8(p32 + 4, 0x8E)
    volatile_write_u8(p32 + 5, 0xD8)
    volatile_write_u8(p32 + 6, 0x8E)
    volatile_write_u8(p32 + 7, 0xC0)
    volatile_write_u8(p32 + 8, 0x8E)
    volatile_write_u8(p32 + 9, 0xD0)

    // mov eax, cr4; or eax, 0x20; mov cr4, eax (enable PAE)
    volatile_write_u8(p32 + 10, 0x0F)
    volatile_write_u8(p32 + 11, 0x20)
    volatile_write_u8(p32 + 12, 0xE0)
    volatile_write_u8(p32 + 13, 0x0D)
    volatile_write_u32(p32 + 14, 0x20)
    volatile_write_u8(p32 + 18, 0x0F)
    volatile_write_u8(p32 + 19, 0x22)
    volatile_write_u8(p32 + 20, 0xE0)

    // mov eax, 0x70000; mov cr3, eax (page table at 0x70000)
    volatile_write_u8(p32 + 21, 0xB8)
    volatile_write_u32(p32 + 22, 0x70000)
    volatile_write_u8(p32 + 26, 0x0F)
    volatile_write_u8(p32 + 27, 0x22)
    volatile_write_u8(p32 + 28, 0xD8)

    // rdmsr 0xC0000080 (EFER); or eax, 0x100 (LME); wrmsr
    volatile_write_u8(p32 + 29, 0xB9)
    volatile_write_u32(p32 + 30, 0xC0000080)
    volatile_write_u8(p32 + 34, 0x0F)
    volatile_write_u8(p32 + 35, 0x32) // rdmsr
    volatile_write_u8(p32 + 36, 0x0D)
    volatile_write_u32(p32 + 37, 0x100) // or eax, LME
    volatile_write_u8(p32 + 41, 0x0F)
    volatile_write_u8(p32 + 42, 0x30) // wrmsr

    // mov eax, cr0; or eax, 0x80000000; mov cr0, eax (enable paging)
    volatile_write_u8(p32 + 43, 0x0F)
    volatile_write_u8(p32 + 44, 0x20)
    volatile_write_u8(p32 + 45, 0xC0)
    volatile_write_u8(p32 + 46, 0x0D)
    volatile_write_u32(p32 + 47, 0x80000000)
    volatile_write_u8(p32 + 51, 0x0F)
    volatile_write_u8(p32 + 52, 0x22)
    volatile_write_u8(p32 + 53, 0xC0)

    // jmp 0x18:0x8060 (far jump to 64-bit code)
    volatile_write_u8(p32 + 54, 0xEA)
    volatile_write_u32(p32 + 55, 0x8060)
    volatile_write_u16(p32 + 59, 0x18) // 64-bit code segment

    // Phase 4: 64-bit long mode at offset 0x60
    let p64: i64 = base + 0x60
    // mov rsp, [0x8100+cpu_id*8] — set per-AP stack
    // For simplicity: set rsp = 0x900000 + ap_counter * 0x10000
    // mov eax, [0x8100] (AP counter)
    volatile_write_u8(p64, 0x8B)
    volatile_write_u8(p64 + 1, 0x04)
    volatile_write_u8(p64 + 2, 0x25)
    volatile_write_u32(p64 + 3, 0x8100) // AP_COUNTER address
    // inc dword [0x8100] (atomically increment AP counter)
    volatile_write_u8(p64 + 7, 0xF0) // LOCK prefix
    volatile_write_u8(p64 + 8, 0xFF)
    volatile_write_u8(p64 + 9, 0x04)
    volatile_write_u8(p64 + 10, 0x25)
    volatile_write_u32(p64 + 11, 0x8100)
    // shl eax, 16 (multiply by 0x10000 = 64KB stack per AP)
    volatile_write_u8(p64 + 15, 0xC1)
    volatile_write_u8(p64 + 16, 0xE0)
    volatile_write_u8(p64 + 17, 16)
    // add rax, 0x910000 (stack base: 0x910000 + cpu*64KB)
    volatile_write_u8(p64 + 18, 0x48)
    volatile_write_u8(p64 + 19, 0x05)
    volatile_write_u32(p64 + 20, 0x910000)
    // mov rsp, rax
    volatile_write_u8(p64 + 24, 0x48)
    volatile_write_u8(p64 + 25, 0x89)
    volatile_write_u8(p64 + 26, 0xC4)
    // Enable LAPIC SVR (spurious interrupt vector)
    // mov ecx, 0xFEE000F0; mov eax, [ecx]; or eax, 0x1FF; mov [ecx], eax
    volatile_write_u8(p64 + 27, 0xB9)
    volatile_write_u32(p64 + 28, 0xFEE000F0)
    volatile_write_u8(p64 + 32, 0x8B)
    volatile_write_u8(p64 + 33, 0x01)
    volatile_write_u8(p64 + 34, 0x0D)
    volatile_write_u32(p64 + 35, 0x1FF)
    volatile_write_u8(p64 + 39, 0x89)
    volatile_write_u8(p64 + 40, 0x01)
    // hlt loop — AP waits for work
    volatile_write_u8(p64 + 41, 0xF4) // hlt
    volatile_write_u8(p64 + 42, 0xEB) // jmp -2
    volatile_write_u8(p64 + 43, 0xFD)

    // GDT at offset 0x80 (minimal: null, code32, data32, code64)
    let gdt: i64 = base + 0x80
    // Null descriptor
    volatile_write_u64(gdt, 0)
    // Code32 (0x08): base=0, limit=0xFFFFF, exec/read, 32-bit
    volatile_write_u64(gdt + 8, 0x00CF9A000000FFFF)
    // Data32 (0x10): base=0, limit=0xFFFFF, read/write
    volatile_write_u64(gdt + 16, 0x00CF92000000FFFF)
    // Code64 (0x18): long mode code segment
    volatile_write_u64(gdt + 24, 0x00209A0000000000)

    // GDT pointer at 0x8080 (limit:16 + base:32 for 16-bit lgdt)
    // Actually the lgdt at 0x8080 is the pointer struct, GDT is at 0x8090
    // Let me fix: move GDT to 0x8090, pointer at 0x8080
    // GDT pointer: limit (2 bytes) + base (4 bytes)
    let gdt_ptr: i64 = base + 0x80
    volatile_write_u16(gdt_ptr, 31) // limit: 4 entries * 8 - 1
    volatile_write_u32(gdt_ptr + 2, 0x8090) // base address of GDT

    // Move GDT entries to 0x8090
    let gdt2: i64 = base + 0x90
    volatile_write_u64(gdt2, 0)
    volatile_write_u64(gdt2 + 8, 0x00CF9A000000FFFF)
    volatile_write_u64(gdt2 + 16, 0x00CF92000000FFFF)
    volatile_write_u64(gdt2 + 24, 0x00209A0000000000)
}

@kernel fn smp_boot_aps() -> i64 {
    // Install trampoline
    smp_install_trampoline()

    // Mark AP stacks as used
    let mut f: i64 = 0x910000 / FRAME_SIZE
    while f < 0x950000 / FRAME_SIZE { frame_mark_used(f); f = f + 1 }

    // Get CPU count from ACPI
    let rsdp = acpi_find_rsdp()
    let total_cpus = if rsdp != 0 { acpi_get_cpu_count(rsdp) } else { 1 }
    if total_cpus <= 1 { return 0 }

    // Reset AP counter
    volatile_write(AP_COUNTER, 0)

    // Send INIT-SIPI-SIPI to each AP (LAPIC IDs 1 to total_cpus-1)
    let mut ap: i64 = 1
    while ap < total_cpus && ap < 16 {
        smp_send_init_sipi(ap)
        ap = ap + 1
    }

    // Wait for APs to boot (poll AP_COUNTER)
    let expected = total_cpus - 1
    let mut wait: i64 = 100000
    while volatile_read(AP_COUNTER) < expected && wait > 0 {
        wait = wait - 1
    }

    let booted = volatile_read(AP_COUNTER)

    // Update per-CPU online status
    let mut cpu: i64 = 1
    while cpu <= booted {
        volatile_write(PER_CPU_BASE + cpu * 64 + 8, 1) // online = true
        cpu = cpu + 1
    }

    booted
}

@kernel fn cmd_smp_boot() {
    cprintln("Booting Application Processors...", YELLOW_ON_BLACK)
    let booted = smp_boot_aps()
    cprint("  APs booted: ", WHITE_ON_BLACK)
    cprint_decimal(booted, if booted > 0 { GREEN_ON_BLACK } else { RED_ON_BLACK })
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Total CPUs online: ", WHITE_ON_BLACK)
    cprint_decimal(booted + 1, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// NVMe Detection (Phase 10 Sprint 28)
// ═══════════════════════════════════════════════

@kernel fn nvme_find_controller() -> i64 {
    // Scan PCI for NVMe controller (class 01h, subclass 08h)
    let mut dev: i64 = 0
    while dev < 32 {
        let id = pci_read32(0, dev, 0, 0)
        if id != 0xFFFFFFFF && id != 0 {
            let cl = pci_read32(0, dev, 0, 8)
            let class = (cl >> 24) & 0xFF
            let subclass = (cl >> 16) & 0xFF
            if class == 1 && subclass == 8 { return dev }
        }
        dev = dev + 1
    }
    -1
}

@kernel fn cmd_nvme() {
    cprintln("NVMe Controller:", YELLOW_ON_BLACK)
    let dev = nvme_find_controller()
    if dev == -1 { cprintln("  No NVMe controller found", RED_ON_BLACK); return }
    cprint("  PCI Device: ", WHITE_ON_BLACK)
    cprint_decimal(dev, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    let id = pci_read32(0, dev, 0, 0)
    cprint("  Vendor:Device: ", WHITE_ON_BLACK)
    cprint_hex(id & 0xFFFF, 4, CYAN_ON_BLACK)
    console_putchar(58, WHITE_ON_BLACK)
    cprint_hex((id >> 16) & 0xFFFF, 4, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    // Read BAR0
    let bar0 = pci_read32(0, dev, 0, 0x10)
    cprint("  BAR0: 0x", WHITE_ON_BLACK)
    cprint_hex(bar0, 8, CYAN_ON_BLACK)
    if (bar0 & 1) == 0 { cprintln(" (MMIO)", WHITE_ON_BLACK) }
    else { cprintln(" (I/O)", WHITE_ON_BLACK) }
    // Map BAR0 if MMIO
    if (bar0 & 1) == 0 && bar0 > 0 {
        let bar_addr = bar0 & 0xFFFFF000
        map_page(bar_addr, bar_addr, PAGE_PRESENT | PAGE_WRITABLE)
        // Read NVMe CAP register (offset 0)
        let cap_lo = volatile_read_u32(bar_addr)
        let cap_hi = volatile_read_u32(bar_addr + 4)
        cprint("  CAP:  0x", WHITE_ON_BLACK)
        cprint_hex(cap_hi, 8, CYAN_ON_BLACK)
        cprint_hex(cap_lo, 8, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        let mqes = (cap_lo & 0xFFFF) + 1
        cprint("  MQES: ", WHITE_ON_BLACK)
        cprint_decimal(mqes, CYAN_ON_BLACK)
        cprintln(" entries", WHITE_ON_BLACK)
        // Read NVMe VS register (offset 0x08)
        let vs = volatile_read_u32(bar_addr + 8)
        cprint("  Version: ", WHITE_ON_BLACK)
        cprint_decimal((vs >> 16) & 0xFFFF, CYAN_ON_BLACK)
        cprint(".", WHITE_ON_BLACK)
        cprint_decimal(vs & 0xFFFF, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    }
}

// ═══════════════════════════════════════════════
// NVMe Block Device Driver (Phase 11 Sprint 31-33)
// NVMe spec 1.4 — Admin queue + I/O queue + sector R/W
// Memory layout:
//   0x800000 — Admin SQ (4KB, 64 entries × 64 bytes)
//   0x801000 — Admin CQ (4KB, 64 entries × 16 bytes)
//   0x802000 — I/O SQ   (4KB, 64 entries × 64 bytes)
//   0x803000 — I/O CQ   (4KB, 64 entries × 16 bytes)
//   0x810000 — DMA data buffer (64KB for sector I/O)
//   0xA00000 — Ramdisk  (1MB, fallback block device)
// ═══════════════════════════════════════════════

const NVME_ASQ: i64 = 0x800000
const NVME_ACQ: i64 = 0x801000
const NVME_ISQ: i64 = 0x802000
const NVME_ICQ: i64 = 0x803000
const NVME_DMA: i64 = 0x810000
const NVME_QUEUE_ENTRIES: i64 = 64
const NVME_SQE_SIZE: i64 = 64
const NVME_CQE_SIZE: i64 = 16
const RAMDISK_BASE: i64 = 0xA00000
const RAMDISK_SIZE: i64 = 0x100000

// NVMe register offsets (from BAR0)
const NVME_REG_CAP: i64 = 0x00
const NVME_REG_VS: i64 = 0x08
const NVME_REG_INTMS: i64 = 0x0C
const NVME_REG_INTMC: i64 = 0x10
const NVME_REG_CC: i64 = 0x14
const NVME_REG_CSTS: i64 = 0x1C
const NVME_REG_AQA: i64 = 0x24
const NVME_REG_ASQ: i64 = 0x28
const NVME_REG_ACQ: i64 = 0x30

// NVMe global state
const NVME_STATE: i64 = 0x804000
// +0: bar_addr (i64)
// +8: sq_tail (i64) — admin SQ tail
// +16: cq_head (i64) — admin CQ head
// +24: phase (i64) — CQ phase bit (1 or 0)
// +32: cmd_id (i64) — next command ID
// +40: dstride (i64) — doorbell stride (from CAP)
// +48: io_sq_tail (i64) — I/O SQ tail
// +56: io_cq_head (i64) — I/O CQ head
// +64: io_phase (i64) — I/O CQ phase
// +72: nsid (i64) — namespace ID (usually 1)
// +80: ns_size (i64) — namespace size in LBAs
// +88: sector_size (i64) — bytes per sector (usually 512)
// +96: initialized (i64) — 1 if driver ready

@kernel fn nvme_state_read(offset: i64) -> i64 {
    volatile_read_u64(NVME_STATE + offset)
}

@kernel fn nvme_state_write(offset: i64, val: i64) {
    volatile_write_u64(NVME_STATE + offset, val)
}

@kernel fn nvme_reg_read32(offset: i64) -> i64 {
    let bar = nvme_state_read(0)
    volatile_read_u32(bar + offset)
}

@kernel fn nvme_reg_write32(offset: i64, val: i64) {
    let bar = nvme_state_read(0)
    volatile_write_u32(bar + offset, val)
}

// ── Sprint 31.1-31.2: Admin Queue Setup ──

@kernel fn nvme_clear_queue(base: i64, size: i64) {
    let mut i: i64 = 0
    while i < size {
        volatile_write_u64(base + i, 0)
        i = i + 8
    }
}

@kernel fn nvme_admin_sq_write(slot: i64, dword_idx: i64, val: i64) {
    // Each SQE is 64 bytes = 16 dwords
    volatile_write_u32(NVME_ASQ + slot * NVME_SQE_SIZE + dword_idx * 4, val)
}

@kernel fn nvme_admin_cq_read(slot: i64, dword_idx: i64) -> i64 {
    volatile_read_u32(NVME_ACQ + slot * NVME_CQE_SIZE + dword_idx * 4)
}

// ── Sprint 31.3-31.5: Controller Enable ──

@kernel fn nvme_init() -> i64 {
    println("[NVMe] Finding controller...")
    let dev = nvme_find_controller()
    if dev == -1 { println("[NVMe] No controller found"); return -1 }
    println("[NVMe] Found at PCI slot")

    // Get BAR0 (MMIO base)
    let bar0 = pci_read32(0, dev, 0, 0x10)
    // Check for invalid BAR: I/O space, zero, or unassigned (0xFFFFFFFF)
    let bar0_masked = bar0 & 0xFFFFFFFF
    if (bar0 & 1) != 0 || bar0 == 0 || bar0_masked == 0xFFFFFFFF || (bar0 & 0xFFFFF000) >= 0xFFF00000 {
        println("[NVMe] BAR0 not assigned by firmware")
        return -2
    }
    let bar_addr = bar0 & 0xFFFFF000
    // Reject BAR addresses beyond 128MB identity map (need explicit mapping)
    if bar_addr >= 0x8000000 && bar_addr < 0xFEC00000 {
        // Address is in unmapped region but we can map it
        println("[NVMe] BAR0 in high memory, mapping...")
    }
    println("[NVMe] BAR0 address read")

    // Enable bus master + memory space in PCI command register
    let cmd = pci_read32(0, dev, 0, 0x04)
    pci_write32(0, dev, 0, 0x04, cmd | 0x06)
    println("[NVMe] Bus master enabled")

    // Map BAR0 pages (may need multiple pages for large register sets)
    println("[NVMe] Mapping BAR0...")
    map_page(bar_addr, bar_addr, PAGE_PRESENT | PAGE_WRITABLE)
    println("[NVMe] BAR0 page 0 mapped")
    map_page(bar_addr + 0x1000, bar_addr + 0x1000, PAGE_PRESENT | PAGE_WRITABLE)
    println("[NVMe] BAR0 page 1 mapped")

    // Store BAR address
    nvme_state_write(0, bar_addr)

    // Read CAP for doorbell stride and max queue entries
    println("[NVMe] Reading CAP register...")
    let cap_lo = volatile_read_u32(bar_addr + NVME_REG_CAP)
    let cap_hi = volatile_read_u32(bar_addr + NVME_REG_CAP + 4)
    println("[NVMe] CAP read OK")
    let dstride = ((cap_hi >> 0) & 0xF)  // DSTRIDE field is bits 35:32 of CAP
    nvme_state_write(40, dstride)

    // Disable controller (CC.EN = 0)
    println("[NVMe] Disabling controller...")
    nvme_reg_write32(NVME_REG_CC, 0)

    // Wait for CSTS.RDY = 0 (controller not ready)
    let mut timeout: i64 = 50000000
    while (nvme_reg_read32(NVME_REG_CSTS) & 1) != 0 && timeout > 0 {
        pause()
        timeout = timeout - 1
    }
    if timeout == 0 { println("[NVMe] Disable timeout!"); return -3 }
    println("[NVMe] Controller disabled")

    // Clear admin queues
    nvme_clear_queue(NVME_ASQ, NVME_QUEUE_ENTRIES * NVME_SQE_SIZE)
    nvme_clear_queue(NVME_ACQ, NVME_QUEUE_ENTRIES * NVME_CQE_SIZE)

    // Mark NVMe queue memory as used in frame allocator
    let mut f: i64 = 0x800000 / FRAME_SIZE
    while f < 0x805000 / FRAME_SIZE { frame_mark_used(f); f = f + 1 }
    // DMA buffer
    f = NVME_DMA / FRAME_SIZE
    while f < (NVME_DMA + 0x10000) / FRAME_SIZE { frame_mark_used(f); f = f + 1 }

    // Map DMA buffer pages
    let mut pg: i64 = NVME_DMA
    while pg < NVME_DMA + 0x10000 {
        map_page(pg, pg, PAGE_PRESENT | PAGE_WRITABLE)
        pg = pg + FRAME_SIZE
    }

    // Set AQA: admin queue attributes (entries - 1 for both SQ and CQ)
    let aqa = ((NVME_QUEUE_ENTRIES - 1) << 16) | (NVME_QUEUE_ENTRIES - 1)
    nvme_reg_write32(NVME_REG_AQA, aqa)

    // Set ASQ: admin submission queue base (physical address, 4KB aligned)
    volatile_write_u32(bar_addr + NVME_REG_ASQ, NVME_ASQ & 0xFFFFFFFF)
    volatile_write_u32(bar_addr + NVME_REG_ASQ + 4, 0)

    // Set ACQ: admin completion queue base
    volatile_write_u32(bar_addr + NVME_REG_ACQ, NVME_ACQ & 0xFFFFFFFF)
    volatile_write_u32(bar_addr + NVME_REG_ACQ + 4, 0)

    // Initialize state
    nvme_state_write(8, 0)    // sq_tail = 0
    nvme_state_write(16, 0)   // cq_head = 0
    nvme_state_write(24, 1)   // phase = 1
    nvme_state_write(32, 0)   // cmd_id = 0
    nvme_state_write(48, 0)   // io_sq_tail = 0
    nvme_state_write(56, 0)   // io_cq_head = 0
    nvme_state_write(64, 1)   // io_phase = 1
    nvme_state_write(72, 1)   // nsid = 1
    nvme_state_write(88, 512) // sector_size default

    // Enable controller: CC = MPS=0 | CSS=NVM(0) | EN=1
    // CC bits: EN(0), CSS(4:6)=0, MPS(7:10)=0, AMS(11:13)=0, SHN(14:15)=0, IOSQES(16:19)=6, IOCQES(20:23)=4
    println("[NVMe] Enabling controller...")
    let cc = 1 | (6 << 16) | (4 << 20)  // EN=1, IOSQES=64B(2^6), IOCQES=16B(2^4)
    nvme_reg_write32(NVME_REG_CC, cc)

    // Wait for CSTS.RDY = 1
    timeout = 50000000
    while (nvme_reg_read32(NVME_REG_CSTS) & 1) == 0 && timeout > 0 {
        pause()
        timeout = timeout - 1
    }
    if timeout == 0 { println("[NVMe] Enable timeout!"); return -4 }
    println("[NVMe] Controller enabled OK")

    nvme_state_write(96, 1) // initialized = 1
    0
}

// ── Sprint 31.6-31.8: Admin Command Submission ──

@kernel fn nvme_admin_submit(opcode: i64, nsid: i64, cdw10: i64, cdw11: i64, prp1: i64, prp2: i64) -> i64 {
    let sq_tail = nvme_state_read(8)
    let cmd_id = nvme_state_read(32)
    let slot = sq_tail

    // Build submission queue entry (16 dwords = 64 bytes)
    // CDW0: opcode(7:0) | FUSE(9:8)=0 | CID(31:16)
    nvme_admin_sq_write(slot, 0, opcode | ((cmd_id & 0xFFFF) << 16))
    nvme_admin_sq_write(slot, 1, nsid)   // NSID
    nvme_admin_sq_write(slot, 2, 0)      // CDW2 reserved
    nvme_admin_sq_write(slot, 3, 0)      // CDW3 reserved
    nvme_admin_sq_write(slot, 4, 0)      // MPTR low
    nvme_admin_sq_write(slot, 5, 0)      // MPTR high
    nvme_admin_sq_write(slot, 6, prp1 & 0xFFFFFFFF)  // PRP1 low
    nvme_admin_sq_write(slot, 7, (prp1 >> 32) & 0xFFFFFFFF) // PRP1 high
    nvme_admin_sq_write(slot, 8, prp2 & 0xFFFFFFFF)  // PRP2 low
    nvme_admin_sq_write(slot, 9, (prp2 >> 32) & 0xFFFFFFFF) // PRP2 high
    nvme_admin_sq_write(slot, 10, cdw10) // CDW10
    nvme_admin_sq_write(slot, 11, cdw11) // CDW11
    nvme_admin_sq_write(slot, 12, 0)     // CDW12
    nvme_admin_sq_write(slot, 13, 0)     // CDW13
    nvme_admin_sq_write(slot, 14, 0)     // CDW14
    nvme_admin_sq_write(slot, 15, 0)     // CDW15

    // Advance SQ tail
    let new_tail = (sq_tail + 1) % NVME_QUEUE_ENTRIES
    nvme_state_write(8, new_tail)
    nvme_state_write(32, cmd_id + 1)

    // Ring doorbell: SQ0 tail doorbell at BAR0 + 0x1000
    let bar = nvme_state_read(0)
    memory_fence()
    volatile_write_u32(bar + 0x1000, new_tail)

    cmd_id
}

@kernel fn nvme_admin_wait_completion() -> i64 {
    let cq_head = nvme_state_read(16)
    let phase = nvme_state_read(24)

    // Poll CQ for completion (phase tag = bit 16 of DW3)
    let mut timeout: i64 = 50000000
    let mut status: i64 = 0
    while timeout > 0 {
        let dw3 = nvme_admin_cq_read(cq_head, 3) // Status field + phase tag + CID
        let cq_phase = (dw3 >> 16) & 1  // Phase tag is bit 16
        if cq_phase == (phase & 1) {
            // Completion arrived
            status = (dw3 >> 17) & 0x7FFF // Status code (bits 31:17)
            // Advance CQ head
            let new_head = (cq_head + 1) % NVME_QUEUE_ENTRIES
            nvme_state_write(16, new_head)
            // Toggle phase if wrapped
            if new_head == 0 {
                nvme_state_write(24, 1 - phase)
            }
            // Ring CQ0 head doorbell at BAR0 + 0x1000 + 1*stride
            let bar = nvme_state_read(0)
            let dstride = nvme_state_read(40)
            let cq_db_offset = 0x1000 + (2 * 0 + 1) * (4 << dstride)
            volatile_write_u32(bar + cq_db_offset, new_head)
            return status
        }
        pause()
        timeout = timeout - 1
    }
    -1 // Timeout
}

// ── Sprint 31.6-31.7: Identify Controller + Namespace ──

@kernel fn nvme_identify_controller() -> i64 {
    // Identify Controller: opcode 0x06, CNS=1 (CDW10)
    // Result written to PRP1 buffer (4KB)
    nvme_clear_queue(NVME_DMA, 4096)
    let cmd_id = nvme_admin_submit(0x06, 0, 1, 0, NVME_DMA, 0)
    let status = nvme_admin_wait_completion()
    if status != 0 { return -1 }
    // Parse: bytes 24-63 = serial number, 64-103 = model number
    0
}

@kernel fn nvme_identify_namespace() -> i64 {
    // Identify Namespace: opcode 0x06, CNS=0 (CDW10), NSID=1
    nvme_clear_queue(NVME_DMA, 4096)
    let cmd_id = nvme_admin_submit(0x06, 1, 0, 0, NVME_DMA, 0)
    let status = nvme_admin_wait_completion()
    if status != 0 { return -1 }
    // Parse NSZE: namespace size at offset 0 (8 bytes, little-endian)
    let nsze = buffer_read_u64_le(NVME_DMA)
    nvme_state_write(80, nsze)
    // Parse LBAF0: offset 128 + 0*4 = 128, bits 23:16 = LBADS (log2 sector size)
    let lbaf0 = buffer_read_u32_le(NVME_DMA + 128)
    let lbads = (lbaf0 >> 16) & 0xFF
    let sector_size = 1 << lbads
    nvme_state_write(88, sector_size)
    0
}

// ── Sprint 32: I/O Queue Setup ──

@kernel fn nvme_create_io_queues() -> i64 {
    // Clear I/O queues
    nvme_clear_queue(NVME_ISQ, NVME_QUEUE_ENTRIES * NVME_SQE_SIZE)
    nvme_clear_queue(NVME_ICQ, NVME_QUEUE_ENTRIES * NVME_CQE_SIZE)

    // Create I/O Completion Queue: admin opcode 0x05
    // CDW10: QSIZE(31:16) | QID(15:0) = (entries-1)<<16 | 1
    // CDW11: PC(0)=1 (physically contiguous) | IEN(1)=0 | IV(31:16)=0
    let cdw10_cq = ((NVME_QUEUE_ENTRIES - 1) << 16) | 1
    let cdw11_cq = 1 // PC=1, no interrupt
    println("[NVMe] Submit Create I/O CQ...")
    nvme_admin_submit(0x05, 0, cdw10_cq, cdw11_cq, NVME_ICQ, 0)
    println("[NVMe] Waiting CQ completion...")
    let status = nvme_admin_wait_completion()
    println("[NVMe] CQ status received")
    if status != 0 {
        println("[NVMe] Create I/O CQ failed")
        return -1
    }
    println("[NVMe] I/O CQ created")

    // Create I/O Submission Queue: admin opcode 0x01
    // CDW10: QSIZE(31:16) | QID(15:0) = (entries-1)<<16 | 1
    // CDW11: PC(0)=1 | QPRIO(2:1)=0 | CQID(31:16)=1
    let cdw10_sq = ((NVME_QUEUE_ENTRIES - 1) << 16) | 1
    let cdw11_sq = 1 | (1 << 16) // PC=1, CQID=1
    println("[NVMe] Submit Create I/O SQ...")
    nvme_admin_submit(0x01, 0, cdw10_sq, cdw11_sq, NVME_ISQ, 0)
    println("[NVMe] Waiting SQ completion...")
    let status2 = nvme_admin_wait_completion()
    println("[NVMe] SQ status received")
    if status2 != 0 {
        println("[NVMe] Create I/O SQ failed")
        return -2
    }
    0
}

// ── Sprint 33: NVM Read/Write Commands ──

@kernel fn nvme_io_sq_write(slot: i64, dword_idx: i64, val: i64) {
    volatile_write_u32(NVME_ISQ + slot * NVME_SQE_SIZE + dword_idx * 4, val)
}

@kernel fn nvme_io_cq_read(slot: i64, dword_idx: i64) -> i64 {
    volatile_read_u32(NVME_ICQ + slot * NVME_CQE_SIZE + dword_idx * 4)
}

@kernel fn nvme_io_submit(opcode: i64, lba: i64, count: i64, prp1: i64) -> i64 {
    let sq_tail = nvme_state_read(48)
    let cmd_id = nvme_state_read(32)
    let nsid = nvme_state_read(72)
    let slot = sq_tail

    // Build NVM command SQE
    nvme_io_sq_write(slot, 0, opcode | ((cmd_id & 0xFFFF) << 16))
    nvme_io_sq_write(slot, 1, nsid)
    nvme_io_sq_write(slot, 2, 0)
    nvme_io_sq_write(slot, 3, 0)
    nvme_io_sq_write(slot, 4, 0)
    nvme_io_sq_write(slot, 5, 0)
    nvme_io_sq_write(slot, 6, prp1 & 0xFFFFFFFF)
    nvme_io_sq_write(slot, 7, (prp1 >> 32) & 0xFFFFFFFF)
    nvme_io_sq_write(slot, 8, 0) // PRP2 low (single-page I/O)
    nvme_io_sq_write(slot, 9, 0) // PRP2 high
    nvme_io_sq_write(slot, 10, lba & 0xFFFFFFFF) // Starting LBA low
    nvme_io_sq_write(slot, 11, (lba >> 32) & 0xFFFFFFFF) // Starting LBA high
    nvme_io_sq_write(slot, 12, (count - 1) & 0xFFFF) // Number of logical blocks (0-based)
    nvme_io_sq_write(slot, 13, 0)
    nvme_io_sq_write(slot, 14, 0)
    nvme_io_sq_write(slot, 15, 0)

    let new_tail = (sq_tail + 1) % NVME_QUEUE_ENTRIES
    nvme_state_write(48, new_tail)
    nvme_state_write(32, cmd_id + 1)

    // Ring I/O SQ doorbell: QID=1, so offset = 0x1000 + 2*1*(4<<dstride)
    let bar = nvme_state_read(0)
    let dstride = nvme_state_read(40)
    let sq_db = 0x1000 + 2 * 1 * (4 << dstride)
    memory_fence()
    volatile_write_u32(bar + sq_db, new_tail)
    cmd_id
}

@kernel fn nvme_io_wait_completion() -> i64 {
    let cq_head = nvme_state_read(56)
    let phase = nvme_state_read(64)

    let mut timeout: i64 = 50000000
    while timeout > 0 {
        let dw3 = nvme_io_cq_read(cq_head, 3)
        let cq_phase = (dw3 >> 16) & 1  // Phase tag is bit 16
        if cq_phase == (phase & 1) {
            let status = (dw3 >> 17) & 0x7FFF
            let new_head = (cq_head + 1) % NVME_QUEUE_ENTRIES
            nvme_state_write(56, new_head)
            if new_head == 0 {
                nvme_state_write(64, 1 - phase)
            }
            // Ring I/O CQ doorbell
            let bar = nvme_state_read(0)
            let dstride = nvme_state_read(40)
            let cq_db = 0x1000 + (2 * 1 + 1) * (4 << dstride)
            volatile_write_u32(bar + cq_db, new_head)
            return status
        }
        pause()
        timeout = timeout - 1
    }
    -1
}

@kernel fn nvme_read_sectors(lba: i64, count: i64, buf: i64) -> i64 {
    if nvme_state_read(96) != 1 { return -1 }
    nvme_io_submit(0x02, lba, count, buf)
    nvme_io_wait_completion()
}

@kernel fn nvme_write_sectors(lba: i64, count: i64, buf: i64) -> i64 {
    if nvme_state_read(96) != 1 { return -1 }
    nvme_io_submit(0x01, lba, count, buf)
    nvme_io_wait_completion()
}

// ── Sprint 34: Block Device Abstraction ──

// Block device table: 4 devices × 32 bytes at 0x804100
// Per device: +0=type (0=none,1=nvme,2=ramdisk,3=virtio), +8=base_lba, +16=total_lba, +24=sector_size
const BLK_TABLE: i64 = 0x804100
const BLK_MAX_DEVS: i64 = 4

@kernel fn blk_register(dev: i64, dev_type: i64, total_lba: i64, sector_size: i64) {
    let base = BLK_TABLE + dev * 32
    volatile_write_u64(base, dev_type)
    volatile_write_u64(base + 8, 0)
    volatile_write_u64(base + 16, total_lba)
    volatile_write_u64(base + 24, sector_size)
}

@kernel fn blk_read(dev: i64, lba: i64, count: i64, buf: i64) -> i64 {
    let dev_type = volatile_read_u64(BLK_TABLE + dev * 32)
    if dev_type == 1 {
        // NVMe
        nvme_read_sectors(lba, count, buf)
    } else if dev_type == 2 {
        // Ramdisk: copy from RAMDISK_BASE + lba*512
        let mut i: i64 = 0
        let bytes = count * 512
        while i < bytes {
            volatile_write_u8(buf + i, volatile_read_u8(RAMDISK_BASE + lba * 512 + i))
            i = i + 1
        }
        0
    } else if dev_type == 3 {
        // USB Mass Storage
        usb_blk_read(lba, count, buf)
    } else {
        -1
    }
}

@kernel fn blk_write(dev: i64, lba: i64, count: i64, buf: i64) -> i64 {
    let dev_type = volatile_read_u64(BLK_TABLE + dev * 32)
    if dev_type == 1 {
        nvme_write_sectors(lba, count, buf)
    } else if dev_type == 2 {
        let mut i: i64 = 0
        let bytes = count * 512
        while i < bytes {
            volatile_write_u8(RAMDISK_BASE + lba * 512 + i, volatile_read_u8(buf + i))
            i = i + 1
        }
        0
    } else {
        -1
    }
}

@kernel fn nvme_full_init() -> i64 {
    println("[NVMe] Initializing controller...")
    cprintln("[NVMe] Initializing controller...", CYAN_ON_BLACK)
    let result = nvme_init()
    if result != 0 {
        println("[NVMe] Init failed")
        cprint("[NVMe] Init failed: ", RED_ON_BLACK)
        cprint_decimal(result, RED_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        // Fallback: register ramdisk
        blk_register(0, 2, RAMDISK_SIZE / 512, 512)
        println("[NVMe] Using ramdisk fallback (1MB)")
        cprintln("[NVMe] Using ramdisk fallback (1MB)", YELLOW_ON_BLACK)
        return -1
    }
    println("[NVMe] Controller enabled")
    cprintln("[NVMe] Controller enabled", GREEN_ON_BLACK)

    // Identify Controller
    println("[NVMe] Identify Controller...")
    let idc = nvme_identify_controller()
    if idc == 0 {
        // Print model string (bytes 24-63 of identify data)
        cprint("[NVMe] Model: ", WHITE_ON_BLACK)
        let mut m: i64 = 24
        while m < 64 {
            let ch = volatile_read_u8(NVME_DMA + m)
            if ch > 31 && ch < 127 { console_putchar(ch, CYAN_ON_BLACK) }
            m = m + 1
        }
        console_putchar(10, WHITE_ON_BLACK)
    }

    // Identify Namespace
    println("[NVMe] Identify Namespace...")
    let idn = nvme_identify_namespace()
    if idn == 0 {
        let ns_size = nvme_state_read(80)
        let sector_sz = nvme_state_read(88)
        cprint("[NVMe] Capacity: ", WHITE_ON_BLACK)
        cprint_decimal(ns_size * sector_sz / 1048576, CYAN_ON_BLACK)
        cprintln(" MB", WHITE_ON_BLACK)
    }

    // Create I/O queues
    println("[NVMe] Creating I/O queues...")
    let ioq = nvme_create_io_queues()
    if ioq != 0 {
        cprint("[NVMe] I/O queue creation failed: ", RED_ON_BLACK)
        cprint_decimal(ioq, RED_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        blk_register(0, 2, RAMDISK_SIZE / 512, 512)
        return -2
    }
    println("[NVMe] I/O queues ready")
    println("[NVMe] Registering block devices...")

    // Register as block device 0
    let ns_size = nvme_state_read(80)
    let sector_sz = nvme_state_read(88)
    blk_register(0, 1, ns_size, sector_sz)
    println("[NVMe] Block device 0 registered")

    // Also register ramdisk as device 1
    blk_register(1, 2, RAMDISK_SIZE / 512, 512)
    println("[NVMe] Block device 1 registered")
    // Mark ramdisk memory as used
    let mut f: i64 = RAMDISK_BASE / FRAME_SIZE
    while f < (RAMDISK_BASE + RAMDISK_SIZE) / FRAME_SIZE { frame_mark_used(f); f = f + 1 }

    // Quick sector 0 read test
    println("[NVMe] Registering block devices...")
    println("[NVMe] Testing sector read...")
    nvme_clear_queue(NVME_DMA, 512)
    let rs = nvme_read_sectors(0, 1, NVME_DMA)
    println("[NVMe] Read sectors returned")
    if rs == 0 {
        let b510 = volatile_read_u8(NVME_DMA + 510)
        let b511 = volatile_read_u8(NVME_DMA + 511)
        if b510 == 0x55 && b511 == 0xAA {
            println("[NVMe] Sector 0 read OK — boot signature found (0x55AA)")
        } else {
            println("[NVMe] Sector 0 read OK — no boot signature")
        }
    } else {
        println("[NVMe] Sector read FAILED")
    }

    // Auto-mount FAT32
    let mnt = fat32_mount(0)
    if mnt == 0 {
        println("[FAT32] Mounted successfully")
    } else {
        println("[FAT32] Mount failed or no FAT32 partition")
    }

    0
}

// ── Shell Commands ──

@kernel fn cmd_nvme_init() {
    let r = nvme_full_init()
    if r == 0 {
        cprintln("NVMe fully initialized", GREEN_ON_BLACK)
    }
}

@kernel fn cmd_disk_read() {
    // Read LBA 0 from device 0
    cprintln("Reading LBA 0 from block device 0...", WHITE_ON_BLACK)
    nvme_clear_queue(NVME_DMA, 512)
    let status = blk_read(0, 0, 1, NVME_DMA)
    cprint("  Status: ", WHITE_ON_BLACK)
    let status_color = if status == 0 { GREEN_ON_BLACK } else { RED_ON_BLACK }
    cprint_decimal(status, status_color)
    console_putchar(10, WHITE_ON_BLACK)
    if status == 0 {
        // Print first 32 bytes as hex
        cprint("  Data: ", WHITE_ON_BLACK)
        let mut i: i64 = 0
        while i < 32 {
            cprint_hex(volatile_read_u8(NVME_DMA + i), 2, CYAN_ON_BLACK)
            cprint(" ", WHITE_ON_BLACK)
            i = i + 1
        }
        console_putchar(10, WHITE_ON_BLACK)
    }
}

@kernel fn cmd_disk_write() {
    cprintln("Writing test pattern to LBA 1 on device 0...", WHITE_ON_BLACK)
    // Write pattern: 0xFA, 0x4A, 0x52, 0x00 ("FAJ\0" marker)
    volatile_write_u8(NVME_DMA, 0xFA)
    volatile_write_u8(NVME_DMA + 1, 0x4A)
    volatile_write_u8(NVME_DMA + 2, 0x52)
    volatile_write_u8(NVME_DMA + 3, 0x00)
    let mut i: i64 = 4
    while i < 512 { volatile_write_u8(NVME_DMA + i, (i % 256)); i = i + 1 }
    let status = blk_write(0, 1, 1, NVME_DMA)
    cprint("  Write status: ", WHITE_ON_BLACK)
    let status_color = if status == 0 { GREEN_ON_BLACK } else { RED_ON_BLACK }
    cprint_decimal(status, status_color)
    console_putchar(10, WHITE_ON_BLACK)
    if status == 0 {
        // Read back and verify
        nvme_clear_queue(NVME_DMA + 512, 512)
        let rs = blk_read(0, 1, 1, NVME_DMA + 512)
        if rs == 0 {
            let b0 = volatile_read_u8(NVME_DMA + 512)
            let b1 = volatile_read_u8(NVME_DMA + 513)
            let b2 = volatile_read_u8(NVME_DMA + 514)
            if b0 == 0xFA && b1 == 0x4A && b2 == 0x52 {
                cprintln("  Verify: OK (FAJ marker found)", GREEN_ON_BLACK)
            } else {
                cprintln("  Verify: MISMATCH", RED_ON_BLACK)
            }
        }
    }
}

@kernel fn cmd_blkdev() {
    cprintln("Block Devices:", YELLOW_ON_BLACK)
    let mut d: i64 = 0
    while d < BLK_MAX_DEVS {
        let dev_type = volatile_read_u64(BLK_TABLE + d * 32)
        if dev_type != 0 {
            cprint("  dev", WHITE_ON_BLACK)
            cprint_decimal(d, CYAN_ON_BLACK)
            cprint(": ", WHITE_ON_BLACK)
            if dev_type == 1 { cprint("nvme", GREEN_ON_BLACK) }
            else if dev_type == 2 { cprint("ramdisk", YELLOW_ON_BLACK) }
            else if dev_type == 3 { cprint("virtio", CYAN_ON_BLACK) }
            let total = volatile_read_u64(BLK_TABLE + d * 32 + 16)
            let ss = volatile_read_u64(BLK_TABLE + d * 32 + 24)
            cprint("  ", WHITE_ON_BLACK)
            cprint_decimal(total * ss / 1048576, CYAN_ON_BLACK)
            cprintln(" MB", WHITE_ON_BLACK)
        }
        d = d + 1
    }
}

// ═══════════════════════════════════════════════
// FAT32 Filesystem (Phase 12 Sprint 36-40)
// Reads FAT32 from block device 0 (NVMe or ramdisk)
// State stored at 0x805000 (256 bytes)
// ═══════════════════════════════════════════════

const FAT32_STATE: i64 = 0x805000
// +0:  valid (1 if mounted)
// +8:  bytes_per_sector
// +16: sectors_per_cluster
// +24: reserved_sectors
// +32: num_fats
// +40: fat_size_sectors
// +48: root_cluster
// +56: total_sectors
// +64: fat_start_lba
// +72: data_start_lba
// +80: cluster_size_bytes
// +88: blk_dev (block device index)

const FAT32_BUF: i64 = 0x820000  // 4KB read buffer for FAT32 ops

@kernel fn fat32_state_read(off: i64) -> i64 { volatile_read_u64(FAT32_STATE + off) }
@kernel fn fat32_state_write(off: i64, val: i64) { volatile_write_u64(FAT32_STATE + off, val) }

// ── Sprint 36: BPB Parsing ──

@kernel fn fat32_mount(blk_dev: i64) -> i64 {
    // Read sector 0 (boot sector / BPB)
    let status = blk_read(blk_dev, 0, 1, FAT32_BUF)
    if status != 0 { return -1 }

    // Validate FAT32 signature (bytes 510-511 = 0x55, 0xAA)
    let sig_lo = volatile_read_u8(FAT32_BUF + 510)
    let sig_hi = volatile_read_u8(FAT32_BUF + 511)
    if sig_lo != 0x55 || sig_hi != 0xAA { return -2 }

    // Parse BPB fields
    let bps = buffer_read_u16_le(FAT32_BUF + 11)    // bytes per sector
    let spc = volatile_read_u8(FAT32_BUF + 13)       // sectors per cluster
    let reserved = buffer_read_u16_le(FAT32_BUF + 14) // reserved sectors
    let num_fats = volatile_read_u8(FAT32_BUF + 16)   // number of FATs
    let fat_size = buffer_read_u32_le(FAT32_BUF + 36)  // FAT32 sectors per FAT
    let root_cluster = buffer_read_u32_le(FAT32_BUF + 44) // root dir cluster
    let total16 = buffer_read_u16_le(FAT32_BUF + 19)
    let total32 = buffer_read_u32_le(FAT32_BUF + 32)
    let total = if total16 != 0 { total16 } else { total32 }

    // Compute derived values
    let fat_start = reserved
    let data_start = reserved + num_fats * fat_size
    let cluster_bytes = bps * spc

    // Store state
    fat32_state_write(0, 1)
    fat32_state_write(8, bps)
    fat32_state_write(16, spc)
    fat32_state_write(24, reserved)
    fat32_state_write(32, num_fats)
    fat32_state_write(40, fat_size)
    fat32_state_write(48, root_cluster)
    fat32_state_write(56, total)
    fat32_state_write(64, fat_start)
    fat32_state_write(72, data_start)
    fat32_state_write(80, cluster_bytes)
    fat32_state_write(88, blk_dev)

    // Mark FAT32 state memory as used
    frame_mark_used(FAT32_STATE / FRAME_SIZE)
    frame_mark_used(FAT32_BUF / FRAME_SIZE)

    0
}

// ── Cluster Operations ──

@kernel fn fat32_cluster_to_lba(cluster: i64) -> i64 {
    let data_start = fat32_state_read(72)
    let spc = fat32_state_read(16)
    data_start + (cluster - 2) * spc
}

@kernel fn fat32_read_fat_entry(cluster: i64) -> i64 {
    // Each FAT entry is 4 bytes
    let fat_start = fat32_state_read(64)
    let bps = fat32_state_read(8)
    let fat_offset = cluster * 4
    let fat_sector = fat_start + fat_offset / bps
    let fat_byte_in_sector = fat_offset % bps

    // Read the FAT sector
    let status = blk_read(fat32_state_read(88), fat_sector, 1, FAT32_BUF)
    if status != 0 { return -1 }

    // Read 4-byte FAT entry (mask upper 4 bits)
    let entry = buffer_read_u32_le(FAT32_BUF + fat_byte_in_sector) & 0x0FFFFFFF
    entry
}

@kernel fn fat32_is_end_of_chain(entry: i64) -> i64 {
    if entry >= 0x0FFFFFF8 { 1 } else { 0 }
}

// ── Sprint 37: Directory + File Read ──

@kernel fn fat32_read_cluster(cluster: i64, buf: i64) -> i64 {
    let lba = fat32_cluster_to_lba(cluster)
    let spc = fat32_state_read(16)
    let dev = fat32_state_read(88)
    blk_read(dev, lba, spc, buf)
}

// Directory entry: 32 bytes
// +0:  name[8] — short name (padded with spaces)
// +8:  ext[3]  — extension
// +11: attr    — attributes (0x10=dir, 0x20=archive)
// +20: cluster_hi (u16)
// +26: cluster_lo (u16)
// +28: file_size (u32)

@kernel fn fat32_dir_entry_name(buf: i64, entry_idx: i64, out_buf: i64) -> i64 {
    // Extract 8.3 filename from directory entry to out_buf
    let base = buf + entry_idx * 32
    let first_byte = volatile_read_u8(base)
    if first_byte == 0 { return 0 }    // End of directory
    if first_byte == 0xE5 { return -1 } // Deleted entry

    let attr = volatile_read_u8(base + 11)
    if attr == 0x0F { return -1 } // LFN entry, skip

    // Copy name (8 chars, trim trailing spaces)
    let mut len: i64 = 0
    let mut i: i64 = 0
    while i < 8 {
        let ch = volatile_read_u8(base + i)
        if ch != 32 { // space
            volatile_write_u8(out_buf + len, ch)
            len = len + 1
        }
        i = i + 1
    }

    // Add dot + extension if extension exists
    let ext0 = volatile_read_u8(base + 8)
    if ext0 != 32 {
        volatile_write_u8(out_buf + len, 46) // '.'
        len = len + 1
        i = 0
        while i < 3 {
            let ch = volatile_read_u8(base + 8 + i)
            if ch != 32 {
                volatile_write_u8(out_buf + len, ch)
                len = len + 1
            }
            i = i + 1
        }
    }

    volatile_write_u8(out_buf + len, 0) // null terminate
    len
}

@kernel fn fat32_dir_entry_cluster(buf: i64, entry_idx: i64) -> i64 {
    let base = buf + entry_idx * 32
    let hi = buffer_read_u16_le(base + 20)
    let lo = buffer_read_u16_le(base + 26)
    let cluster = hi << 16 | lo
    cluster
}

@kernel fn fat32_dir_entry_size(buf: i64, entry_idx: i64) -> i64 {
    buffer_read_u32_le(buf + entry_idx * 32 + 28)
}

@kernel fn fat32_dir_entry_attr(buf: i64, entry_idx: i64) -> i64 {
    volatile_read_u8(buf + entry_idx * 32 + 11)
}

@kernel fn fat32_dir_entry_is_dir(buf: i64, entry_idx: i64) -> i64 {
    if (fat32_dir_entry_attr(buf, entry_idx) & 0x10) != 0 { 1 } else { 0 }
}

// ── File Lookup + Read ──

// Secondary buffer for directory scanning (separate from FAT32_BUF)
const FAT32_DIR_BUF: i64 = 0x821000
const FAT32_NAME_BUF: i64 = 0x822000

@kernel fn fat32_str_eq(a: i64, b: i64) -> i64 {
    let mut i: i64 = 0
    while i < 64 {
        let ca = volatile_read_u8(a + i)
        let cb = volatile_read_u8(b + i)
        if ca != cb { return 0 }
        if ca == 0 { return 1 }
        i = i + 1
    }
    1
}

// Convert lowercase to uppercase for FAT32 comparison
@kernel fn fat32_toupper(ch: i64) -> i64 {
    if ch >= 97 && ch <= 122 { ch - 32 } else { ch }
}

@kernel fn fat32_str_eq_nocase(a: i64, b: i64) -> i64 {
    let mut i: i64 = 0
    while i < 64 {
        let ca = fat32_toupper(volatile_read_u8(a + i))
        let cb = fat32_toupper(volatile_read_u8(b + i))
        if ca != cb { return 0 }
        if ca == 0 { return 1 }
        i = i + 1
    }
    1
}

@kernel fn fat32_write_str(buf: i64, s: i64, s_len: i64) {
    let mut i: i64 = 0
    while i < s_len {
        volatile_write_u8(buf + i, volatile_read_u8(s + i))
        i = i + 1
    }
    volatile_write_u8(buf + s_len, 0)
}

// Find file in root directory, return (cluster, size) packed as cluster*0x100000000+size
@kernel fn fat32_find_in_dir(dir_cluster: i64, name_buf: i64) -> i64 {
    let mut cluster = dir_cluster
    while fat32_is_end_of_chain(cluster) == 0 && cluster >= 2 {
        let status = fat32_read_cluster(cluster, FAT32_DIR_BUF)
        if status != 0 { return -1 }

        let cluster_bytes = fat32_state_read(80)
        let entries = cluster_bytes / 32
        let mut idx: i64 = 0
        while idx < entries {
            let first = volatile_read_u8(FAT32_DIR_BUF + idx * 32)
            if first == 0 { return -1 } // End of directory
            if first != 0xE5 {
                let name_len = fat32_dir_entry_name(FAT32_DIR_BUF, idx, FAT32_NAME_BUF)
                if name_len > 0 {
                    if fat32_str_eq_nocase(FAT32_NAME_BUF, name_buf) == 1 {
                        let file_cluster = fat32_dir_entry_cluster(FAT32_DIR_BUF, idx)
                        let file_size = fat32_dir_entry_size(FAT32_DIR_BUF, idx)
                        let is_dir = fat32_dir_entry_is_dir(FAT32_DIR_BUF, idx)
                        // Pack: cluster in upper 32 bits, size in lower 32 bits
                        let packed = (file_cluster << 32) | (file_size & 0xFFFFFFFF)
                        let packed2 = packed | (is_dir << 63)
                        return packed2
                    }
                }
            }
            idx = idx + 1
        }
        cluster = fat32_read_fat_entry(cluster)
    }
    -1
}

@kernel fn fat32_read_file(cluster: i64, size: i64, out_buf: i64) -> i64 {
    let cluster_bytes = fat32_state_read(80)
    let mut cur_cluster = cluster
    let mut bytes_read: i64 = 0

    while bytes_read < size && fat32_is_end_of_chain(cur_cluster) == 0 && cur_cluster >= 2 {
        let status = fat32_read_cluster(cur_cluster, FAT32_DIR_BUF)
        if status != 0 { return -1 }

        let to_copy = if size - bytes_read > cluster_bytes { cluster_bytes } else { size - bytes_read }
        let mut i: i64 = 0
        while i < to_copy {
            volatile_write_u8(out_buf + bytes_read + i, volatile_read_u8(FAT32_DIR_BUF + i))
            i = i + 1
        }
        bytes_read = bytes_read + to_copy
        cur_cluster = fat32_read_fat_entry(cur_cluster)
    }
    bytes_read
}

// ── FAT32 Write Operations (Sprint B1-B2) ──

@kernel fn fat32_write_fat_entry(cluster: i64, value: i64) -> i64 {
    let fat_start = fat32_state_read(64)
    let bps = fat32_state_read(8)
    let fat_offset = cluster * 4
    let fat_sector = fat_start + fat_offset / bps
    let byte_in_sector = fat_offset % bps
    let dev = fat32_state_read(88)

    // Read sector containing FAT entry
    let status = blk_read(dev, fat_sector, 1, FAT32_BUF)
    if status != 0 { return -1 }

    // Modify the 4-byte entry (preserve upper 4 bits)
    let old = buffer_read_u32_le(FAT32_BUF + byte_in_sector)
    let new_val = (old & 0xF0000000) | (value & 0x0FFFFFFF)
    buffer_write_u32_le(FAT32_BUF + byte_in_sector, new_val)

    // Write sector back
    let ws = blk_write(dev, fat_sector, 1, FAT32_BUF)
    if ws != 0 { return -2 }
    0
}

@kernel fn fat32_find_free_cluster() -> i64 {
    let fat_start = fat32_state_read(64)
    let bps = fat32_state_read(8)
    let total = fat32_state_read(56)
    let data_start = fat32_state_read(72)
    let spc = fat32_state_read(16)
    let total_clusters = (total - data_start) / spc + 2
    let dev = fat32_state_read(88)

    let mut cluster: i64 = 2
    while cluster < total_clusters {
        let fat_offset = cluster * 4
        let fat_sector = fat_start + fat_offset / bps
        let byte_in_sector = fat_offset % bps

        let rs = blk_read(dev, fat_sector, 1, FAT32_BUF)
        if rs != 0 { return -1 }

        let entry = buffer_read_u32_le(FAT32_BUF + byte_in_sector) & 0x0FFFFFFF
        if entry == 0 { return cluster }
        cluster = cluster + 1
    }
    -1 // Disk full
}

@kernel fn fat32_alloc_cluster(prev_cluster: i64) -> i64 {
    let free = fat32_find_free_cluster()
    if free < 2 { return -1 }

    // Mark new cluster as end-of-chain
    let ws1 = fat32_write_fat_entry(free, 0x0FFFFFFF)
    if ws1 != 0 { return -2 }

    // Link previous cluster to new one (if not first)
    if prev_cluster >= 2 {
        let ws2 = fat32_write_fat_entry(prev_cluster, free)
        if ws2 != 0 { return -3 }
    }
    free
}

@kernel fn fat32_write_cluster(cluster: i64, buf: i64) -> i64 {
    let lba = fat32_cluster_to_lba(cluster)
    let spc = fat32_state_read(16)
    let dev = fat32_state_read(88)
    blk_write(dev, lba, spc, buf)
}

@kernel fn fat32_free_chain(start_cluster: i64) {
    let mut cluster = start_cluster
    while cluster >= 2 && fat32_is_end_of_chain(cluster) == 0 {
        let next = fat32_read_fat_entry(cluster)
        fat32_write_fat_entry(cluster, 0)
        cluster = next
    }
    // Free the last cluster too
    if cluster >= 2 {
        fat32_write_fat_entry(cluster, 0)
    }
}

// Create 8.3 filename in buffer (11 bytes, space-padded)
@kernel fn fat32_make_83_name(src: i64, dst: i64) {
    // Clear with spaces
    let mut i: i64 = 0
    while i < 11 { volatile_write_u8(dst + i, 32); i = i + 1 }

    // Copy name part (before dot)
    let mut si: i64 = 0
    let mut di: i64 = 0
    while di < 8 {
        let ch = volatile_read_u8(src + si)
        if ch == 0 || ch == 46 { di = 8 } // null or '.'
        else {
            volatile_write_u8(dst + di, fat32_toupper(ch))
            si = si + 1
            di = di + 1
        }
    }

    // Skip to dot
    let mut si2: i64 = 0
    while volatile_read_u8(src + si2) != 0 && volatile_read_u8(src + si2) != 46 { si2 = si2 + 1 }
    if volatile_read_u8(src + si2) == 46 {
        si2 = si2 + 1
        // Copy extension
        let mut ei: i64 = 0
        while ei < 3 {
            let ch = volatile_read_u8(src + si2)
            if ch == 0 { ei = 3 }
            else {
                volatile_write_u8(dst + 8 + ei, fat32_toupper(ch))
                si2 = si2 + 1
                ei = ei + 1
            }
        }
    }
}

@kernel fn fat32_create_dir_entry(dir_cluster: i64, name: i64, first_cluster: i64, file_size: i64, is_dir: i64) -> i64 {
    let cluster_bytes = fat32_state_read(80)
    let dev = fat32_state_read(88)
    let mut cluster = dir_cluster

    while fat32_is_end_of_chain(cluster) == 0 && cluster >= 2 {
        let status = fat32_read_cluster(cluster, FAT32_DIR_BUF)
        if status != 0 { return -1 }

        let entries = cluster_bytes / 32
        let mut idx: i64 = 0
        while idx < entries {
            let first_byte = volatile_read_u8(FAT32_DIR_BUF + idx * 32)
            if first_byte == 0 || first_byte == 0xE5 {
                // Found free entry — write it
                let base = FAT32_DIR_BUF + idx * 32

                // 8.3 name (11 bytes)
                let name_buf: i64 = 0x806600
                fat32_make_83_name(name, name_buf)
                let mut k: i64 = 0
                while k < 11 { volatile_write_u8(base + k, volatile_read_u8(name_buf + k)); k = k + 1 }

                // Attributes
                let attr = if is_dir == 1 { 0x10 } else { 0x20 }
                volatile_write_u8(base + 11, attr)

                // Reserved + timestamps (zero for now)
                k = 12
                while k < 20 { volatile_write_u8(base + k, 0); k = k + 1 }

                // Cluster high + low
                buffer_write_u16_le(base + 20, (first_cluster >> 16) & 0xFFFF)
                buffer_write_u16_le(base + 26, first_cluster & 0xFFFF)

                // File size
                buffer_write_u32_le(base + 28, file_size)

                // Write cluster back to disk
                let ws = fat32_write_cluster(cluster, FAT32_DIR_BUF)
                if ws != 0 { return -2 }
                return 0
            }
            idx = idx + 1
        }
        cluster = fat32_read_fat_entry(cluster)
    }
    -3 // Directory full
}

@kernel fn fat32_create_file(name: i64, data: i64, data_len: i64) -> i64 {
    if fat32_state_read(0) != 1 { return -1 }
    let root = fat32_state_read(48)
    let cluster_bytes = fat32_state_read(80)

    // Allocate first cluster
    let first_cluster = fat32_alloc_cluster(0)
    if first_cluster < 2 { return -2 }

    // Write data to clusters
    let mut bytes_written: i64 = 0
    let mut cur_cluster = first_cluster
    while bytes_written < data_len {
        // Fill cluster buffer
        let to_write = if data_len - bytes_written > cluster_bytes { cluster_bytes } else { data_len - bytes_written }

        // Clear buffer first
        memset_buf(FAT32_DIR_BUF, 0, cluster_bytes)

        // Copy data
        memcpy_buf(FAT32_DIR_BUF, data + bytes_written, to_write)

        // Write cluster
        let ws = fat32_write_cluster(cur_cluster, FAT32_DIR_BUF)
        if ws != 0 { return -3 }

        bytes_written = bytes_written + to_write

        // Allocate next cluster if needed
        if bytes_written < data_len {
            let next = fat32_alloc_cluster(cur_cluster)
            if next < 2 { return -4 }
            cur_cluster = next
        }
    }

    // Create directory entry
    let de = fat32_create_dir_entry(root, name, first_cluster, data_len, 0)
    if de != 0 { return -5 }
    0
}

@kernel fn fat32_delete_file(name: i64) -> i64 {
    if fat32_state_read(0) != 1 { return -1 }
    let root = fat32_state_read(48)
    let cluster_bytes = fat32_state_read(80)

    // Find file in directory
    let result = fat32_find_in_dir(root, name)
    if result == -1 { return -2 }

    let shifted = result >> 32
    let file_cluster = shifted & 0x7FFFFFFF

    // Free cluster chain
    fat32_free_chain(file_cluster)

    // Mark directory entry as deleted (0xE5)
    let mut cluster = root
    while fat32_is_end_of_chain(cluster) == 0 && cluster >= 2 {
        let status = fat32_read_cluster(cluster, FAT32_DIR_BUF)
        if status != 0 { return -3 }

        let entries = cluster_bytes / 32
        let mut idx: i64 = 0
        while idx < entries {
            let first = volatile_read_u8(FAT32_DIR_BUF + idx * 32)
            if first != 0 && first != 0xE5 {
                let name_len = fat32_dir_entry_name(FAT32_DIR_BUF, idx, FAT32_NAME_BUF)
                if name_len > 0 && fat32_str_eq_nocase(FAT32_NAME_BUF, name) == 1 {
                    volatile_write_u8(FAT32_DIR_BUF + idx * 32, 0xE5)
                    fat32_write_cluster(cluster, FAT32_DIR_BUF)
                    return 0
                }
            }
            idx = idx + 1
        }
        cluster = fat32_read_fat_entry(cluster)
    }
    -4
}

// ── FAT32 Write Shell Commands ──

@kernel fn cmd_fatwrite() {
    // "fatwrite <name> <text>" — create file with content
    if fat32_state_read(0) != 1 { cprintln("FAT32 not mounted", RED_ON_BLACK); return }

    // Parse: skip "fatwrite " (9 chars), get filename until space, rest is content
    let mut pos: i64 = 9
    let mut fname_len: i64 = 0
    while pos < 64 {
        let ch = volatile_read_u8(0x6F800 + pos)
        if ch == 0 || ch == 32 { pos = 64 }
        else { volatile_write_u8(FAT32_NAME_BUF + 512 + fname_len, ch); fname_len = fname_len + 1; pos = pos + 1 }
    }
    volatile_write_u8(FAT32_NAME_BUF + 512 + fname_len, 0)

    if fname_len == 0 { cprintln("Usage: fatwrite <file> <text>", YELLOW_ON_BLACK); return }

    // Skip space after filename, rest is content
    let mut content_start: i64 = 9 + fname_len
    if volatile_read_u8(0x6F800 + content_start) == 32 { content_start = content_start + 1 }
    let mut content_len: i64 = 0
    while volatile_read_u8(0x6F800 + content_start + content_len) != 0 { content_len = content_len + 1 }

    if content_len == 0 { cprintln("No content provided", YELLOW_ON_BLACK); return }

    // Copy content to buffer
    let content_buf: i64 = 0x830000
    memcpy_buf(content_buf, 0x6F800 + content_start, content_len)

    let result = fat32_create_file(FAT32_NAME_BUF + 512, content_buf, content_len)
    if result == 0 {
        cprint("Created: ", GREEN_ON_BLACK)
        let mut k: i64 = 0
        while k < fname_len { console_putchar(volatile_read_u8(FAT32_NAME_BUF + 512 + k), CYAN_ON_BLACK); k = k + 1 }
        cprint(" (", WHITE_ON_BLACK)
        cprint_decimal(content_len, CYAN_ON_BLACK)
        cprintln(" bytes)", WHITE_ON_BLACK)
    } else {
        cprint("Write failed: ", RED_ON_BLACK)
        cprint_decimal(result, RED_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    }
}

@kernel fn cmd_fatrm() {
    // "fatrm <name>" — delete file
    if fat32_state_read(0) != 1 { cprintln("FAT32 not mounted", RED_ON_BLACK); return }

    let mut fname_len: i64 = 0
    let mut i: i64 = 6
    while i < 64 {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch == 0 { i = 64 }
        else { volatile_write_u8(FAT32_NAME_BUF + 512 + fname_len, ch); fname_len = fname_len + 1; i = i + 1 }
    }
    volatile_write_u8(FAT32_NAME_BUF + 512 + fname_len, 0)

    if fname_len == 0 { cprintln("Usage: fatrm <file>", YELLOW_ON_BLACK); return }

    let result = fat32_delete_file(FAT32_NAME_BUF + 512)
    if result == 0 {
        cprintln("Deleted", GREEN_ON_BLACK)
    } else {
        cprint("Delete failed: ", RED_ON_BLACK)
        cprint_decimal(result, RED_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    }
}

// ── Shell Commands ──

@kernel fn cmd_fat32_mount() {
    cprintln("Mounting FAT32 from block device 0...", WHITE_ON_BLACK)
    let r = fat32_mount(0)
    if r == 0 {
        cprintln("  FAT32 mounted!", GREEN_ON_BLACK)
        cprint("  Bytes/sector:     ", WHITE_ON_BLACK)
        cprint_decimal(fat32_state_read(8), CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        cprint("  Sectors/cluster:  ", WHITE_ON_BLACK)
        cprint_decimal(fat32_state_read(16), CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        cprint("  FAT start LBA:   ", WHITE_ON_BLACK)
        cprint_decimal(fat32_state_read(64), CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        cprint("  Data start LBA:  ", WHITE_ON_BLACK)
        cprint_decimal(fat32_state_read(72), CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        cprint("  Root cluster:    ", WHITE_ON_BLACK)
        cprint_decimal(fat32_state_read(48), CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        cprint("  Total sectors:   ", WHITE_ON_BLACK)
        cprint_decimal(fat32_state_read(56), CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        let total_mb = fat32_state_read(56) * fat32_state_read(8) / 1048576
        cprint("  Volume size:     ", WHITE_ON_BLACK)
        cprint_decimal(total_mb, CYAN_ON_BLACK)
        cprintln(" MB", WHITE_ON_BLACK)
    } else {
        cprint("  Mount failed: ", RED_ON_BLACK)
        cprint_decimal(r, RED_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    }
}

@kernel fn cmd_fat32_ls() {
    if fat32_state_read(0) != 1 { cprintln("FAT32 not mounted", RED_ON_BLACK); return }
    cprintln("FAT32 root directory:", YELLOW_ON_BLACK)
    let root = fat32_state_read(48)
    let mut cluster = root
    let mut total_files: i64 = 0
    while fat32_is_end_of_chain(cluster) == 0 && cluster >= 2 {
        let status = fat32_read_cluster(cluster, FAT32_DIR_BUF)
        if status != 0 { cprintln("  Read error", RED_ON_BLACK); return }
        let entries = fat32_state_read(80) / 32
        let mut idx: i64 = 0
        while idx < entries {
            let first = volatile_read_u8(FAT32_DIR_BUF + idx * 32)
            if first == 0 { idx = entries } // break
            else if first != 0xE5 {
                let name_len = fat32_dir_entry_name(FAT32_DIR_BUF, idx, FAT32_NAME_BUF)
                if name_len > 0 {
                    let is_dir = fat32_dir_entry_is_dir(FAT32_DIR_BUF, idx)
                    let size = fat32_dir_entry_size(FAT32_DIR_BUF, idx)
                    cprint("  ", WHITE_ON_BLACK)
                    if is_dir == 1 { cprint("[DIR] ", CYAN_ON_BLACK) }
                    else {
                        cprint_decimal(size, WHITE_ON_BLACK)
                        cprint("B ", WHITE_ON_BLACK)
                    }
                    // Print filename
                    let mut k: i64 = 0
                    while k < name_len {
                        let ch = volatile_read_u8(FAT32_NAME_BUF + k)
                        if ch > 0 {
                            let name_color = if is_dir == 1 { CYAN_ON_BLACK } else { GREEN_ON_BLACK }
                            console_putchar(ch, name_color)
                        }
                        k = k + 1
                    }
                    console_putchar(10, WHITE_ON_BLACK)
                    total_files = total_files + 1
                }
            }
            idx = idx + 1
        }
        cluster = fat32_read_fat_entry(cluster)
    }
    cprint("  Total: ", WHITE_ON_BLACK)
    cprint_decimal(total_files, CYAN_ON_BLACK)
    cprintln(" entries", WHITE_ON_BLACK)
}

@kernel fn cmd_fat32_cat() {
    // Read filename from command buffer: "fatcat <filename>"
    // Parse: skip "fatcat " (7 chars), read rest as filename
    if fat32_state_read(0) != 1 { cprintln("FAT32 not mounted", RED_ON_BLACK); return }

    // Copy filename from cmdbuf offset 7
    let mut fname_len: i64 = 0
    let mut i: i64 = 7
    while i < 64 {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch == 0 { i = 64 } // break
        else {
            volatile_write_u8(FAT32_NAME_BUF + 256 + fname_len, ch)
            fname_len = fname_len + 1
            i = i + 1
        }
    }
    volatile_write_u8(FAT32_NAME_BUF + 256 + fname_len, 0)

    if fname_len == 0 {
        cprintln("Usage: fatcat <filename>", YELLOW_ON_BLACK)
        return
    }

    // Search root directory
    let root = fat32_state_read(48)
    let search_buf = FAT32_NAME_BUF + 256
    let result = fat32_find_in_dir(root, search_buf)
    if result == -1 {
        cprintln("File not found", RED_ON_BLACK)
        return
    }

    let shifted = result >> 32
    let file_cluster = shifted & 0x7FFFFFFF
    let file_size = result & 0xFFFFFFFF

    // Read file into buffer at 0x830000
    let file_buf: i64 = 0x830000
    let bytes = fat32_read_file(file_cluster, file_size, file_buf)
    if bytes < 0 {
        cprintln("Read error", RED_ON_BLACK)
        return
    }

    // Print file contents
    i = 0
    while i < bytes {
        let ch = volatile_read_u8(file_buf + i)
        if ch == 10 { console_putchar(10, WHITE_ON_BLACK) }
        else if ch >= 32 && ch < 127 { console_putchar(ch, GREEN_ON_BLACK) }
        i = i + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  (", WHITE_ON_BLACK)
    cprint_decimal(bytes, CYAN_ON_BLACK)
    cprintln(" bytes)", WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// VFS — Virtual Filesystem Switch (Phase 13)
// Mount table, unified path resolution, /dev, /proc
// State at 0x806000 (mount table + fd table)
// ═══════════════════════════════════════════════

// Mount table: 8 entries × 64 bytes at 0x806000
// Per entry: +0=fs_type (0=none,1=ramfs,2=fat32,3=devfs,4=procfs)
//            +8=device_id, +16=mountpoint_hash, +24=flags
const VFS_MOUNT_TABLE: i64 = 0x806000
const VFS_MAX_MOUNTS: i64 = 8
const VFS_MOUNT_SIZE: i64 = 64
const VFS_FS_NONE: i64 = 0
const VFS_FS_RAMFS: i64 = 1
const VFS_FS_FAT32: i64 = 2
const VFS_FS_DEVFS: i64 = 3
const VFS_FS_PROCFS: i64 = 4

// Mountpoint string table at 0x806200 (8 entries × 32 bytes)
const VFS_MOUNT_NAMES: i64 = 0x806200

// Simple hash for path matching
@kernel fn vfs_path_hash(path_addr: i64) -> i64 {
    let mut hash: i64 = 5381
    let mut i: i64 = 0
    while i < 32 {
        let ch = volatile_read_u8(path_addr + i)
        if ch == 0 { i = 32 }
        else {
            hash = hash * 33 + ch
            i = i + 1
        }
    }
    hash
}

@kernel fn vfs_mount_set(slot: i64, fs_type: i64, dev_id: i64, name_addr: i64) {
    let base = VFS_MOUNT_TABLE + slot * VFS_MOUNT_SIZE
    volatile_write_u64(base, fs_type)
    volatile_write_u64(base + 8, dev_id)
    // Copy mountpoint name
    let name_base = VFS_MOUNT_NAMES + slot * 32
    let mut i: i64 = 0
    while i < 31 {
        let ch = volatile_read_u8(name_addr + i)
        volatile_write_u8(name_base + i, ch)
        if ch == 0 { i = 31 }
        else { i = i + 1 }
    }
    volatile_write_u8(name_base + 31, 0)
    volatile_write_u64(base + 16, vfs_path_hash(name_base))
}

@kernel fn vfs_find_mount(path_addr: i64) -> i64 {
    // Find longest matching mountpoint for path
    let mut best_slot: i64 = -1
    let mut best_len: i64 = 0
    let mut slot: i64 = 0
    while slot < VFS_MAX_MOUNTS {
        let fs_type = volatile_read_u64(VFS_MOUNT_TABLE + slot * VFS_MOUNT_SIZE)
        if fs_type != VFS_FS_NONE {
            let name_base = VFS_MOUNT_NAMES + slot * 32
            // Check if path starts with mountpoint
            let mut match_len: i64 = 0
            let mut matches: i64 = 1
            let mut k: i64 = 0
            while k < 31 && matches == 1 {
                let mc = volatile_read_u8(name_base + k)
                if mc == 0 { k = 31 } // end of mountpoint
                else {
                    let pc = volatile_read_u8(path_addr + k)
                    if mc != pc { matches = 0 }
                    else { match_len = match_len + 1 }
                    k = k + 1
                }
            }
            if matches == 1 && match_len > best_len {
                best_len = match_len
                best_slot = slot
            }
        }
        slot = slot + 1
    }
    best_slot
}

@kernel fn vfs_init() {
    // Clear mount table
    let mut i: i64 = 0
    while i < VFS_MAX_MOUNTS * VFS_MOUNT_SIZE {
        volatile_write_u8(VFS_MOUNT_TABLE + i, 0)
        i = i + 1
    }
    // Mount ramfs at /
    let slash: i64 = 0x806400 // temp buffer for "/"
    volatile_write_u8(slash, 47) // '/'
    volatile_write_u8(slash + 1, 0)
    vfs_mount_set(0, VFS_FS_RAMFS, 0, slash)

    // Mount devfs at /dev
    volatile_write_u8(slash, 47)
    volatile_write_u8(slash + 1, 100) // 'd'
    volatile_write_u8(slash + 2, 101) // 'e'
    volatile_write_u8(slash + 3, 118) // 'v'
    volatile_write_u8(slash + 4, 0)
    vfs_mount_set(1, VFS_FS_DEVFS, 0, slash)

    // Mount procfs at /proc
    volatile_write_u8(slash, 47)
    volatile_write_u8(slash + 1, 112) // 'p'
    volatile_write_u8(slash + 2, 114) // 'r'
    volatile_write_u8(slash + 3, 111) // 'o'
    volatile_write_u8(slash + 4, 99)  // 'c'
    volatile_write_u8(slash + 5, 0)
    vfs_mount_set(2, VFS_FS_PROCFS, 0, slash)

    // If FAT32 mounted, add /mnt
    if fat32_state_read(0) == 1 {
        volatile_write_u8(slash, 47)
        volatile_write_u8(slash + 1, 109) // 'm'
        volatile_write_u8(slash + 2, 110) // 'n'
        volatile_write_u8(slash + 3, 116) // 't'
        volatile_write_u8(slash + 4, 0)
        vfs_mount_set(3, VFS_FS_FAT32, 0, slash)
    }

    frame_mark_used(VFS_MOUNT_TABLE / FRAME_SIZE)
}

// ── /dev Device Files ──

@kernel fn dev_read(name_addr: i64, buf: i64, size: i64) -> i64 {
    // Check device name (after "/dev/")
    let c0 = volatile_read_u8(name_addr)
    let c1 = volatile_read_u8(name_addr + 1)
    let c2 = volatile_read_u8(name_addr + 2)
    let c3 = volatile_read_u8(name_addr + 3)

    // /dev/null — returns 0 bytes (EOF)
    if c0 == 110 && c1 == 117 && c2 == 108 && c3 == 108 {
        return 0
    }

    // /dev/zero — fills buffer with zeros
    if c0 == 122 && c1 == 101 && c2 == 114 && c3 == 111 {
        let mut i: i64 = 0
        while i < size { volatile_write_u8(buf + i, 0); i = i + 1 }
        return size
    }

    // /dev/random — fills buffer with pseudo-random bytes
    if c0 == 114 && c1 == 97 && c2 == 110 && c3 == 100 {
        let mut i: i64 = 0
        while i < size {
            let r = rdrand()
            volatile_write_u8(buf + i, r & 0xFF)
            i = i + 1
        }
        return size
    }

    -1 // Unknown device
}

// ── /proc Virtual Files ──

@kernel fn proc_read(name_addr: i64, buf: i64) -> i64 {
    let c0 = volatile_read_u8(name_addr)

    // /proc/version — "FajarOS Nova v1.0.0"
    if c0 == 118 { // 'v' for version
        let ver_str: i64 = 0x806500
        volatile_write_u8(ver_str, 70)  // F
        volatile_write_u8(ver_str + 1, 97) // a
        volatile_write_u8(ver_str + 2, 106) // j
        volatile_write_u8(ver_str + 3, 97)  // a
        volatile_write_u8(ver_str + 4, 114) // r
        volatile_write_u8(ver_str + 5, 79)  // O
        volatile_write_u8(ver_str + 6, 83)  // S
        volatile_write_u8(ver_str + 7, 32)  // ' '
        volatile_write_u8(ver_str + 8, 78) // N
        volatile_write_u8(ver_str + 9, 111)  // o
        volatile_write_u8(ver_str + 10, 118) // v
        volatile_write_u8(ver_str + 11, 97)  // a
        volatile_write_u8(ver_str + 12, 10)  // \n
        volatile_write_u8(ver_str + 13, 0)
        let mut i: i64 = 0
        while i < 13 { volatile_write_u8(buf + i, volatile_read_u8(ver_str + i)); i = i + 1 }
        return 13
    }

    // /proc/uptime — ticks / 100 (seconds)
    if c0 == 117 { // 'u' for uptime
        let ticks = read_timer_ticks()
        let secs = ticks / 100
        // Write decimal number to buffer (simple)
        let mut val = secs
        let mut digits: i64 = 0
        let mut temp = val
        if temp == 0 { digits = 1 }
        while temp > 0 { digits = digits + 1; temp = temp / 10 }
        let mut pos = digits - 1
        if val == 0 { volatile_write_u8(buf, 48) } // '0'
        while val > 0 {
            volatile_write_u8(buf + pos, 48 + val % 10)
            val = val / 10
            pos = pos - 1
        }
        volatile_write_u8(buf + digits, 10) // \n
        return digits + 1
    }

    -1
}

// ── Shell Commands ──

@kernel fn cmd_vfs_mounts() {
    cprintln("VFS Mount Table:", YELLOW_ON_BLACK)
    let mut slot: i64 = 0
    while slot < VFS_MAX_MOUNTS {
        let fs_type = volatile_read_u64(VFS_MOUNT_TABLE + slot * VFS_MOUNT_SIZE)
        if fs_type != VFS_FS_NONE {
            cprint("  ", WHITE_ON_BLACK)
            let name_base = VFS_MOUNT_NAMES + slot * 32
            let mut k: i64 = 0
            while k < 31 {
                let ch = volatile_read_u8(name_base + k)
                if ch == 0 { k = 31 }
                else { console_putchar(ch, CYAN_ON_BLACK); k = k + 1 }
            }
            cprint(" -> ", WHITE_ON_BLACK)
            if fs_type == VFS_FS_RAMFS { cprintln("ramfs", GREEN_ON_BLACK) }
            else if fs_type == VFS_FS_FAT32 { cprintln("fat32", GREEN_ON_BLACK) }
            else if fs_type == VFS_FS_DEVFS { cprintln("devfs", GREEN_ON_BLACK) }
            else if fs_type == VFS_FS_PROCFS { cprintln("procfs", GREEN_ON_BLACK) }
            else { cprintln("unknown", RED_ON_BLACK) }
        }
        slot = slot + 1
    }
}

@kernel fn cmd_dev_read() {
    // "devread <device> <size>" — e.g., "devread random 16"
    cprintln("/dev devices:", YELLOW_ON_BLACK)
    // Read 16 bytes from /dev/random
    let buf: i64 = 0x830000
    let n = dev_read(0x806500, buf, 0) // Use temp buffer; first test /dev/null
    // null test
    volatile_write_u8(0x806500, 110) // 'n'
    volatile_write_u8(0x806501, 117) // 'u'
    volatile_write_u8(0x806502, 108) // 'l'
    volatile_write_u8(0x806503, 108) // 'l'
    volatile_write_u8(0x806504, 0)
    let null_r = dev_read(0x806500, buf, 16)
    cprint("  /dev/null read: ", WHITE_ON_BLACK)
    cprint_decimal(null_r, CYAN_ON_BLACK)
    cprintln(" bytes", WHITE_ON_BLACK)
    // zero test
    volatile_write_u8(0x806500, 122) // 'z'
    volatile_write_u8(0x806501, 101) // 'e'
    volatile_write_u8(0x806502, 114) // 'r'
    volatile_write_u8(0x806503, 111) // 'o'
    volatile_write_u8(0x806504, 0)
    let zero_r = dev_read(0x806500, buf, 8)
    cprint("  /dev/zero read: ", WHITE_ON_BLACK)
    cprint_decimal(zero_r, CYAN_ON_BLACK)
    cprint(" bytes, first=", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u8(buf), CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    // random test
    volatile_write_u8(0x806500, 114) // 'r'
    volatile_write_u8(0x806501, 97)  // 'a'
    volatile_write_u8(0x806502, 110) // 'n'
    volatile_write_u8(0x806503, 100) // 'd'
    volatile_write_u8(0x806504, 0)
    let rand_r = dev_read(0x806500, buf, 8)
    cprint("  /dev/random read: ", WHITE_ON_BLACK)
    cprint_decimal(rand_r, CYAN_ON_BLACK)
    cprint(" bytes: ", WHITE_ON_BLACK)
    let mut ri: i64 = 0
    while ri < 8 {
        cprint_hex(volatile_read_u8(buf + ri), 2, CYAN_ON_BLACK)
        cprint(" ", WHITE_ON_BLACK)
        ri = ri + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_proc_version() {
    let buf: i64 = 0x830000
    volatile_write_u8(0x806500, 118) // 'v'
    volatile_write_u8(0x806501, 0)
    let n = proc_read(0x806500, buf)
    if n > 0 {
        let mut i: i64 = 0
        while i < n {
            let ch = volatile_read_u8(buf + i)
            if ch == 10 { console_putchar(10, WHITE_ON_BLACK) }
            else if ch > 31 { console_putchar(ch, GREEN_ON_BLACK) }
            i = i + 1
        }
    }
}

@kernel fn cmd_proc_uptime_vfs() {
    let buf: i64 = 0x830000
    volatile_write_u8(0x806500, 117) // 'u'
    volatile_write_u8(0x806501, 0)
    let n = proc_read(0x806500, buf)
    if n > 0 {
        cprint("Uptime: ", WHITE_ON_BLACK)
        let mut i: i64 = 0
        while i < n {
            let ch = volatile_read_u8(buf + i)
            if ch >= 48 && ch <= 57 { console_putchar(ch, CYAN_ON_BLACK) }
            i = i + 1
        }
        cprintln(" seconds", WHITE_ON_BLACK)
    }
}

// ═══════════════════════════════════════════════
// Network Stack (Phase 15)
// Virtio-net driver + Ethernet + ARP + IPv4 + ICMP + UDP
// State at 0x860000, RX/TX buffers at 0x870000
// ═══════════════════════════════════════════════

const NET_STATE: i64 = 0x860000
// +0: initialized (1 if driver ready)
// +8: mac[0..5] (6 bytes at offset 8)
// +16: ip_addr (packed as u32, e.g., 10.0.2.15 = 0x0A00020F)
// +24: gateway (e.g., 10.0.2.2 = 0x0A000202)
// +32: netmask (e.g., 255.255.255.0 = 0xFFFFFF00)
// +40: rx_count
// +48: tx_count
// +56: virtio_bar (BAR0 base for virtio-net)

const NET_RX_BUF: i64 = 0x870000  // 16KB RX buffer
const NET_TX_BUF: i64 = 0x874000  // 16KB TX buffer
const NET_ARP_CACHE: i64 = 0x878000  // ARP cache: 16 entries × 16 bytes (ip:4 + mac:6 + pad:6)
const NET_PKT_BUF: i64 = 0x87C000  // Temp packet build buffer (4KB)

// Virtqueue memory layout (at 0x890000, page-aligned)
// Queue 0 = RX, Queue 1 = TX
// Each queue: 16 descriptors × 16 bytes = 256 bytes descriptors
//   + avail ring: 6 + 16*2 = 38 bytes (padded to 4096 boundary)
//   + used ring: 4 + 16*8 = 132 bytes
// Total per queue: ~4KB (page-aligned)
// IMPORTANT: This must match what the device reports via port_inw(io_base + 0x0C).
// QEMU virtio-net typically reports 256. The driver MUST use this value for
// ring layout calculations, even if we only fill a subset of descriptors.
const VQ_NUM_ENTRIES: i64 = 256
const VQ_RX_BASE: i64 = 0x890000     // RX queue (page 0)
const VQ_TX_BASE: i64 = 0x894000     // TX queue (page 1)
const VQ_RX_BUFS: i64 = 0x898000    // RX packet buffers: 16 × 2KB = 32KB
const VIRTIO_NET_HDR_SIZE: i64 = 10  // virtio-net header prepended to each packet

// Net state extended offsets:
// +64: rx_avail_idx (current avail ring index for RX)
// +72: tx_avail_idx
// +80: rx_used_last (last processed used ring index)
// +88: tx_used_last

// Descriptor flags
const VRING_DESC_F_NEXT: i64 = 1
const VRING_DESC_F_WRITE: i64 = 2  // buffer is write-only (for device → driver)

// Virtqueue descriptor: 16 bytes
// +0: addr (u64) — physical address of buffer
// +8: len  (u32) — buffer length
// +12: flags (u16) — VRING_DESC_F_*
// +14: next (u16) — next descriptor index (if F_NEXT)

@kernel fn vq_desc_set(base: i64, idx: i64, addr: i64, len: i64, flags: i64, next: i64) {
    let off = base + idx * 16
    volatile_write_u64(off, addr)
    volatile_write_u32(off + 8, len)
    volatile_write_u16(off + 12, flags)
    volatile_write_u16(off + 14, next)
}

// Avail ring layout (after descriptors):
// +0: flags (u16) — 0 = no interrupt suppression
// +2: idx (u16) — next slot to fill
// +4: ring[N] (u16 each) — descriptor indices

@kernel fn vq_avail_offset(base: i64) -> i64 {
    // Avail ring starts after descriptor table: N * 16 bytes
    base + VQ_NUM_ENTRIES * 16
}

@kernel fn vq_avail_add(base: i64, desc_idx: i64) {
    let avail = vq_avail_offset(base)
    let idx = volatile_read_u16(avail + 2) & 0xFFFF
    let ring_idx = idx % VQ_NUM_ENTRIES
    volatile_write_u16(avail + 4 + ring_idx * 2, desc_idx)
    // Memory barrier (ensure descriptor is visible before updating idx)
    // On x86 stores are ordered, but add a compiler fence
    volatile_write_u16(avail + 2, (idx + 1) & 0xFFFF)
}

// Used ring layout (page-aligned after avail ring):
// +0: flags (u16)
// +2: idx (u16)
// +4: ring[N] × 8 bytes: id(u32) + len(u32)

@kernel fn vq_used_offset(base: i64) -> i64 {
    // Used ring: page-aligned after descriptors + available ring
    // virtio spec: align(sizeof_desc + sizeof_avail, VIRTIO_PCI_VRING_ALIGN)
    // VIRTIO_PCI_VRING_ALIGN = 4096 for legacy PCI
    // sizeof_desc = VQ_NUM_ENTRIES * 16
    // sizeof_avail = 4 + 2 * VQ_NUM_ENTRIES  (flags:2 + idx:2 + ring[N]:N*2)
    let avail_end = VQ_NUM_ENTRIES * 16 + 4 + VQ_NUM_ENTRIES * 2
    let used_offset = ((avail_end + 4095) / 4096) * 4096
    base + used_offset
}

@kernel fn vq_used_idx(base: i64) -> i64 {
    // Check if we have a discovered used ring offset (from scan)
    let discovered = net_state_read(96)
    if discovered > 0 {
        return volatile_read_u16(base + discovered + 2) & 0xFFFF
    }
    volatile_read_u16(vq_used_offset(base) + 2) & 0xFFFF
}

@kernel fn vq_setup_queue(io_base: i64, queue_idx: i64, queue_base: i64) {
    // Select queue
    port_outw(io_base + 0x0E, queue_idx)
    // Read queue size (should return max entries)
    let qsz = port_inw(io_base + 0x0C) & 0xFFFF
    if qsz == 0 {
        println("[VQ] Queue size = 0, skipping")
        return
    }
    // Log actual queue size from device
    println("[VQ] Queue size from device (should be 256)")
    // Write queue PFN (physical address >> 12 = page frame number)
    port_outd(io_base + 0x08, queue_base / 4096)
}

@kernel fn vq_init_mem(base: i64) {
    // Zero the entire queue region: descriptors + avail ring + used ring
    // For 256 entries: desc=4096, avail=518, used at 8192, used=2052
    // Total: ~10KB, zero 16KB to be safe (4 pages)
    let mut i: i64 = 0
    while i < 16384 { volatile_write_u8(base + i, 0); i = i + 1 }
}

const VQ_RX_FILL: i64 = 16  // Only pre-fill 16 RX buffers (not all 256)

@kernel fn net_setup_rx_queue() {
    // Pre-fill first 16 RX descriptors (device writes received packets here)
    let mut i: i64 = 0
    while i < VQ_RX_FILL {
        let buf_addr = VQ_RX_BUFS + i * 2048  // 2KB per RX buffer
        // Descriptor: addr=buf, len=2048, flags=WRITE (device fills it), no next
        vq_desc_set(VQ_RX_BASE, i, buf_addr, 2048, VRING_DESC_F_WRITE, 0)
        // Add to avail ring
        vq_avail_add(VQ_RX_BASE, i)
        i = i + 1
    }
    // Store our tracking indices
    net_state_write(64, VQ_RX_FILL)  // rx_avail_idx = 16 (we filled 16 entries)
    net_state_write(80, 0)               // rx_used_last = 0

    // CRITICAL: Notify the device that RX buffers are available (kick RX queue 0)
    let io_base = net_state_read(56)
    if io_base != 0 {
        port_outw(io_base + 0x10, 0) // Notify queue 0 (RX)
    }
}

@kernel fn net_tx_packet(data: i64, len: i64) -> i64 {
    // Send a packet via virtio-net TX queue
    // data must include the 10-byte virtio-net header prepended
    let io_base = net_state_read(56)
    if io_base == 0 { return -1 }

    let tx_idx = net_state_read(72) & 0xFFFF
    let desc_idx = tx_idx % VQ_NUM_ENTRIES

    // Set descriptor: point to TX buffer with data
    vq_desc_set(VQ_TX_BASE, desc_idx, data, len, 0, 0)

    // Add to avail ring
    vq_avail_add(VQ_TX_BASE, desc_idx)

    // Update our tracking
    net_state_write(72, tx_idx + 1)

    // Kick the device (notify TX queue = queue 1)
    port_outw(io_base + 0x10, 1)

    // Increment TX counter
    net_state_write(48, net_state_read(48) + 1)

    0
}

@kernel fn net_rx_poll() -> i64 {
    // Check for received packets. Returns length of packet or -1 if none.
    // Received packet data is at VQ_RX_BUFS + desc_idx * 2048
    let used_idx = vq_used_idx(VQ_RX_BASE)
    let last = net_state_read(80) & 0xFFFF
    if used_idx == last { return -1 }  // no new packets

    // Read the used ring entry
    let used_base = vq_used_offset(VQ_RX_BASE)
    let ring_idx = last % VQ_NUM_ENTRIES
    let desc_id = volatile_read_u32(used_base + 4 + ring_idx * 8) & 0xFFFF
    let pkt_len = volatile_read_u32(used_base + 4 + ring_idx * 8 + 4)

    // Advance last-processed index
    net_state_write(80, last + 1)

    // Increment RX counter
    net_state_write(40, net_state_read(40) + 1)

    // Copy received data to NET_RX_BUF for parsing
    let src = VQ_RX_BUFS + desc_id * 2048
    let mut i: i64 = 0
    while i < pkt_len && i < 16384 {
        volatile_write_u8(NET_RX_BUF + i, volatile_read_u8(src + i))
        i = i + 1
    }

    // Re-add this descriptor to available ring for future receives
    vq_avail_add(VQ_RX_BASE, desc_id)
    net_state_write(64, net_state_read(64) + 1)

    // Notify RX queue
    let io_base = net_state_read(56)
    port_outw(io_base + 0x10, 0)

    pkt_len
}

@kernel fn net_send_frame(frame_data: i64, frame_len: i64) -> i64 {
    // Prepend 10-byte virtio-net header + send via TX queue
    // Header: flags(1)=0, gso_type(1)=0, hdr_len(2)=0, gso_size(2)=0,
    //         csum_start(2)=0, csum_offset(2)=0
    let tx_buf = NET_TX_BUF + 4096  // Use upper part of TX buffer area
    // Zero virtio-net header
    let mut i: i64 = 0
    while i < VIRTIO_NET_HDR_SIZE { volatile_write_u8(tx_buf + i, 0); i = i + 1 }
    // Copy frame after header
    i = 0
    while i < frame_len { volatile_write_u8(tx_buf + VIRTIO_NET_HDR_SIZE + i, volatile_read_u8(frame_data + i)); i = i + 1 }

    net_tx_packet(tx_buf, VIRTIO_NET_HDR_SIZE + frame_len)
}

@kernel fn net_check_icmp_reply() -> i64 {
    // Poll for ICMP echo reply. Returns RTT in TSC cycles or -1.
    let t0 = rdtsc()
    let mut attempts: i64 = 0
    while attempts < 50000000 {  // ~5 second timeout
        let pkt_len = net_rx_poll()
        if pkt_len > 0 {
            // Skip virtio-net header (10 bytes)
            let eth_off = VIRTIO_NET_HDR_SIZE
            // Check ethertype at offset 12 (after 6+6 MAC addresses)
            let et_hi = volatile_read_u8(NET_RX_BUF + eth_off + 12)
            let et_lo = volatile_read_u8(NET_RX_BUF + eth_off + 13)
            if et_hi == 0x08 && et_lo == 0x00 {
                // IPv4 — check protocol at IP offset 9
                let ip_off = eth_off + 14
                let proto = volatile_read_u8(NET_RX_BUF + ip_off + 9)
                if proto == 1 {
                    // ICMP — check type at ICMP offset 0
                    let icmp_off = ip_off + 20
                    let icmp_type = volatile_read_u8(NET_RX_BUF + icmp_off)
                    if icmp_type == 0 {
                        // Type 0 = Echo Reply!
                        return rdtsc() - t0
                    }
                }
            }
        }
        pause()
        attempts = attempts + 1
    }
    -1  // timeout
}

@kernel fn net_state_read(off: i64) -> i64 { volatile_read_u64(NET_STATE + off) }
@kernel fn net_state_write(off: i64, val: i64) { volatile_write_u64(NET_STATE + off, val) }

// ── Virtio-Net PCI Discovery ──

@kernel fn net_find_virtio() -> i64 {
    let mut dev: i64 = 0
    while dev < 32 {
        let id = pci_read32(0, dev, 0, 0)
        if id != 0xFFFFFFFF && id != 0 {
            let vendor = id & 0xFFFF
            let device_id = (id >> 16) & 0xFFFF
            // Virtio vendor: 0x1AF4, network device: 0x1000 (legacy) or 0x1041 (modern)
            if vendor == 0x1AF4 && (device_id == 0x1000 || device_id == 0x1041) {
                return dev
            }
        }
        dev = dev + 1
    }
    -1
}

@kernel fn net_init() -> i64 {
    let dev = net_find_virtio()
    if dev == -1 {
        // No virtio-net — set up with static config for simulation
        // Use fake MAC 52:54:00:12:34:56 (QEMU default)
        volatile_write_u8(NET_STATE + 8, 0x52)
        volatile_write_u8(NET_STATE + 9, 0x54)
        volatile_write_u8(NET_STATE + 10, 0x00)
        volatile_write_u8(NET_STATE + 11, 0x12)
        volatile_write_u8(NET_STATE + 12, 0x34)
        volatile_write_u8(NET_STATE + 13, 0x56)
        // Default QEMU user-mode IP
        net_state_write(16, 0x0A00020F) // 10.0.2.15
        net_state_write(24, 0x0A000202) // 10.0.2.2
        net_state_write(32, 0xFFFFFF00) // 255.255.255.0
        net_state_write(0, 1) // initialized
        return 0
    }

    // Enable PCI bus master + I/O space
    let cmd = pci_read32(0, dev, 0, 0x04)
    pci_write32(0, dev, 0, 0x04, cmd | 0x07)

    // Get BAR0 (I/O port base for legacy virtio)
    let bar0 = pci_read32(0, dev, 0, 0x10)
    let io_base = bar0 & 0xFFFFFFFC
    net_state_write(56, io_base)

    // Virtio legacy device initialization sequence
    // 1. Reset device: write 0 to status register (offset 0x12)
    port_outb(io_base + 0x12, 0)
    // 2. Set ACKNOWLEDGE status bit (1)
    port_outb(io_base + 0x12, 1)
    // 3. Set DRIVER status bit (2)
    port_outb(io_base + 0x12, 3)

    // 4. Read device features (offset 0x00, 32-bit)
    let features = port_ind(io_base)
    // 5. Write accepted features (offset 0x04) — accept MAC feature
    port_outd(io_base + 4, features & 0x20) // VIRTIO_NET_F_MAC (bit 5)

    // 6. Set FEATURES_OK (8)
    port_outb(io_base + 0x12, 11) // ACKNOWLEDGE | DRIVER | FEATURES_OK

    // 7. Read MAC address from device config (offset 0x14-0x19)
    let mut i: i64 = 0
    while i < 6 {
        let mac_byte = port_inb(io_base + 0x14 + i) & 0xFF
        volatile_write_u8(NET_STATE + 8 + i, mac_byte)
        i = i + 1
    }

    // 7.5. Set up virtqueues BEFORE DRIVER_OK
    // Initialize queue memory
    vq_init_mem(VQ_RX_BASE)
    vq_init_mem(VQ_TX_BASE)
    // Zero RX buffers
    i = 0
    while i < 16 * 2048 { volatile_write_u8(VQ_RX_BUFS + i, 0); i = i + 1 }
    // Mark queue memory as used in frame allocator
    let mut f: i64 = VQ_RX_BASE / FRAME_SIZE
    while f < (VQ_RX_BUFS + 16 * 2048) / FRAME_SIZE { frame_mark_used(f); f = f + 1 }
    // Map queue pages
    let mut pg: i64 = VQ_RX_BASE
    while pg < VQ_RX_BUFS + 16 * 2048 {
        map_page(pg, pg, PAGE_PRESENT | PAGE_WRITABLE)
        pg = pg + FRAME_SIZE
    }
    // Set up RX queue (index 0)
    vq_setup_queue(io_base, 0, VQ_RX_BASE)
    // Set up TX queue (index 1)
    vq_setup_queue(io_base, 1, VQ_TX_BASE)
    // Pre-fill RX queue with empty buffers
    net_setup_rx_queue()
    println("[NET] Virtqueues configured (RX=0, TX=1)")

    // 8. Set DRIVER_OK (4) — device is live
    port_outb(io_base + 0x12, 15) // ACKNOWLEDGE | DRIVER | FEATURES_OK | DRIVER_OK

    // Default IP config (QEMU user-mode networking)
    net_state_write(16, 0x0A00020F) // 10.0.2.15
    net_state_write(24, 0x0A000202) // 10.0.2.2
    net_state_write(32, 0xFFFFFF00) // 255.255.255.0

    // Mark memory used
    let mut f: i64 = NET_STATE / FRAME_SIZE
    while f < 0x880000 / FRAME_SIZE { frame_mark_used(f); f = f + 1 }

    net_state_write(40, 0) // rx_count
    net_state_write(48, 0) // tx_count
    net_state_write(0, 1)  // initialized

    0
}

// ── Ethernet Frame Build/Parse ──

@kernel fn eth_build_frame(dst_mac: i64, ethertype: i64, payload: i64, payload_len: i64) -> i64 {
    let buf = NET_TX_BUF
    // Destination MAC (6 bytes from dst_mac address)
    let mut i: i64 = 0
    while i < 6 { volatile_write_u8(buf + i, volatile_read_u8(dst_mac + i)); i = i + 1 }
    // Source MAC (our MAC)
    i = 0
    while i < 6 { volatile_write_u8(buf + 6 + i, volatile_read_u8(NET_STATE + 8 + i)); i = i + 1 }
    // EtherType (big-endian u16)
    volatile_write_u8(buf + 12, (ethertype >> 8) & 0xFF)
    volatile_write_u8(buf + 13, ethertype & 0xFF)
    // Payload
    i = 0
    while i < payload_len { volatile_write_u8(buf + 14 + i, volatile_read_u8(payload + i)); i = i + 1 }
    14 + payload_len // total frame length
}

// ── ARP ──

@kernel fn arp_build_request(target_ip: i64) -> i64 {
    let buf = NET_PKT_BUF
    // Hardware type: Ethernet (1)
    buffer_write_u16_be(buf, 1)
    // Protocol type: IPv4 (0x0800)
    buffer_write_u16_be(buf + 2, 0x0800)
    // Hardware addr len: 6, Protocol addr len: 4
    volatile_write_u8(buf + 4, 6)
    volatile_write_u8(buf + 5, 4)
    // Operation: request (1)
    buffer_write_u16_be(buf + 6, 1)
    // Sender MAC (our MAC)
    let mut i: i64 = 0
    while i < 6 { volatile_write_u8(buf + 8 + i, volatile_read_u8(NET_STATE + 8 + i)); i = i + 1 }
    // Sender IP
    let our_ip = net_state_read(16)
    buffer_write_u32_be(buf + 14, our_ip)
    // Target MAC (zeros for request)
    i = 0
    while i < 6 { volatile_write_u8(buf + 18 + i, 0); i = i + 1 }
    // Target IP
    buffer_write_u32_be(buf + 24, target_ip)
    28 // ARP packet size
}

@kernel fn arp_cache_lookup(ip: i64) -> i64 {
    // Returns address of MAC in cache, or -1 if not found
    let mut i: i64 = 0
    while i < 16 {
        let cached_ip = buffer_read_u32_be(NET_ARP_CACHE + i * 16)
        if cached_ip == ip { return NET_ARP_CACHE + i * 16 + 4 }
        i = i + 1
    }
    -1
}

@kernel fn arp_cache_add(ip: i64, mac_addr: i64) {
    // Find empty slot or overwrite oldest
    let mut slot: i64 = 0
    let mut i: i64 = 0
    while i < 16 {
        if buffer_read_u32_be(NET_ARP_CACHE + i * 16) == 0 { slot = i; i = 16 }
        else { i = i + 1 }
    }
    buffer_write_u32_be(NET_ARP_CACHE + slot * 16, ip)
    let mut j: i64 = 0
    while j < 6 {
        volatile_write_u8(NET_ARP_CACHE + slot * 16 + 4 + j, volatile_read_u8(mac_addr + j))
        j = j + 1
    }
}

// ── IPv4 ──

@kernel fn ip_build_header(dst_ip: i64, proto: i64, payload_len: i64) -> i64 {
    let buf = NET_PKT_BUF + 512 // Use offset 512 for IP header build
    let total_len = 20 + payload_len
    // Version(4) + IHL(5) = 0x45
    volatile_write_u8(buf, 0x45)
    // DSCP/ECN
    volatile_write_u8(buf + 1, 0)
    // Total length
    buffer_write_u16_be(buf + 2, total_len)
    // Identification
    buffer_write_u16_be(buf + 4, 0x1234)
    // Flags + Fragment offset
    buffer_write_u16_be(buf + 6, 0x4000) // Don't Fragment
    // TTL
    volatile_write_u8(buf + 8, 64)
    // Protocol (1=ICMP, 6=TCP, 17=UDP)
    volatile_write_u8(buf + 9, proto)
    // Checksum (set to 0, compute later)
    buffer_write_u16_be(buf + 10, 0)
    // Source IP
    buffer_write_u32_be(buf + 12, net_state_read(16))
    // Destination IP
    buffer_write_u32_be(buf + 16, dst_ip)

    // Compute checksum
    let mut sum: i64 = 0
    let mut k: i64 = 0
    while k < 20 {
        let word = buffer_read_u16_be(buf + k)
        sum = sum + word
        k = k + 2
    }
    // Fold carries
    while sum > 0xFFFF { sum = (sum & 0xFFFF) + (sum >> 16) }
    let checksum = (sum ^ 0xFFFF) & 0xFFFF
    buffer_write_u16_be(buf + 10, checksum)

    20 // header length
}

// ── ICMP (Ping) ──

@kernel fn icmp_build_echo_request(seq: i64) -> i64 {
    let buf = NET_PKT_BUF + 1024
    // Type: 8 (Echo Request)
    volatile_write_u8(buf, 8)
    // Code: 0
    volatile_write_u8(buf + 1, 0)
    // Checksum: 0 (compute after)
    buffer_write_u16_be(buf + 2, 0)
    // Identifier
    buffer_write_u16_be(buf + 4, 0xFAFA)
    // Sequence number
    buffer_write_u16_be(buf + 6, seq)
    // Payload: 8 bytes of pattern
    let mut i: i64 = 0
    while i < 8 { volatile_write_u8(buf + 8 + i, 0x41 + i); i = i + 1 }

    // Compute ICMP checksum
    let pkt_len: i64 = 16
    let mut sum: i64 = 0
    let mut k: i64 = 0
    while k < pkt_len {
        sum = sum + buffer_read_u16_be(buf + k)
        k = k + 2
    }
    while sum > 0xFFFF { sum = (sum & 0xFFFF) + (sum >> 16) }
    buffer_write_u16_be(buf + 2, (sum ^ 0xFFFF) & 0xFFFF)

    pkt_len
}

// ── UDP ──

@kernel fn udp_build(src_port: i64, dst_port: i64, payload: i64, payload_len: i64) -> i64 {
    // Build UDP header at NET_PKT_BUF + 1536
    let buf = NET_PKT_BUF + 1536
    let udp_len = 8 + payload_len
    buffer_write_u16_be(buf, src_port)       // Source port
    buffer_write_u16_be(buf + 2, dst_port)   // Destination port
    buffer_write_u16_be(buf + 4, udp_len)    // Length (header + data)
    buffer_write_u16_be(buf + 6, 0)          // Checksum (0 = disabled)
    // Copy payload after header
    let mut i: i64 = 0
    while i < payload_len { volatile_write_u8(buf + 8 + i, volatile_read_u8(payload + i)); i = i + 1 }
    udp_len
}

// ── DHCP Client ──

const DHCP_BUF: i64 = 0x87E000  // 2KB DHCP packet buffer
const DHCP_XID: i64 = 0xFAFA1234  // Transaction ID

@kernel fn dhcp_build_discover() -> i64 {
    // Build DHCP Discover packet at DHCP_BUF (236 + options bytes)
    let buf = DHCP_BUF
    let mut i: i64 = 0
    while i < 576 { volatile_write_u8(buf + i, 0); i = i + 1 }

    volatile_write_u8(buf, 1)          // op: BOOTREQUEST
    volatile_write_u8(buf + 1, 1)      // htype: Ethernet
    volatile_write_u8(buf + 2, 6)      // hlen: 6 bytes MAC
    volatile_write_u8(buf + 3, 0)      // hops: 0
    buffer_write_u32_be(buf + 4, DHCP_XID)  // xid: transaction ID

    // chaddr: our MAC address (at NET_STATE + 8)
    i = 0
    while i < 6 { volatile_write_u8(buf + 28 + i, volatile_read_u8(NET_STATE + 8 + i)); i = i + 1 }

    // Magic cookie: 0x63825363
    volatile_write_u8(buf + 236, 0x63)
    volatile_write_u8(buf + 237, 0x82)
    volatile_write_u8(buf + 238, 0x53)
    volatile_write_u8(buf + 239, 0x63)

    // DHCP options
    let mut opt: i64 = 240
    // Option 53: DHCP Message Type = 1 (Discover)
    volatile_write_u8(buf + opt, 53); opt = opt + 1
    volatile_write_u8(buf + opt, 1); opt = opt + 1
    volatile_write_u8(buf + opt, 1); opt = opt + 1   // Discover

    // Option 55: Parameter Request List
    volatile_write_u8(buf + opt, 55); opt = opt + 1
    volatile_write_u8(buf + opt, 3); opt = opt + 1   // 3 params
    volatile_write_u8(buf + opt, 1); opt = opt + 1   // Subnet Mask
    volatile_write_u8(buf + opt, 3); opt = opt + 1   // Router
    volatile_write_u8(buf + opt, 6); opt = opt + 1   // DNS

    // End option
    volatile_write_u8(buf + opt, 255); opt = opt + 1

    opt // total DHCP packet length
}

@kernel fn dhcp_build_request(server_ip: i64, offered_ip: i64) -> i64 {
    let buf = DHCP_BUF
    let mut i: i64 = 0
    while i < 576 { volatile_write_u8(buf + i, 0); i = i + 1 }

    volatile_write_u8(buf, 1)          // op: BOOTREQUEST
    volatile_write_u8(buf + 1, 1)      // htype: Ethernet
    volatile_write_u8(buf + 2, 6)      // hlen: 6
    buffer_write_u32_be(buf + 4, DHCP_XID)

    // chaddr: our MAC
    i = 0
    while i < 6 { volatile_write_u8(buf + 28 + i, volatile_read_u8(NET_STATE + 8 + i)); i = i + 1 }

    // Magic cookie
    volatile_write_u8(buf + 236, 0x63)
    volatile_write_u8(buf + 237, 0x82)
    volatile_write_u8(buf + 238, 0x53)
    volatile_write_u8(buf + 239, 0x63)

    let mut opt: i64 = 240
    // Option 53: DHCP Message Type = 3 (Request)
    volatile_write_u8(buf + opt, 53); opt = opt + 1
    volatile_write_u8(buf + opt, 1); opt = opt + 1
    volatile_write_u8(buf + opt, 3); opt = opt + 1

    // Option 50: Requested IP
    volatile_write_u8(buf + opt, 50); opt = opt + 1
    volatile_write_u8(buf + opt, 4); opt = opt + 1
    buffer_write_u32_be(buf + opt, offered_ip); opt = opt + 4

    // Option 54: Server Identifier
    volatile_write_u8(buf + opt, 54); opt = opt + 1
    volatile_write_u8(buf + opt, 4); opt = opt + 1
    buffer_write_u32_be(buf + opt, server_ip); opt = opt + 4

    // End
    volatile_write_u8(buf + opt, 255); opt = opt + 1
    opt
}

@kernel fn dhcp_parse_offer(buf: i64, len: i64) -> i64 {
    // Parse DHCP Offer/Ack. Returns offered IP or -1.
    // DHCP response: op=2 (BOOTREPLY), yiaddr at offset 16
    if volatile_read_u8(buf) != 2 { return -1 }  // not a reply
    let xid = buffer_read_u32_be(buf + 4)
    if xid != DHCP_XID { return -2 }  // wrong transaction

    let offered_ip = buffer_read_u32_be(buf + 16) // yiaddr
    if offered_ip == 0 { return -3 }

    // Find DHCP message type in options (after magic cookie at 236+4=240)
    let mut opt: i64 = 240
    let mut msg_type: i64 = 0
    let mut server_ip: i64 = 0
    let mut subnet: i64 = 0
    let mut router: i64 = 0
    while opt < len && opt < 576 {
        let code = volatile_read_u8(buf + opt)
        if code == 255 { opt = len }  // end
        else if code == 0 { opt = opt + 1 }  // pad
        else {
            let olen = volatile_read_u8(buf + opt + 1)
            if code == 53 { msg_type = volatile_read_u8(buf + opt + 2) }
            if code == 54 { server_ip = buffer_read_u32_be(buf + opt + 2) }
            if code == 1 { subnet = buffer_read_u32_be(buf + opt + 2) }
            if code == 3 { router = buffer_read_u32_be(buf + opt + 2) }
            opt = opt + 2 + olen
        }
    }

    // Store parsed values
    net_state_write(104, server_ip) // DHCP server IP
    net_state_write(112, subnet)    // subnet mask
    if router != 0 { net_state_write(24, router) } // gateway

    // Return: msg_type in high byte, offered_ip
    // Pack as msg_type * 0x100000000 + offered_ip (64-bit)
    (msg_type << 32) | (offered_ip & 0xFFFFFFFF)
}

@kernel fn dhcp_do() -> i64 {
    // Full DHCP: Discover → Offer → Request → Ack
    println("[DHCP] Sending Discover...")

    // Build DHCP Discover
    let dhcp_len = dhcp_build_discover()
    // Wrap in UDP: src=68, dst=67
    let udp_len = udp_build(68, 67, DHCP_BUF, dhcp_len)
    // Wrap in IP: src=0.0.0.0, dst=255.255.255.255, proto=17 (UDP)
    // Special: for DHCP, src IP must be 0.0.0.0
    let old_ip = net_state_read(16)
    net_state_write(16, 0) // temporarily set src IP to 0.0.0.0
    let ip_len = ip_build_header(0xFFFFFFFF, 17, udp_len) // broadcast, UDP
    net_state_write(16, old_ip) // restore

    // Combine IP + UDP into packet
    let pkt: i64 = NET_PKT_BUF + 2048
    let mut ci: i64 = 0
    while ci < ip_len { volatile_write_u8(pkt + ci, volatile_read_u8(NET_PKT_BUF + 512 + ci)); ci = ci + 1 }
    ci = 0
    while ci < udp_len { volatile_write_u8(pkt + ip_len + ci, volatile_read_u8(NET_PKT_BUF + 1536 + ci)); ci = ci + 1 }

    // Send as broadcast ethernet frame
    let bcast: i64 = NET_PKT_BUF + 3072
    let mut bj: i64 = 0
    while bj < 6 { volatile_write_u8(bcast + bj, 0xFF); bj = bj + 1 }
    let frame_len = eth_build_frame(bcast, 0x0800, pkt, ip_len + udp_len)
    net_send_frame(NET_TX_BUF, frame_len)

    // Wait for Offer
    delay_us(500000) // 500ms
    let mut found_offer: i64 = 0
    let mut offered_ip: i64 = 0
    let mut buf_idx: i64 = 0
    while buf_idx < 16 && found_offer == 0 {
        let rb = VQ_RX_BUFS + buf_idx * 2048
        // Scan for DHCP magic cookie (0x63825363) starting after IP+UDP headers
        let mut off: i64 = 0
        while off < 300 && found_offer == 0 {
            if volatile_read_u8(rb + off) == 0x63 && volatile_read_u8(rb + off + 1) == 0x82 && volatile_read_u8(rb + off + 2) == 0x53 && volatile_read_u8(rb + off + 3) == 0x63 {
                // Found DHCP packet! Parse from start of DHCP header (off - 236)
                let dhcp_start = off - 236
                if dhcp_start >= 0 {
                    let result = dhcp_parse_offer(rb + dhcp_start, 576)
                    let msg = (result >> 32) & 0xFF
                    let ip = result & 0xFFFFFFFF
                    if msg == 2 && ip > 0 { // Offer
                        offered_ip = ip
                        found_offer = 1
                        println("[DHCP] Offer received!")
                    } else if msg == 5 && ip > 0 { // Ack (if server skips to Ack)
                        offered_ip = ip
                        found_offer = 2 // already acked
                        println("[DHCP] Ack received directly!")
                    }
                }
            }
            off = off + 1
        }
        buf_idx = buf_idx + 1
    }

    if found_offer == 0 {
        println("[DHCP] No offer received")
        return -1
    }

    // Configure IP from offer
    net_state_write(16, offered_ip)
    println("[DHCP] IP address assigned!")

    if found_offer == 1 {
        // Send DHCP Request
        println("[DHCP] Sending Request...")
        let server_ip = net_state_read(104)
        let req_len = dhcp_build_request(server_ip, offered_ip)
        let req_udp = udp_build(68, 67, DHCP_BUF, req_len)
        net_state_write(16, 0)
        let req_ip = ip_build_header(0xFFFFFFFF, 17, req_udp)
        net_state_write(16, offered_ip)
        let req_pkt: i64 = NET_PKT_BUF + 2048
        ci = 0
        while ci < req_ip { volatile_write_u8(req_pkt + ci, volatile_read_u8(NET_PKT_BUF + 512 + ci)); ci = ci + 1 }
        ci = 0
        while ci < req_udp { volatile_write_u8(req_pkt + req_ip + ci, volatile_read_u8(NET_PKT_BUF + 1536 + ci)); ci = ci + 1 }
        let req_frame = eth_build_frame(bcast, 0x0800, req_pkt, req_ip + req_udp)
        net_send_frame(NET_TX_BUF, req_frame)
        println("[DHCP] Request sent, waiting for Ack...")
        delay_us(500000)
    }

    println("[DHCP] Configuration complete")
    0
}

// ── TCP Client ──

// TCP state at 0x87F000 (256 bytes)
const TCP_STATE: i64 = 0x87F000
// +0: state (0=closed, 1=syn_sent, 2=established, 3=fin_wait)
// +8: local_port
// +16: remote_port
// +24: remote_ip
// +32: seq_num (our sequence number)
// +40: ack_num (their sequence number)
// +48: remote_seq (for tracking)

const TCP_DATA_BUF: i64 = 0x87F100 // 3KB for TCP send/recv data

@kernel fn tcp_state_write(off: i64, val: i64) { volatile_write_u64(TCP_STATE + off, val) }
@kernel fn tcp_state_read(off: i64) -> i64 { volatile_read_u64(TCP_STATE + off) }

@kernel fn tcp_build_header(src_port: i64, dst_port: i64, seq: i64, ack: i64, flags: i64, payload_len: i64) -> i64 {
    // Build TCP header at NET_PKT_BUF + 1792 (20 bytes, no options)
    let buf = NET_PKT_BUF + 1792
    buffer_write_u16_be(buf, src_port)        // Source port
    buffer_write_u16_be(buf + 2, dst_port)    // Destination port
    buffer_write_u32_be(buf + 4, seq)          // Sequence number
    buffer_write_u32_be(buf + 8, ack)          // Acknowledgment number
    // Data offset (5 = 20 bytes, in upper 4 bits of byte) + reserved
    volatile_write_u8(buf + 12, 0x50)          // 5 << 4 = 0x50 (20-byte header)
    volatile_write_u8(buf + 13, flags & 0xFF)  // Flags: FIN=1, SYN=2, RST=4, PSH=8, ACK=16
    buffer_write_u16_be(buf + 14, 8192)        // Window size
    buffer_write_u16_be(buf + 16, 0)           // Checksum (0 for now — QEMU accepts without)
    buffer_write_u16_be(buf + 18, 0)           // Urgent pointer
    20 // TCP header length
}

@kernel fn tcp_send_packet(flags: i64, payload: i64, payload_len: i64) -> i64 {
    let src_port = tcp_state_read(8)
    let dst_port = tcp_state_read(16)
    let remote_ip = tcp_state_read(24)
    let seq = tcp_state_read(32)
    let ack = tcp_state_read(40)

    // Build TCP header
    let tcp_len = tcp_build_header(src_port, dst_port, seq, ack, flags, payload_len)

    // Copy payload after TCP header
    let tcp_buf = NET_PKT_BUF + 1792
    let mut i: i64 = 0
    while i < payload_len { volatile_write_u8(tcp_buf + tcp_len + i, volatile_read_u8(payload + i)); i = i + 1 }

    // Build IP header (proto=6 for TCP)
    let ip_len = ip_build_header(remote_ip, 6, tcp_len + payload_len)

    // Combine IP + TCP into packet
    let pkt: i64 = NET_PKT_BUF + 2048
    let mut ci: i64 = 0
    while ci < ip_len { volatile_write_u8(pkt + ci, volatile_read_u8(NET_PKT_BUF + 512 + ci)); ci = ci + 1 }
    ci = 0
    while ci < tcp_len + payload_len { volatile_write_u8(pkt + ip_len + ci, volatile_read_u8(tcp_buf + ci)); ci = ci + 1 }

    // Get destination MAC from ARP cache
    let dst_mac = arp_cache_lookup(remote_ip)
    if dst_mac < 0 {
        // Use gateway MAC
        let gw = net_state_read(24)
        let gw_mac = arp_cache_lookup(gw)
        if gw_mac < 0 { return -1 }
        let frame_len = eth_build_frame(gw_mac, 0x0800, pkt, ip_len + tcp_len + payload_len)
        return net_send_frame(NET_TX_BUF, frame_len)
    }
    let frame_len = eth_build_frame(dst_mac, 0x0800, pkt, ip_len + tcp_len + payload_len)
    net_send_frame(NET_TX_BUF, frame_len)
}

@kernel fn tcp_find_response() -> i64 {
    // Scan RX buffers for TCP packet (IP proto=6)
    let mut buf_idx: i64 = 0
    while buf_idx < 16 {
        let rb = VQ_RX_BUFS + buf_idx * 2048
        let mut off: i64 = 0
        while off < 50 {
            // Look for IPv4 header (0x45) followed by proto=6 (TCP) at +9
            if volatile_read_u8(rb + off) == 0x45 && volatile_read_u8(rb + off + 9) == 6 {
                // Found TCP packet! Return buffer offset
                // Copy to TCP_DATA_BUF for parsing
                let mut c: i64 = 0
                while c < 1500 { volatile_write_u8(TCP_DATA_BUF + c, volatile_read_u8(rb + off + c)); c = c + 1 }
                return off
            }
            off = off + 1
        }
        buf_idx = buf_idx + 1
    }
    -1
}

@kernel fn tcp_connect(remote_ip: i64, remote_port: i64) -> i64 {
    // TCP 3-way handshake: SYN → SYN-ACK → ACK
    let local_port: i64 = 49152 + (rdtsc() % 16384) // ephemeral port

    tcp_state_write(0, 0)  // closed
    tcp_state_write(8, local_port)
    tcp_state_write(16, remote_port)
    tcp_state_write(24, remote_ip)
    tcp_state_write(32, rdtsc() & 0xFFFFFFFF) // initial seq number
    tcp_state_write(40, 0)  // ack = 0

    // Step 1: Send SYN (flags = 0x02)
    println("[TCP] Sending SYN...")
    tcp_state_write(0, 1)  // syn_sent
    let syn_result = tcp_send_packet(0x02, 0, 0) // SYN flag
    if syn_result < 0 { println("[TCP] SYN send failed"); return -1 }

    // Step 2: Wait for SYN-ACK
    delay_us(500000) // 500ms
    let resp = tcp_find_response()
    if resp < 0 { println("[TCP] No SYN-ACK received"); return -2 }

    // Parse SYN-ACK: TCP header at IP offset 20
    let tcp_off: i64 = 20 // after IP header
    let flags = volatile_read_u8(TCP_DATA_BUF + tcp_off + 13)
    if (flags & 0x12) != 0x12 { // SYN+ACK = 0x12
        println("[TCP] Not a SYN-ACK")
        return -3
    }
    println("[TCP] SYN-ACK received!")

    // Extract server's seq number and ack
    let server_seq = buffer_read_u32_be(TCP_DATA_BUF + tcp_off + 4)
    let server_ack = buffer_read_u32_be(TCP_DATA_BUF + tcp_off + 8)

    // Update state
    tcp_state_write(32, server_ack) // our next seq = their ack
    tcp_state_write(40, server_seq + 1) // our ack = their seq + 1
    tcp_state_write(48, server_seq)

    // Step 3: Send ACK (flags = 0x10)
    println("[TCP] Sending ACK...")
    tcp_send_packet(0x10, 0, 0) // ACK flag
    tcp_state_write(0, 2) // established
    println("[TCP] Connection ESTABLISHED!")
    0
}

@kernel fn tcp_send(data: i64, len: i64) -> i64 {
    // Send data on established connection (PSH+ACK = 0x18)
    if tcp_state_read(0) != 2 { return -1 } // not established
    let result = tcp_send_packet(0x18, data, len)
    // Advance seq number
    tcp_state_write(32, tcp_state_read(32) + len)
    result
}

@kernel fn tcp_recv() -> i64 {
    // Check for received TCP data, return length or -1
    delay_us(500000) // wait for response
    let resp = tcp_find_response()
    if resp < 0 { return -1 }

    let tcp_off: i64 = 20
    let flags = volatile_read_u8(TCP_DATA_BUF + tcp_off + 13)
    let data_off_byte = volatile_read_u8(TCP_DATA_BUF + tcp_off + 12)
    let tcp_hdr_len = ((data_off_byte >> 4) & 0xF) * 4
    let ip_total = buffer_read_u16_be(TCP_DATA_BUF + 2)
    let data_len = ip_total - 20 - tcp_hdr_len

    if data_len > 0 {
        // Copy data payload to TCP_DATA_BUF + 512
        let data_start = tcp_off + tcp_hdr_len
        let mut i: i64 = 0
        while i < data_len && i < 1024 {
            volatile_write_u8(TCP_DATA_BUF + 512 + i, volatile_read_u8(TCP_DATA_BUF + data_start + i))
            i = i + 1
        }

        // Send ACK for received data
        let server_seq = buffer_read_u32_be(TCP_DATA_BUF + tcp_off + 4)
        tcp_state_write(40, server_seq + data_len) // ack their data
        tcp_send_packet(0x10, 0, 0) // ACK
    }

    data_len
}

@kernel fn cmd_wget() {
    // wget — simple HTTP GET via TCP
    // Connects to 10.0.2.2:80 (QEMU host)
    if net_state_read(0) != 1 { cprintln("Network not ready", RED_ON_BLACK); return }

    let host_ip = ip_pack(10, 0, 2, 2) // QEMU host gateway
    println("[HTTP] Connecting to 10.0.2.2:80...")
    let conn = tcp_connect(host_ip, 80)
    if conn < 0 {
        println("[HTTP] Connection failed")
        return
    }

    // Send HTTP GET request
    let req = TCP_DATA_BUF + 1024
    // "GET / HTTP/1.0\r\nHost: 10.0.2.2\r\n\r\n"
    let mut ri: i64 = 0
    let http_req_bytes: [i64; 38] = [71, 69, 84, 32, 47, 32, 72, 84, 84, 80, 47, 49, 46, 48, 13, 10, 72, 111, 115, 116, 58, 32, 49, 48, 46, 48, 46, 50, 46, 50, 13, 10, 13, 10, 0, 0, 0, 0]
    while ri < 34 { volatile_write_u8(req + ri, http_req_bytes[ri]); ri = ri + 1 }

    println("[HTTP] Sending GET /...")
    tcp_send(req, 34)

    // Receive response
    let recv_len = tcp_recv()
    if recv_len > 0 {
        println("[HTTP] Response received!")
        // Print first 200 bytes of response to serial
        let mut pi: i64 = 0
        while pi < recv_len && pi < 200 {
            let ch = volatile_read_u8(TCP_DATA_BUF + 512 + pi)
            if ch > 31 && ch < 127 {
                port_outb(0x3F8, ch) // print to serial
            } else if ch == 10 || ch == 13 {
                port_outb(0x3F8, ch)
            }
            pi = pi + 1
        }
        port_outb(0x3F8, 10) // newline
    } else {
        println("[HTTP] No response data")
    }
}

// ── IP address helpers ──

@kernel fn ip_pack(a: i64, b: i64, c: i64, d: i64) -> i64 {
    (a << 24) | (b << 16) | (c << 8) | d
}

@kernel fn ip_print(ip: i64) {
    cprint_decimal((ip >> 24) & 0xFF, CYAN_ON_BLACK)
    cprint(".", WHITE_ON_BLACK)
    cprint_decimal((ip >> 16) & 0xFF, CYAN_ON_BLACK)
    cprint(".", WHITE_ON_BLACK)
    cprint_decimal((ip >> 8) & 0xFF, CYAN_ON_BLACK)
    cprint(".", WHITE_ON_BLACK)
    cprint_decimal(ip & 0xFF, CYAN_ON_BLACK)
}

@kernel fn mac_print(addr: i64) {
    let mut i: i64 = 0
    while i < 6 {
        if i > 0 { cprint(":", WHITE_ON_BLACK) }
        cprint_hex(volatile_read_u8(addr + i), 2, CYAN_ON_BLACK)
        i = i + 1
    }
}

// ── Shell Commands ──

@kernel fn cmd_ifconfig() {
    if net_state_read(0) != 1 { cprintln("Network not initialized", RED_ON_BLACK); return }
    cprintln("Network Interface:", YELLOW_ON_BLACK)
    cprint("  MAC:     ", WHITE_ON_BLACK)
    mac_print(NET_STATE + 8)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  IPv4:    ", WHITE_ON_BLACK)
    ip_print(net_state_read(16))
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Gateway: ", WHITE_ON_BLACK)
    ip_print(net_state_read(24))
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Netmask: ", WHITE_ON_BLACK)
    ip_print(net_state_read(32))
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  RX pkts: ", WHITE_ON_BLACK)
    cprint_decimal(net_state_read(40), CYAN_ON_BLACK)
    cprint("  TX pkts: ", WHITE_ON_BLACK)
    cprint_decimal(net_state_read(48), CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    let vbar = net_state_read(56)
    if vbar != 0 {
        cprint("  Virtio:  BAR0=0x", WHITE_ON_BLACK)
        cprint_hex(vbar, 4, CYAN_ON_BLACK)
        cprintln(" (active)", GREEN_ON_BLACK)
    } else {
        cprintln("  Driver:  simulated (no virtio-net)", YELLOW_ON_BLACK)
    }
}

@kernel fn cmd_ping() {
    if net_state_read(0) != 1 { cprintln("Network not initialized", RED_ON_BLACK); return }
    let target = net_state_read(24) // ping gateway by default
    cprint("PING ", WHITE_ON_BLACK)
    ip_print(target)
    cprintln(":", WHITE_ON_BLACK)

    // Build ICMP echo request
    let icmp_len = icmp_build_echo_request(1)
    // Build IP header
    let ip_len = ip_build_header(target, 1, icmp_len)

    // Copy IP header + ICMP payload together
    let pkt_buf: i64 = NET_PKT_BUF + 2048
    let mut i: i64 = 0
    while i < ip_len { volatile_write_u8(pkt_buf + i, volatile_read_u8(NET_PKT_BUF + 512 + i)); i = i + 1 }
    i = 0
    while i < icmp_len { volatile_write_u8(pkt_buf + ip_len + i, volatile_read_u8(NET_PKT_BUF + 1024 + i)); i = i + 1 }

    // Build ethernet frame with broadcast MAC (for simplicity)
    let bcast_mac: i64 = NET_PKT_BUF + 3072
    let mut j: i64 = 0
    while j < 6 { volatile_write_u8(bcast_mac + j, 0xFF); j = j + 1 }
    let frame_len = eth_build_frame(bcast_mac, 0x0800, pkt_buf, ip_len + icmp_len)

    // Increment TX counter
    net_state_write(48, net_state_read(48) + 1)

    cprint("  Sent ", WHITE_ON_BLACK)
    cprint_decimal(frame_len, CYAN_ON_BLACK)
    cprint(" byte ICMP echo to ", WHITE_ON_BLACK)
    ip_print(target)
    console_putchar(10, WHITE_ON_BLACK)

    // Send packet via virtio-net or simulate
    if net_state_read(56) == 0 {
        cprintln("  (simulated — no virtio-net device found)", YELLOW_ON_BLACK)
        cprintln("  Reply: 64 bytes, ttl=64, time<1ms (simulated)", GREEN_ON_BLACK)
    } else {
        // Real TX via virtqueue
        let tx_result = net_send_frame(NET_TX_BUF, frame_len)
        if tx_result == 0 {
            cprintln("  Packet sent via virtio-net TX", GREEN_ON_BLACK)
            // Wait for ICMP echo reply
            let rtt = net_check_icmp_reply()
            if rtt >= 0 {
                cprint("  Reply from ", WHITE_ON_BLACK)
                ip_print(target)
                cprint(": time=", WHITE_ON_BLACK)
                // Convert TSC cycles to approximate microseconds
                // Assume ~2GHz TSC → rtt/2000 = microseconds
                cprint_decimal(rtt / 2000, CYAN_ON_BLACK)
                cprintln("us", WHITE_ON_BLACK)
            } else {
                cprintln("  Request timed out", RED_ON_BLACK)
            }
        } else {
            cprintln("  TX failed", RED_ON_BLACK)
        }
    }
}

@kernel fn cmd_arp() {
    cprintln("ARP Cache:", YELLOW_ON_BLACK)
    let mut count: i64 = 0
    let mut i: i64 = 0
    while i < 16 {
        let ip = buffer_read_u32_be(NET_ARP_CACHE + i * 16)
        if ip != 0 {
            cprint("  ", WHITE_ON_BLACK)
            ip_print(ip)
            cprint(" -> ", WHITE_ON_BLACK)
            mac_print(NET_ARP_CACHE + i * 16 + 4)
            console_putchar(10, WHITE_ON_BLACK)
            count = count + 1
        }
        i = i + 1
    }
    if count == 0 { cprintln("  (empty)", WHITE_ON_BLACK) }
}

@kernel fn cmd_net_init() {
    let r = net_init()
    if r == 0 {
        cprintln("Network initialized", GREEN_ON_BLACK)
        cmd_ifconfig()
    } else {
        cprintln("Network init failed", RED_ON_BLACK)
    }
}

// ═══════════════════════════════════════════════
// Phase E3: DNS Resolver + nslookup
// Minimal DNS client: sends UDP query to 10.0.2.3 (QEMU DNS)
// Response parsed for A records (IPv4 addresses)
// ═══════════════════════════════════════════════

const DNS_SERVER: i64 = 0x0A000203  // 10.0.2.3 (QEMU user-mode DNS)
const DNS_PORT: i64 = 53
const DNS_BUF: i64 = 0x87A200  // DNS packet build buffer (512B)
const DNS_RESP: i64 = 0x87A400  // DNS response buffer (512B)

// ── E3.8: Build DNS query for hostname ──
@kernel fn dns_build_query(name_addr: i64, name_len: i64) -> i64 {
    let b = DNS_BUF
    // DNS header (12 bytes)
    // Transaction ID = 0xFAFA
    volatile_write_u8(b, 0xFA)
    volatile_write_u8(b + 1, 0xFA)
    // Flags: 0x0100 (standard query, recursion desired)
    volatile_write_u8(b + 2, 0x01)
    volatile_write_u8(b + 3, 0x00)
    // QDCOUNT = 1
    volatile_write_u8(b + 4, 0x00)
    volatile_write_u8(b + 5, 0x01)
    // ANCOUNT, NSCOUNT, ARCOUNT = 0
    let mut i: i64 = 6
    while i < 12 { volatile_write_u8(b + i, 0); i = i + 1 }

    // Question section: encode hostname as DNS labels
    // e.g., "example.com" → [7]example[3]com[0]
    let mut off: i64 = 12
    let mut label_start = off
    off = off + 1  // skip length byte (filled later)
    let mut label_len: i64 = 0
    i = 0
    while i < name_len {
        let ch = volatile_read_u8(name_addr + i)
        if ch == 46 {  // '.' — end of label
            volatile_write_u8(b + label_start, label_len)
            label_start = off
            off = off + 1
            label_len = 0
        } else {
            volatile_write_u8(b + off, ch)
            off = off + 1
            label_len = label_len + 1
        }
        i = i + 1
    }
    // Final label
    volatile_write_u8(b + label_start, label_len)
    // Null terminator
    volatile_write_u8(b + off, 0)
    off = off + 1

    // QTYPE = A (1) — 2 bytes big-endian
    volatile_write_u8(b + off, 0x00)
    volatile_write_u8(b + off + 1, 0x01)
    off = off + 2
    // QCLASS = IN (1) — 2 bytes big-endian
    volatile_write_u8(b + off, 0x00)
    volatile_write_u8(b + off + 1, 0x01)
    off = off + 2

    off  // total query length
}

// ── Parse DNS response for A record ──
@kernel fn dns_parse_response(buf: i64, len: i64) -> i64 {
    if len < 12 { return -1 }

    // Check transaction ID
    let tid = volatile_read_u8(buf) * 256 + volatile_read_u8(buf + 1)
    if tid != 0xFAFA { return -2 }

    // Check flags: QR bit must be set (response)
    let flags = volatile_read_u8(buf + 2)
    if flags & 0x80 == 0 { return -3 }

    // Answer count
    let ancount = volatile_read_u8(buf + 6) * 256 + volatile_read_u8(buf + 7)
    if ancount == 0 { return -4 }

    // Skip question section (variable length)
    let mut off: i64 = 12
    // Skip QNAME (labels until 0x00)
    while off < len && volatile_read_u8(buf + off) != 0 {
        let label_len = volatile_read_u8(buf + off)
        if label_len & 0xC0 == 0xC0 {
            off = off + 2  // compressed pointer
            off = off - 1  // will be incremented below
        }
        off = off + label_len + 1
    }
    off = off + 1  // skip null
    off = off + 4  // skip QTYPE + QCLASS

    // Parse first answer
    if off + 12 > len { return -5 }

    // Skip NAME (may be compressed pointer 0xC0xx)
    if volatile_read_u8(buf + off) & 0xC0 == 0xC0 {
        off = off + 2  // compressed pointer
    } else {
        while off < len && volatile_read_u8(buf + off) != 0 {
            off = off + volatile_read_u8(buf + off) + 1
        }
        off = off + 1
    }

    // TYPE (2B), CLASS (2B), TTL (4B), RDLENGTH (2B)
    let rtype = volatile_read_u8(buf + off) * 256 + volatile_read_u8(buf + off + 1)
    off = off + 2  // skip TYPE
    off = off + 2  // skip CLASS
    off = off + 4  // skip TTL
    let rdlen = volatile_read_u8(buf + off) * 256 + volatile_read_u8(buf + off + 1)
    off = off + 2

    if rtype != 1 || rdlen != 4 { return -6 }  // not A record or wrong length

    // Read 4-byte IPv4 address
    let a = volatile_read_u8(buf + off)
    let b = volatile_read_u8(buf + off + 1)
    let c = volatile_read_u8(buf + off + 2)
    let d = volatile_read_u8(buf + off + 3)

    ip_pack(a, b, c, d)
}

// ── E3.8: DNS query function ──
@kernel fn dns_resolve(name_addr: i64, name_len: i64) -> i64 {
    if net_state_read(0) == 0 { return -1 }  // network not initialized

    // Build DNS query
    let query_len = dns_build_query(name_addr, name_len)

    // Wrap in UDP (src=12345, dst=53)
    let udp_len = udp_build(12345, DNS_PORT, DNS_BUF, query_len)

    // Wrap in IP header (protocol=17=UDP, dst=DNS_SERVER)
    let ip_len = ip_build_header(DNS_SERVER, 17, udp_len)

    // Build packet: IP + UDP in contiguous buffer
    let pkt: i64 = NET_PKT_BUF + 2048
    let mut ci: i64 = 0
    while ci < ip_len {
        volatile_write_u8(pkt + ci, volatile_read_u8(NET_PKT_BUF + 512 + ci))
        ci = ci + 1
    }
    ci = 0
    while ci < udp_len {
        volatile_write_u8(pkt + ip_len + ci, volatile_read_u8(NET_PKT_BUF + 1536 + ci))
        ci = ci + 1
    }

    // Send via gateway
    let gw_mac = arp_cache_lookup(net_state_read(24))
    if gw_mac < 0 {
        // No gateway MAC — send broadcast
        let bcast: i64 = NET_PKT_BUF + 3072
        let mut bj: i64 = 0
        while bj < 6 { volatile_write_u8(bcast + bj, 0xFF); bj = bj + 1 }
        let flen = eth_build_frame(bcast, 0x0800, pkt, ip_len + udp_len)
        net_send_frame(NET_TX_BUF, flen)
    } else {
        let flen = eth_build_frame(gw_mac, 0x0800, pkt, ip_len + udp_len)
        net_send_frame(NET_TX_BUF, flen)
    }

    // Wait for response (poll RX buffers, 1 second timeout)
    delay_us(500000)

    // Scan RX buffers for DNS response (UDP port 53)
    let mut found: i64 = -1
    let mut buf_idx: i64 = 0
    while buf_idx < 16 && found == -1 {
        let rb = VQ_RX_BUFS + buf_idx * 2048
        // Look for IP protocol=17 (UDP) and DNS transaction ID 0xFAFA
        let mut off: i64 = 0
        while off < 100 && found == -1 {
            if volatile_read_u8(rb + off) == 0x45 {  // IP version+IHL
                if volatile_read_u8(rb + off + 9) == 17 {  // UDP
                    // UDP starts at IP + 20
                    let udp_off = off + 20
                    // DNS starts at UDP + 8
                    let dns_off = udp_off + 8
                    let tid = volatile_read_u8(rb + dns_off) * 256 + volatile_read_u8(rb + dns_off + 1)
                    if tid == 0xFAFA {
                        // Copy response
                        let resp_len = volatile_read_u8(rb + udp_off + 4) * 256 + volatile_read_u8(rb + udp_off + 5) - 8
                        let mut k: i64 = 0
                        while k < resp_len && k < 512 {
                            volatile_write_u8(DNS_RESP + k, volatile_read_u8(rb + dns_off + k))
                            k = k + 1
                        }
                        found = dns_parse_response(DNS_RESP, resp_len)
                    }
                }
            }
            off = off + 1
        }
        buf_idx = buf_idx + 1
    }

    found
}

// ── E3.9: nslookup command ──
@kernel fn cmd_nslookup() {
    let len = cmdbuf_len()
    if len <= 9 {
        cprintln("Usage: nslookup <hostname>", YELLOW_ON_BLACK)
        cprintln("  Example: nslookup example.com", WHITE_ON_BLACK)
        return
    }

    // Copy hostname from command buffer (skip "nslookup ")
    let name_start: i64 = 0x87A600
    let name_len = len - 9
    let mut i: i64 = 0
    while i < name_len && i < 128 {
        volatile_write_u8(name_start + i, volatile_read_u8(0x6F800 + 9 + i))
        i = i + 1
    }

    cprint("Server:  10.0.2.3 (QEMU DNS)\n", WHITE_ON_BLACK)
    cprint("Name:    ", WHITE_ON_BLACK)
    i = 0
    while i < name_len {
        console_putchar(volatile_read_u8(name_start + i), CYAN_ON_BLACK)
        i = i + 1
    }
    console_putchar(10, WHITE_ON_BLACK)

    let result = dns_resolve(name_start, name_len)
    if result > 0 {
        cprint("Address: ", WHITE_ON_BLACK)
        ip_print(result)
        console_putchar(10, WHITE_ON_BLACK)
    } else if result == -1 {
        cprintln("Error: network not initialized", RED_ON_BLACK)
    } else {
        cprint("Error: DNS query failed (code ", RED_ON_BLACK)
        cprint_decimal(result, RED_ON_BLACK)
        cprintln(")", RED_ON_BLACK)
        cprintln("  DNS responses may not be reaching us via virtio-net", YELLOW_ON_BLACK)
    }
}

// ── E3.10: Network demo command ──
@kernel fn cmd_netdemo() {
    cprintln("=== Network Stack Demo ===", YELLOW_ON_BLACK)

    // Step 1: Interface
    cprintln("[1/5] Network Interface:", WHITE_ON_BLACK)
    let mac0 = net_state_read(8)
    let our_ip = net_state_read(16)
    let gw_ip = net_state_read(24)
    cprint("  MAC: ", WHITE_ON_BLACK)
    let mut mi: i64 = 0
    while mi < 6 {
        cprint_hex(volatile_read_u8(mac0 + mi), 2, CYAN_ON_BLACK)
        if mi < 5 { cprint(":", WHITE_ON_BLACK) }
        mi = mi + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  IP:  ", WHITE_ON_BLACK)
    ip_print(our_ip)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  GW:  ", WHITE_ON_BLACK)
    ip_print(gw_ip)
    console_putchar(10, WHITE_ON_BLACK)

    // Step 2: ICMP Ping
    cprintln("[2/5] ICMP Ping:", WHITE_ON_BLACK)
    cprint("  Sending echo to gateway... ", WHITE_ON_BLACK)
    let icmp_len = icmp_build_echo_request(42)
    let ip_len = ip_build_header(gw_ip, 1, icmp_len)
    cprintln("sent", GREEN_ON_BLACK)

    // Step 3: ARP cache
    cprintln("[3/5] ARP Cache:", WHITE_ON_BLACK)
    let mut ai: i64 = 0
    let mut arp_count: i64 = 0
    while ai < 16 {
        let entry_ip = volatile_read_u64(NET_ARP_CACHE + ai * 16)
        if entry_ip != 0 {
            cprint("  ", WHITE_ON_BLACK)
            ip_print(entry_ip)
            cprintln(" → cached", CYAN_ON_BLACK)
            arp_count = arp_count + 1
        }
        ai = ai + 1
    }
    if arp_count == 0 { cprintln("  (empty)", WHITE_ON_BLACK) }

    // Step 4: TCP status
    cprintln("[4/5] TCP State:", WHITE_ON_BLACK)
    let tcp_state = volatile_read_u64(TCP_STATE)
    cprint("  State: ", WHITE_ON_BLACK)
    if tcp_state == 0 { cprintln("closed", WHITE_ON_BLACK) }
    else if tcp_state == 1 { cprintln("syn_sent", YELLOW_ON_BLACK) }
    else if tcp_state == 2 { cprintln("established", GREEN_ON_BLACK) }
    else if tcp_state == 3 { cprintln("fin_wait", YELLOW_ON_BLACK) }
    else { cprintln("unknown", RED_ON_BLACK) }

    // Step 5: DNS test
    cprintln("[5/5] DNS Resolver:", WHITE_ON_BLACK)
    cprint("  Server: 10.0.2.3 (port 53)\n", WHITE_ON_BLACK)
    cprintln("  Use 'nslookup <host>' to test", WHITE_ON_BLACK)

    cprintln("", WHITE_ON_BLACK)
    cprintln("Network stack: Ethernet + ARP + IPv4 + ICMP + UDP + TCP + DHCP + DNS", GREEN_ON_BLACK)
}

// ═══════════════════════════════════════════════
// ELF Loader + Syscall ABI (Phase 16)
// Loads and executes ELF64 binaries from FAT32
// Syscall dispatch table for user-space programs
// ═══════════════════════════════════════════════

const ELF_LOAD_BASE: i64 = 0x2000000  // 32MB — user ELF load address
const ELF_STACK_TOP: i64 = 0x3000000  // 48MB — user stack top
const ELF_BUF: i64 = 0x880000  // ELF read buffer (64KB)
const ELF_MAGIC: i64 = 0x464C457F // \x7FELF

// ELF64 header offsets
const ELF_OFF_MAGIC: i64 = 0
const ELF_OFF_CLASS: i64 = 4   // 1=32-bit, 2=64-bit
const ELF_OFF_DATA: i64 = 5    // 1=LE, 2=BE
const ELF_OFF_TYPE: i64 = 16   // 2=ET_EXEC, 3=ET_DYN
const ELF_OFF_MACHINE: i64 = 18 // 0x3E=x86_64
const ELF_OFF_ENTRY: i64 = 24  // Entry point (8 bytes)
const ELF_OFF_PHOFF: i64 = 32  // Program header offset (8 bytes)
const ELF_OFF_PHENTSIZE: i64 = 54 // Program header entry size (2 bytes)
const ELF_OFF_PHNUM: i64 = 56  // Number of program headers (2 bytes)

// Program header offsets (64-bit)
const PH_OFF_TYPE: i64 = 0     // 1=PT_LOAD
const PH_OFF_FLAGS: i64 = 4    // PF_X=1, PF_W=2, PF_R=4
const PH_OFF_OFFSET: i64 = 8   // File offset (8 bytes)
const PH_OFF_VADDR: i64 = 16   // Virtual address (8 bytes)
const PH_OFF_FILESZ: i64 = 32  // Size in file (8 bytes)
const PH_OFF_MEMSZ: i64 = 40   // Size in memory (8 bytes)

@kernel fn elf_validate(buf: i64) -> i64 {
    // Check ELF magic: 0x7F 'E' 'L' 'F'
    let m0 = volatile_read_u8(buf)
    let m1 = volatile_read_u8(buf + 1)
    let m2 = volatile_read_u8(buf + 2)
    let m3 = volatile_read_u8(buf + 3)
    if m0 != 0x7F || m1 != 0x45 || m2 != 0x4C || m3 != 0x46 { return -1 }
    // Check 64-bit
    if volatile_read_u8(buf + ELF_OFF_CLASS) != 2 { return -2 }
    // Check little-endian
    if volatile_read_u8(buf + ELF_OFF_DATA) != 1 { return -3 }
    // Check x86_64
    let machine = buffer_read_u16_le(buf + ELF_OFF_MACHINE)
    if machine != 0x3E { return -4 }
    0
}

@kernel fn elf_get_entry(buf: i64) -> i64 {
    buffer_read_u64_le(buf + ELF_OFF_ENTRY)
}

@kernel fn elf_get_phoff(buf: i64) -> i64 {
    buffer_read_u64_le(buf + ELF_OFF_PHOFF)
}

@kernel fn elf_get_phnum(buf: i64) -> i64 {
    buffer_read_u16_le(buf + ELF_OFF_PHNUM)
}

@kernel fn elf_get_phentsize(buf: i64) -> i64 {
    buffer_read_u16_le(buf + ELF_OFF_PHENTSIZE)
}

@kernel fn elf_load_segments(buf: i64, file_size: i64) -> i64 {
    let phoff = elf_get_phoff(buf)
    let phnum = elf_get_phnum(buf)
    let phentsize = elf_get_phentsize(buf)
    let mut loaded: i64 = 0

    let mut i: i64 = 0
    while i < phnum {
        let ph = buf + phoff + i * phentsize
        let ph_type = buffer_read_u32_le(ph + PH_OFF_TYPE)

        if ph_type == 1 { // PT_LOAD
            let offset = buffer_read_u64_le(ph + PH_OFF_OFFSET)
            let vaddr = buffer_read_u64_le(ph + PH_OFF_VADDR)
            let filesz = buffer_read_u64_le(ph + PH_OFF_FILESZ)
            let memsz = buffer_read_u64_le(ph + PH_OFF_MEMSZ)

            // Map pages for this segment
            let mut pg: i64 = vaddr & 0xFFFFF000
            let end_pg = (vaddr + memsz + 0xFFF) & 0xFFFFF000
            while pg < end_pg {
                // Allocate frame and map
                let frame = frame_alloc()
                if frame != -1 {
                    map_page(pg, frame * FRAME_SIZE, PAGE_PRESENT | PAGE_WRITABLE | PAGE_USER)
                }
                pg = pg + FRAME_SIZE
            }

            // Copy file data to memory
            let mut j: i64 = 0
            while j < filesz {
                if offset + j < file_size {
                    volatile_write_u8(vaddr + j, volatile_read_u8(buf + offset + j))
                }
                j = j + 1
            }

            // Zero BSS (memsz - filesz)
            while j < memsz {
                volatile_write_u8(vaddr + j, 0)
                j = j + 1
            }

            loaded = loaded + 1
        }
        i = i + 1
    }
    loaded
}

// ── Syscall Dispatch Table (v0.7 "Nexus") ──

const SYSCALL_TABLE: i64 = 0x884000      // 32 entries × 8 bytes (fn pointers)
const SYSCALL_DISPATCH_FN: i64 = 0x884008 // fn pointer for linker indirect call

// Syscall numbers (v0.7 — 26 syscalls)
const SYS_EXIT: i64 = 0       // EXIT handled in linker asm (never returns)
const SYS_WRITE: i64 = 1      // write(fd, buf, len) -> bytes_written
const SYS_READ: i64 = 2       // read(fd, buf, len) -> bytes_read
const SYS_GETPID: i64 = 3     // getpid() -> pid
const SYS_YIELD: i64 = 4      // yield() -> 0
const SYS_BRK: i64 = 5        // brk(increment) -> new_brk
const SYS_MMAP: i64 = 6       // mmap(addr, len, prot) -> va
const SYS_CLOCK: i64 = 7      // clock() -> ticks
const SYS_SLEEP: i64 = 8      // sleep(ms) -> 0
const SYS_SBRK: i64 = 9       // sbrk(increment) -> old_brk

// File I/O syscalls (F2)
const SYS_OPEN: i64 = 10      // open(path, flags) -> fd
const SYS_CLOSE: i64 = 11     // close(fd) -> 0
const SYS_STAT: i64 = 12      // stat(path, buf) -> 0
const SYS_FSTAT: i64 = 13     // fstat(fd, buf) -> 0
const SYS_LSEEK: i64 = 14     // lseek(fd, offset, whence) -> new_offset
const SYS_DUP: i64 = 15       // dup(old_fd) -> new_fd
const SYS_DUP2: i64 = 16      // dup2(old_fd, new_fd) -> new_fd
const SYS_GETCWD: i64 = 17    // getcwd(buf, size) -> len
const SYS_CHDIR: i64 = 18     // chdir(path) -> 0
const SYS_UNLINK: i64 = 19    // unlink(path) -> 0

// FD_TABLE_V2 at 0x8D0000 (relocated from 0x894000 to fix virtio TX conflict)
const FD_TABLE_V2: i64 = 0x8D0000  // 16 procs × 16 FDs × 16 bytes = 4096 bytes
const FD_MAX: i64 = 16
const FD_ENTRY_SIZE: i64 = 16
// FD types
const FD_CLOSED: i64 = 0
const FD_CONSOLE: i64 = 1
const FD_RAMFS: i64 = 2
const FD_PIPE_READ: i64 = 3
const FD_PIPE_WRITE: i64 = 4
const FD_FAT32: i64 = 5

// LSEEK whence values
const SEEK_SET: i64 = 0
const SEEK_CUR: i64 = 1
const SEEK_END: i64 = 2

// Per-process heap tracking base: PROC_TABLE + pid*256 + 96
const PROC_OFF_BRK: i64 = 96
// Per-process CWD: PROC_TABLE + pid*256 + 128 (32 bytes)
const PROC_OFF_CWD: i64 = 128
// User heap region: 0x2800000 (40MB)
const USER_HEAP_BASE: i64 = 0x2800000

@kernel fn syscall_init() {
    // Clear syscall table
    let mut i: i64 = 0
    while i < 32 * 8 { volatile_write_u8(SYSCALL_TABLE + i, 0); i = i + 1 }
    frame_mark_used(SYSCALL_TABLE / FRAME_SIZE)
}

// Store syscall_dispatch fn pointer for linker indirect call (F1.1)
@kernel fn syscall_register_dispatch() {
    volatile_write_u64(SYSCALL_DISPATCH_FN, fn_addr("syscall_dispatch"))
}

// Main syscall dispatcher — called from linker __syscall_entry via indirect call
// System V ABI: RDI=num, RSI=arg0, RDX=arg1, RCX=arg2
// Returns result in RAX
@kernel fn syscall_dispatch(num: i64, arg0: i64, arg1: i64, arg2: i64) -> i64 {
    if num == SYS_WRITE { return sys_write(arg0, arg1, arg2) }
    if num == SYS_READ { return sys_read(arg0, arg1, arg2) }
    if num == SYS_GETPID { return sys_getpid() }
    if num == SYS_YIELD { return sys_yield() }
    if num == SYS_BRK { return sys_brk(arg0) }
    if num == SYS_MMAP { return sys_mmap(arg0, arg1, arg2) }
    if num == SYS_CLOCK { return sys_clock() }
    if num == SYS_SLEEP { return sys_sleep(arg0) }
    if num == SYS_SBRK { return sys_sbrk(arg0) }
    // File I/O syscalls (Sprint F2)
    if num == SYS_OPEN { return sys_open(arg0, arg1) }
    if num == SYS_CLOSE { return sys_close(arg0) }
    if num == SYS_STAT { return sys_stat(arg0, arg1) }
    if num == SYS_FSTAT { return sys_fstat(arg0, arg1) }
    if num == SYS_LSEEK { return sys_lseek(arg0, arg1, arg2) }
    if num == SYS_DUP { return sys_dup(arg0) }
    if num == SYS_DUP2 { return sys_dup2(arg0, arg1) }
    if num == SYS_GETCWD { return sys_getcwd(arg0, arg1) }
    if num == SYS_CHDIR { return sys_chdir(arg0) }
    if num == SYS_UNLINK { return sys_unlink(arg0) }
    // Process syscalls (Sprint G1-G3)
    if num == SYS_FORK { return sys_fork() }
    if num == SYS_EXEC { return sys_exec(arg0, arg1) }
    if num == SYS_WAITPID { return sys_waitpid(arg0, arg1, arg2) }
    if num == SYS_SETPGID { return sys_setpgid(arg0, arg1) }
    if num == SYS_PIPE { return sys_pipe(arg0) }
    if num == SYS_KILL { return sys_kill(arg0, arg1) }
    if num == SYS_SIGNAL { return sys_signal(arg0, arg1) }
    // Socket syscalls (Phase O)
    if num == SYS_SOCKET { return sys_socket(arg0) }
    if num == SYS_BIND { return sys_bind(arg0, arg1) }
    if num == SYS_LISTEN { return sys_listen(arg0, arg1) }
    if num == SYS_ACCEPT { return sys_accept(arg0) }
    if num == SYS_CONNECT_SOCK { return sys_connect_sock(arg0, arg1, arg2) }
    -1 // Unknown syscall
}

// SYS_WRITE(1): write to fd via FD table v2
@kernel fn sys_write(fd: i64, buf_addr: i64, len: i64) -> i64 {
    if fd < 0 || fd >= FD_MAX { return -1 }
    let pid = volatile_read_u64(0x6FE00)
    let ftype = fd_v2_get_type(pid, fd)

    if ftype == FD_CONSOLE {
        let mut i: i64 = 0
        while i < len {
            let ch = volatile_read_u8(buf_addr + i)
            console_putchar(ch, WHITE_ON_BLACK)
            i = i + 1
        }
        return len
    }
    if ftype == FD_RAMFS {
        // Write to ramfs file (append at current offset)
        let data = fd_v2_get_data(pid, fd)
        let idx = data & 0xFFFFFFFF
        let offset = (data >> 32) & 0xFFFFFFFF
        let entry_addr = ramfs_entry_addr(idx)
        let data_ptr = volatile_read(entry_addr + 40)
        if data_ptr == 0 { return -1 }
        let mut i: i64 = 0
        while i < len {
            volatile_write_u8(data_ptr + offset + i, volatile_read_u8(buf_addr + i))
            i = i + 1
        }
        let new_offset = offset + len
        let new_data = (new_offset << 32) | idx
        fd_v2_set(pid, fd, ftype, new_data)
        let old_size = volatile_read(entry_addr + 32)
        if new_offset > old_size { volatile_write(entry_addr + 32, new_offset) }
        return len
    }
    if ftype == FD_PIPE_WRITE {
        let slot = fd_v2_get_data(pid, fd)
        return pipe_write_circular(slot, buf_addr, len)
    }
    if ftype == FD_SOCKET {
        return socket_write(fd_v2_get_data(pid, fd), buf_addr, len)
    }
    -1
}

// SYS_READ(2): read from fd via FD table v2
@kernel fn sys_read(fd: i64, buf_addr: i64, len: i64) -> i64 {
    if fd < 0 || fd >= FD_MAX { return -1 }
    let pid = volatile_read_u64(0x6FE00)
    let ftype = fd_v2_get_type(pid, fd)

    if ftype == FD_CONSOLE {
        // Read from keyboard ring buffer
        let read_idx = volatile_read_u8(0x6FBF8)
        let write_idx = volatile_read_u8(0x6FBF0)
        if read_idx == write_idx { return 0 }
        let ch = volatile_read_u8(0x6FB00 + read_idx)
        volatile_write_u8(buf_addr, ch)
        volatile_write_u8(0x6FBF8, (read_idx + 1) % 256)
        return 1
    }
    if ftype == FD_RAMFS {
        // Read from ramfs file at current offset
        let data = fd_v2_get_data(pid, fd)
        let idx = data & 0xFFFFFFFF
        let offset = (data >> 32) & 0xFFFFFFFF
        let entry_addr = ramfs_entry_addr(idx)
        let size = volatile_read(entry_addr + 32)
        let data_ptr = volatile_read(entry_addr + 40)
        if data_ptr == 0 { return 0 }
        let available = size - offset
        if available <= 0 { return 0 } // EOF
        let to_read = if len < available { len } else { available }
        let mut i: i64 = 0
        while i < to_read {
            volatile_write_u8(buf_addr + i, volatile_read_u8(data_ptr + offset + i))
            i = i + 1
        }
        let new_offset = offset + to_read
        let new_data = (new_offset << 32) | idx
        fd_v2_set(pid, fd, ftype, new_data)
        return to_read
    }
    if ftype == FD_PIPE_READ {
        let slot = fd_v2_get_data(pid, fd)
        return pipe_read_circular(slot, buf_addr, len)
    }
    if ftype == FD_SOCKET {
        return socket_read(fd_v2_get_data(pid, fd), buf_addr, len)
    }
    -1
}

// SYS_GETPID(3): return current process ID
@kernel fn sys_getpid() -> i64 {
    volatile_read_u64(0x6FE00)
}

// SYS_YIELD(4): voluntarily yield CPU
@kernel fn sys_yield() -> i64 {
    // Mark current process READY, let scheduler pick next on timer
    let pid = volatile_read_u64(0x6FE00)
    if pid > 0 {
        volatile_write_u64(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_STATE, PROC_STATE_READY)
    }
    0
}

// SYS_BRK(5): set program break (heap end)
@kernel fn sys_brk(new_brk: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    let brk_addr = PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_BRK
    let current_brk = volatile_read_u64(brk_addr)
    if new_brk == 0 {
        // Query current break
        if current_brk == 0 {
            // Initialize heap
            volatile_write_u64(brk_addr, USER_HEAP_BASE)
            return USER_HEAP_BASE
        }
        return current_brk
    }
    if new_brk >= USER_HEAP_BASE && new_brk < ELF_STACK_TOP - 0x10000 {
        // Allocate pages between current_brk and new_brk
        let old = if current_brk == 0 { USER_HEAP_BASE } else { current_brk }
        let mut page = (old + FRAME_SIZE - 1) / FRAME_SIZE * FRAME_SIZE
        while page < new_brk {
            let frame = frame_alloc()
            if frame != -1 {
                map_page(page, frame * FRAME_SIZE, PAGE_PRESENT | PAGE_WRITABLE | PAGE_USER)
            }
            page = page + FRAME_SIZE
        }
        volatile_write_u64(brk_addr, new_brk)
        return new_brk
    }
    -1
}

// SYS_MMAP(6): allocate pages in user space
@kernel fn sys_mmap(addr: i64, len: i64, prot: i64) -> i64 {
    let pages = (len + FRAME_SIZE - 1) / FRAME_SIZE
    let base = if addr != 0 { addr } else { USER_HEAP_BASE + 0x100000 }
    let mut pg: i64 = 0
    while pg < pages {
        let frame = frame_alloc()
        if frame != -1 {
            map_page(base + pg * FRAME_SIZE, frame * FRAME_SIZE, PAGE_PRESENT | PAGE_WRITABLE | PAGE_USER)
        }
        pg = pg + 1
    }
    base
}

// SYS_CLOCK(7): return timer ticks since boot (100 Hz)
@kernel fn sys_clock() -> i64 {
    volatile_read_u64(0x6FE08)
}

// SYS_SLEEP(8): sleep for N milliseconds
@kernel fn sys_sleep(ms: i64) -> i64 {
    let target_ticks = volatile_read_u64(0x6FE08) + (ms + 9) / 10  // 10ms per tick
    let pid = volatile_read_u64(0x6FE00)
    if pid > 0 {
        // Store wake-up tick at proc entry +104 (PROC_OFF_WAKE)
        volatile_write_u64(PROC_TABLE + pid * PROC_ENTRY_SIZE + 104, target_ticks)
        volatile_write_u64(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_STATE, PROC_STATE_BLOCKED)
    }
    // Busy-wait fallback for PID 0 (shell)
    while volatile_read_u64(0x6FE08) < target_ticks { }
    0
}

// SYS_SBRK(9): increment program break, return OLD break
@kernel fn sys_sbrk(increment: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    let brk_addr = PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_BRK
    let current_brk = volatile_read_u64(brk_addr)
    let old = if current_brk == 0 { USER_HEAP_BASE } else { current_brk }
    if increment == 0 { return old }
    let new_brk = old + increment
    let result = sys_brk(new_brk)
    if result == -1 { return -1 }
    old
}

// ═══════════════════════════════════════════════
// File I/O Syscalls (Sprint F2)
// ═══════════════════════════════════════════════

// FD table v2 helpers (relocated to 0x8D0000)

@kernel fn fd_v2_addr(pid: i64, fd: i64) -> i64 {
    FD_TABLE_V2 + pid * FD_MAX * FD_ENTRY_SIZE + fd * FD_ENTRY_SIZE
}

@kernel fn fd_v2_get_type(pid: i64, fd: i64) -> i64 {
    volatile_read_u64(fd_v2_addr(pid, fd))
}

@kernel fn fd_v2_get_data(pid: i64, fd: i64) -> i64 {
    volatile_read_u64(fd_v2_addr(pid, fd) + 8)
}

@kernel fn fd_v2_set(pid: i64, fd: i64, ftype: i64, data: i64) {
    let addr = fd_v2_addr(pid, fd)
    volatile_write_u64(addr, ftype)
    volatile_write_u64(addr + 8, data)
}

@kernel fn fd_v2_init(pid: i64) {
    // FD 0=stdin, 1=stdout, 2=stderr (all console)
    fd_v2_set(pid, 0, FD_CONSOLE, 0)
    fd_v2_set(pid, 1, FD_CONSOLE, 0)
    fd_v2_set(pid, 2, FD_CONSOLE, 0)
    let mut fd: i64 = 3
    while fd < FD_MAX {
        fd_v2_set(pid, fd, FD_CLOSED, 0)
        fd = fd + 1
    }
}

@kernel fn fd_v2_alloc(pid: i64) -> i64 {
    // Find lowest free FD
    let mut fd: i64 = 0
    while fd < FD_MAX {
        if fd_v2_get_type(pid, fd) == FD_CLOSED { return fd }
        fd = fd + 1
    }
    -1
}

// Helper: find ramfs entry by buffer address (null-terminated string)
@kernel fn ramfs_find_by_addr(name_addr: i64) -> i64 {
    let count = volatile_read(FS_BASE)
    // Get name length
    let mut nlen: i64 = 0
    while nlen < 31 && volatile_read_u8(name_addr + nlen) != 0 { nlen = nlen + 1 }
    if nlen == 0 { return -1 }
    let mut i: i64 = 0
    while i < count {
        let addr = ramfs_entry_addr(i)
        let mut match_ok: i64 = 1
        let mut j: i64 = 0
        while j < nlen && match_ok == 1 {
            if volatile_read_u8(addr + j) != volatile_read_u8(name_addr + j) { match_ok = 0 }
            j = j + 1
        }
        if match_ok == 1 && volatile_read_u8(addr + nlen) == 0 { return i }
        i = i + 1
    }
    -1
}

// SYS_OPEN(10): open file, return FD
// data field packs: low 32 bits = ramfs_index, high 32 bits = offset
@kernel fn sys_open(path_addr: i64, flags: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    let fd = fd_v2_alloc(pid)
    if fd == -1 { return -1 } // no free FDs

    // Try ramfs first
    let idx = ramfs_find_by_addr(path_addr)
    if idx >= 0 {
        let entry_addr = ramfs_entry_addr(idx)
        let ftype = volatile_read(entry_addr + 48)
        if ftype != 1 { return -1 } // not a regular file
        // M2.5: Check read permission
        if fs_check_perm(entry_addr, 4) != 0 { return -1 } // no read access
        fd_v2_set(pid, fd, FD_RAMFS, idx)
        return fd
    }

    // TODO: try FAT32 (future sprint)
    -1 // file not found
}

// SYS_CLOSE(11): close FD
@kernel fn sys_close(fd: i64) -> i64 {
    if fd < 0 || fd >= FD_MAX { return -1 }
    let pid = volatile_read_u64(0x6FE00)
    let ftype = fd_v2_get_type(pid, fd)
    if ftype == FD_CLOSED { return -1 }
    // Pipe refcount handling (H1)
    if ftype == FD_PIPE_READ {
        let slot = fd_v2_get_data(pid, fd)
        let freed = pipe_decref(slot, 0) // is_writer=0
        if freed == 1 { pipe_free(slot) }
    }
    if ftype == FD_PIPE_WRITE {
        let slot = fd_v2_get_data(pid, fd)
        let freed = pipe_decref(slot, 1) // is_writer=1
        if freed == 1 { pipe_free(slot) }
    }
    fd_v2_set(pid, fd, FD_CLOSED, 0)
    0
}

// SYS_STAT(12): stat file by path, write size to user buffer
// buf layout: +0=size(i64), +8=type(i64: 1=file, 2=dir)
@kernel fn sys_stat(path_addr: i64, buf_addr: i64) -> i64 {
    let idx = ramfs_find_by_addr(path_addr)
    if idx >= 0 {
        let entry_addr = ramfs_entry_addr(idx)
        let size = volatile_read(entry_addr + 32)
        let ftype = volatile_read(entry_addr + 48)
        volatile_write_u64(buf_addr, size)
        volatile_write_u64(buf_addr + 8, ftype)
        return 0
    }
    -1 // not found
}

// SYS_FSTAT(13): stat by FD
@kernel fn sys_fstat(fd: i64, buf_addr: i64) -> i64 {
    if fd < 0 || fd >= FD_MAX { return -1 }
    let pid = volatile_read_u64(0x6FE00)
    let ftype = fd_v2_get_type(pid, fd)
    if ftype == FD_CONSOLE {
        volatile_write_u64(buf_addr, 0)     // size = 0 (stream)
        volatile_write_u64(buf_addr + 8, 0) // type = special
        return 0
    }
    if ftype == FD_RAMFS {
        let data = fd_v2_get_data(pid, fd)
        let idx = data & 0xFFFFFFFF
        let entry_addr = ramfs_entry_addr(idx)
        let size = volatile_read(entry_addr + 32)
        let ft = volatile_read(entry_addr + 48)
        volatile_write_u64(buf_addr, size)
        volatile_write_u64(buf_addr + 8, ft)
        return 0
    }
    -1
}

// SYS_LSEEK(14): set file offset
@kernel fn sys_lseek(fd: i64, offset: i64, whence: i64) -> i64 {
    if fd < 0 || fd >= FD_MAX { return -1 }
    let pid = volatile_read_u64(0x6FE00)
    let ftype = fd_v2_get_type(pid, fd)
    if ftype != FD_RAMFS && ftype != FD_FAT32 { return -1 } // not seekable

    let data = fd_v2_get_data(pid, fd)
    let idx = data & 0xFFFFFFFF
    let current_offset = (data >> 32) & 0xFFFFFFFF

    let new_offset = if whence == SEEK_SET {
        offset
    } else if whence == SEEK_CUR {
        current_offset + offset
    } else if whence == SEEK_END {
        let entry_addr = ramfs_entry_addr(idx)
        let size = volatile_read(entry_addr + 32)
        size + offset
    } else {
        -1
    }

    if new_offset < 0 { return -1 }
    // Pack new offset into data high 32 bits
    let new_data = (new_offset << 32) | idx
    fd_v2_set(pid, fd, ftype, new_data)
    new_offset
}

// SYS_DUP(15): duplicate FD to lowest free slot
@kernel fn sys_dup(old_fd: i64) -> i64 {
    if old_fd < 0 || old_fd >= FD_MAX { return -1 }
    let pid = volatile_read_u64(0x6FE00)
    let ftype = fd_v2_get_type(pid, old_fd)
    if ftype == FD_CLOSED { return -1 }
    let new_fd = fd_v2_alloc(pid)
    if new_fd == -1 { return -1 }
    let data = fd_v2_get_data(pid, old_fd)
    fd_v2_set(pid, new_fd, ftype, data)
    new_fd
}

// SYS_DUP2(16): duplicate FD to specific slot
@kernel fn sys_dup2(old_fd: i64, new_fd: i64) -> i64 {
    if old_fd < 0 || old_fd >= FD_MAX { return -1 }
    if new_fd < 0 || new_fd >= FD_MAX { return -1 }
    let pid = volatile_read_u64(0x6FE00)
    let ftype = fd_v2_get_type(pid, old_fd)
    if ftype == FD_CLOSED { return -1 }
    if old_fd == new_fd { return new_fd }
    // Close target if open
    let target_type = fd_v2_get_type(pid, new_fd)
    if target_type != FD_CLOSED { sys_close(new_fd) }
    // Copy
    let data = fd_v2_get_data(pid, old_fd)
    fd_v2_set(pid, new_fd, ftype, data)
    new_fd
}

// SYS_GETCWD(17): get current working directory
@kernel fn sys_getcwd(buf_addr: i64, size: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    let cwd_addr = PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_CWD
    // Read CWD string from process table
    let mut len: i64 = 0
    while len < 31 && len < size - 1 {
        let ch = volatile_read_u8(cwd_addr + len)
        if ch == 0 { len = size } // break
        else { volatile_write_u8(buf_addr + len, ch); len = len + 1 }
    }
    // If CWD is empty, default to "/"
    if len == 0 || len >= size {
        volatile_write_u8(buf_addr, 47) // '/'
        volatile_write_u8(buf_addr + 1, 0)
        return 1
    }
    volatile_write_u8(buf_addr + len, 0)
    len
}

// SYS_CHDIR(18): change working directory
@kernel fn sys_chdir(path_addr: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    let cwd_addr = PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_CWD
    // Verify path exists (check ramfs for directory)
    let idx = ramfs_find_by_addr(path_addr)
    if idx >= 0 {
        let entry_addr = ramfs_entry_addr(idx)
        let ftype = volatile_read(entry_addr + 48)
        if ftype != 2 { return -1 } // not a directory
    }
    // Copy path to process CWD (max 31 chars)
    let mut i: i64 = 0
    while i < 31 {
        let ch = volatile_read_u8(path_addr + i)
        volatile_write_u8(cwd_addr + i, ch)
        if ch == 0 { return 0 }
        i = i + 1
    }
    volatile_write_u8(cwd_addr + 31, 0)
    0
}

// SYS_UNLINK(19): remove file
@kernel fn sys_unlink(path_addr: i64) -> i64 {
    let idx = ramfs_find_by_addr(path_addr)
    if idx < 0 { return -1 }
    let entry_addr = ramfs_entry_addr(idx)
    let ftype = volatile_read(entry_addr + 48)
    if ftype == 2 { return -1 } // can't unlink directory
    // M2.7: Check write permission
    if fs_check_perm(entry_addr, 2) != 0 { return -1 }
    // Mark entry as unused
    volatile_write_u8(entry_addr, 0)
    volatile_write(entry_addr + 32, 0) // size = 0
    volatile_write(entry_addr + 48, 0) // type = unused
    0
}

// ═══════════════════════════════════════════════
// Copy-on-Write (Sprint L1 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// CoW page flag: PTE bit 9 (AVL) = 0x200
const PAGE_COW: i64 = 0x200

// Page refcount table at 0x950000: 32K entries × 2 bytes = 64KB
// Covers 32K frames × 4KB = 128MB physical memory
const PAGE_REFCOUNT: i64 = 0x950000
const PAGE_REFCOUNT_MAX: i64 = 32768

// L1.4: Initialize refcount table (all counts = 0)
@kernel fn cow_init() {
    let mut i: i64 = 0
    while i < PAGE_REFCOUNT_MAX * 2 {
        volatile_write_u8(PAGE_REFCOUNT + i, 0)
        i = i + 1
    }
}

// L1.5: Get/set refcount for a physical frame
@kernel fn cow_refcount_get(frame_idx: i64) -> i64 {
    if frame_idx < 0 || frame_idx >= PAGE_REFCOUNT_MAX { return 0 }
    let addr = PAGE_REFCOUNT + frame_idx * 2
    volatile_read_u8(addr) + volatile_read_u8(addr + 1) * 256
}

@kernel fn cow_refcount_set(frame_idx: i64, count: i64) {
    if frame_idx >= 0 && frame_idx < PAGE_REFCOUNT_MAX {
        let addr = PAGE_REFCOUNT + frame_idx * 2
        volatile_write_u8(addr, count & 0xFF)
        volatile_write_u8(addr + 1, (count >> 8) & 0xFF)
    }
}

@kernel fn cow_refcount_inc(frame_idx: i64) {
    let count = cow_refcount_get(frame_idx)
    cow_refcount_set(frame_idx, count + 1)
}

@kernel fn cow_refcount_dec(frame_idx: i64) -> i64 {
    let count = cow_refcount_get(frame_idx)
    let new_count = if count > 0 { count - 1 } else { 0 }
    cow_refcount_set(frame_idx, new_count)
    new_count
}

// L1.3: Mark a PTE as CoW (remove WRITABLE, set COW bit)
@kernel fn cow_mark_readonly(table: i64, idx: i64) {
    let entry = page_table_entry(table, idx)
    if entry != 0 && (entry & PAGE_PRESENT) != 0 && (entry & PAGE_WRITABLE) != 0 {
        // Clear WRITABLE, set COW flag
        let new_entry = (entry & (0xFFFFFFFFFFFF ^ PAGE_WRITABLE)) | PAGE_COW
        page_table_set(table, idx, new_entry)
    }
}

// L1.6: Handle CoW page fault — called from page fault handler
// Returns 0 on success (page copied), -1 if not a CoW fault
@kernel fn cow_handle_fault(fault_addr: i64) -> i64 {
    // Walk page tables to find the PTE for fault_addr
    let pml4_idx = (fault_addr >> 39) & 0x1FF
    let pdpt_idx = (fault_addr >> 30) & 0x1FF
    let pd_idx = (fault_addr >> 21) & 0x1FF
    let pt_idx = (fault_addr >> 12) & 0x1FF

    let pml4_entry = page_table_entry(PML4_BASE, pml4_idx)
    if (pml4_entry & PAGE_PRESENT) == 0 { return -1 }
    let pdpt_addr = pml4_entry & 0xFFFFFFFFF000

    let pdpt_entry = page_table_entry(pdpt_addr, pdpt_idx)
    if (pdpt_entry & PAGE_PRESENT) == 0 { return -1 }
    let pd_addr = pdpt_entry & 0xFFFFFFFFF000

    let pd_entry = page_table_entry(pd_addr, pd_idx)
    if (pd_entry & PAGE_PRESENT) == 0 { return -1 }
    let pt_addr = pd_entry & 0xFFFFFFFFF000

    let pt_entry = page_table_entry(pt_addr, pt_idx)
    if (pt_entry & PAGE_PRESENT) == 0 { return -1 }

    // Check if this is a CoW page
    if (pt_entry & PAGE_COW) == 0 { return -1 } // not CoW, real fault

    let old_phys = pt_entry & 0xFFFFFFFFF000
    let old_frame = old_phys / FRAME_SIZE
    let old_flags = pt_entry & 0xFFF

    // Check refcount
    let refcount = cow_refcount_get(old_frame)

    if refcount <= 1 {
        // Last reference — just make writable again (no copy needed)
        let new_flags = (old_flags | PAGE_WRITABLE) & (0xFFF ^ PAGE_COW)
        page_table_set(pt_addr, pt_idx, old_phys | new_flags)
    } else {
        // Multiple references — need to copy
        let new_phys = frame_alloc()
        if new_phys == -1 { return -1 } // OOM
        let new_frame = new_phys / FRAME_SIZE

        // Copy 4KB page content
        let mut i: i64 = 0
        while i < FRAME_SIZE {
            volatile_write_u8(new_phys + i, volatile_read_u8(old_phys + i))
            i = i + 1
        }

        // Remap to new page (writable, clear CoW)
        let new_flags = (old_flags | PAGE_WRITABLE) & (0xFFF ^ PAGE_COW)
        page_table_set(pt_addr, pt_idx, new_phys | new_flags)

        // Decrement old page refcount
        cow_refcount_dec(old_frame)

        // Set new page refcount to 1
        cow_refcount_set(new_frame, 1)
    }

    // L1.6: TLB flush + L2.7: increment fault counter
    cow_invlpg(fault_addr)
    let faults = volatile_read_u64(COW_FAULT_COUNT)
    volatile_write_u64(COW_FAULT_COUNT, faults + 1)
    0
}

// Invalidate TLB entry for a virtual address
@kernel fn cow_invlpg(addr: i64) {
    // invlpg instruction — flush single TLB entry
    // This would be asm!("invlpg [rdi]") in real code
    // For now, use write_cr3(read_cr3()) as full TLB flush fallback
    write_cr3(read_cr3())
}

// L1.3 (modified): Fork with CoW instead of deep-copy
// Replaces fork_copy_page_level at PT level
@kernel fn fork_cow_share_pt(parent_table: i64, child_table: i64) {
    let mut idx: i64 = 0
    while idx < 512 {
        let entry = page_table_entry(parent_table, idx)
        if entry != 0 && (entry & PAGE_PRESENT) != 0 && (entry & PAGE_USER) != 0 {
            let phys = entry & 0xFFFFFFFFF000
            let frame_idx = phys / FRAME_SIZE

            // Mark parent page as read-only + CoW
            cow_mark_readonly(parent_table, idx)

            // Child gets same physical page (read-only + CoW)
            let cow_flags = (entry & (0xFFF ^ PAGE_WRITABLE)) | PAGE_COW
            page_table_set(child_table, idx, phys | cow_flags)

            // Increment refcount
            let current_rc = cow_refcount_get(frame_idx)
            if current_rc == 0 {
                cow_refcount_set(frame_idx, 2) // was 1 (parent), now 2 (parent + child)
            } else {
                cow_refcount_inc(frame_idx)
            }
        }
        idx = idx + 1
    }
}

// L1.7: Decrement refcounts for all user pages of a process (on exit)
@kernel fn cow_release_pages(pml4: i64) {
    let mut pml4_idx: i64 = 0
    while pml4_idx < 512 {
        let pml4_entry = page_table_entry(pml4, pml4_idx)
        if pml4_entry != 0 && (pml4_entry & PAGE_USER) != 0 {
            cow_release_level(pml4_entry & 0xFFFFFFFFF000, 3)
        }
        pml4_idx = pml4_idx + 1
    }
}

@kernel fn cow_release_level(table: i64, level: i64) {
    let mut idx: i64 = 0
    while idx < 512 {
        let entry = page_table_entry(table, idx)
        if entry != 0 && (entry & PAGE_PRESENT) != 0 {
            if level == 1 {
                // PT level: decrement refcount, free if last
                let phys = entry & 0xFFFFFFFFF000
                let frame_idx = phys / FRAME_SIZE
                let remaining = cow_refcount_dec(frame_idx)
                if remaining == 0 { frame_mark_free(frame_idx) }
            } else {
                if (entry & PAGE_USER) != 0 {
                    cow_release_level(entry & 0xFFFFFFFFF000, level - 1)
                }
            }
        }
        idx = idx + 1
    }
}

// CoW fault counter at 0x950048
const COW_FAULT_COUNT: i64 = 0x950048

// L1.8: CoW statistics command
@kernel fn cmd_cowstat() {
    cprintln("CoW Statistics:", YELLOW_ON_BLACK)
    let mut shared: i64 = 0
    let mut total: i64 = 0
    let mut i: i64 = 0
    while i < PAGE_REFCOUNT_MAX {
        let rc = cow_refcount_get(i)
        if rc > 0 { total = total + 1 }
        if rc > 1 { shared = shared + 1 }
        i = i + 1
    }
    cprint("  Tracked pages: ", WHITE_ON_BLACK)
    cprint_decimal(total, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Shared (CoW): ", WHITE_ON_BLACK)
    cprint_decimal(shared, GREEN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Private: ", WHITE_ON_BLACK)
    cprint_decimal(total - shared, WHITE_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  CoW faults: ", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(COW_FAULT_COUNT), YELLOW_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Multi-User Account System (Sprint M1 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// User table at 0x960000: 16 users × 64 bytes
// Per user: +0=uid(i64), +8=username[16], +24=password_hash(i64), +32=gid(i64), +40=home[16], +56=active(i64)
const USER_TABLE: i64 = 0x960000
const USER_MAX: i64 = 16
const USER_ENTRY_SIZE: i64 = 64
const USER_OFF_UID: i64 = 0
const USER_OFF_NAME: i64 = 8
const USER_OFF_PASS: i64 = 24
const USER_OFF_GID: i64 = 32
const USER_OFF_HOME: i64 = 40
const USER_OFF_ACTIVE: i64 = 56

// Per-process UID/GID: PROC_TABLE + pid*256 + 168/176
const PROC_OFF_UID: i64 = 168
const PROC_OFF_GID: i64 = 176

// Current session UID at 0x652070
const CURRENT_UID_ADDR: i64 = 0x652070

// M1.1: Simple hash for passwords (FNV-1a variant)
@kernel fn simple_hash(addr: i64) -> i64 {
    let mut hash: i64 = 0x811C9DC5 // FNV offset basis (32-bit)
    let mut i: i64 = 0
    while i < 16 {
        let ch = volatile_read_u8(addr + i)
        if ch == 0 { i = 16 }
        else {
            hash = hash ^ ch
            hash = (hash * 16777619) & 0x7FFFFFFF // FNV prime, keep positive
            i = i + 1
        }
    }
    hash
}

// M1.2: Initialize user table with root
@kernel fn user_init() {
    // Clear table
    let mut i: i64 = 0
    while i < USER_MAX * USER_ENTRY_SIZE { volatile_write_u8(USER_TABLE + i, 0); i = i + 1 }
    // Create root user (uid=0)
    let root = USER_TABLE
    volatile_write_u64(root + USER_OFF_UID, 0)
    // username = "root"
    volatile_write_u8(root + USER_OFF_NAME, 114) // r
    volatile_write_u8(root + USER_OFF_NAME + 1, 111) // o
    volatile_write_u8(root + USER_OFF_NAME + 2, 111) // o
    volatile_write_u8(root + USER_OFF_NAME + 3, 116) // t
    volatile_write_u8(root + USER_OFF_NAME + 4, 0)
    // password hash for "root"
    let pass_buf: i64 = 0x843E80
    volatile_write_u8(pass_buf, 114)
    volatile_write_u8(pass_buf + 1, 111)
    volatile_write_u8(pass_buf + 2, 111)
    volatile_write_u8(pass_buf + 3, 116)
    volatile_write_u8(pass_buf + 4, 0)
    volatile_write_u64(root + USER_OFF_PASS, simple_hash(pass_buf))
    volatile_write_u64(root + USER_OFF_GID, 0)
    // home = "/"
    volatile_write_u8(root + USER_OFF_HOME, 47)
    volatile_write_u8(root + USER_OFF_HOME + 1, 0)
    volatile_write_u64(root + USER_OFF_ACTIVE, 1)

    // Set current session UID to root
    volatile_write_u64(CURRENT_UID_ADDR, 0)
}

// M1.3: Find user by name (returns slot index or -1)
@kernel fn user_find(name_addr: i64) -> i64 {
    let mut i: i64 = 0
    while i < USER_MAX {
        let entry = USER_TABLE + i * USER_ENTRY_SIZE
        if volatile_read_u64(entry + USER_OFF_ACTIVE) == 1 {
            let mut match_ok: i64 = 1
            let mut j: i64 = 0
            while j < 16 && match_ok == 1 {
                let a = volatile_read_u8(entry + USER_OFF_NAME + j)
                let b = volatile_read_u8(name_addr + j)
                if a != b { match_ok = 0 }
                if a == 0 && b == 0 { j = 16 }
                else { j = j + 1 }
            }
            if match_ok == 1 { return i }
        }
        i = i + 1
    }
    -1
}

// M1.3: `adduser` command — "adduser <name> <password>"
@kernel fn cmd_adduser() {
    let len = cmdbuf_len()
    if len <= 8 { cprintln("Usage: adduser <name> <pass>", YELLOW_ON_BLACK); return }
    // Only root can add users
    if volatile_read_u64(CURRENT_UID_ADDR) != 0 { cprintln("Permission denied (root only)", RED_ON_BLACK); return }
    // Parse name and password
    let name_buf: i64 = 0x843E00
    let pass_buf: i64 = 0x843E40
    let mut pos: i64 = 8
    let mut ni: i64 = 0
    while pos < len && volatile_read_u8(0x6F800 + pos) != 32 && ni < 15 {
        volatile_write_u8(name_buf + ni, volatile_read_u8(0x6F800 + pos))
        ni = ni + 1; pos = pos + 1
    }
    volatile_write_u8(name_buf + ni, 0)
    pos = pos + 1 // skip space
    let mut pi: i64 = 0
    while pos < len && pi < 15 {
        volatile_write_u8(pass_buf + pi, volatile_read_u8(0x6F800 + pos))
        pi = pi + 1; pos = pos + 1
    }
    volatile_write_u8(pass_buf + pi, 0)
    // Check if user exists
    if user_find(name_buf) >= 0 { cprintln("User already exists", RED_ON_BLACK); return }
    // Find free slot
    let mut slot: i64 = -1
    let mut si: i64 = 0
    while si < USER_MAX && slot == -1 {
        if volatile_read_u64(USER_TABLE + si * USER_ENTRY_SIZE + USER_OFF_ACTIVE) == 0 { slot = si }
        si = si + 1
    }
    if slot == -1 { cprintln("User table full", RED_ON_BLACK); return }
    // Create user
    let entry = USER_TABLE + slot * USER_ENTRY_SIZE
    volatile_write_u64(entry + USER_OFF_UID, slot)
    let mut ci: i64 = 0
    while ci <= ni { volatile_write_u8(entry + USER_OFF_NAME + ci, volatile_read_u8(name_buf + ci)); ci = ci + 1 }
    volatile_write_u64(entry + USER_OFF_PASS, simple_hash(pass_buf))
    volatile_write_u64(entry + USER_OFF_GID, slot)
    // home = /home/<name>
    volatile_write_u8(entry + USER_OFF_HOME, 47) // /
    ci = 0
    while ci < ni { volatile_write_u8(entry + USER_OFF_HOME + 1 + ci, volatile_read_u8(name_buf + ci)); ci = ci + 1 }
    volatile_write_u8(entry + USER_OFF_HOME + 1 + ni, 0)
    volatile_write_u64(entry + USER_OFF_ACTIVE, 1)
    cprint("User created: ", WHITE_ON_BLACK)
    ci = 0
    while ci < ni { console_putchar(volatile_read_u8(name_buf + ci), GREEN_ON_BLACK); ci = ci + 1 }
    cprint(" (uid=", WHITE_ON_BLACK)
    cprint_decimal(slot, CYAN_ON_BLACK)
    cprintln(")", WHITE_ON_BLACK)
}

// M1.4: `passwd` command — "passwd <newpassword>"
@kernel fn cmd_passwd() {
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: passwd <newpass>", YELLOW_ON_BLACK); return }
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    let entry = USER_TABLE + uid * USER_ENTRY_SIZE
    let pass_buf: i64 = 0x843E40
    let mut pi: i64 = 0
    let mut pos: i64 = 7
    while pos < len && pi < 15 {
        volatile_write_u8(pass_buf + pi, volatile_read_u8(0x6F800 + pos))
        pi = pi + 1; pos = pos + 1
    }
    volatile_write_u8(pass_buf + pi, 0)
    volatile_write_u64(entry + USER_OFF_PASS, simple_hash(pass_buf))
    cprintln("Password changed", GREEN_ON_BLACK)
}

// M1.5: `login` command — "login <name> <password>"
@kernel fn cmd_login() {
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: login <name> <pass>", YELLOW_ON_BLACK); return }
    let name_buf: i64 = 0x843E00
    let pass_buf: i64 = 0x843E40
    let mut pos: i64 = 6
    let mut ni: i64 = 0
    while pos < len && volatile_read_u8(0x6F800 + pos) != 32 && ni < 15 {
        volatile_write_u8(name_buf + ni, volatile_read_u8(0x6F800 + pos))
        ni = ni + 1; pos = pos + 1
    }
    volatile_write_u8(name_buf + ni, 0)
    pos = pos + 1
    let mut pi: i64 = 0
    while pos < len && pi < 15 {
        volatile_write_u8(pass_buf + pi, volatile_read_u8(0x6F800 + pos))
        pi = pi + 1; pos = pos + 1
    }
    volatile_write_u8(pass_buf + pi, 0)
    let slot = user_find(name_buf)
    if slot < 0 { cprintln("User not found", RED_ON_BLACK); return }
    let entry = USER_TABLE + slot * USER_ENTRY_SIZE
    let stored_hash = volatile_read_u64(entry + USER_OFF_PASS)
    let input_hash = simple_hash(pass_buf)
    if stored_hash != input_hash { cprintln("Wrong password", RED_ON_BLACK); return }
    // Login success
    volatile_write_u64(CURRENT_UID_ADDR, slot)
    // M1.9: Set UID/GID on PID 0
    let pid = volatile_read_u64(0x6FE00)
    volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_UID, slot)
    volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_GID, volatile_read_u64(entry + USER_OFF_GID))
    cprint("Logged in as ", WHITE_ON_BLACK)
    let mut ci: i64 = 0
    while ci < ni { console_putchar(volatile_read_u8(name_buf + ci), GREEN_ON_BLACK); ci = ci + 1 }
    console_putchar(10, WHITE_ON_BLACK)
}

// M1.6: `whoami` — show current user
@kernel fn cmd_whoami_user() {
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    let entry = USER_TABLE + uid * USER_ENTRY_SIZE
    let mut i: i64 = 0
    while i < 16 {
        let ch = volatile_read_u8(entry + USER_OFF_NAME + i)
        if ch == 0 { i = 16 } else { console_putchar(ch, WHITE_ON_BLACK); i = i + 1 }
    }
    console_putchar(10, WHITE_ON_BLACK)
}

// M1.7: `su` command — "su <name>"
@kernel fn cmd_su() {
    let len = cmdbuf_len()
    if len <= 3 { cprintln("Usage: su <name>", YELLOW_ON_BLACK); return }
    let name_buf: i64 = 0x843E00
    let mut ni: i64 = 0
    let mut pos: i64 = 3
    while pos < len && ni < 15 {
        volatile_write_u8(name_buf + ni, volatile_read_u8(0x6F800 + pos))
        ni = ni + 1; pos = pos + 1
    }
    volatile_write_u8(name_buf + ni, 0)
    let slot = user_find(name_buf)
    if slot < 0 { cprintln("User not found", RED_ON_BLACK); return }
    // Root can switch without password
    let current_uid = volatile_read_u64(CURRENT_UID_ADDR)
    if current_uid != 0 { cprintln("Permission denied (root only)", RED_ON_BLACK); return }
    volatile_write_u64(CURRENT_UID_ADDR, slot)
    let pid = volatile_read_u64(0x6FE00)
    volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_UID, slot)
    volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_GID, volatile_read_u64(USER_TABLE + slot * USER_ENTRY_SIZE + USER_OFF_GID))
    cprint("Switched to ", WHITE_ON_BLACK)
    let mut ci: i64 = 0
    while ci < ni { console_putchar(volatile_read_u8(name_buf + ci), GREEN_ON_BLACK); ci = ci + 1 }
    console_putchar(10, WHITE_ON_BLACK)
}

// M1.8: `id` command — show uid, gid, username
@kernel fn cmd_id() {
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    let entry = USER_TABLE + uid * USER_ENTRY_SIZE
    cprint("uid=", WHITE_ON_BLACK)
    cprint_decimal(uid, CYAN_ON_BLACK)
    cprint("(", WHITE_ON_BLACK)
    let mut i: i64 = 0
    while i < 16 {
        let ch = volatile_read_u8(entry + USER_OFF_NAME + i)
        if ch == 0 { i = 16 } else { console_putchar(ch, CYAN_ON_BLACK); i = i + 1 }
    }
    cprint(") gid=", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(entry + USER_OFF_GID), CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// M1.10: `users` command — list all users
@kernel fn cmd_users() {
    let mut i: i64 = 0
    let mut count: i64 = 0
    while i < USER_MAX {
        let entry = USER_TABLE + i * USER_ENTRY_SIZE
        if volatile_read_u64(entry + USER_OFF_ACTIVE) == 1 {
            cprint("  uid=", WHITE_ON_BLACK)
            cprint_decimal(volatile_read_u64(entry + USER_OFF_UID), CYAN_ON_BLACK)
            cprint(" ", WHITE_ON_BLACK)
            let mut j: i64 = 0
            while j < 16 {
                let ch = volatile_read_u8(entry + USER_OFF_NAME + j)
                if ch == 0 { j = 16 } else { console_putchar(ch, GREEN_ON_BLACK); j = j + 1 }
            }
            cprint(" home=", WHITE_ON_BLACK)
            j = 0
            while j < 16 {
                let ch = volatile_read_u8(entry + USER_OFF_HOME + j)
                if ch == 0 { j = 16 } else { console_putchar(ch, WHITE_ON_BLACK); j = j + 1 }
            }
            console_putchar(10, WHITE_ON_BLACK)
            count = count + 1
        }
        i = i + 1
    }
    if count == 0 { cprintln("No users configured", WHITE_ON_BLACK) }
}

// ═══════════════════════════════════════════════
// File Permissions (Sprint M2 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// Extended ramfs entry offsets (within 128-byte entry)
// +0-31: name, +32: size, +40: data_ptr, +48: type
// NEW: +56: owner_uid, +64: owner_gid, +72: mode (rwxrwxrwx as octal bits)
const FS_OFF_OWNER_UID: i64 = 56
const FS_OFF_OWNER_GID: i64 = 64
const FS_OFF_MODE: i64 = 72

// Default permissions
const PERM_FILE_DEFAULT: i64 = 0x1A4  // 0644 = rw-r--r--
const PERM_DIR_DEFAULT: i64 = 0x1ED   // 0755 = rwxr-xr-x

// Permission bit masks
const PERM_OWNER_R: i64 = 0x100  // owner read
const PERM_OWNER_W: i64 = 0x080  // owner write
const PERM_OWNER_X: i64 = 0x040  // owner execute
const PERM_GROUP_R: i64 = 0x020  // group read
const PERM_GROUP_W: i64 = 0x010  // group write
const PERM_GROUP_X: i64 = 0x008  // group execute
const PERM_OTHER_R: i64 = 0x004  // other read
const PERM_OTHER_W: i64 = 0x002  // other write
const PERM_OTHER_X: i64 = 0x001  // other execute

// M2.2: Set default permissions when creating files/dirs
@kernel fn fs_set_default_perms(entry_addr: i64, ftype: i64) {
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    volatile_write(entry_addr + FS_OFF_OWNER_UID, uid)
    volatile_write(entry_addr + FS_OFF_OWNER_GID, uid) // gid = uid for simplicity
    let mode = if ftype == 2 { PERM_DIR_DEFAULT } else { PERM_FILE_DEFAULT }
    volatile_write(entry_addr + FS_OFF_MODE, mode)
}

// M2.5: Check permission for access
// access: 4=read, 2=write, 1=execute
@kernel fn fs_check_perm(entry_addr: i64, access: i64) -> i64 {
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    // M2.9: Root bypasses all permission checks
    if uid == 0 { return 0 }

    let owner_uid = volatile_read(entry_addr + FS_OFF_OWNER_UID)
    let owner_gid = volatile_read(entry_addr + FS_OFF_OWNER_GID)
    let mode = volatile_read(entry_addr + FS_OFF_MODE)
    let proc_gid = volatile_read(PROC_TABLE + volatile_read_u64(0x6FE00) * PROC_ENTRY_SIZE + PROC_OFF_GID)

    // Check owner permissions
    if uid == owner_uid {
        let owner_bits = (mode >> 6) & 7
        if (owner_bits & access) == access { return 0 }
        return -1
    }

    // Check group permissions
    if proc_gid == owner_gid {
        let group_bits = (mode >> 3) & 7
        if (group_bits & access) == access { return 0 }
        return -1
    }

    // Check other permissions
    let other_bits = mode & 7
    if (other_bits & access) == access { return 0 }
    -1
}

// M2.3: `chmod` command — "chmod <mode> <file>"
@kernel fn cmd_chmod() {
    let len = cmdbuf_len()
    if len <= 10 { cprintln("Usage: chmod <mode> <file>", YELLOW_ON_BLACK); return }
    // Parse octal mode (3 digits)
    let d0 = volatile_read_u8(0x6F800 + 6) - 48
    let d1 = volatile_read_u8(0x6F800 + 7) - 48
    let d2 = volatile_read_u8(0x6F800 + 8) - 48
    let mode = d0 * 64 + d1 * 8 + d2
    // Parse filename
    let fname: i64 = 0x843D00
    let mut fi: i64 = 0
    let mut pos: i64 = 10
    while pos < len && fi < 31 {
        volatile_write_u8(fname + fi, volatile_read_u8(0x6F800 + pos))
        fi = fi + 1; pos = pos + 1
    }
    volatile_write_u8(fname + fi, 0)
    let idx = ramfs_find_by_addr(fname)
    if idx < 0 { cprintln("File not found", RED_ON_BLACK); return }
    let entry = ramfs_entry_addr(idx)
    // Only owner or root can chmod
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    let owner = volatile_read(entry + FS_OFF_OWNER_UID)
    if uid != 0 && uid != owner { cprintln("Permission denied", RED_ON_BLACK); return }
    volatile_write(entry + FS_OFF_MODE, mode)
    cprint("Mode set to ", WHITE_ON_BLACK)
    cprint_decimal(d0, CYAN_ON_BLACK)
    cprint_decimal(d1, CYAN_ON_BLACK)
    cprint_decimal(d2, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// M2.4: `chown` command — "chown <uid> <file>"
@kernel fn cmd_chown() {
    let len = cmdbuf_len()
    if len <= 8 { cprintln("Usage: chown <uid> <file>", YELLOW_ON_BLACK); return }
    // Only root can chown
    if volatile_read_u64(CURRENT_UID_ADDR) != 0 { cprintln("Permission denied (root only)", RED_ON_BLACK); return }
    let new_uid = volatile_read_u8(0x6F800 + 6) - 48
    let fname: i64 = 0x843D00
    let mut fi: i64 = 0
    let mut pos: i64 = 8
    while pos < len && fi < 31 {
        volatile_write_u8(fname + fi, volatile_read_u8(0x6F800 + pos))
        fi = fi + 1; pos = pos + 1
    }
    volatile_write_u8(fname + fi, 0)
    let idx = ramfs_find_by_addr(fname)
    if idx < 0 { cprintln("File not found", RED_ON_BLACK); return }
    volatile_write(ramfs_entry_addr(idx) + FS_OFF_OWNER_UID, new_uid)
    cprint("Owner set to uid=", WHITE_ON_BLACK)
    cprint_decimal(new_uid, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// M2.8: `ls -l` long listing with permissions
@kernel fn cmd_ls_long() {
    let count = volatile_read(FS_BASE)
    let mut i: i64 = 0
    while i < count {
        let addr = ramfs_entry_addr(i)
        let ftype = volatile_read(addr + 48)
        if ftype != 0 {
            // Type indicator
            if ftype == 2 { cprint("d", CYAN_ON_BLACK) } else { cprint("-", WHITE_ON_BLACK) }
            // Permission bits
            let mode = volatile_read(addr + FS_OFF_MODE)
            if mode == 0 {
                // Legacy file (no permissions set) — show default
                cprint("rw-r--r--", WHITE_ON_BLACK)
            } else {
                fs_print_mode(mode)
            }
            cprint(" ", WHITE_ON_BLACK)
            // Owner UID
            cprint_decimal(volatile_read(addr + FS_OFF_OWNER_UID), CYAN_ON_BLACK)
            cprint(" ", WHITE_ON_BLACK)
            // Size
            let size = volatile_read(addr + 32)
            cprint_decimal(size, WHITE_ON_BLACK)
            cprint(" ", WHITE_ON_BLACK)
            // Name
            let mut j: i64 = 0
            while j < 32 {
                let ch = volatile_read_u8(addr + j)
                if ch == 0 { j = 32 } else { console_putchar(ch, GREEN_ON_BLACK); j = j + 1 }
            }
            console_putchar(10, WHITE_ON_BLACK)
        }
        i = i + 1
    }
}

// Print rwxrwxrwx from mode bits
@kernel fn fs_print_mode(mode: i64) {
    let owner = (mode >> 6) & 7
    let group = (mode >> 3) & 7
    let other = mode & 7
    fs_print_rwx(owner)
    fs_print_rwx(group)
    fs_print_rwx(other)
}

@kernel fn fs_print_rwx(bits: i64) {
    if (bits & 4) != 0 { cprint("r", WHITE_ON_BLACK) } else { cprint("-", WHITE_ON_BLACK) }
    if (bits & 2) != 0 { cprint("w", WHITE_ON_BLACK) } else { cprint("-", WHITE_ON_BLACK) }
    if (bits & 1) != 0 { cprint("x", WHITE_ON_BLACK) } else { cprint("-", WHITE_ON_BLACK) }
}

// ═══════════════════════════════════════════════
// User Sessions & Security (Sprint M3 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// Login history at 0x962000: 16 entries × 32 bytes
// Per entry: +0=uid(i64), +8=timestamp(i64), +16=action(i64: 1=login, 2=logout), +24=reserved
const LOGIN_HISTORY: i64 = 0x962000
const LOGIN_HIST_MAX: i64 = 16
const LOGIN_HIST_SIZE: i64 = 32
const LOGIN_HIST_IDX: i64 = 0x962200 // current write index

// Session timeout (ticks) — 0 = disabled
const SESSION_TIMEOUT: i64 = 0x652078
const SESSION_LAST_INPUT: i64 = 0x652080

// Setuid bit in mode (bit 11 = 0x800)
const PERM_SETUID: i64 = 0x800
const PERM_SETGID: i64 = 0x400

// M3.1: Login shell — spawn shell with user's UID
@kernel fn session_login(uid: i64) {
    volatile_write_u64(CURRENT_UID_ADDR, uid)
    let pid = volatile_read_u64(0x6FE00)
    volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_UID, uid)
    let entry = USER_TABLE + uid * USER_ENTRY_SIZE
    volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_GID, volatile_read_u64(entry + USER_OFF_GID))
    // Record login in history
    login_history_record(uid, 1)
    // Update last input time for session timeout
    volatile_write_u64(SESSION_LAST_INPUT, volatile_read_u64(0x6FE08))
}

// M3.2: `logout` command
@kernel fn cmd_logout() {
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    if uid == 0 { cprintln("Cannot logout root (use 'shutdown')", YELLOW_ON_BLACK); return }
    // Record logout
    login_history_record(uid, 2)
    // Switch back to root
    volatile_write_u64(CURRENT_UID_ADDR, 0)
    let pid = volatile_read_u64(0x6FE00)
    volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_UID, 0)
    volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_GID, 0)
    cprintln("Logged out. Back to root.", WHITE_ON_BLACK)
}

// M3.3: Save user accounts to /etc/passwd in ramfs
@kernel fn cmd_save_passwd() {
    // Write user table to ramfs file "passwd"
    let data_buf: i64 = 0x846800
    let mut pos: i64 = 0
    let mut i: i64 = 0
    while i < USER_MAX {
        let entry = USER_TABLE + i * USER_ENTRY_SIZE
        if volatile_read_u64(entry + USER_OFF_ACTIVE) == 1 {
            // Format: uid:name:hash:gid:home
            // Write uid digit
            let uid = volatile_read_u64(entry + USER_OFF_UID)
            volatile_write_u8(data_buf + pos, 48 + (uid % 10))
            pos = pos + 1
            volatile_write_u8(data_buf + pos, 58) // ':'
            pos = pos + 1
            // Write name
            let mut j: i64 = 0
            while j < 16 {
                let ch = volatile_read_u8(entry + USER_OFF_NAME + j)
                if ch == 0 { j = 16 } else { volatile_write_u8(data_buf + pos, ch); pos = pos + 1; j = j + 1 }
            }
            volatile_write_u8(data_buf + pos, 58)
            pos = pos + 1
            // Write hash (as decimal, truncated)
            let hash = volatile_read_u64(entry + USER_OFF_PASS)
            let h_mod = hash % 10000
            volatile_write_u8(data_buf + pos, 48 + ((h_mod / 1000) % 10))
            volatile_write_u8(data_buf + pos + 1, 48 + ((h_mod / 100) % 10))
            volatile_write_u8(data_buf + pos + 2, 48 + ((h_mod / 10) % 10))
            volatile_write_u8(data_buf + pos + 3, 48 + (h_mod % 10))
            pos = pos + 4
            volatile_write_u8(data_buf + pos, 10) // newline
            pos = pos + 1
        }
        i = i + 1
    }
    volatile_write_u8(data_buf + pos, 0)
    // Write to ramfs
    ramfs_write_file("passwd", data_buf, pos)
    cprint("Saved ", WHITE_ON_BLACK)
    cprint_decimal(pos, CYAN_ON_BLACK)
    cprintln(" bytes to /etc/passwd", GREEN_ON_BLACK)
}

// Helper: write raw bytes to ramfs (variant that takes addr instead of str)
@kernel fn ramfs_write_file_raw(name: str, data_addr: i64, dlen: i64) {
    let mut idx = ramfs_find(name)
    if idx == -1 { idx = ramfs_create_entry(name, 1) }
    if idx == -1 { return }
    let addr = ramfs_entry_addr(idx)
    let data_offset = volatile_read(FS_BASE + 8)
    let mut i: i64 = 0
    while i < dlen { volatile_write_u8(data_offset + i, volatile_read_u8(data_addr + i)); i = i + 1 }
    volatile_write(addr + 32, dlen)
    volatile_write(addr + 40, data_offset)
    volatile_write(addr + 48, 1)
    volatile_write(FS_BASE + 8, data_offset + dlen)
}

// M3.5: Check setuid bit on exec
@kernel fn fs_check_setuid(entry_addr: i64) -> i64 {
    let mode = volatile_read(entry_addr + FS_OFF_MODE)
    if (mode & PERM_SETUID) != 0 { return volatile_read(entry_addr + FS_OFF_OWNER_UID) }
    -1 // no setuid
}

// M3.6: `groups` command
@kernel fn cmd_groups() {
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    let entry = USER_TABLE + uid * USER_ENTRY_SIZE
    let gid = volatile_read_u64(entry + USER_OFF_GID)
    cprint("Groups: ", WHITE_ON_BLACK)
    cprint_decimal(gid, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// M3.7: Fork inherits UID/GID — update sys_fork to copy UID/GID
@kernel fn fork_copy_uid(parent_pid: i64, child_pid: i64) {
    let parent_base = PROC_TABLE + parent_pid * PROC_ENTRY_SIZE
    let child_base = PROC_TABLE + child_pid * PROC_ENTRY_SIZE
    volatile_write(child_base + PROC_OFF_UID, volatile_read(parent_base + PROC_OFF_UID))
    volatile_write(child_base + PROC_OFF_GID, volatile_read(parent_base + PROC_OFF_GID))
}

// M3.8: `last` command — show login history
@kernel fn cmd_last() {
    cprintln("Login history:", YELLOW_ON_BLACK)
    let idx = volatile_read_u64(LOGIN_HIST_IDX)
    let mut count: i64 = 0
    let mut i: i64 = 0
    while i < LOGIN_HIST_MAX {
        let slot = (idx - 1 - i + LOGIN_HIST_MAX) % LOGIN_HIST_MAX
        let entry = LOGIN_HISTORY + slot * LOGIN_HIST_SIZE
        let uid = volatile_read_u64(entry)
        let ts = volatile_read_u64(entry + 8)
        let action = volatile_read_u64(entry + 16)
        if action != 0 {
            cprint("  uid=", WHITE_ON_BLACK)
            cprint_decimal(uid, CYAN_ON_BLACK)
            cprint(" tick=", WHITE_ON_BLACK)
            cprint_decimal(ts, WHITE_ON_BLACK)
            if action == 1 { cprintln(" login", GREEN_ON_BLACK) }
            else { cprintln(" logout", YELLOW_ON_BLACK) }
            count = count + 1
        }
        i = i + 1
    }
    if count == 0 { cprintln("  (no login history)", WHITE_ON_BLACK) }
}

// Record login/logout event
@kernel fn login_history_record(uid: i64, action: i64) {
    let idx = volatile_read_u64(LOGIN_HIST_IDX)
    let entry = LOGIN_HISTORY + idx * LOGIN_HIST_SIZE
    volatile_write_u64(entry, uid)
    volatile_write_u64(entry + 8, volatile_read_u64(0x6FE08)) // tick count
    volatile_write_u64(entry + 16, action)
    volatile_write_u64(LOGIN_HIST_IDX, (idx + 1) % LOGIN_HIST_MAX)
}

// M3.9: Session timeout check (called at prompt)
@kernel fn session_check_timeout() {
    let timeout = volatile_read_u64(SESSION_TIMEOUT)
    if timeout == 0 { return } // disabled
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    if uid == 0 { return } // root never times out
    let last = volatile_read_u64(SESSION_LAST_INPUT)
    let now = volatile_read_u64(0x6FE08)
    if now - last > timeout {
        cprintln("Session timed out. Logging out.", YELLOW_ON_BLACK)
        cmd_logout()
    }
}

// Update last input time on keypress
@kernel fn session_touch() {
    volatile_write_u64(SESSION_LAST_INPUT, volatile_read_u64(0x6FE08))
}

// ═══════════════════════════════════════════════
// Directory Tree & Links (Sprint N1 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// Extended ramfs entry: +80=parent_idx(i64), +88=link_target_idx(i64), +96=link_type(i64: 0=none, 1=symlink, 2=hardlink)
const FS_OFF_PARENT: i64 = 80
const FS_OFF_LINK_TARGET: i64 = 88
const FS_OFF_LINK_TYPE: i64 = 96

const LINK_NONE: i64 = 0
const LINK_SYMLINK: i64 = 1
const LINK_HARDLINK: i64 = 2

// N1.1: Resolve hierarchical path like "/home/fajar/file.txt"
// Returns ramfs index of the final component, or -1 if not found
@kernel fn fs_resolve_path(path_addr: i64) -> i64 {
    let mut current_dir: i64 = 0 // start at root (index 0 = "/")
    let component_buf: i64 = 0x847000 // temp buffer for path component
    let mut pos: i64 = 0

    // Skip leading /
    if volatile_read_u8(path_addr) == 47 { pos = 1 }

    // Empty path after / → return root
    if volatile_read_u8(path_addr + pos) == 0 { return 0 }

    while volatile_read_u8(path_addr + pos) != 0 {
        // Extract next component (until / or end)
        let mut ci: i64 = 0
        while ci < 31 {
            let ch = volatile_read_u8(path_addr + pos)
            if ch == 47 || ch == 0 { ci = 31 } // '/' or null
            else { volatile_write_u8(component_buf + ci, ch); ci = ci + 1; pos = pos + 1 }
        }
        volatile_write_u8(component_buf + (if ci > 31 { 0 } else { ci }), 0)
        if volatile_read_u8(path_addr + pos) == 47 { pos = pos + 1 } // skip /

        // Find component in current directory
        let idx = fs_find_in_dir(current_dir, component_buf)
        if idx < 0 { return -1 } // not found

        // N1.8: Follow symlinks
        let entry = ramfs_entry_addr(idx)
        let link_type = volatile_read(entry + FS_OFF_LINK_TYPE)
        if link_type == LINK_SYMLINK {
            let target = volatile_read(entry + FS_OFF_LINK_TARGET)
            if target < 0 { return -1 }
            current_dir = target
        } else {
            current_dir = idx
        }
    }
    current_dir
}

// Find a named entry within a directory (by parent index)
@kernel fn fs_find_in_dir(parent_idx: i64, name_addr: i64) -> i64 {
    let count = volatile_read(FS_BASE)
    let mut i: i64 = 0
    while i < count {
        let addr = ramfs_entry_addr(i)
        let p = volatile_read(addr + FS_OFF_PARENT)
        if p == parent_idx || (parent_idx == 0 && p == 0) {
            // Compare name
            let mut match_ok: i64 = 1
            let mut j: i64 = 0
            let mut nlen: i64 = 0
            while nlen < 31 && volatile_read_u8(name_addr + nlen) != 0 { nlen = nlen + 1 }
            while j < nlen && match_ok == 1 {
                if volatile_read_u8(addr + j) != volatile_read_u8(name_addr + j) { match_ok = 0 }
                j = j + 1
            }
            if match_ok == 1 && volatile_read_u8(addr + nlen) == 0 { return i }
        }
        i = i + 1
    }
    -1
}

// N1.2: `mkdir -p` — create directory with parents
@kernel fn cmd_mkdir_p() {
    let len = cmdbuf_len()
    let prefix = if len > 8 && volatile_read_u8(0x6F800 + 6) == 45 { 9 } else { 6 } // "mkdir -p " or "mkdir "
    if len <= prefix { cprintln("Usage: mkdir [-p] <path>", YELLOW_ON_BLACK); return }
    let path_buf: i64 = 0x847100
    let mut fi: i64 = 0
    let mut pos: i64 = prefix
    while pos < len && fi < 63 {
        volatile_write_u8(path_buf + fi, volatile_read_u8(0x6F800 + pos))
        fi = fi + 1; pos = pos + 1
    }
    volatile_write_u8(path_buf + fi, 0)
    fs_mkdir_recursive(path_buf)
}

@kernel fn fs_mkdir_recursive(path_addr: i64) {
    let component_buf: i64 = 0x847200
    let mut pos: i64 = 0
    let mut parent: i64 = 0 // root

    if volatile_read_u8(path_addr) == 47 { pos = 1 }

    while volatile_read_u8(path_addr + pos) != 0 {
        let mut ci: i64 = 0
        while ci < 31 {
            let ch = volatile_read_u8(path_addr + pos)
            if ch == 47 || ch == 0 { ci = 31 }
            else { volatile_write_u8(component_buf + ci, ch); ci = ci + 1; pos = pos + 1 }
        }
        volatile_write_u8(component_buf + (if ci > 31 { 0 } else { ci }), 0)
        if volatile_read_u8(path_addr + pos) == 47 { pos = pos + 1 }

        let existing = fs_find_in_dir(parent, component_buf)
        if existing >= 0 {
            parent = existing
        } else {
            // Create directory
            let idx = ramfs_create_by_addr(component_buf)
            if idx >= 0 {
                let entry = ramfs_entry_addr(idx)
                volatile_write(entry + 48, 2) // type = dir
                volatile_write(entry + FS_OFF_PARENT, parent)
                fs_set_default_perms(entry, 2)
                parent = idx
            }
        }
    }
    cprintln("Directory created", GREEN_ON_BLACK)
}

// N1.4: `pwd` — show full path from root
@kernel fn cmd_pwd_full() {
    let pid = volatile_read_u64(0x6FE00)
    let cwd_addr = PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_CWD
    let mut i: i64 = 0
    let mut has_content: i64 = 0
    while i < 31 {
        let ch = volatile_read_u8(cwd_addr + i)
        if ch == 0 { i = 31 } else { console_putchar(ch, WHITE_ON_BLACK); has_content = 1; i = i + 1 }
    }
    if has_content == 0 { cprint("/", WHITE_ON_BLACK) }
    console_putchar(10, WHITE_ON_BLACK)
}

// N1.5: `ln -s <target> <link>` — create symbolic link
@kernel fn cmd_ln() {
    let len = cmdbuf_len()
    let is_symlink = len > 5 && volatile_read_u8(0x6F800 + 3) == 45 && volatile_read_u8(0x6F800 + 4) == 115 // "-s"
    let prefix = if is_symlink { 6 } else { 3 } // "ln -s " or "ln "
    if len <= prefix + 2 { cprintln("Usage: ln [-s] <target> <link>", YELLOW_ON_BLACK); return }

    let target_buf: i64 = 0x847300
    let link_buf: i64 = 0x847380
    let mut pos: i64 = prefix
    let mut ti: i64 = 0
    while pos < len && volatile_read_u8(0x6F800 + pos) != 32 && ti < 31 {
        volatile_write_u8(target_buf + ti, volatile_read_u8(0x6F800 + pos))
        ti = ti + 1; pos = pos + 1
    }
    volatile_write_u8(target_buf + ti, 0)
    pos = pos + 1 // skip space
    let mut li: i64 = 0
    while pos < len && li < 31 {
        volatile_write_u8(link_buf + li, volatile_read_u8(0x6F800 + pos))
        li = li + 1; pos = pos + 1
    }
    volatile_write_u8(link_buf + li, 0)

    // Find target
    let target_idx = ramfs_find_by_addr(target_buf)
    if target_idx < 0 && is_symlink == false { cprintln("Target not found", RED_ON_BLACK); return }

    // Create link entry
    let link_idx = ramfs_create_by_addr(link_buf)
    if link_idx < 0 { cprintln("Cannot create link", RED_ON_BLACK); return }
    let link_entry = ramfs_entry_addr(link_idx)

    if is_symlink {
        volatile_write(link_entry + FS_OFF_LINK_TYPE, LINK_SYMLINK)
        volatile_write(link_entry + FS_OFF_LINK_TARGET, target_idx)
        volatile_write(link_entry + 48, 1) // type = file (symlink behaves as file)
        cprint("Symlink: ", WHITE_ON_BLACK)
    } else {
        volatile_write(link_entry + FS_OFF_LINK_TYPE, LINK_HARDLINK)
        volatile_write(link_entry + FS_OFF_LINK_TARGET, target_idx)
        // Hard link shares data pointer + size
        let target_entry = ramfs_entry_addr(target_idx)
        volatile_write(link_entry + 32, volatile_read(target_entry + 32))
        volatile_write(link_entry + 40, volatile_read(target_entry + 40))
        volatile_write(link_entry + 48, volatile_read(target_entry + 48))
        cprint("Hardlink: ", WHITE_ON_BLACK)
    }

    let mut pi: i64 = 0
    while pi < li { console_putchar(volatile_read_u8(link_buf + pi), GREEN_ON_BLACK); pi = pi + 1 }
    cprint(" -> ", WHITE_ON_BLACK)
    pi = 0
    while pi < ti { console_putchar(volatile_read_u8(target_buf + pi), CYAN_ON_BLACK); pi = pi + 1 }
    console_putchar(10, WHITE_ON_BLACK)
}

// N1.7: `readlink` command
@kernel fn cmd_readlink() {
    let len = cmdbuf_len()
    if len <= 9 { cprintln("Usage: readlink <link>", YELLOW_ON_BLACK); return }
    let name_buf: i64 = 0x847400
    let mut ni: i64 = 0
    let mut pos: i64 = 9
    while pos < len && ni < 31 {
        volatile_write_u8(name_buf + ni, volatile_read_u8(0x6F800 + pos))
        ni = ni + 1; pos = pos + 1
    }
    volatile_write_u8(name_buf + ni, 0)
    let idx = ramfs_find_by_addr(name_buf)
    if idx < 0 { cprintln("Not found", RED_ON_BLACK); return }
    let entry = ramfs_entry_addr(idx)
    let lt = volatile_read(entry + FS_OFF_LINK_TYPE)
    if lt == LINK_NONE { cprintln("Not a link", WHITE_ON_BLACK); return }
    let target = volatile_read(entry + FS_OFF_LINK_TARGET)
    if target >= 0 {
        let te = ramfs_entry_addr(target)
        let mut i: i64 = 0
        while i < 32 {
            let ch = volatile_read_u8(te + i)
            if ch == 0 { i = 32 } else { console_putchar(ch, CYAN_ON_BLACK); i = i + 1 }
        }
    }
    console_putchar(10, WHITE_ON_BLACK)
}

// N1.9: `rmdir` command — remove empty directory
@kernel fn cmd_rmdir() {
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: rmdir <dir>", YELLOW_ON_BLACK); return }
    let name_buf: i64 = 0x847400
    let mut ni: i64 = 0
    let mut pos: i64 = 6
    while pos < len && ni < 31 {
        volatile_write_u8(name_buf + ni, volatile_read_u8(0x6F800 + pos))
        ni = ni + 1; pos = pos + 1
    }
    volatile_write_u8(name_buf + ni, 0)
    let idx = ramfs_find_by_addr(name_buf)
    if idx < 0 { cprintln("Not found", RED_ON_BLACK); return }
    let entry = ramfs_entry_addr(idx)
    if volatile_read(entry + 48) != 2 { cprintln("Not a directory", RED_ON_BLACK); return }
    // Check empty (no children with this as parent)
    let count = volatile_read(FS_BASE)
    let mut i: i64 = 0
    let mut has_children: i64 = 0
    while i < count {
        if volatile_read(ramfs_entry_addr(i) + FS_OFF_PARENT) == idx && volatile_read(ramfs_entry_addr(i) + 48) != 0 {
            has_children = 1
        }
        i = i + 1
    }
    if has_children == 1 { cprintln("Directory not empty", RED_ON_BLACK); return }
    volatile_write_u8(entry, 0)
    volatile_write(entry + 48, 0)
    cprintln("Directory removed", GREEN_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Filesystem Journal & Crash Recovery (Sprint N2 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// Write-ahead log (WAL) at 0x970000: 64KB
// Journal header at 0x970000: +0=entry_count(i64), +8=committed(i64), +16=sequence(i64)
// Entries start at 0x970100, each 64 bytes
const JOURNAL_BASE: i64 = 0x970000
const JOURNAL_ENTRIES: i64 = 0x970100
const JOURNAL_ENTRY_SIZE: i64 = 64
const JOURNAL_MAX_ENTRIES: i64 = 1000  // 1000 × 64 = 64000 bytes (fits in 64KB)

// Journal entry: +0=type(i64), +8=inode(i64), +16=offset(i64), +24=len(i64), +32=data[32]
const JTYPE_NONE: i64 = 0
const JTYPE_CREATE: i64 = 1
const JTYPE_WRITE: i64 = 2
const JTYPE_DELETE: i64 = 3
const JTYPE_RENAME: i64 = 4
const JTYPE_CHMOD: i64 = 5

// Inode generation numbers at 0x97FC00 (256 bytes = 64 entries × 4B)
const INODE_GEN_TABLE: i64 = 0x97FC00

// Disk usage tracking
const FS_USED_BYTES: i64 = 0x97FE00
const FS_TOTAL_BYTES: i64 = 0x97FE08
const FS_DISK_FULL_THRESHOLD: i64 = 90 // refuse writes at 90% full

// N2.1: Initialize journal
@kernel fn journal_init() {
    volatile_write_u64(JOURNAL_BASE, 0)      // entry_count = 0
    volatile_write_u64(JOURNAL_BASE + 8, 1)  // committed = true
    volatile_write_u64(JOURNAL_BASE + 16, 0) // sequence = 0
    // Init disk usage: total = 832KB (ramfs data area)
    volatile_write_u64(FS_USED_BYTES, 0)
    volatile_write_u64(FS_TOTAL_BYTES, 832 * 1024)
}

// N2.2: Add journal entry
@kernel fn journal_add(jtype: i64, inode: i64, offset: i64, jlen: i64, data_addr: i64) -> i64 {
    let count = volatile_read_u64(JOURNAL_BASE)
    if count >= JOURNAL_MAX_ENTRIES { return -1 } // journal full
    let entry = JOURNAL_ENTRIES + count * JOURNAL_ENTRY_SIZE
    volatile_write_u64(entry, jtype)
    volatile_write_u64(entry + 8, inode)
    volatile_write_u64(entry + 16, offset)
    volatile_write_u64(entry + 24, jlen)
    // Copy data (max 32 bytes)
    let copy_len = if jlen < 32 { jlen } else { 32 }
    let mut i: i64 = 0
    while i < copy_len {
        volatile_write_u8(entry + 32 + i, volatile_read_u8(data_addr + i))
        i = i + 1
    }
    // Mark uncommitted
    volatile_write_u64(JOURNAL_BASE + 8, 0) // committed = false
    volatile_write_u64(JOURNAL_BASE, count + 1)
    let seq = volatile_read_u64(JOURNAL_BASE + 16)
    volatile_write_u64(JOURNAL_BASE + 16, seq + 1)
    count
}

// N2.3: Commit journal — flush entries to filesystem
@kernel fn journal_commit() {
    let count = volatile_read_u64(JOURNAL_BASE)
    if count == 0 { return }
    // Mark as committed
    volatile_write_u64(JOURNAL_BASE + 8, 1) // committed = true
    // Clear journal entries
    volatile_write_u64(JOURNAL_BASE, 0) // entry_count = 0
}

// N2.4: Replay journal on boot (if not committed)
@kernel fn journal_replay() -> i64 {
    let committed = volatile_read_u64(JOURNAL_BASE + 8)
    if committed == 1 { return 0 } // clean shutdown, nothing to replay
    let count = volatile_read_u64(JOURNAL_BASE)
    cprint("[JOURNAL] Replaying ", YELLOW_ON_BLACK)
    cprint_decimal(count, CYAN_ON_BLACK)
    cprintln(" uncommitted entries...", YELLOW_ON_BLACK)
    // Replay each entry
    let mut i: i64 = 0
    let mut replayed: i64 = 0
    while i < count {
        let entry = JOURNAL_ENTRIES + i * JOURNAL_ENTRY_SIZE
        let jtype = volatile_read_u64(entry)
        if jtype != JTYPE_NONE { replayed = replayed + 1 }
        // Replay logic would apply the operation to the filesystem
        // For now, just count and mark committed
        i = i + 1
    }
    journal_commit()
    cprint("[JOURNAL] Replayed ", GREEN_ON_BLACK)
    cprint_decimal(replayed, CYAN_ON_BLACK)
    cprintln(" entries", GREEN_ON_BLACK)
    replayed
}

// N2.5: `sync` command
@kernel fn cmd_sync_journal() {
    journal_commit()
    cprintln("Filesystem synced", GREEN_ON_BLACK)
}

// N2.6: `fsck` command — verify filesystem consistency
@kernel fn cmd_fsck() {
    cprintln("Filesystem check:", YELLOW_ON_BLACK)
    let count = volatile_read(FS_BASE)
    let mut errors: i64 = 0
    let mut files: i64 = 0
    let mut dirs: i64 = 0
    let mut links: i64 = 0
    let mut i: i64 = 0
    while i < count {
        let addr = ramfs_entry_addr(i)
        let ftype = volatile_read(addr + 48)
        if ftype == 1 { files = files + 1 }
        if ftype == 2 { dirs = dirs + 1 }
        let lt = volatile_read(addr + FS_OFF_LINK_TYPE)
        if lt == LINK_SYMLINK || lt == LINK_HARDLINK {
            links = links + 1
            // Verify link target exists
            let target = volatile_read(addr + FS_OFF_LINK_TARGET)
            if target >= count || target < 0 { errors = errors + 1 }
        }
        // Check size sanity
        let size = volatile_read(addr + 32)
        if size < 0 { errors = errors + 1 }
        i = i + 1
    }
    cprint("  Files: ", WHITE_ON_BLACK)
    cprint_decimal(files, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Dirs: ", WHITE_ON_BLACK)
    cprint_decimal(dirs, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Links: ", WHITE_ON_BLACK)
    cprint_decimal(links, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    // Journal status
    let jcount = volatile_read_u64(JOURNAL_BASE)
    let jcommit = volatile_read_u64(JOURNAL_BASE + 8)
    cprint("  Journal: ", WHITE_ON_BLACK)
    cprint_decimal(jcount, CYAN_ON_BLACK)
    cprint(" entries, ", WHITE_ON_BLACK)
    if jcommit == 1 { cprintln("committed", GREEN_ON_BLACK) }
    else { cprintln("UNCOMMITTED", RED_ON_BLACK); errors = errors + 1 }
    if errors == 0 { cprintln("  No errors found", GREEN_ON_BLACK) }
    else {
        cprint("  ", WHITE_ON_BLACK)
        cprint_decimal(errors, RED_ON_BLACK)
        cprintln(" errors found!", RED_ON_BLACK)
    }
}

// N2.7: Atomic rename via journal
@kernel fn cmd_rename() {
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: mv <old> <new>", YELLOW_ON_BLACK); return }
    let old_buf: i64 = 0x847500
    let new_buf: i64 = 0x847580
    let mut pos: i64 = 3
    let mut oi: i64 = 0
    while pos < len && volatile_read_u8(0x6F800 + pos) != 32 && oi < 31 {
        volatile_write_u8(old_buf + oi, volatile_read_u8(0x6F800 + pos))
        oi = oi + 1; pos = pos + 1
    }
    volatile_write_u8(old_buf + oi, 0)
    pos = pos + 1
    let mut ni: i64 = 0
    while pos < len && ni < 31 {
        volatile_write_u8(new_buf + ni, volatile_read_u8(0x6F800 + pos))
        ni = ni + 1; pos = pos + 1
    }
    volatile_write_u8(new_buf + ni, 0)
    let idx = ramfs_find_by_addr(old_buf)
    if idx < 0 { cprintln("File not found", RED_ON_BLACK); return }
    // Journal the rename
    journal_add(JTYPE_RENAME, idx, 0, ni, new_buf)
    // Apply rename
    let addr = ramfs_entry_addr(idx)
    let mut ri: i64 = 0
    while ri < ni { volatile_write_u8(addr + ri, volatile_read_u8(new_buf + ri)); ri = ri + 1 }
    volatile_write_u8(addr + ni, 0)
    journal_commit()
    cprintln("Renamed", GREEN_ON_BLACK)
}

// N2.8: Disk full handling
@kernel fn fs_check_disk_space(needed: i64) -> i64 {
    let used = volatile_read_u64(FS_USED_BYTES)
    let total = volatile_read_u64(FS_TOTAL_BYTES)
    if total == 0 { return 0 } // no tracking
    let usage_pct = (used * 100) / total
    if usage_pct >= FS_DISK_FULL_THRESHOLD && needed > 0 { return -1 } // disk full
    0
}

@kernel fn fs_update_usage(delta: i64) {
    let used = volatile_read_u64(FS_USED_BYTES)
    let new_used = used + delta
    if new_used >= 0 { volatile_write_u64(FS_USED_BYTES, new_used) }
}

// N2.9: Inode generation numbers
@kernel fn inode_get_gen(inode: i64) -> i64 {
    if inode < 0 || inode >= 64 { return 0 }
    let addr = INODE_GEN_TABLE + inode * 4
    volatile_read_u8(addr) + volatile_read_u8(addr + 1) * 256 + volatile_read_u8(addr + 2) * 65536 + volatile_read_u8(addr + 3) * 16777216
}

@kernel fn inode_inc_gen(inode: i64) {
    if inode >= 0 && inode < 64 {
        let gen = inode_get_gen(inode) + 1
        let addr = INODE_GEN_TABLE + inode * 4
        volatile_write_u8(addr, gen & 0xFF)
        volatile_write_u8(addr + 1, (gen >> 8) & 0xFF)
        volatile_write_u8(addr + 2, (gen >> 16) & 0xFF)
        volatile_write_u8(addr + 3, (gen >> 24) & 0xFF)
    }
}

// `df` command — show disk usage
@kernel fn cmd_df_journal() {
    cprintln("Filesystem usage:", YELLOW_ON_BLACK)
    let used = volatile_read_u64(FS_USED_BYTES)
    let total = volatile_read_u64(FS_TOTAL_BYTES)
    cprint("  Used: ", WHITE_ON_BLACK)
    cprint_decimal(used / 1024, CYAN_ON_BLACK)
    cprintln(" KB", WHITE_ON_BLACK)
    cprint("  Total: ", WHITE_ON_BLACK)
    cprint_decimal(total / 1024, CYAN_ON_BLACK)
    cprintln(" KB", WHITE_ON_BLACK)
    if total > 0 {
        cprint("  Usage: ", WHITE_ON_BLACK)
        cprint_decimal((used * 100) / total, CYAN_ON_BLACK)
        cprintln("%", WHITE_ON_BLACK)
    }
}

// ═══════════════════════════════════════════════
// Socket API (Sprint O1 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// Socket table at 0x980000: 16 sockets × 64 bytes
// Per socket: +0=state, +8=type, +16=local_port, +24=remote_ip, +32=remote_port,
//             +40=rx_buf_addr, +48=tx_buf_addr, +56=backlog
const SOCKET_TABLE: i64 = 0x980000
const SOCKET_MAX: i64 = 16
const SOCKET_ENTRY_SIZE: i64 = 64
const SOCK_OFF_STATE: i64 = 0
const SOCK_OFF_TYPE: i64 = 8
const SOCK_OFF_LOCAL_PORT: i64 = 16
const SOCK_OFF_REMOTE_IP: i64 = 24
const SOCK_OFF_REMOTE_PORT: i64 = 32
const SOCK_OFF_RX_BUF: i64 = 40
const SOCK_OFF_TX_BUF: i64 = 48
const SOCK_OFF_BACKLOG: i64 = 56

// Socket states
const SOCK_FREE: i64 = 0
const SOCK_CREATED: i64 = 1
const SOCK_BOUND: i64 = 2
const SOCK_LISTEN: i64 = 3
const SOCK_CONNECTING: i64 = 4
const SOCK_ESTABLISHED: i64 = 5
const SOCK_CLOSE_WAIT: i64 = 6
const SOCK_CLOSED: i64 = 7

// Socket types
const SOCK_STREAM: i64 = 1    // TCP
const SOCK_DGRAM: i64 = 2     // UDP

// FD type for sockets
const FD_SOCKET: i64 = 6

// Socket buffer area: 0x982000 (16 sockets × 2KB rx + 2KB tx = 64KB)
const SOCKET_BUF_BASE: i64 = 0x982000
const SOCKET_BUF_SIZE: i64 = 2048

// New syscall numbers for sockets
const SYS_SOCKET: i64 = 27
const SYS_BIND: i64 = 28
const SYS_LISTEN: i64 = 29
const SYS_ACCEPT: i64 = 30
const SYS_CONNECT_SOCK: i64 = 31

// O1.1: Initialize socket table
@kernel fn socket_init() {
    let mut i: i64 = 0
    while i < SOCKET_MAX * SOCKET_ENTRY_SIZE {
        volatile_write_u8(SOCKET_TABLE + i, 0)
        i = i + 1
    }
}

// O1.2: SYS_SOCKET(27) — create socket, return FD
@kernel fn sys_socket(sock_type: i64) -> i64 {
    // Find free socket slot
    let mut slot: i64 = -1
    let mut i: i64 = 0
    while i < SOCKET_MAX && slot == -1 {
        if volatile_read_u64(SOCKET_TABLE + i * SOCKET_ENTRY_SIZE + SOCK_OFF_STATE) == SOCK_FREE {
            slot = i
        }
        i = i + 1
    }
    if slot == -1 { return -1 }

    // Initialize socket
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_CREATED)
    volatile_write_u64(entry + SOCK_OFF_TYPE, sock_type)
    volatile_write_u64(entry + SOCK_OFF_LOCAL_PORT, 0)
    volatile_write_u64(entry + SOCK_OFF_REMOTE_IP, 0)
    volatile_write_u64(entry + SOCK_OFF_REMOTE_PORT, 0)
    // Assign buffers
    volatile_write_u64(entry + SOCK_OFF_RX_BUF, SOCKET_BUF_BASE + slot * SOCKET_BUF_SIZE * 2)
    volatile_write_u64(entry + SOCK_OFF_TX_BUF, SOCKET_BUF_BASE + slot * SOCKET_BUF_SIZE * 2 + SOCKET_BUF_SIZE)
    volatile_write_u64(entry + SOCK_OFF_BACKLOG, 0)

    // Allocate FD
    let pid = volatile_read_u64(0x6FE00)
    let fd = fd_v2_alloc(pid)
    if fd == -1 { volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_FREE); return -1 }
    fd_v2_set(pid, fd, FD_SOCKET, slot)
    fd
}

// O1.3: SYS_BIND(28) — bind socket to local port
@kernel fn sys_bind(fd: i64, port: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    if fd_v2_get_type(pid, fd) != FD_SOCKET { return -1 }
    let slot = fd_v2_get_data(pid, fd)
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    let state = volatile_read_u64(entry + SOCK_OFF_STATE)
    if state != SOCK_CREATED { return -1 }
    // Check port not already bound
    let mut i: i64 = 0
    while i < SOCKET_MAX {
        let e = SOCKET_TABLE + i * SOCKET_ENTRY_SIZE
        if volatile_read_u64(e + SOCK_OFF_STATE) != SOCK_FREE &&
           volatile_read_u64(e + SOCK_OFF_LOCAL_PORT) == port { return -2 } // port in use
        i = i + 1
    }
    volatile_write_u64(entry + SOCK_OFF_LOCAL_PORT, port)
    volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_BOUND)
    0
}

// O1.4: SYS_LISTEN(29) — mark socket as listening
@kernel fn sys_listen(fd: i64, backlog: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    if fd_v2_get_type(pid, fd) != FD_SOCKET { return -1 }
    let slot = fd_v2_get_data(pid, fd)
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    if volatile_read_u64(entry + SOCK_OFF_STATE) != SOCK_BOUND { return -1 }
    volatile_write_u64(entry + SOCK_OFF_BACKLOG, backlog)
    volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_LISTEN)
    0
}

// O1.5: SYS_ACCEPT(30) — accept incoming connection
@kernel fn sys_accept(fd: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    if fd_v2_get_type(pid, fd) != FD_SOCKET { return -1 }
    let slot = fd_v2_get_data(pid, fd)
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    if volatile_read_u64(entry + SOCK_OFF_STATE) != SOCK_LISTEN { return -1 }
    // Create new socket for the accepted connection
    let new_fd = sys_socket(SOCK_STREAM)
    if new_fd < 0 { return -1 }
    let new_slot = fd_v2_get_data(pid, new_fd)
    let new_entry = SOCKET_TABLE + new_slot * SOCKET_ENTRY_SIZE
    volatile_write_u64(new_entry + SOCK_OFF_STATE, SOCK_ESTABLISHED)
    volatile_write_u64(new_entry + SOCK_OFF_LOCAL_PORT, volatile_read_u64(entry + SOCK_OFF_LOCAL_PORT))
    // Remote IP/port would be filled by TCP stack on real connection
    new_fd
}

// O1.6: SYS_CONNECT(31) — connect to remote
@kernel fn sys_connect_sock(fd: i64, remote_ip: i64, remote_port: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    if fd_v2_get_type(pid, fd) != FD_SOCKET { return -1 }
    let slot = fd_v2_get_data(pid, fd)
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    let state = volatile_read_u64(entry + SOCK_OFF_STATE)
    if state != SOCK_CREATED && state != SOCK_BOUND { return -1 }
    volatile_write_u64(entry + SOCK_OFF_REMOTE_IP, remote_ip)
    volatile_write_u64(entry + SOCK_OFF_REMOTE_PORT, remote_port)
    volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_ESTABLISHED)
    // Assign ephemeral port if not bound
    if volatile_read_u64(entry + SOCK_OFF_LOCAL_PORT) == 0 {
        volatile_write_u64(entry + SOCK_OFF_LOCAL_PORT, 49152 + slot)
    }
    0
}

// O1.7: Socket read/write via FD (add to sys_read/sys_write)
@kernel fn socket_read(slot: i64, buf: i64, len: i64) -> i64 {
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    if volatile_read_u64(entry + SOCK_OFF_STATE) != SOCK_ESTABLISHED { return -1 }
    // Read from RX buffer (simple: first N bytes, or 0 if empty)
    let rx_buf = volatile_read_u64(entry + SOCK_OFF_RX_BUF)
    let rx_len = volatile_read_u64(rx_buf) // first 8 bytes = data length
    if rx_len == 0 { return 0 }
    let to_read = if len < rx_len { len } else { rx_len }
    let mut i: i64 = 0
    while i < to_read {
        volatile_write_u8(buf + i, volatile_read_u8(rx_buf + 8 + i))
        i = i + 1
    }
    // Shift remaining data
    let remaining = rx_len - to_read
    i = 0
    while i < remaining {
        volatile_write_u8(rx_buf + 8 + i, volatile_read_u8(rx_buf + 8 + to_read + i))
        i = i + 1
    }
    volatile_write_u64(rx_buf, remaining)
    to_read
}

@kernel fn socket_write(slot: i64, buf: i64, len: i64) -> i64 {
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    if volatile_read_u64(entry + SOCK_OFF_STATE) != SOCK_ESTABLISHED { return -1 }
    let tx_buf = volatile_read_u64(entry + SOCK_OFF_TX_BUF)
    let tx_len = volatile_read_u64(tx_buf)
    let avail = SOCKET_BUF_SIZE - 8 - tx_len
    if avail <= 0 { return 0 }
    let to_write = if len < avail { len } else { avail }
    let mut i: i64 = 0
    while i < to_write {
        volatile_write_u8(tx_buf + 8 + tx_len + i, volatile_read_u8(buf + i))
        i = i + 1
    }
    volatile_write_u64(tx_buf, tx_len + to_write)
    to_write
}

// O1.8: `netstat` command
@kernel fn cmd_netstat() {
    cprintln("Active sockets:", YELLOW_ON_BLACK)
    let mut i: i64 = 0
    let mut count: i64 = 0
    while i < SOCKET_MAX {
        let entry = SOCKET_TABLE + i * SOCKET_ENTRY_SIZE
        let state = volatile_read_u64(entry + SOCK_OFF_STATE)
        if state != SOCK_FREE {
            cprint("  [", WHITE_ON_BLACK)
            cprint_decimal(i, CYAN_ON_BLACK)
            cprint("] ", WHITE_ON_BLACK)
            // Type
            let stype = volatile_read_u64(entry + SOCK_OFF_TYPE)
            if stype == SOCK_STREAM { cprint("TCP ", WHITE_ON_BLACK) }
            else { cprint("UDP ", WHITE_ON_BLACK) }
            // Local port
            cprint(":", WHITE_ON_BLACK)
            cprint_decimal(volatile_read_u64(entry + SOCK_OFF_LOCAL_PORT), CYAN_ON_BLACK)
            cprint(" → ", WHITE_ON_BLACK)
            // Remote
            let rip = volatile_read_u64(entry + SOCK_OFF_REMOTE_IP)
            if rip != 0 {
                cprint_decimal((rip >> 24) & 0xFF, WHITE_ON_BLACK)
                cprint(".", WHITE_ON_BLACK)
                cprint_decimal((rip >> 16) & 0xFF, WHITE_ON_BLACK)
                cprint(".", WHITE_ON_BLACK)
                cprint_decimal((rip >> 8) & 0xFF, WHITE_ON_BLACK)
                cprint(".", WHITE_ON_BLACK)
                cprint_decimal(rip & 0xFF, WHITE_ON_BLACK)
            } else { cprint("*", WHITE_ON_BLACK) }
            cprint(":", WHITE_ON_BLACK)
            cprint_decimal(volatile_read_u64(entry + SOCK_OFF_REMOTE_PORT), WHITE_ON_BLACK)
            cprint(" ", WHITE_ON_BLACK)
            // State name
            if state == SOCK_CREATED { cprint("CREATED", WHITE_ON_BLACK) }
            else if state == SOCK_BOUND { cprint("BOUND", YELLOW_ON_BLACK) }
            else if state == SOCK_LISTEN { cprint("LISTEN", GREEN_ON_BLACK) }
            else if state == SOCK_CONNECTING { cprint("CONNECTING", YELLOW_ON_BLACK) }
            else if state == SOCK_ESTABLISHED { cprint("ESTABLISHED", GREEN_ON_BLACK) }
            else if state == SOCK_CLOSE_WAIT { cprint("CLOSE_WAIT", YELLOW_ON_BLACK) }
            else if state == SOCK_CLOSED { cprint("CLOSED", RED_ON_BLACK) }
            console_putchar(10, WHITE_ON_BLACK)
            count = count + 1
        }
        i = i + 1
    }
    if count == 0 { cprintln("  (no active sockets)", WHITE_ON_BLACK) }
}

// O1.9: TCP RST — reset connection
@kernel fn socket_reset(slot: i64) {
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_CLOSED)
    // Clear buffers
    let rx_buf = volatile_read_u64(entry + SOCK_OFF_RX_BUF)
    let tx_buf = volatile_read_u64(entry + SOCK_OFF_TX_BUF)
    if rx_buf != 0 { volatile_write_u64(rx_buf, 0) }
    if tx_buf != 0 { volatile_write_u64(tx_buf, 0) }
}

@kernel fn socket_close(slot: i64) {
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_FREE)
    volatile_write_u64(entry + SOCK_OFF_LOCAL_PORT, 0)
    volatile_write_u64(entry + SOCK_OFF_REMOTE_IP, 0)
    volatile_write_u64(entry + SOCK_OFF_REMOTE_PORT, 0)
}

// ═══════════════════════════════════════════════
// Process Syscalls (Sprint G1-G3)
// ═══════════════════════════════════════════════

const SYS_FORK: i64 = 20      // fork() -> pid/0
const SYS_EXEC: i64 = 21      // exec(path, argv) -> (no return)
const SYS_WAITPID: i64 = 22   // waitpid(pid, status, opts) -> child_pid
const SYS_PIPE: i64 = 23      // pipe(fds_buf) -> 0
const SYS_KILL: i64 = 24      // kill(pid, signum) -> 0
const SYS_SIGNAL: i64 = 25    // signal(signum, handler) -> old_handler
const SYS_SETPGID: i64 = 26   // setpgid(pid, pgid) -> 0

// Process state constants
const PROC_STATE_FREE: i64 = 0
const PROC_STATE_READY: i64 = 1
const PROC_STATE_RUNNING: i64 = 2
const PROC_STATE_BLOCKED: i64 = 3
const PROC_STATE_ZOMBIE: i64 = 4

// Context frame: 15 GPRs + 5 IRETQ fields = 20 × 8 = 160 bytes
const CTX_FRAME_SIZE: i64 = 160
// GPR offsets from frame bottom (order: R15,R14,...,RBP,RDI,RSI,RDX,RCX,RBX,RAX,RIP,CS,RFLAGS,RSP,SS)
const CTX_OFF_RAX: i64 = 112   // RAX is 15th from bottom: 14*8=112
const CTX_OFF_RIP: i64 = 120   // RIP: 15*8=120

// SYS_FORK(20): create child process as copy of parent
@kernel fn sys_fork() -> i64 {
    let parent_pid = volatile_read_u64(0x6FE00)
    let parent_base = PROC_TABLE + parent_pid * PROC_ENTRY_SIZE

    // G1.1: Find free PID
    let mut child_pid: i64 = -1
    let mut i: i64 = 1
    while i < PROC_MAX && child_pid == -1 {
        if volatile_read(PROC_TABLE + i * PROC_ENTRY_SIZE + PROC_OFF_STATE) == PROC_STATE_FREE {
            child_pid = i
        }
        i = i + 1
    }
    if child_pid == -1 { return -1 } // no free PIDs

    // G1.2: Clone page tables (kernel entries + deep-copy user pages)
    let parent_cr3 = volatile_read(parent_base + PROC_OFF_CR3)
    let child_pml4 = fork_clone_page_tables(parent_cr3)
    if child_pml4 == -1 { return -1 }

    // G1.3: Copy FD table from parent to child
    fork_copy_fd_table(parent_pid, child_pid)
    fork_copy_uid(parent_pid, child_pid) // M3.7: inherit UID/GID

    // G1.4: Copy CWD, brk, and other proc fields
    let child_base = PROC_TABLE + child_pid * PROC_ENTRY_SIZE
    // Copy bytes 96-159 (brk, wake, cwd, etc.)
    let mut off: i64 = PROC_OFF_BRK
    while off < PROC_OFF_CWD + 32 {
        volatile_write_u8(child_base + off, volatile_read_u8(parent_base + off))
        off = off + 1
    }

    // G1.5: Build child kernel stack (copy parent's context frame)
    let child_kstack_base = KSTACK_BASE + child_pid * KSTACK_SIZE
    let child_kstack_top = child_kstack_base + KSTACK_SIZE - 16
    // Ensure kernel stack pages are mapped
    let mut pg: i64 = child_kstack_base
    while pg < child_kstack_base + KSTACK_SIZE {
        map_page(pg, pg, PAGE_PRESENT | PAGE_WRITABLE)
        frame_mark_used(pg / FRAME_SIZE)
        pg = pg + FRAME_SIZE
    }

    // Copy parent's saved context frame from parent kernel stack
    let parent_rsp = volatile_read(parent_base + PROC_OFF_RSP)
    let child_sp = child_kstack_top - CTX_FRAME_SIZE
    let mut ci: i64 = 0
    while ci < CTX_FRAME_SIZE {
        volatile_write_u8(child_sp + ci, volatile_read_u8(parent_rsp + ci))
        ci = ci + 1
    }

    // G1.7: Set child RAX=0 (fork returns 0 to child)
    // RAX is at frame_bottom + CTX_OFF_RAX
    volatile_write_u64(child_sp + CTX_OFF_RAX, 0)

    // G1.6: Set child process table entry
    volatile_write(child_base + PROC_OFF_STATE, PROC_STATE_READY)
    volatile_write(child_base + PROC_OFF_RSP, child_sp)
    volatile_write(child_base + PROC_OFF_ENTRY, volatile_read(parent_base + PROC_OFF_ENTRY))
    volatile_write(child_base + PROC_OFF_TICKS, 0)
    volatile_write(child_base + PROC_OFF_CR3, child_pml4)
    volatile_write(child_base + PROC_OFF_EXIT, 0)
    volatile_write(child_base + PROC_OFF_PPID, parent_pid)
    // Copy process name
    let mut ni: i64 = 0
    while ni < 16 {
        volatile_write_u8(child_base + PROC_OFF_NAME + ni, volatile_read_u8(parent_base + PROC_OFF_NAME + ni))
        ni = ni + 1
    }

    // Return child_pid to parent
    child_pid
}

// G1.2: Clone page tables — copy kernel entries, deep-copy user pages
@kernel fn fork_clone_page_tables(parent_pml4: i64) -> i64 {
    // Clone kernel PML4 first
    let child_pml4 = clone_kernel_pml4()
    if child_pml4 == -1 { return -1 }

    // Deep-copy user pages (PML4 entries where PAGE_USER is set)
    // Walk PML4 → PDPT → PD → PT for entries with PAGE_USER
    let mut pml4_idx: i64 = 0
    while pml4_idx < 512 {
        let pml4_entry = page_table_entry(parent_pml4, pml4_idx)
        if pml4_entry != 0 && (pml4_entry & PAGE_USER) != 0 {
            // This is a user-accessible entry — need to deep-copy the subtree
            let parent_pdpt = pml4_entry & 0xFFFFFFFFF000  // mask flags
            let child_pdpt = fork_copy_page_level(parent_pdpt, 3)
            if child_pdpt != -1 {
                page_table_set(child_pml4, pml4_idx, child_pdpt | (pml4_entry & 0xFFF))
            }
        }
        pml4_idx = pml4_idx + 1
    }

    child_pml4
}

// Deep-copy one level of page table hierarchy
// level: 3=PDPT, 2=PD, 1=PT
@kernel fn fork_copy_page_level(parent_table: i64, level: i64) -> i64 {
    let child_frame = frame_alloc()
    if child_frame == -1 { return -1 }
    let child_table = child_frame * FRAME_SIZE

    // Zero the new table
    let mut z: i64 = 0
    while z < 4096 { volatile_write_u8(child_table + z, 0); z = z + 1 }

    let mut idx: i64 = 0
    while idx < 512 {
        let entry = page_table_entry(parent_table, idx)
        if entry != 0 && (entry & PAGE_PRESENT) != 0 {
            if level == 1 {
                // L2.3: PT level — CoW share instead of deep-copy
                if (entry & PAGE_USER) != 0 {
                    // Share the page: mark parent read-only+CoW, child same
                    let phys = entry & 0xFFFFFFFFF000
                    let frame_idx = phys / FRAME_SIZE
                    let cow_flags = (entry & (0xFFF ^ PAGE_WRITABLE)) | PAGE_COW
                    // Mark parent as CoW (read-only)
                    page_table_set(parent_table, idx, phys | cow_flags)
                    // Child gets same mapping (CoW)
                    page_table_set(child_table, idx, phys | cow_flags)
                    // Set refcount
                    let rc = cow_refcount_get(frame_idx)
                    if rc == 0 { cow_refcount_set(frame_idx, 2) }
                    else { cow_refcount_inc(frame_idx) }
                } else {
                    // Kernel page at PT level — share directly
                    page_table_set(child_table, idx, entry)
                }
            } else {
                // Higher level: recurse
                if (entry & PAGE_USER) != 0 {
                    let subtable = entry & 0xFFFFFFFFF000
                    let child_subtable = fork_copy_page_level(subtable, level - 1)
                    if child_subtable != -1 {
                        page_table_set(child_table, idx, child_subtable | (entry & 0xFFF))
                    }
                } else {
                    // Kernel entry: share (don't deep-copy)
                    page_table_set(child_table, idx, entry)
                }
            }
        }
        idx = idx + 1
    }

    child_table
}

// G1.3: Copy FD table from parent to child (H1.9: pipe refcount increment)
@kernel fn fork_copy_fd_table(parent_pid: i64, child_pid: i64) {
    let mut fd: i64 = 0
    while fd < FD_MAX {
        let ftype = fd_v2_get_type(parent_pid, fd)
        let data = fd_v2_get_data(parent_pid, fd)
        fd_v2_set(child_pid, fd, ftype, data)
        // H1.9: Increment pipe refcounts on fork
        if ftype == FD_PIPE_READ {
            pipe_incref(data, 0) // is_writer=0
        }
        if ftype == FD_PIPE_WRITE {
            pipe_incref(data, 1) // is_writer=1
        }
        fd = fd + 1
    }
}

// G1.8: `sysfork` shell command (tests sys_fork syscall path)
@kernel fn cmd_sysfork_test() {
    cprintln("SysFork test:", YELLOW_ON_BLACK)
    cprintln("  Note: sys_fork() creates child with deep-copied page tables", WHITE_ON_BLACK)

    let child_pid = sys_fork()
    if child_pid < 0 {
        cprintln("  Fork failed: no free PIDs", RED_ON_BLACK)
    } else {
        cprint("  Forked child PID: ", WHITE_ON_BLACK)
        cprint_decimal(child_pid, GREEN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        cprint("  Child PPID: ", WHITE_ON_BLACK)
        let child_ppid = volatile_read(PROC_TABLE + child_pid * PROC_ENTRY_SIZE + PROC_OFF_PPID)
        cprint_decimal(child_ppid, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        cprint("  Child state: ", WHITE_ON_BLACK)
        let child_state = volatile_read(PROC_TABLE + child_pid * PROC_ENTRY_SIZE + PROC_OFF_STATE)
        cprint_decimal(child_state, CYAN_ON_BLACK)
        cprintln(" (1=READY)", WHITE_ON_BLACK)
    }
}

// ═══════════════════════════════════════════════
// SYS_EXEC (Sprint G2)
// ═══════════════════════════════════════════════

// ARGV_BUF at 0x8D6000: 8KB for argument passing
const ARGV_BUF: i64 = 0x8D6000
const ARGV_MAX: i64 = 16        // max 16 arguments
const ARGV_STR_SIZE: i64 = 256  // max 256 bytes per argument string

// SYS_EXEC(21): replace current process image with ELF from path
// path_addr: pointer to null-terminated filename string
// argv_addr: pointer to null-terminated argument list (0 = no args)
// Returns: does NOT return on success; returns -1 on failure
@kernel fn sys_exec(path_addr: i64, argv_addr: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE

    // G2.1: Find and load ELF file
    // Try ramfs first (for in-memory ELFs)
    let ramfs_idx = ramfs_find_by_addr(path_addr)
    let mut elf_loaded: i64 = 0

    if ramfs_idx >= 0 {
        // Load from ramfs into ELF_BUF
        let entry_addr = ramfs_entry_addr(ramfs_idx)
        let file_size = volatile_read(entry_addr + 32)
        let data_ptr = volatile_read(entry_addr + 40)
        if data_ptr == 0 || file_size == 0 { return -1 }
        // Copy to ELF_BUF
        let mut ci: i64 = 0
        while ci < file_size && ci < 0x10000 {
            volatile_write_u8(ELF_BUF + ci, volatile_read_u8(data_ptr + ci))
            ci = ci + 1
        }
        elf_loaded = file_size
    }

    // Try FAT32 if ramfs didn't find it
    if elf_loaded == 0 && fat32_state_read(0) == 1 {
        // Copy path to FAT32 name buffer
        let mut ni: i64 = 0
        while ni < 64 {
            let ch = volatile_read_u8(path_addr + ni)
            volatile_write_u8(FAT32_NAME_BUF + 256 + ni, ch)
            if ch == 0 { ni = 64 } else { ni = ni + 1 }
        }
        let root = fat32_state_read(48)
        let result = fat32_find_in_dir(root, FAT32_NAME_BUF + 256)
        if result != -1 {
            let shifted = result >> 32
            let file_cluster = shifted & 0x7FFFFFFF
            let file_size = result & 0xFFFFFFFF
            let bytes = fat32_read_file(file_cluster, file_size, ELF_BUF)
            if bytes > 0 { elf_loaded = bytes }
        }
    }

    if elf_loaded == 0 { return -1 } // file not found

    // Validate ELF
    let valid = elf_validate(ELF_BUF)
    if valid != 0 { return -1 }

    // G2.2: Free old user pages
    exec_free_user_pages(pid)

    // G2.3: Load new ELF segments
    let loaded = elf_load_segments(ELF_BUF, elf_loaded)
    if loaded == 0 { return -1 }

    let entry = elf_get_entry(ELF_BUF)

    // G2.4: Setup new user stack (64KB at ELF_STACK_TOP - 0x10000)
    let user_stack_base = ELF_STACK_TOP - 0x10000
    let mut pg: i64 = user_stack_base
    while pg < ELF_STACK_TOP {
        let frame = frame_alloc()
        if frame != -1 {
            map_page(pg, frame * FRAME_SIZE, PAGE_PRESENT | PAGE_WRITABLE | PAGE_USER)
        }
        pg = pg + FRAME_SIZE
    }

    // G2.5: Setup argv on user stack
    let user_rsp = exec_setup_argv(argv_addr)

    // G2.6: Reset close-on-exec FDs (close FDs 3+ for now)
    exec_reset_fds(pid)

    // G2.7: Reset signal handlers (future: clear signal table)
    // For now, nothing to reset — signal table not yet implemented

    // G2.8: Update process entry — rebuild context frame for Ring 3
    let kstack_top = KSTACK_BASE + pid * KSTACK_SIZE + KSTACK_SIZE - 16
    let mut sp = kstack_top

    // IRETQ frame for Ring 3
    sp = sp - 8; volatile_write_u64(sp, 0x1B)       // SS (user data RPL=3)
    sp = sp - 8; volatile_write_u64(sp, user_rsp)    // RSP (user stack)
    sp = sp - 8; volatile_write_u64(sp, 0x202)       // RFLAGS (IF=1)
    sp = sp - 8; volatile_write_u64(sp, 0x23)        // CS (user code RPL=3)
    sp = sp - 8; volatile_write_u64(sp, entry)        // RIP (ELF entry point)

    // 15 GPRs (zeroed — fresh start)
    let mut r: i64 = 0
    while r < 15 { sp = sp - 8; volatile_write_u64(sp, 0); r = r + 1 }

    // Update process table
    volatile_write(base + PROC_OFF_RSP, sp)
    volatile_write(base + PROC_OFF_ENTRY, entry)
    volatile_write(base + PROC_OFF_TICKS, 0)
    volatile_write(base + PROC_OFF_STATE, PROC_STATE_READY)
    // Reset heap break
    volatile_write_u64(base + PROC_OFF_BRK, 0)

    // exec never returns on success — the process will be scheduled
    // and resume at the new entry point via the timer ISR
    0
}

// G2.2: Free all user pages for a process (pages with PAGE_USER flag)
@kernel fn exec_free_user_pages(pid: i64) {
    // L2.1: Use CoW-aware page cleanup on exec
    // Release all CoW-tracked user pages (decrement refcounts)
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE
    let cr3 = volatile_read(base + PROC_OFF_CR3)
    if cr3 != 0 && cr3 != PML4_BASE {
        cow_release_pages(cr3)
    }
}

// G2.5: Setup argv on user stack, return adjusted RSP
@kernel fn exec_setup_argv(argv_addr: i64) -> i64 {
    let mut user_rsp = ELF_STACK_TOP - 8

    if argv_addr == 0 {
        // No arguments: argc=0, argv=NULL
        user_rsp = user_rsp - 8; volatile_write_u64(user_rsp, 0) // argv = NULL
        user_rsp = user_rsp - 8; volatile_write_u64(user_rsp, 0) // argc = 0
        return user_rsp
    }

    // Parse arguments from argv_addr (space-separated string or pointer array)
    // Simple: treat argv_addr as a space-separated string, copy to ARGV_BUF
    let mut argc: i64 = 0
    let mut pos: i64 = 0
    let mut arg_start: i64 = 0
    let mut in_arg: i64 = 0

    // First pass: count args and copy strings to ARGV_BUF
    let mut ch = volatile_read_u8(argv_addr + pos)
    while ch != 0 && argc < ARGV_MAX {
        if ch == 32 { // space
            if in_arg == 1 {
                // End of argument
                volatile_write_u8(ARGV_BUF + argc * ARGV_STR_SIZE + (pos - arg_start), 0)
                argc = argc + 1
                in_arg = 0
            }
        } else {
            if in_arg == 0 {
                arg_start = pos
                in_arg = 1
            }
            let offset = pos - arg_start
            if offset < ARGV_STR_SIZE - 1 {
                volatile_write_u8(ARGV_BUF + argc * ARGV_STR_SIZE + offset, ch)
            }
        }
        pos = pos + 1
        ch = volatile_read_u8(argv_addr + pos)
    }
    // Last arg
    if in_arg == 1 {
        volatile_write_u8(ARGV_BUF + argc * ARGV_STR_SIZE + (pos - arg_start), 0)
        argc = argc + 1
    }

    // Copy arg strings to user stack
    let mut arg_addrs: i64 = ARGV_BUF + ARGV_MAX * ARGV_STR_SIZE // temp storage for pointers
    let mut ai: i64 = 0
    while ai < argc {
        // Find string length
        let mut slen: i64 = 0
        while volatile_read_u8(ARGV_BUF + ai * ARGV_STR_SIZE + slen) != 0 { slen = slen + 1 }
        // Push string onto user stack
        user_rsp = user_rsp - (slen + 1)
        user_rsp = (user_rsp / 8) * 8 // 8-byte align
        let mut si: i64 = 0
        while si <= slen {
            volatile_write_u8(user_rsp + si, volatile_read_u8(ARGV_BUF + ai * ARGV_STR_SIZE + si))
            si = si + 1
        }
        // Store pointer
        volatile_write_u64(arg_addrs + ai * 8, user_rsp)
        ai = ai + 1
    }

    // Push NULL terminator for argv array
    user_rsp = user_rsp - 8; volatile_write_u64(user_rsp, 0)
    // Push argv pointers (reverse order so argv[0] is at lowest addr)
    let mut aj: i64 = argc - 1
    while aj >= 0 {
        user_rsp = user_rsp - 8
        volatile_write_u64(user_rsp, volatile_read_u64(arg_addrs + aj * 8))
        aj = aj - 1
    }
    let argv_base = user_rsp

    // Push argv pointer and argc (System V ABI: RDI=argc, RSI=argv)
    user_rsp = user_rsp - 8; volatile_write_u64(user_rsp, argv_base)
    user_rsp = user_rsp - 8; volatile_write_u64(user_rsp, argc)

    // Align to 16 bytes (System V ABI requirement)
    user_rsp = (user_rsp / 16) * 16 // 16-byte align (System V ABI)

    user_rsp
}

// G2.6: Reset FDs on exec (close non-stdio FDs)
@kernel fn exec_reset_fds(pid: i64) {
    // Keep FD 0 (stdin), 1 (stdout), 2 (stderr)
    // Close everything else (simple CLOEXEC behavior)
    let mut fd: i64 = 3
    while fd < FD_MAX {
        let ftype = fd_v2_get_type(pid, fd)
        if ftype != FD_CLOSED {
            fd_v2_set(pid, fd, FD_CLOSED, 0)
        }
        fd = fd + 1
    }
}

// ═══════════════════════════════════════════════
// SYS_WAITPID + Process Groups (Sprint G3)
// ═══════════════════════════════════════════════

// PROC_WAIT_TABLE at 0x8D2000: per-process wait state
// Per entry (16 bytes): +0=waiting_for_pid (i64), +8=options (i64)
const PROC_WAIT_TABLE: i64 = 0x8D2000
const WAIT_ENTRY_SIZE: i64 = 16

// waitpid options
const WNOHANG: i64 = 1

// Process group offset in proc table
const PROC_OFF_PGID: i64 = 120

// Exit status packing: bits 0-7 = signal, bits 8-15 = exit code
@kernel fn wait_pack_status(exit_code: i64, signal: i64) -> i64 {
    ((exit_code & 0xFF) << 8) | (signal & 0xFF)
}

@kernel fn wait_unpack_exit(status: i64) -> i64 {
    (status >> 8) & 0xFF
}

@kernel fn wait_unpack_signal(status: i64) -> i64 {
    status & 0xFF
}

// G3.1: SYS_WAITPID(22) — wait for child process
// pid: specific child PID, or -1 for any child
// status_addr: user buffer to write exit status (0 = don't write)
// options: WNOHANG (1) = return immediately if no child exited
@kernel fn sys_waitpid(pid: i64, status_addr: i64, options: i64) -> i64 {
    let parent_pid = volatile_read_u64(0x6FE00)

    // G3.4: Wait for any child (pid == -1)
    if pid == -1 {
        return waitpid_any(parent_pid, status_addr, options)
    }

    // Wait for specific child
    if pid < 1 || pid >= PROC_MAX { return -1 }
    let child_base = PROC_TABLE + pid * PROC_ENTRY_SIZE

    // Verify this is actually our child
    let child_ppid = volatile_read(child_base + PROC_OFF_PPID)
    if child_ppid != parent_pid { return -1 }

    let state = volatile_read(child_base + PROC_OFF_STATE)

    // G3.6: If child is ZOMBIE, reap immediately
    if state == PROC_STATE_ZOMBIE {
        let exit_code = volatile_read(child_base + PROC_OFF_EXIT)
        let status = wait_pack_status(exit_code, 0) // normal exit, signal=0
        if status_addr != 0 {
            volatile_write_u64(status_addr, status)
        }
        // Reap: free the slot
        volatile_write(child_base + PROC_OFF_STATE, PROC_STATE_FREE)
        volatile_write(child_base + PROC_OFF_TICKS, 0)
        volatile_write(child_base + PROC_OFF_ENTRY, 0)
        return pid
    }

    // G3.3: WNOHANG — return 0 if child hasn't exited yet
    if (options & WNOHANG) != 0 {
        return 0
    }

    // G3.2: Block parent until child exits
    // Store wait state and block
    volatile_write_u64(PROC_WAIT_TABLE + parent_pid * WAIT_ENTRY_SIZE, pid)
    volatile_write_u64(PROC_WAIT_TABLE + parent_pid * WAIT_ENTRY_SIZE + 8, options)
    volatile_write(PROC_TABLE + parent_pid * PROC_ENTRY_SIZE + PROC_OFF_STATE, PROC_STATE_BLOCKED)

    // The parent is now BLOCKED. When the child exits (process_exit_v2),
    // it will wake the parent by setting state=READY and storing the result.
    // For now, busy-wait fallback for PID 0 (shell doesn't get descheduled)
    if parent_pid == 0 {
        waitpid_busy_wait(pid, child_base, status_addr, parent_pid)
    } else {
        // For non-shell processes: the scheduler will resume us when child exits
        0
    }
}

// Busy-wait fallback for PID 0 (shell)
@kernel fn waitpid_busy_wait(pid: i64, child_base: i64, status_addr: i64, parent_pid: i64) -> i64 {
    waitpid_spin(child_base)
    let exit_code = volatile_read(child_base + PROC_OFF_EXIT)
    let status = wait_pack_status(exit_code, 0)
    waitpid_write_status(status_addr, status)
    waitpid_reap_child(child_base, parent_pid)
    pid
}

@kernel fn waitpid_spin(child_base: i64) {
    while volatile_read(child_base + PROC_OFF_STATE) != PROC_STATE_ZOMBIE { hlt() }
}

@kernel fn waitpid_reap_child(child_base: i64, parent_pid: i64) {
    volatile_write(child_base + PROC_OFF_STATE, PROC_STATE_FREE)
    volatile_write(child_base + PROC_OFF_TICKS, 0)
    volatile_write(child_base + PROC_OFF_ENTRY, 0)
    volatile_write(PROC_TABLE + parent_pid * PROC_ENTRY_SIZE + PROC_OFF_STATE, PROC_STATE_RUNNING)
}

@kernel fn waitpid_write_status(addr: i64, status: i64) {
    if addr != 0 { volatile_write_u64(addr, status) }
}

// G3.4: Wait for any child
@kernel fn waitpid_any(parent_pid: i64, status_addr: i64, options: i64) -> i64 {
    // Scan all PIDs for zombie children of this parent
    let mut i: i64 = 1
    while i < PROC_MAX {
        let child_base = PROC_TABLE + i * PROC_ENTRY_SIZE
        let child_ppid = volatile_read(child_base + PROC_OFF_PPID)
        let child_state = volatile_read(child_base + PROC_OFF_STATE)
        if child_ppid == parent_pid && child_state == PROC_STATE_ZOMBIE {
            let exit_code = volatile_read(child_base + PROC_OFF_EXIT)
            let status = wait_pack_status(exit_code, 0)
            if status_addr != 0 {
                volatile_write_u64(status_addr, status)
            }
            // Reap
            volatile_write(child_base + PROC_OFF_STATE, PROC_STATE_FREE)
            volatile_write(child_base + PROC_OFF_TICKS, 0)
            volatile_write(child_base + PROC_OFF_ENTRY, 0)
            return i
        }
        i = i + 1
    }

    // No zombie child found
    if (options & WNOHANG) != 0 { return 0 }

    // Check if we have any children at all
    let mut has_children: i64 = 0
    i = 1
    while i < PROC_MAX {
        let child_ppid = volatile_read(PROC_TABLE + i * PROC_ENTRY_SIZE + PROC_OFF_PPID)
        let child_state = volatile_read(PROC_TABLE + i * PROC_ENTRY_SIZE + PROC_OFF_STATE)
        if child_ppid == parent_pid && child_state != PROC_STATE_FREE { has_children = 1 }
        i = i + 1
    }
    if has_children == 0 { return -1 } // no children at all

    // Block and wait (same mechanism as specific pid)
    volatile_write_u64(PROC_WAIT_TABLE + parent_pid * WAIT_ENTRY_SIZE, -1)
    volatile_write(PROC_TABLE + parent_pid * PROC_ENTRY_SIZE + PROC_OFF_STATE, PROC_STATE_BLOCKED)
    0
}

// G3.7: Reparent orphaned children to init (PID 1)
@kernel fn reparent_children(exiting_pid: i64) {
    let mut i: i64 = 1
    while i < PROC_MAX {
        let child_base = PROC_TABLE + i * PROC_ENTRY_SIZE
        let child_ppid = volatile_read(child_base + PROC_OFF_PPID)
        let child_state = volatile_read(child_base + PROC_OFF_STATE)
        if child_ppid == exiting_pid && child_state != PROC_STATE_FREE {
            // Reparent to init (PID 1)
            volatile_write(child_base + PROC_OFF_PPID, 1)
            // If child is zombie, init will auto-reap
            if child_state == PROC_STATE_ZOMBIE {
                volatile_write(child_base + PROC_OFF_STATE, PROC_STATE_FREE)
                volatile_write(child_base + PROC_OFF_TICKS, 0)
            }
        }
        i = i + 1
    }
}

// Wake parent that is waiting in waitpid
@kernel fn wake_waiting_parent(child_pid: i64, exit_code: i64) {
    let child_base = PROC_TABLE + child_pid * PROC_ENTRY_SIZE
    let parent_pid = volatile_read(child_base + PROC_OFF_PPID)
    if parent_pid <= 0 || parent_pid >= PROC_MAX { return }

    let parent_base = PROC_TABLE + parent_pid * PROC_ENTRY_SIZE
    let parent_state = volatile_read(parent_base + PROC_OFF_STATE)

    // Only wake if parent is actually BLOCKED (in waitpid)
    if parent_state == PROC_STATE_BLOCKED {
        let wait_pid = volatile_read_u64(PROC_WAIT_TABLE + parent_pid * WAIT_ENTRY_SIZE)
        // Check if parent is waiting for this specific child or any child (-1)
        if wait_pid == child_pid || wait_pid == -1 {
            volatile_write(parent_base + PROC_OFF_STATE, PROC_STATE_READY)
        }
    }
}

// Enhanced process_exit that handles reparenting + parent waking
@kernel fn process_exit_v2(exit_code: i64) {
    let pid = volatile_read(0x6FE00)
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE

    // Set ZOMBIE state and exit code
    volatile_write(base + PROC_OFF_STATE, PROC_STATE_ZOMBIE)
    volatile_write(base + PROC_OFF_EXIT, exit_code)

    // G3.7: Reparent any children to init
    reparent_children(pid)

    // Wake parent if waiting
    wake_waiting_parent(pid, exit_code)

    // Close all FDs
    let mut fd: i64 = 0
    while fd < FD_MAX {
        fd_v2_set(pid, fd, FD_CLOSED, 0)
        fd = fd + 1
    }

    // Print exit message
    cprint("[PROC] PID ", WHITE_ON_BLACK)
    cprint_decimal(pid, CYAN_ON_BLACK)
    cprint(" exited (code ", WHITE_ON_BLACK)
    cprint_decimal(exit_code, CYAN_ON_BLACK)
    cprintln(")", WHITE_ON_BLACK)

    // Halt — scheduler will skip ZOMBIE processes
    while 1 == 1 { hlt() }
}

// G3.8: Process groups (PGID)
@kernel fn sys_setpgid(pid: i64, pgid: i64) -> i64 {
    let target_pid = if pid == 0 { volatile_read_u64(0x6FE00) } else { pid }
    if target_pid < 0 || target_pid >= PROC_MAX { return -1 }
    let target_pgid = if pgid == 0 { target_pid } else { pgid }
    volatile_write(PROC_TABLE + target_pid * PROC_ENTRY_SIZE + PROC_OFF_PGID, target_pgid)
    0
}

@kernel fn sys_getpgid(pid: i64) -> i64 {
    let target_pid = if pid == 0 { volatile_read_u64(0x6FE00) } else { pid }
    if target_pid < 0 || target_pid >= PROC_MAX { return -1 }
    volatile_read(PROC_TABLE + target_pid * PROC_ENTRY_SIZE + PROC_OFF_PGID)
}

// G3.9: `waitpid` shell command
@kernel fn cmd_waitpid() {
    let len = cmdbuf_len()
    if len <= 5 {
        cprintln("Usage: wait <pid>", YELLOW_ON_BLACK)
        return
    }
    // Parse PID from "wait N"
    let pid_ch = volatile_read_u8(0x6F800 + 5)
    let target_pid = pid_ch - 48 // ASCII digit to number
    if target_pid < 1 || target_pid > 15 {
        cprintln("Invalid PID (1-15)", RED_ON_BLACK)
        return
    }
    cprint("Waiting for PID ", WHITE_ON_BLACK)
    cprint_decimal(target_pid, CYAN_ON_BLACK)
    cprintln("...", WHITE_ON_BLACK)

    let result = sys_waitpid(target_pid, 0, 0)
    if result == -1 {
        cprintln("  Not a child process or not found", RED_ON_BLACK)
    } else {
        cprint("  PID ", WHITE_ON_BLACK)
        cprint_decimal(result, CYAN_ON_BLACK)
        cprintln(" reaped", GREEN_ON_BLACK)
    }
}

// ═══════════════════════════════════════════════
// Shell Pipe & Redirect (Sprint H2)
// ═══════════════════════════════════════════════

// Scratch buffer for split commands (0x842000, 1KB each side)
const SHELL_SPLIT_BUF: i64 = 0x842000
const SHELL_SPLIT_BUF2: i64 = 0x842400

// H2.1: Scan cmdbuf for pipe character '|' (ASCII 124)
@kernel fn shell_find_pipe() -> i64 {
    let len = cmdbuf_len()
    let mut i: i64 = 0
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch == 124 { return i } // '|' found at position i
        i = i + 1
    }
    -1 // no pipe
}

// H2.5: Scan cmdbuf for redirect operators
// Returns: 0=none, 1='>' (truncate), 2='>>' (append), 3='<' (input)
@kernel fn shell_find_redirect() -> i64 {
    let len = cmdbuf_len()
    let mut i: i64 = 0
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch == 62 { // '>'
            if i + 1 < len && volatile_read_u8(0x6F800 + i + 1) == 62 {
                return 200 + i // '>>' at position i (encoded as 200+pos)
            }
            return 100 + i // '>' at position i (encoded as 100+pos)
        }
        if ch == 60 { return 300 + i } // '<' at position i (encoded as 300+pos)
        i = i + 1
    }
    0
}

// Copy part of cmdbuf to a buffer (with trimming)
@kernel fn shell_copy_segment(src_start: i64, src_end: i64, dst: i64) -> i64 {
    // Skip leading spaces
    let mut start = src_start
    while start < src_end && volatile_read_u8(0x6F800 + start) == 32 { start = start + 1 }
    // Skip trailing spaces
    let mut end = src_end
    while end > start && volatile_read_u8(0x6F800 + end - 1) == 32 { end = end - 1 }
    // Copy
    let len = end - start
    let mut i: i64 = 0
    while i < len {
        volatile_write_u8(dst + i, volatile_read_u8(0x6F800 + start + i))
        i = i + 1
    }
    volatile_write_u8(dst + len, 0)
    len
}

// Execute a command from a buffer (not cmdbuf) — copies to cmdbuf then dispatches
@kernel fn shell_exec_from_buf(buf: i64, len: i64) {
    // Save current cmdbuf
    let saved_len = cmdbuf_len()
    let saved_buf: i64 = 0x843000 // temp save area
    let mut si: i64 = 0
    while si < saved_len { volatile_write_u8(saved_buf + si, volatile_read_u8(0x6F800 + si)); si = si + 1 }
    volatile_write_u8(saved_buf + saved_len, 0)

    // Install new command into cmdbuf
    cmdbuf_clear()
    let mut ci: i64 = 0
    while ci < len {
        volatile_write_u8(0x6F800 + ci, volatile_read_u8(buf + ci))
        ci = ci + 1
    }
    volatile_write_u8(0x6F800 + len, 0)
    volatile_write(0x6F880, len)

    // Dispatch
    dispatch_command()

    // Restore cmdbuf
    cmdbuf_clear()
    let mut ri: i64 = 0
    while ri < saved_len { volatile_write_u8(0x6F800 + ri, volatile_read_u8(saved_buf + ri)); ri = ri + 1 }
    volatile_write_u8(0x6F800 + saved_len, 0)
    volatile_write(0x6F880, saved_len)
}

// H2.2: Execute single pipe: cmd1 | cmd2
// Since we don't have real fork+exec in kernel shell (Ring 0), we simulate:
// 1. Create pipe
// 2. Execute cmd1 with stdout redirected to pipe write end
// 3. Execute cmd2 with stdin redirected to pipe read end
@kernel fn shell_exec_pipe(pipe_pos: i64) {
    let len = cmdbuf_len()

    // Split at pipe position
    let len1 = shell_copy_segment(0, pipe_pos, SHELL_SPLIT_BUF)
    let len2 = shell_copy_segment(pipe_pos + 1, len, SHELL_SPLIT_BUF2)

    if len1 == 0 || len2 == 0 {
        cprintln("Syntax error: empty pipe segment", RED_ON_BLACK)
        return
    }

    // Create pipe
    let slot = pipe_create()
    if slot < 0 { cprintln("No free pipes", RED_ON_BLACK); return }

    // Initialize pipe refcounts
    let ref_base = PIPE_REFCOUNT + slot * 16
    volatile_write_u64(ref_base, 1)     // reader
    volatile_write_u64(ref_base + 8, 1) // writer

    // Execute cmd1: redirect stdout (FD 1) to pipe write end
    let pid = volatile_read_u64(0x6FE00)
    let saved_fd1_type = fd_v2_get_type(pid, 1)
    let saved_fd1_data = fd_v2_get_data(pid, 1)
    fd_v2_set(pid, 1, FD_PIPE_WRITE, slot) // stdout → pipe

    shell_exec_from_buf(SHELL_SPLIT_BUF, len1)

    // Restore stdout
    fd_v2_set(pid, 1, saved_fd1_type, saved_fd1_data)

    // Close write end (signal EOF to reader)
    volatile_write_u64(ref_base + 8, 0) // writer_count = 0

    // Execute cmd2: redirect stdin (FD 0) to pipe read end
    let saved_fd0_type = fd_v2_get_type(pid, 0)
    let saved_fd0_data = fd_v2_get_data(pid, 0)
    fd_v2_set(pid, 0, FD_PIPE_READ, slot) // stdin → pipe

    shell_exec_from_buf(SHELL_SPLIT_BUF2, len2)

    // Restore stdin
    fd_v2_set(pid, 0, saved_fd0_type, saved_fd0_data)

    // Free pipe
    pipe_free(slot)
    volatile_write_u64(ref_base, 0)
}

// H2.5/H2.6/H2.7: Execute with I/O redirection
@kernel fn shell_exec_redirect(redirect_info: i64) {
    let len = cmdbuf_len()
    let pid = volatile_read_u64(0x6FE00)

    if redirect_info >= 300 {
        // H2.7: Input redirect '<'
        let pos = redirect_info - 300
        let cmd_len = shell_copy_segment(0, pos, SHELL_SPLIT_BUF)
        let file_len = shell_copy_segment(pos + 1, len, SHELL_SPLIT_BUF2)
        if cmd_len == 0 || file_len == 0 { cprintln("Syntax error", RED_ON_BLACK); return }

        // Open file for reading
        let fd = sys_open(SHELL_SPLIT_BUF2, 0)
        if fd < 0 { cprintln("File not found", RED_ON_BLACK); return }

        // Redirect stdin
        let saved_type = fd_v2_get_type(pid, 0)
        let saved_data = fd_v2_get_data(pid, 0)
        let file_type = fd_v2_get_type(pid, fd)
        let file_data = fd_v2_get_data(pid, fd)
        fd_v2_set(pid, 0, file_type, file_data)

        shell_exec_from_buf(SHELL_SPLIT_BUF, cmd_len)

        // Restore stdin
        fd_v2_set(pid, 0, saved_type, saved_data)
        sys_close(fd)

    } else if redirect_info >= 200 {
        // H2.6: Append redirect '>>'
        let pos = redirect_info - 200
        let cmd_len = shell_copy_segment(0, pos, SHELL_SPLIT_BUF)
        let file_len = shell_copy_segment(pos + 2, len, SHELL_SPLIT_BUF2)
        if cmd_len == 0 || file_len == 0 { cprintln("Syntax error", RED_ON_BLACK); return }

        shell_exec_redirect_output(cmd_len, file_len, 1) // append=1

    } else if redirect_info >= 100 {
        // H2.5: Truncate redirect '>'
        let pos = redirect_info - 100
        let cmd_len = shell_copy_segment(0, pos, SHELL_SPLIT_BUF)
        let file_len = shell_copy_segment(pos + 1, len, SHELL_SPLIT_BUF2)
        if cmd_len == 0 || file_len == 0 { cprintln("Syntax error", RED_ON_BLACK); return }

        shell_exec_redirect_output(cmd_len, file_len, 0) // append=0
    }
}

// Helper: redirect stdout to file for command execution
@kernel fn shell_exec_redirect_output(cmd_len: i64, file_len: i64, append: i64) {
    let pid = volatile_read_u64(0x6FE00)

    // Create or open file in ramfs
    let idx = ramfs_find_by_addr(SHELL_SPLIT_BUF2)
    let mut target_idx = idx
    if target_idx < 0 {
        // Create new file
        // Need to pass as str — write filename bytes, then create
        target_idx = ramfs_create_by_addr(SHELL_SPLIT_BUF2)
        if target_idx < 0 { cprintln("Cannot create file", RED_ON_BLACK); return }
    }

    // If truncate mode, reset file size to 0
    if append == 0 {
        let entry_addr = ramfs_entry_addr(target_idx)
        volatile_write(entry_addr + 32, 0) // size = 0
    }

    // Open file FD (with offset at end for append, 0 for truncate)
    let fd = fd_v2_alloc(pid)
    if fd < 0 { cprintln("No free FDs", RED_ON_BLACK); return }
    let offset = if append == 1 {
        let entry_addr = ramfs_entry_addr(target_idx)
        volatile_read(entry_addr + 32) // current size = end
    } else { 0 }
    let packed_data = (offset << 32) | target_idx
    fd_v2_set(pid, fd, FD_RAMFS, packed_data)

    // Redirect stdout to file FD
    let saved_type = fd_v2_get_type(pid, 1)
    let saved_data = fd_v2_get_data(pid, 1)
    fd_v2_set(pid, 1, FD_RAMFS, packed_data)

    shell_exec_from_buf(SHELL_SPLIT_BUF, cmd_len)

    // Restore stdout and close file FD
    fd_v2_set(pid, 1, saved_type, saved_data)
    // Update file size from the written offset
    let written_data = fd_v2_get_data(pid, 1)
    fd_v2_set(pid, fd, FD_CLOSED, 0)
}

// Helper: create ramfs file by address (null-terminated name)
@kernel fn ramfs_create_by_addr(name_addr: i64) -> i64 {
    let count = volatile_read(FS_BASE)
    if count >= FS_MAX_FILES { return -1 }
    let addr = ramfs_entry_addr(count)
    // Write name
    let mut i: i64 = 0
    while i < 31 {
        let ch = volatile_read_u8(name_addr + i)
        volatile_write_u8(addr + i, ch)
        if ch == 0 { i = 31 } else { i = i + 1 }
    }
    volatile_write_u8(addr + i, 0)
    // Set type = file, allocate data space
    volatile_write(addr + 48, 1) // type = file
    volatile_write(addr + 32, 0) // size = 0
    let data_offset = volatile_read(FS_BASE + 8)
    volatile_write(addr + 40, data_offset) // data_ptr
    volatile_write(FS_BASE + 8, data_offset + 4096) // reserve 4KB
    volatile_write(FS_BASE, count + 1)
    count
}

// H2.9: List of builtins that must NOT be forked (run in shell process)
@kernel fn is_shell_builtin(c0: i64, c1: i64) -> i64 {
    // cd (99,100)
    if c0 == 99 && c1 == 100 { return 1 }
    // export (first 2 chars: 101,120)
    if c0 == 101 && c1 == 120 { return 1 }
    // set (115,101)
    if c0 == 115 && c1 == 101 { return 1 }
    // exit (101,120) — same prefix as export, check len later
    0
}

// Main entry point: preprocess pipe/redirect before dispatch
@kernel fn shell_execute() {
    let len = cmdbuf_len()
    if len == 0 { return }

    // Check for pipe first
    let pipe_pos = shell_find_pipe()
    if pipe_pos > 0 {
        shell_exec_pipe(pipe_pos)
        return
    }

    // Check for redirects
    let redir = shell_find_redirect()
    if redir > 0 {
        shell_exec_redirect(redir)
        return
    }

    // No pipe or redirect — normal dispatch
    dispatch_command()
}

// ═══════════════════════════════════════════════
// SYS_PIPE + Pipe FD Integration (Sprint H1)
// ═══════════════════════════════════════════════

// Pipe refcount table at 0x8D4000: 8 pipes × 16 bytes
// Per pipe: +0=reader_count(i64), +8=writer_count(i64)
const PIPE_REFCOUNT: i64 = 0x8D4000

// Circular pipe buffer constants
const PIPE_BUF_OFFSET: i64 = 32    // data starts at offset 32 in each 4KB pipe
const PIPE_BUF_SIZE: i64 = 4064    // 4096 - 32 = 4064 bytes usable

// H1.1: SYS_PIPE(23) — create pipe, return read/write FDs
@kernel fn sys_pipe(fds_addr: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)

    // Create pipe slot
    let slot = pipe_create()
    if slot < 0 { return -1 }

    // Allocate 2 FDs: read end and write end
    let read_fd = fd_v2_alloc(pid)
    if read_fd < 0 { return -1 }
    fd_v2_set(pid, read_fd, FD_PIPE_READ, slot)

    let write_fd = fd_v2_alloc(pid)
    if write_fd < 0 {
        fd_v2_set(pid, read_fd, FD_CLOSED, 0)
        return -1
    }
    fd_v2_set(pid, write_fd, FD_PIPE_WRITE, slot)

    // Initialize refcounts
    let ref_base = PIPE_REFCOUNT + slot * 16
    volatile_write_u64(ref_base, 1)     // reader_count = 1
    volatile_write_u64(ref_base + 8, 1) // writer_count = 1

    // Write FD pair to user buffer: [read_fd, write_fd]
    if fds_addr != 0 {
        volatile_write_u64(fds_addr, read_fd)
        volatile_write_u64(fds_addr + 8, write_fd)
    }

    0
}

// H1.2: Pipe refcount helpers
@kernel fn pipe_incref(slot: i64, is_writer: i64) {
    let ref_base = PIPE_REFCOUNT + slot * 16
    if is_writer != 0 {
        let count = volatile_read_u64(ref_base + 8)
        volatile_write_u64(ref_base + 8, count + 1)
    } else {
        let count = volatile_read_u64(ref_base)
        volatile_write_u64(ref_base, count + 1)
    }
}

@kernel fn pipe_decref(slot: i64, is_writer: i64) -> i64 {
    let ref_base = PIPE_REFCOUNT + slot * 16
    if is_writer != 0 {
        let count = volatile_read_u64(ref_base + 8)
        let new_count = if count > 0 { count - 1 } else { 0 }
        volatile_write_u64(ref_base + 8, new_count)
    } else {
        let count = volatile_read_u64(ref_base)
        let new_count = if count > 0 { count - 1 } else { 0 }
        volatile_write_u64(ref_base, new_count)
    }
    // Return 1 if pipe is fully closed (both counts = 0)
    let rc = volatile_read_u64(ref_base)
    let wc = volatile_read_u64(ref_base + 8)
    if rc == 0 && wc == 0 { 1 } else { 0 }
}

@kernel fn pipe_has_writers(slot: i64) -> i64 {
    volatile_read_u64(PIPE_REFCOUNT + slot * 16 + 8)
}

@kernel fn pipe_has_readers(slot: i64) -> i64 {
    volatile_read_u64(PIPE_REFCOUNT + slot * 16)
}

// H1.8: Circular pipe read/write (replaces linear pipe_read/pipe_write for FD use)
@kernel fn pipe_read_circular(slot: i64, buf: i64, len: i64) -> i64 {
    let pipe_base = PIPE_POOL + slot * 4096
    let read_pos = volatile_read_u64(pipe_base + 8)
    let write_pos = volatile_read_u64(pipe_base + 16)

    // Calculate available bytes (circular)
    let available = (write_pos - read_pos + PIPE_BUF_SIZE) % PIPE_BUF_SIZE
    if write_pos == read_pos {
        // H1.5: Empty pipe — check if writers exist
        if pipe_has_writers(slot) == 0 { return 0 } // EOF
        return -2 // would block (no data, writers exist)
    }

    let to_read = if len < available { len } else { available }
    let mut i: i64 = 0
    while i < to_read {
        let pos = (read_pos + i) % PIPE_BUF_SIZE
        volatile_write_u8(buf + i, volatile_read_u8(pipe_base + PIPE_BUF_OFFSET + pos))
        i = i + 1
    }
    volatile_write_u64(pipe_base + 8, (read_pos + to_read) % PIPE_BUF_SIZE)
    to_read
}

@kernel fn pipe_write_circular(slot: i64, data: i64, len: i64) -> i64 {
    let pipe_base = PIPE_POOL + slot * 4096
    let read_pos = volatile_read_u64(pipe_base + 8)
    let write_pos = volatile_read_u64(pipe_base + 16)

    // H1.7: Check if readers exist (broken pipe)
    if pipe_has_readers(slot) == 0 { return -1 }

    // Calculate free space (circular, leave 1 byte to distinguish full from empty)
    let used = (write_pos - read_pos + PIPE_BUF_SIZE) % PIPE_BUF_SIZE
    let free = PIPE_BUF_SIZE - 1 - used
    if free <= 0 { return -2 } // pipe full, would block

    let to_write = if len < free { len } else { free }
    let mut i: i64 = 0
    while i < to_write {
        let pos = (write_pos + i) % PIPE_BUF_SIZE
        volatile_write_u8(pipe_base + PIPE_BUF_OFFSET + pos, volatile_read_u8(data + i))
        i = i + 1
    }
    volatile_write_u64(pipe_base + 16, (write_pos + to_write) % PIPE_BUF_SIZE)
    to_write
}

// Free a pipe slot (clear in_use flag + reset positions)
@kernel fn pipe_free(slot: i64) {
    let pipe_base = PIPE_POOL + slot * 4096
    volatile_write_u64(pipe_base, 0)      // in_use = 0
    volatile_write_u64(pipe_base + 8, 0)  // read_pos = 0
    volatile_write_u64(pipe_base + 16, 0) // write_pos = 0
}

// ═══════════════════════════════════════════════
// Signal Infrastructure (Sprint I1)
// ═══════════════════════════════════════════════

// Signal table at 0x8D1000: 16 procs × 64 bytes each = 1024 bytes
// Per process: +0=pending_bitmap(i64), +8=mask_bitmap(i64),
//              +16=handler[0..7] (8 × 8 bytes = handlers for signals 0-7)
// Only 8 signal slots stored (to fit 64 bytes): SIGHUP(0), SIGINT(1), SIGKILL(2),
// SIGSEGV(3), SIGTERM(4), SIGCHLD(5), SIGSTOP(6), SIGCONT(7)
// We map standard POSIX numbers → our internal slot index
const SIGNAL_TABLE: i64 = 0x8D1000
const SIG_ENTRY_SIZE: i64 = 64
const SIG_OFF_PENDING: i64 = 0
const SIG_OFF_MASK: i64 = 8
const SIG_OFF_HANDLERS: i64 = 16
const SIG_MAX_SLOTS: i64 = 8

// I1.2: Signal numbers (POSIX standard)
const SIGHUP: i64 = 1
const SIGINT: i64 = 2
const SIGKILL: i64 = 9
const SIGSEGV: i64 = 11
const SIGTERM: i64 = 15
const SIGCHLD: i64 = 17
const SIGCONT: i64 = 18
const SIGSTOP: i64 = 19
const SIGTSTP: i64 = 20

// Special handler values
const SIG_DFL: i64 = 0   // default handler
const SIG_IGN: i64 = 1   // ignore signal

// Map POSIX signal number to internal slot (0-7)
@kernel fn sig_to_slot(signum: i64) -> i64 {
    if signum == SIGHUP { 0 }
    else if signum == SIGINT { 1 }
    else if signum == SIGKILL { 2 }
    else if signum == SIGSEGV { 3 }
    else if signum == SIGTERM { 4 }
    else if signum == SIGCHLD { 5 }
    else if signum == SIGSTOP { 6 }
    else if signum == SIGCONT { 7 }
    else { -1 }
}

// I1.1: Signal table helpers
@kernel fn sig_entry_addr(pid: i64) -> i64 {
    SIGNAL_TABLE + pid * SIG_ENTRY_SIZE
}

@kernel fn sig_init(pid: i64) {
    let base = sig_entry_addr(pid)
    volatile_write_u64(base + SIG_OFF_PENDING, 0)
    volatile_write_u64(base + SIG_OFF_MASK, 0)
    let mut i: i64 = 0
    while i < SIG_MAX_SLOTS {
        volatile_write_u64(base + SIG_OFF_HANDLERS + i * 8, SIG_DFL)
        i = i + 1
    }
}

// I1.5: Set signal as pending
@kernel fn signal_send(pid: i64, signum: i64) -> i64 {
    if pid < 0 || pid >= PROC_MAX { return -1 }
    let slot = sig_to_slot(signum)
    if slot < 0 { return -1 }

    let base = sig_entry_addr(pid)
    let pending = volatile_read_u64(base + SIG_OFF_PENDING)
    volatile_write_u64(base + SIG_OFF_PENDING, pending | (1 << slot))

    // I1.4: Handle SIGKILL immediately — cannot be caught or ignored
    if signum == SIGKILL {
        signal_deliver_default(pid, signum)
    }
    // SIGCONT: wake stopped process
    if signum == SIGCONT {
        let state = volatile_read(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_STATE)
        if state == PROC_STATE_BLOCKED {
            volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_STATE, PROC_STATE_READY)
        }
    }
    0
}

// I1.4: Default signal action
@kernel fn signal_deliver_default(pid: i64, signum: i64) {
    if signum == SIGKILL || signum == SIGTERM || signum == SIGINT || signum == SIGHUP || signum == SIGSEGV {
        // Terminate process
        let base = PROC_TABLE + pid * PROC_ENTRY_SIZE
        volatile_write(base + PROC_OFF_STATE, PROC_STATE_ZOMBIE)
        volatile_write(base + PROC_OFF_EXIT, 128 + signum) // exit code = 128 + signal
        // Reparent children
        reparent_children(pid)
        // Wake parent
        wake_waiting_parent(pid, 128 + signum)
        // Close FDs
        let mut fd: i64 = 0
        while fd < FD_MAX { fd_v2_set(pid, fd, FD_CLOSED, 0); fd = fd + 1 }
    }
    if signum == SIGSTOP || signum == SIGTSTP {
        // Stop process
        volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_STATE, PROC_STATE_BLOCKED)
    }
    // SIGCHLD, SIGCONT: default = ignore (no action needed)
}

// I1.6: Check and deliver pending signals (called before return-to-user)
@kernel fn signal_check_pending(pid: i64) -> i64 {
    let base = sig_entry_addr(pid)
    let pending = volatile_read_u64(base + SIG_OFF_PENDING)
    let mask = volatile_read_u64(base + SIG_OFF_MASK)
    let xor_mask = mask ^ 0xFF
    let deliverable = pending & xor_mask

    if deliverable == 0 { 0 }
    else { signal_deliver_first(pid, base, pending, deliverable) }
}

// Helper: deliver the first pending signal (avoids deep nesting)
@kernel fn signal_deliver_first(pid: i64, base: i64, pending: i64, deliverable: i64) -> i64 {
    let slot = signal_find_first_bit(deliverable)
    if slot < 0 { 0 }
    else {
        // Clear pending bit
        let clear_mask = 0xFF ^ (1 << slot)
        volatile_write_u64(base + SIG_OFF_PENDING, pending & clear_mask)
        // Dispatch to handler
        let handler = volatile_read_u64(base + SIG_OFF_HANDLERS + slot * 8)
        if handler == SIG_DFL {
            signal_deliver_default(pid, slot_to_signum(slot))
        }
        // SIG_IGN: do nothing. Custom handlers: future sprint.
        slot + 1
    }
}

// Find lowest set bit in bitmap (0-7)
@kernel fn signal_find_first_bit(bitmap: i64) -> i64 {
    if (bitmap & 1) != 0 { 0 }
    else if (bitmap & 2) != 0 { 1 }
    else if (bitmap & 4) != 0 { 2 }
    else if (bitmap & 8) != 0 { 3 }
    else if (bitmap & 16) != 0 { 4 }
    else if (bitmap & 32) != 0 { 5 }
    else if (bitmap & 64) != 0 { 6 }
    else if (bitmap & 128) != 0 { 7 }
    else { -1 }
}

// Map slot back to POSIX signal number
@kernel fn slot_to_signum(slot: i64) -> i64 {
    if slot == 0 { SIGHUP }
    else if slot == 1 { SIGINT }
    else if slot == 2 { SIGKILL }
    else if slot == 3 { SIGSEGV }
    else if slot == 4 { SIGTERM }
    else if slot == 5 { SIGCHLD }
    else if slot == 6 { SIGSTOP }
    else if slot == 7 { SIGCONT }
    else { 0 }
}

// I1.3: SYS_KILL(24) — send signal to process
@kernel fn sys_kill(pid: i64, signum: i64) -> i64 {
    if pid < 0 || pid >= PROC_MAX { return -1 }
    let state = volatile_read(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_STATE)
    if state == PROC_STATE_FREE { return -1 }
    signal_send(pid, signum)
}

// I1.8: SYS_SIGNAL(25) — register signal handler
@kernel fn sys_signal(signum: i64, handler: i64) -> i64 {
    // I1.9: SIGKILL and SIGSTOP cannot be caught
    if signum == SIGKILL || signum == SIGSTOP { return -1 }

    let slot = sig_to_slot(signum)
    if slot < 0 { return -1 }

    let pid = volatile_read_u64(0x6FE00)
    let base = sig_entry_addr(pid)
    let old_handler = volatile_read_u64(base + SIG_OFF_HANDLERS + slot * 8)
    volatile_write_u64(base + SIG_OFF_HANDLERS + slot * 8, handler)
    old_handler
}

// I1.7: Enhanced process_exit — send SIGCHLD to parent
@kernel fn process_exit_with_signal(exit_code: i64) {
    let pid = volatile_read(0x6FE00)
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE

    volatile_write(base + PROC_OFF_STATE, PROC_STATE_ZOMBIE)
    volatile_write(base + PROC_OFF_EXIT, exit_code)

    reparent_children(pid)

    // Send SIGCHLD to parent
    let ppid = volatile_read(base + PROC_OFF_PPID)
    if ppid >= 0 && ppid < PROC_MAX {
        signal_send(ppid, SIGCHLD)
    }

    wake_waiting_parent(pid, exit_code)

    // L2.2: Release CoW pages on exit
    let cr3 = volatile_read(base + PROC_OFF_CR3)
    if cr3 != 0 && cr3 != PML4_BASE { cow_release_pages(cr3) }

    // Close all FDs
    let mut fd: i64 = 0
    while fd < FD_MAX { fd_v2_set(pid, fd, FD_CLOSED, 0); fd = fd + 1 }

    cprint("[PROC] PID ", WHITE_ON_BLACK)
    cprint_decimal(pid, CYAN_ON_BLACK)
    cprint(" exited (code ", WHITE_ON_BLACK)
    cprint_decimal(exit_code, CYAN_ON_BLACK)
    cprintln(")", WHITE_ON_BLACK)

    while 1 == 1 { hlt() }
}

// ═══════════════════════════════════════════════
// Job Control (Sprint I2)
// ═══════════════════════════════════════════════

// Job table at 0x8D8000: 16 jobs × 64 bytes
// Per job: +0=pid(i64), +8=state(i64: 0=free,1=running,2=stopped,3=done), +16=cmd[48]
const JOB_TABLE: i64 = 0x8D8000
const JOB_MAX: i64 = 16
const JOB_ENTRY_SIZE: i64 = 64
const JOB_OFF_PID: i64 = 0
const JOB_OFF_STATE: i64 = 8
const JOB_OFF_CMD: i64 = 16

// Job states
const JOB_FREE: i64 = 0
const JOB_RUNNING: i64 = 1
const JOB_STOPPED: i64 = 2
const JOB_DONE: i64 = 3

// Foreground process group at 0x652068
const FG_PGID_ADDR: i64 = 0x652068
// Ctrl key state at 0x6FBE4
const CTRL_STATE_ADDR: i64 = 0x6FBE4

// I2.1: Set/get foreground process group
@kernel fn set_fg_pgid(pgid: i64) {
    volatile_write_u64(FG_PGID_ADDR, pgid)
}

@kernel fn get_fg_pgid() -> i64 {
    volatile_read_u64(FG_PGID_ADDR)
}

// I2.2: Send signal to foreground process group (Ctrl+C → SIGINT)
@kernel fn signal_fg_group(signum: i64) {
    let fg_pgid = get_fg_pgid()
    if fg_pgid == 0 { return } // shell is foreground, ignore
    // Send signal to all processes in foreground group
    let mut pid: i64 = 1
    while pid < PROC_MAX {
        let base = PROC_TABLE + pid * PROC_ENTRY_SIZE
        let state = volatile_read(base + PROC_OFF_STATE)
        if state != PROC_STATE_FREE && state != PROC_STATE_ZOMBIE {
            let pgid = volatile_read(base + PROC_OFF_PGID)
            if pgid == fg_pgid {
                signal_send(pid, signum)
            }
        }
        pid = pid + 1
    }
}

// I2.4: Background '&' — parse trailing & from command
@kernel fn shell_has_background() -> i64 {
    let len = cmdbuf_len()
    if len < 2 { return 0 }
    // Check last non-space character is '&'
    let mut pos = len - 1
    while pos > 0 && volatile_read_u8(0x6F800 + pos) == 32 { pos = pos - 1 }
    if volatile_read_u8(0x6F800 + pos) == 38 { // '&'
        return pos // position of '&'
    }
    0
}

// I2.5: Job table operations
@kernel fn job_add(pid: i64, cmd_addr: i64, cmd_len: i64) -> i64 {
    let mut slot: i64 = 0
    while slot < JOB_MAX {
        let base = JOB_TABLE + slot * JOB_ENTRY_SIZE
        if volatile_read_u64(base + JOB_OFF_STATE) == JOB_FREE {
            volatile_write_u64(base + JOB_OFF_PID, pid)
            volatile_write_u64(base + JOB_OFF_STATE, JOB_RUNNING)
            // Copy command string (max 47 chars)
            let copy_len = if cmd_len < 47 { cmd_len } else { 47 }
            let mut i: i64 = 0
            while i < copy_len {
                volatile_write_u8(base + JOB_OFF_CMD + i, volatile_read_u8(cmd_addr + i))
                i = i + 1
            }
            volatile_write_u8(base + JOB_OFF_CMD + copy_len, 0)
            return slot
        }
        slot = slot + 1
    }
    -1
}

@kernel fn job_find_by_pid(pid: i64) -> i64 {
    let mut slot: i64 = 0
    while slot < JOB_MAX {
        let base = JOB_TABLE + slot * JOB_ENTRY_SIZE
        if volatile_read_u64(base + JOB_OFF_PID) == pid &&
           volatile_read_u64(base + JOB_OFF_STATE) != JOB_FREE {
            return slot
        }
        slot = slot + 1
    }
    -1
}

// I2.9: Check for completed background jobs, print notifications
@kernel fn job_check_notifications() {
    let mut slot: i64 = 0
    while slot < JOB_MAX {
        let base = JOB_TABLE + slot * JOB_ENTRY_SIZE
        let state = volatile_read_u64(base + JOB_OFF_STATE)
        if state == JOB_RUNNING {
            let pid = volatile_read_u64(base + JOB_OFF_PID)
            let proc_state = volatile_read(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_STATE)
            if proc_state == PROC_STATE_ZOMBIE || proc_state == PROC_STATE_FREE {
                // Job is done
                volatile_write_u64(base + JOB_OFF_STATE, JOB_DONE)
                cprint("[", WHITE_ON_BLACK)
                cprint_decimal(slot + 1, CYAN_ON_BLACK)
                cprint("]+  Done                    ", WHITE_ON_BLACK)
                // Print command
                let mut ci: i64 = 0
                while ci < 47 {
                    let ch = volatile_read_u8(base + JOB_OFF_CMD + ci)
                    if ch == 0 { ci = 47 }
                    else { console_putchar(ch, WHITE_ON_BLACK); ci = ci + 1 }
                }
                console_putchar(10, WHITE_ON_BLACK)
                // Reap zombie
                if proc_state == PROC_STATE_ZOMBIE {
                    process_reap(pid)
                }
                // Free job slot
                volatile_write_u64(base + JOB_OFF_STATE, JOB_FREE)
            }
        }
        slot = slot + 1
    }
}

// I2.6: `jobs` command
@kernel fn cmd_jobs() {
    let mut slot: i64 = 0
    let mut count: i64 = 0
    while slot < JOB_MAX {
        let base = JOB_TABLE + slot * JOB_ENTRY_SIZE
        let state = volatile_read_u64(base + JOB_OFF_STATE)
        if state != JOB_FREE {
            cprint("[", WHITE_ON_BLACK)
            cprint_decimal(slot + 1, CYAN_ON_BLACK)
            cprint("]  ", WHITE_ON_BLACK)
            let pid = volatile_read_u64(base + JOB_OFF_PID)
            cprint_decimal(pid, CYAN_ON_BLACK)
            cprint("  ", WHITE_ON_BLACK)
            if state == JOB_RUNNING { cprint("Running   ", GREEN_ON_BLACK) }
            else if state == JOB_STOPPED { cprint("Stopped   ", YELLOW_ON_BLACK) }
            else if state == JOB_DONE { cprint("Done      ", WHITE_ON_BLACK) }
            // Print command
            let mut ci: i64 = 0
            while ci < 47 {
                let ch = volatile_read_u8(base + JOB_OFF_CMD + ci)
                if ch == 0 { ci = 47 }
                else { console_putchar(ch, WHITE_ON_BLACK); ci = ci + 1 }
            }
            console_putchar(10, WHITE_ON_BLACK)
            count = count + 1
        }
        slot = slot + 1
    }
    if count == 0 { cprintln("No background jobs", WHITE_ON_BLACK) }
}

// I2.7: `fg` command — bring job to foreground
@kernel fn cmd_fg() {
    let len = cmdbuf_len()
    // Parse job number from "fg %N" or "fg N"
    let mut target: i64 = -1
    if len > 3 {
        let ch = volatile_read_u8(0x6F800 + 3)
        if ch == 37 { // '%'
            target = volatile_read_u8(0x6F800 + 4) - 48 - 1 // %1 → slot 0
        } else {
            target = ch - 48 - 1
        }
    }
    if target < 0 || target >= JOB_MAX {
        // Find most recent job
        let mut slot = JOB_MAX - 1
        while slot >= 0 && target < 0 {
            let base = JOB_TABLE + slot * JOB_ENTRY_SIZE
            if volatile_read_u64(base + JOB_OFF_STATE) != JOB_FREE { target = slot }
            slot = slot - 1
        }
    }
    if target < 0 { cprintln("No current job", RED_ON_BLACK); return }

    let base = JOB_TABLE + target * JOB_ENTRY_SIZE
    let pid = volatile_read_u64(base + JOB_OFF_PID)
    let state = volatile_read_u64(base + JOB_OFF_STATE)

    // If stopped, send SIGCONT
    if state == JOB_STOPPED {
        signal_send(pid, SIGCONT)
        volatile_write_u64(base + JOB_OFF_STATE, JOB_RUNNING)
    }

    // Set as foreground
    set_fg_pgid(pid)

    // Wait for it
    cprint("Foreground: PID ", WHITE_ON_BLACK)
    cprint_decimal(pid, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    sys_waitpid(pid, 0, 0)

    // Clear foreground
    set_fg_pgid(0)
    volatile_write_u64(base + JOB_OFF_STATE, JOB_FREE)
}

// I2.8: `bg` command — resume stopped job in background
@kernel fn cmd_bg() {
    let len = cmdbuf_len()
    let mut target: i64 = -1
    if len > 3 {
        let ch = volatile_read_u8(0x6F800 + 3)
        if ch == 37 { target = volatile_read_u8(0x6F800 + 4) - 48 - 1 }
        else { target = ch - 48 - 1 }
    }
    if target < 0 || target >= JOB_MAX {
        let mut slot = JOB_MAX - 1
        while slot >= 0 && target < 0 {
            let base = JOB_TABLE + slot * JOB_ENTRY_SIZE
            if volatile_read_u64(base + JOB_OFF_STATE) == JOB_STOPPED { target = slot }
            slot = slot - 1
        }
    }
    if target < 0 { cprintln("No stopped job", RED_ON_BLACK); return }

    let base = JOB_TABLE + target * JOB_ENTRY_SIZE
    let pid = volatile_read_u64(base + JOB_OFF_PID)
    signal_send(pid, SIGCONT)
    volatile_write_u64(base + JOB_OFF_STATE, JOB_RUNNING)
    cprint("[", WHITE_ON_BLACK)
    cprint_decimal(target + 1, CYAN_ON_BLACK)
    cprint("]  ", WHITE_ON_BLACK)
    cprint_decimal(pid, CYAN_ON_BLACK)
    cprintln(" &", WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Shell Variables & Script Loading (Sprint J1)
// ═══════════════════════════════════════════════

// ENV_TABLE at 0x8D3000: 128 entries × 32 bytes = 4096 bytes
// Per entry: +0=key[16] (null-terminated), +16=value[16] (null-terminated)
const ENV_TABLE: i64 = 0x8D3000
const ENV_MAX: i64 = 128
const ENV_ENTRY_SIZE: i64 = 32
const ENV_KEY_SIZE: i64 = 16
const ENV_VAL_SIZE: i64 = 16

// Last exit code at 0x652060
const LAST_EXIT_CODE: i64 = 0x652060

// J1.1: Environment variable operations
@kernel fn env_find(key_addr: i64) -> i64 {
    let mut i: i64 = 0
    while i < ENV_MAX {
        let entry = ENV_TABLE + i * ENV_ENTRY_SIZE
        let first_ch = volatile_read_u8(entry)
        if first_ch == 0 { return -1 } // empty slot = end of entries
        // Compare key
        let mut match_ok: i64 = 1
        let mut j: i64 = 0
        while j < ENV_KEY_SIZE && match_ok == 1 {
            let a = volatile_read_u8(entry + j)
            let b = volatile_read_u8(key_addr + j)
            if a != b { match_ok = 0 }
            if a == 0 && b == 0 { j = ENV_KEY_SIZE } // both null = match
            else { j = j + 1 }
        }
        if match_ok == 1 { return i }
        i = i + 1
    }
    -1
}

@kernel fn env_set(key_addr: i64, val_addr: i64) -> i64 {
    let idx = env_find(key_addr)
    let target = if idx >= 0 { idx } else {
        // Find first empty slot
        let mut i: i64 = 0
        let mut found: i64 = -1
        while i < ENV_MAX && found == -1 {
            if volatile_read_u8(ENV_TABLE + i * ENV_ENTRY_SIZE) == 0 { found = i }
            i = i + 1
        }
        found
    }
    if target < 0 { return -1 } // table full

    let entry = ENV_TABLE + target * ENV_ENTRY_SIZE
    // Copy key
    let mut i: i64 = 0
    while i < ENV_KEY_SIZE - 1 {
        let ch = volatile_read_u8(key_addr + i)
        volatile_write_u8(entry + i, ch)
        if ch == 0 { i = ENV_KEY_SIZE }
        else { i = i + 1 }
    }
    volatile_write_u8(entry + ENV_KEY_SIZE - 1, 0) // ensure null
    // Copy value
    i = 0
    while i < ENV_VAL_SIZE - 1 {
        let ch = volatile_read_u8(val_addr + i)
        volatile_write_u8(entry + ENV_KEY_SIZE + i, ch)
        if ch == 0 { i = ENV_VAL_SIZE }
        else { i = i + 1 }
    }
    volatile_write_u8(entry + ENV_KEY_SIZE + ENV_VAL_SIZE - 1, 0)
    0
}

@kernel fn env_get(key_addr: i64, buf: i64) -> i64 {
    let idx = env_find(key_addr)
    if idx < 0 { return -1 }
    let entry = ENV_TABLE + idx * ENV_ENTRY_SIZE + ENV_KEY_SIZE
    let mut i: i64 = 0
    while i < ENV_VAL_SIZE {
        let ch = volatile_read_u8(entry + i)
        volatile_write_u8(buf + i, ch)
        if ch == 0 { return i }
        i = i + 1
    }
    i
}

// J1.2: `export` shell builtin — "export KEY=VALUE"
@kernel fn cmd_export() {
    let len = cmdbuf_len()
    if len <= 7 {
        // Print all env vars
        cmd_env_list()
        return
    }
    // Parse KEY=VALUE from "export KEY=VALUE" (offset 7)
    let key_buf: i64 = 0x843800
    let val_buf: i64 = 0x843900
    let mut pos: i64 = 7
    let mut ki: i64 = 0
    // Read key up to '='
    while pos < len && ki < ENV_KEY_SIZE - 1 {
        let ch = volatile_read_u8(0x6F800 + pos)
        if ch == 61 { pos = pos + 1; ki = ENV_KEY_SIZE } // '=' found
        else { volatile_write_u8(key_buf + ki, ch); ki = ki + 1; pos = pos + 1 }
    }
    volatile_write_u8(key_buf + (if ki >= ENV_KEY_SIZE { ENV_KEY_SIZE - 1 } else { ki }), 0)
    // Read value
    let mut vi: i64 = 0
    while pos < len && vi < ENV_VAL_SIZE - 1 {
        volatile_write_u8(val_buf + vi, volatile_read_u8(0x6F800 + pos))
        vi = vi + 1
        pos = pos + 1
    }
    volatile_write_u8(val_buf + vi, 0)
    env_set(key_buf, val_buf)
}

// J1.3: `set` builtin (env vars)
@kernel fn cmd_setenv() {
    let len = cmdbuf_len()
    if len <= 4 {
        cmd_env_list()
        return
    }
    // "set KEY=VALUE" (offset 4)
    let key_buf: i64 = 0x843800
    let val_buf: i64 = 0x843900
    let mut pos: i64 = 4
    let mut ki: i64 = 0
    while pos < len && ki < ENV_KEY_SIZE - 1 {
        let ch = volatile_read_u8(0x6F800 + pos)
        if ch == 61 { pos = pos + 1; ki = ENV_KEY_SIZE }
        else { volatile_write_u8(key_buf + ki, ch); ki = ki + 1; pos = pos + 1 }
    }
    volatile_write_u8(key_buf + (if ki >= ENV_KEY_SIZE { ENV_KEY_SIZE - 1 } else { ki }), 0)
    let mut vi: i64 = 0
    while pos < len && vi < ENV_VAL_SIZE - 1 {
        volatile_write_u8(val_buf + vi, volatile_read_u8(0x6F800 + pos))
        vi = vi + 1
        pos = pos + 1
    }
    volatile_write_u8(val_buf + vi, 0)
    env_set(key_buf, val_buf)
}

// List all environment variables
@kernel fn cmd_env_list() {
    let mut i: i64 = 0
    let mut count: i64 = 0
    while i < ENV_MAX {
        let entry = ENV_TABLE + i * ENV_ENTRY_SIZE
        if volatile_read_u8(entry) != 0 {
            // Print key
            let mut j: i64 = 0
            while j < ENV_KEY_SIZE {
                let ch = volatile_read_u8(entry + j)
                if ch == 0 { j = ENV_KEY_SIZE }
                else { console_putchar(ch, CYAN_ON_BLACK); j = j + 1 }
            }
            cprint("=", WHITE_ON_BLACK)
            // Print value
            j = 0
            while j < ENV_VAL_SIZE {
                let ch = volatile_read_u8(entry + ENV_KEY_SIZE + j)
                if ch == 0 { j = ENV_VAL_SIZE }
                else { console_putchar(ch, WHITE_ON_BLACK); j = j + 1 }
            }
            console_putchar(10, WHITE_ON_BLACK)
            count = count + 1
        } else {
            i = ENV_MAX // end
        }
        i = i + 1
    }
    if count == 0 { cprintln("(no variables set)", WHITE_ON_BLACK) }
}

// J1.4: $VAR expansion in cmdbuf (before dispatch)
@kernel fn shell_expand_vars() {
    let len = cmdbuf_len()
    let expand_buf: i64 = 0x844000 // temporary expansion buffer
    let mut src: i64 = 0
    let mut dst: i64 = 0

    while src < len && dst < 62 {
        let ch = volatile_read_u8(0x6F800 + src)
        if ch == 36 { // '$'
            src = src + 1
            // J1.5: $? = last exit code
            if volatile_read_u8(0x6F800 + src) == 63 { // '?'
                src = src + 1
                let code = volatile_read_u64(LAST_EXIT_CODE)
                // Write decimal to expand_buf
                if code == 0 {
                    volatile_write_u8(expand_buf + dst, 48) // '0'
                    dst = dst + 1
                } else {
                    let mut tmp = code
                    let digit_start = dst
                    while tmp > 0 && dst < 62 {
                        volatile_write_u8(expand_buf + dst, 48 + (tmp % 10))
                        dst = dst + 1
                        tmp = tmp / 10
                    }
                    // Reverse digits
                    let mut lo = digit_start
                    let mut hi = dst - 1
                    while lo < hi {
                        let t = volatile_read_u8(expand_buf + lo)
                        volatile_write_u8(expand_buf + lo, volatile_read_u8(expand_buf + hi))
                        volatile_write_u8(expand_buf + hi, t)
                        lo = lo + 1
                        hi = hi - 1
                    }
                }
            }
            // J1.6: $$ = current PID
            else if volatile_read_u8(0x6F800 + src) == 36 { // '$$'
                src = src + 1
                let pid = volatile_read_u64(0x6FE00)
                volatile_write_u8(expand_buf + dst, 48 + pid)
                dst = dst + 1
            }
            // $VAR — lookup in ENV_TABLE
            else {
                let var_name: i64 = 0x843A00
                let mut ni: i64 = 0
                while src < len && ni < 15 {
                    let vc = volatile_read_u8(0x6F800 + src)
                    // Stop at space, null, or non-alphanumeric
                    if vc == 32 || vc == 0 || vc == 36 || vc == 47 { ni = 15 }
                    else { volatile_write_u8(var_name + ni, vc); ni = ni + 1; src = src + 1 }
                }
                volatile_write_u8(var_name + (if ni >= 15 { 14 } else { ni }), 0)
                let val_buf: i64 = 0x843B00
                let vlen = env_get(var_name, val_buf)
                if vlen > 0 {
                    let mut vi: i64 = 0
                    while vi < vlen && dst < 62 {
                        volatile_write_u8(expand_buf + dst, volatile_read_u8(val_buf + vi))
                        dst = dst + 1
                        vi = vi + 1
                    }
                }
            }
        } else {
            volatile_write_u8(expand_buf + dst, ch)
            dst = dst + 1
            src = src + 1
        }
    }
    volatile_write_u8(expand_buf + dst, 0)

    // Copy back to cmdbuf
    let mut ci: i64 = 0
    while ci < dst {
        volatile_write_u8(0x6F800 + ci, volatile_read_u8(expand_buf + ci))
        ci = ci + 1
    }
    volatile_write_u8(0x6F800 + dst, 0)
    volatile_write(0x6F880, dst)
}

// J1.8: Script file loading — "sh <filename>" or "source <filename>"
@kernel fn cmd_sh() {
    let len = cmdbuf_len()
    let prefix = if volatile_read_u8(0x6F800 + 1) == 104 { 3 } else { 7 } // "sh " or "source "
    if len <= prefix {
        cprintln("Usage: sh <script>", YELLOW_ON_BLACK)
        return
    }

    // Get filename from cmdbuf
    let fname_addr: i64 = 0x843C00
    let mut fi: i64 = 0
    let mut pos: i64 = prefix
    while pos < len && fi < 31 {
        volatile_write_u8(fname_addr + fi, volatile_read_u8(0x6F800 + pos))
        fi = fi + 1
        pos = pos + 1
    }
    volatile_write_u8(fname_addr + fi, 0)

    // Try ramfs first
    let idx = ramfs_find_by_addr(fname_addr)
    let mut script_buf: i64 = 0x845000
    let mut script_len: i64 = 0

    if idx >= 0 {
        let entry = ramfs_entry_addr(idx)
        let size = volatile_read(entry + 32)
        let data_ptr = volatile_read(entry + 40)
        if data_ptr != 0 && size > 0 {
            let mut si: i64 = 0
            while si < size && si < 4096 {
                volatile_write_u8(script_buf + si, volatile_read_u8(data_ptr + si))
                si = si + 1
            }
            script_len = size
        }
    }

    if script_len == 0 {
        cprintln("Script not found", RED_ON_BLACK)
        return
    }

    // Parse and execute lines
    let line_buf: i64 = 0x846000
    let mut lpos: i64 = 0
    let mut line_len: i64 = 0
    let mut line_num: i64 = 0

    while lpos < script_len {
        let ch = volatile_read_u8(script_buf + lpos)
        if ch == 10 || lpos == script_len - 1 {
            if ch != 10 && line_len < 63 {
                volatile_write_u8(line_buf + line_len, ch)
                line_len = line_len + 1
            }
            volatile_write_u8(line_buf + line_len, 0)
            line_num = line_num + 1

            // J1.9: Skip comments (#) and blank lines
            let first = volatile_read_u8(line_buf)
            if line_len > 0 && first != 35 { // 35 = '#'
                shell_exec_from_buf(line_buf, line_len)
            }
            line_len = 0
        } else {
            if line_len < 63 {
                volatile_write_u8(line_buf + line_len, ch)
                line_len = line_len + 1
            }
        }
        lpos = lpos + 1
    }
}

// Update shell_execute to expand variables before dispatch
@kernel fn shell_execute_v2() {
    let len = cmdbuf_len()
    if len == 0 { return }

    // J1.4: Expand $VAR in cmdbuf
    shell_expand_vars()

    // Check for pipe first
    let pipe_pos = shell_find_pipe()
    if pipe_pos > 0 {
        shell_exec_pipe(pipe_pos)
        return
    }

    // Check for redirects
    let redir = shell_find_redirect()
    if redir > 0 {
        shell_exec_redirect(redir)
        return
    }

    // No pipe or redirect — normal dispatch
    dispatch_command()
}

// ═══════════════════════════════════════════════
// Shell Control Flow (Sprint J2)
// ═══════════════════════════════════════════════

// SCRIPT_BUF at 0x8D5000: control flow state machine
// +0:    mode (0=interactive, 1=if, 2=for, 3=while)
// +8:    depth (nesting level, max 8)
// +16:   condition_result (0=false, 1=true) for current if/while
// +24:   in_else (0=then branch, 1=else branch)
// +32:   for_var_addr (address of loop variable name)
// +40:   for_items_addr (address of item list)
// +48:   for_item_idx (current item index)
// +56:   for_item_count (total items)
// +64:   while_script_pos (position in script to loop back to)
// +72:   collecting (1=collecting lines for body, 0=executing)
// +80:   body_buf (address of collected body lines, 0x8D5100)
// +88:   body_len (length of collected body)
const SCRIPT_STATE: i64 = 0x8D5000
const SCRIPT_BODY_BUF: i64 = 0x8D5100  // 3.75KB for body lines

const SMODE_NONE: i64 = 0
const SMODE_IF: i64 = 1
const SMODE_FOR: i64 = 2
const SMODE_WHILE: i64 = 3

// J2.5: Initialize script state
@kernel fn script_state_init() {
    volatile_write_u64(SCRIPT_STATE, SMODE_NONE)     // mode
    volatile_write_u64(SCRIPT_STATE + 8, 0)           // depth
    volatile_write_u64(SCRIPT_STATE + 16, 0)          // condition_result
    volatile_write_u64(SCRIPT_STATE + 24, 0)          // in_else
    volatile_write_u64(SCRIPT_STATE + 72, 0)          // collecting
    volatile_write_u64(SCRIPT_STATE + 88, 0)          // body_len
}

// J2.6: `test` / `[` builtin — evaluate conditions, set LAST_EXIT_CODE
@kernel fn cmd_test() {
    let len = cmdbuf_len()
    let result: i64 = 0

    // Parse test expression from cmdbuf
    // "test -f <file>" — file exists
    if len > 8 && volatile_read_u8(0x6F800 + 5) == 45 && volatile_read_u8(0x6F800 + 6) == 102 {
        // -f flag: check if file exists
        let fname_addr: i64 = 0x843D00
        let mut fi: i64 = 0
        let mut pos: i64 = 8
        while pos < len && fi < 31 {
            volatile_write_u8(fname_addr + fi, volatile_read_u8(0x6F800 + pos))
            fi = fi + 1
            pos = pos + 1
        }
        volatile_write_u8(fname_addr + fi, 0)
        let idx = ramfs_find_by_addr(fname_addr)
        if idx >= 0 { volatile_write_u64(LAST_EXIT_CODE, 0) }
        else { volatile_write_u64(LAST_EXIT_CODE, 1) }
        return
    }

    // "test -d <dir>" — directory exists
    if len > 8 && volatile_read_u8(0x6F800 + 5) == 45 && volatile_read_u8(0x6F800 + 6) == 100 {
        let fname_addr: i64 = 0x843D00
        let mut fi: i64 = 0
        let mut pos: i64 = 8
        while pos < len && fi < 31 {
            volatile_write_u8(fname_addr + fi, volatile_read_u8(0x6F800 + pos))
            fi = fi + 1
            pos = pos + 1
        }
        volatile_write_u8(fname_addr + fi, 0)
        let idx = ramfs_find_by_addr(fname_addr)
        if idx >= 0 {
            let entry = ramfs_entry_addr(idx)
            let ftype = volatile_read(entry + 48)
            if ftype == 2 { volatile_write_u64(LAST_EXIT_CODE, 0) }
            else { volatile_write_u64(LAST_EXIT_CODE, 1) }
        } else { volatile_write_u64(LAST_EXIT_CODE, 1) }
        return
    }

    // "test <a> -eq <b>" — integer equality
    // "test <a> = <b>" — string equality
    // Simple: just set exit code 0 (true) for "test" alone
    volatile_write_u64(LAST_EXIT_CODE, 0)
}

// J2.1/J2.2: `if` command — "if <cmd>; then ... [else ...] fi"
// In interactive/script mode, we collect lines until fi
@kernel fn cmd_if_start() {
    let len = cmdbuf_len()
    // Parse condition command after "if "
    let cond_buf: i64 = 0x843E00
    let mut ci: i64 = 0
    let mut pos: i64 = 3 // skip "if "

    // Find "; then" or end of line
    while pos < len && ci < 62 {
        let ch = volatile_read_u8(0x6F800 + pos)
        // Check for "; then" or ";then"
        if ch == 59 { pos = len } // ';' found, stop
        else { volatile_write_u8(cond_buf + ci, ch); ci = ci + 1; pos = pos + 1 }
    }
    volatile_write_u8(cond_buf + ci, 0)

    // Execute condition command
    shell_exec_from_buf(cond_buf, ci)
    let cond_result = volatile_read_u64(LAST_EXIT_CODE)

    // Set script state
    volatile_write_u64(SCRIPT_STATE, SMODE_IF)
    volatile_write_u64(SCRIPT_STATE + 16, if cond_result == 0 { 1 } else { 0 })
    volatile_write_u64(SCRIPT_STATE + 24, 0) // in_else = false
    volatile_write_u64(SCRIPT_STATE + 72, 1) // collecting = true
    volatile_write_u64(SCRIPT_STATE + 88, 0) // body_len = 0
}

// Process a line during if/for/while collection
@kernel fn script_process_line(line: i64, line_len: i64) {
    let mode = volatile_read_u64(SCRIPT_STATE)

    if mode == SMODE_IF {
        // Check for "else"
        if line_len == 4 && volatile_read_u8(line) == 101 && volatile_read_u8(line + 1) == 108 &&
           volatile_read_u8(line + 2) == 115 && volatile_read_u8(line + 3) == 101 {
            volatile_write_u64(SCRIPT_STATE + 24, 1) // in_else = true
            return
        }
        // Check for "fi"
        if line_len == 2 && volatile_read_u8(line) == 102 && volatile_read_u8(line + 1) == 105 {
            // Execute collected body
            script_exec_if_body()
            script_state_init()
            return
        }
        // Collect line into body buffer
        let cond_true = volatile_read_u64(SCRIPT_STATE + 16)
        let in_else = volatile_read_u64(SCRIPT_STATE + 24)
        let should_exec = (cond_true == 1 && in_else == 0) || (cond_true == 0 && in_else == 1)
        if should_exec == 1 {
            shell_exec_from_buf(line, line_len)
        }
        return
    }

    if mode == SMODE_FOR {
        // Check for "done"
        if line_len == 4 && volatile_read_u8(line) == 100 && volatile_read_u8(line + 1) == 111 &&
           volatile_read_u8(line + 2) == 110 && volatile_read_u8(line + 3) == 101 {
            script_state_init()
            return
        }
        // Execute line with current loop variable
        shell_exec_from_buf(line, line_len)
        return
    }

    if mode == SMODE_WHILE {
        // Check for "done"
        if line_len == 4 && volatile_read_u8(line) == 100 && volatile_read_u8(line + 1) == 111 &&
           volatile_read_u8(line + 2) == 110 && volatile_read_u8(line + 3) == 101 {
            script_state_init()
            return
        }
        shell_exec_from_buf(line, line_len)
        return
    }
}

// Execute the if body (already dispatched line-by-line above)
@kernel fn script_exec_if_body() {
    // Body already executed inline during collection
    // Nothing extra needed — lines were dispatched as they came in
}

// J2.3: `for` command — "for x in a b c; do ... done"
@kernel fn cmd_for_start() {
    let len = cmdbuf_len()
    // Parse: "for <var> in <items>; do"
    // Find variable name after "for "
    let var_buf: i64 = 0x843F00
    let mut vi: i64 = 0
    let mut pos: i64 = 4 // skip "for "
    while pos < len && volatile_read_u8(0x6F800 + pos) != 32 && vi < 15 {
        volatile_write_u8(var_buf + vi, volatile_read_u8(0x6F800 + pos))
        vi = vi + 1
        pos = pos + 1
    }
    volatile_write_u8(var_buf + vi, 0)

    // Skip " in "
    while pos < len && volatile_read_u8(0x6F800 + pos) == 32 { pos = pos + 1 }
    // Skip "in "
    if pos + 2 < len && volatile_read_u8(0x6F800 + pos) == 105 { pos = pos + 3 }

    // Parse items (space-separated, until ';' or end)
    let items_buf: i64 = 0x844800
    let mut ii: i64 = 0
    while pos < len && ii < 255 {
        let ch = volatile_read_u8(0x6F800 + pos)
        if ch == 59 { pos = len } // ';' — stop
        else { volatile_write_u8(items_buf + ii, ch); ii = ii + 1; pos = pos + 1 }
    }
    volatile_write_u8(items_buf + ii, 0)

    // Count items
    let mut item_count: i64 = 0
    let mut in_item: i64 = 0
    let mut ci: i64 = 0
    while ci < ii {
        let ch = volatile_read_u8(items_buf + ci)
        if ch == 32 {
            if in_item == 1 { item_count = item_count + 1; in_item = 0 }
        } else { in_item = 1 }
        ci = ci + 1
    }
    if in_item == 1 { item_count = item_count + 1 }

    // Set state for for loop
    volatile_write_u64(SCRIPT_STATE, SMODE_FOR)
    volatile_write_u64(SCRIPT_STATE + 32, var_buf)
    volatile_write_u64(SCRIPT_STATE + 40, items_buf)
    volatile_write_u64(SCRIPT_STATE + 48, 0)          // item_idx = 0
    volatile_write_u64(SCRIPT_STATE + 56, item_count)
    volatile_write_u64(SCRIPT_STATE + 72, 1)           // collecting body
    volatile_write_u64(SCRIPT_STATE + 88, 0)
}

// J2.4: `while` command — "while <cmd>; do ... done"
@kernel fn cmd_while_start() {
    let len = cmdbuf_len()
    // Parse condition after "while "
    let cond_buf: i64 = 0x844A00
    let mut ci: i64 = 0
    let mut pos: i64 = 6 // skip "while "
    while pos < len && ci < 62 {
        let ch = volatile_read_u8(0x6F800 + pos)
        if ch == 59 { pos = len } // ';'
        else { volatile_write_u8(cond_buf + ci, ch); ci = ci + 1; pos = pos + 1 }
    }
    volatile_write_u8(cond_buf + ci, 0)

    // Execute condition
    shell_exec_from_buf(cond_buf, ci)
    let cond_result = volatile_read_u64(LAST_EXIT_CODE)

    volatile_write_u64(SCRIPT_STATE, SMODE_WHILE)
    volatile_write_u64(SCRIPT_STATE + 16, if cond_result == 0 { 1 } else { 0 })
    volatile_write_u64(SCRIPT_STATE + 72, 1)
    volatile_write_u64(SCRIPT_STATE + 88, 0)
}

// J2.8: Handle quoted strings — find end of quoted segment
@kernel fn shell_find_quote_end(buf: i64, start: i64, len: i64, quote_char: i64) -> i64 {
    let mut pos = start + 1
    while pos < len {
        if volatile_read_u8(buf + pos) == quote_char { return pos }
        pos = pos + 1
    }
    len // unterminated quote
}

// J2.9: `exit` builtin
@kernel fn cmd_exit_shell() {
    let len = cmdbuf_len()
    let mut code: i64 = 0
    if len > 5 {
        code = volatile_read_u8(0x6F800 + 5) - 48
    }
    cprint("Exiting with code ", WHITE_ON_BLACK)
    cprint_decimal(code, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    volatile_write_u64(LAST_EXIT_CODE, code)
    // In interactive mode, this triggers shutdown
    // In script mode, this stops script execution
    if volatile_read_u64(SCRIPT_STATE) == SMODE_NONE {
        shutdown_clean()
    }
}

// ── Shell Commands ──

@kernel fn cmd_readelf() {
    // "readelf <filename>" — parse ELF from FAT32
    if fat32_state_read(0) != 1 { cprintln("FAT32 not mounted", RED_ON_BLACK); return }

    // Get filename from cmdbuf offset 8 ("readelf ")
    let mut fname_len: i64 = 0
    let mut i: i64 = 8
    while i < 64 {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch == 0 { i = 64 }
        else { volatile_write_u8(FAT32_NAME_BUF + 256 + fname_len, ch); fname_len = fname_len + 1; i = i + 1 }
    }
    volatile_write_u8(FAT32_NAME_BUF + 256 + fname_len, 0)

    if fname_len == 0 { cprintln("Usage: readelf <filename>", YELLOW_ON_BLACK); return }

    // Find file
    let root = fat32_state_read(48)
    let result = fat32_find_in_dir(root, FAT32_NAME_BUF + 256)
    if result == -1 { cprintln("File not found", RED_ON_BLACK); return }

    let shifted = result >> 32
    let file_cluster = shifted & 0x7FFFFFFF
    let file_size = result & 0xFFFFFFFF

    // Read file
    let bytes = fat32_read_file(file_cluster, file_size, ELF_BUF)
    if bytes <= 0 { cprintln("Read error", RED_ON_BLACK); return }

    // Validate ELF
    let valid = elf_validate(ELF_BUF)
    if valid != 0 {
        cprint("Not a valid ELF64: error ", RED_ON_BLACK)
        cprint_decimal(valid, RED_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        return
    }

    cprintln("ELF64 Header:", YELLOW_ON_BLACK)
    let entry = elf_get_entry(ELF_BUF)
    cprint("  Entry point: 0x", WHITE_ON_BLACK)
    cprint_hex(entry, 16, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    let phnum = elf_get_phnum(ELF_BUF)
    cprint("  Program headers: ", WHITE_ON_BLACK)
    cprint_decimal(phnum, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    let phoff = elf_get_phoff(ELF_BUF)
    let phentsize = elf_get_phentsize(ELF_BUF)
    i = 0
    while i < phnum {
        let ph = ELF_BUF + phoff + i * phentsize
        let ph_type = buffer_read_u32_le(ph + PH_OFF_TYPE)
        let vaddr = buffer_read_u64_le(ph + PH_OFF_VADDR)
        let filesz = buffer_read_u64_le(ph + PH_OFF_FILESZ)
        let memsz = buffer_read_u64_le(ph + PH_OFF_MEMSZ)
        let flags = buffer_read_u32_le(ph + PH_OFF_FLAGS)
        cprint("  [", WHITE_ON_BLACK)
        cprint_decimal(i, CYAN_ON_BLACK)
        cprint("] type=", WHITE_ON_BLACK)
        if ph_type == 1 { cprint("LOAD", GREEN_ON_BLACK) }
        else { cprint_decimal(ph_type, WHITE_ON_BLACK) }
        cprint(" vaddr=0x", WHITE_ON_BLACK)
        cprint_hex(vaddr, 8, CYAN_ON_BLACK)
        cprint(" filesz=", WHITE_ON_BLACK)
        cprint_decimal(filesz, CYAN_ON_BLACK)
        cprint(" memsz=", WHITE_ON_BLACK)
        cprint_decimal(memsz, CYAN_ON_BLACK)
        cprint(" flags=", WHITE_ON_BLACK)
        if flags & 4 != 0 { cprint("R", GREEN_ON_BLACK) }
        if flags & 2 != 0 { cprint("W", YELLOW_ON_BLACK) }
        if flags & 1 != 0 { cprint("X", RED_ON_BLACK) }
        console_putchar(10, WHITE_ON_BLACK)
        i = i + 1
    }

    cprint("  File size: ", WHITE_ON_BLACK)
    cprint_decimal(bytes, CYAN_ON_BLACK)
    cprintln(" bytes", WHITE_ON_BLACK)
}

@kernel fn cmd_exec() {
    // "exec <filename>" — load and execute ELF from FAT32
    if fat32_state_read(0) != 1 { cprintln("FAT32 not mounted", RED_ON_BLACK); return }

    let mut fname_len: i64 = 0
    let mut i: i64 = 5
    while i < 64 {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch == 0 { i = 64 }
        else { volatile_write_u8(FAT32_NAME_BUF + 256 + fname_len, ch); fname_len = fname_len + 1; i = i + 1 }
    }
    volatile_write_u8(FAT32_NAME_BUF + 256 + fname_len, 0)

    if fname_len == 0 { cprintln("Usage: exec <filename>", YELLOW_ON_BLACK); return }

    let root = fat32_state_read(48)
    let result = fat32_find_in_dir(root, FAT32_NAME_BUF + 256)
    if result == -1 { cprintln("File not found", RED_ON_BLACK); return }

    let shifted = result >> 32
    let file_cluster = shifted & 0x7FFFFFFF
    let file_size = result & 0xFFFFFFFF

    cprint("Loading ", WHITE_ON_BLACK)
    let mut k: i64 = 0
    while k < fname_len {
        console_putchar(volatile_read_u8(FAT32_NAME_BUF + 256 + k), CYAN_ON_BLACK)
        k = k + 1
    }
    cprint(" (", WHITE_ON_BLACK)
    cprint_decimal(file_size, CYAN_ON_BLACK)
    cprintln(" bytes)...", WHITE_ON_BLACK)

    let bytes = fat32_read_file(file_cluster, file_size, ELF_BUF)
    if bytes <= 0 { cprintln("Read error", RED_ON_BLACK); return }

    let valid = elf_validate(ELF_BUF)
    if valid != 0 {
        cprintln("Not a valid ELF64", RED_ON_BLACK)
        return
    }

    // Load PT_LOAD segments into memory
    let loaded = elf_load_segments(ELF_BUF, bytes)
    cprint("  Loaded ", WHITE_ON_BLACK)
    cprint_decimal(loaded, CYAN_ON_BLACK)
    cprintln(" segments", WHITE_ON_BLACK)

    let entry = elf_get_entry(ELF_BUF)
    cprint("  Entry: 0x", WHITE_ON_BLACK)
    cprint_hex(entry, 16, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    // Setup user stack (64KB at ELF_STACK_TOP - 0x10000)
    let user_stack_base = ELF_STACK_TOP - 0x10000
    let mut pg: i64 = user_stack_base
    while pg < ELF_STACK_TOP {
        let frame = frame_alloc()
        if frame != -1 {
            map_page(pg, frame * FRAME_SIZE, PAGE_PRESENT | PAGE_WRITABLE | PAGE_USER)
        }
        pg = pg + FRAME_SIZE
    }

    let user_rsp = ELF_STACK_TOP - 8 // Stack grows down, leave room
    cprintln("  Transitioning to Ring 3...", YELLOW_ON_BLACK)

    // Setup SYSCALL/SYSRET MSRs for return path
    // IA32_STAR (0xC0000081): SYSRET CS/SS in bits 63:48, SYSCALL CS/SS in 47:32
    // Kernel CS=0x08, Kernel SS=0x10, User CS=0x20|3=0x23, User SS=0x18|3=0x1B
    // STAR: (user_cs_base << 48) | (kernel_cs << 32)
    // SYSRET loads CS from STAR[63:48]+16, SS from STAR[63:48]+8
    // So user_cs_base = 0x18 (SYSRET adds 16 → 0x28? No...)
    // Actually: SYSRET 64-bit loads CS = STAR[63:48]+16, SS = STAR[63:48]+8
    // We want CS=0x23 (0x20|RPL3). STAR[63:48] = 0x13 → CS = 0x13+16 = 0x23. SS = 0x13+8 = 0x1B.
    let star_val = (0x13 << 48) | (0x08 << 32)
    wrmsr(0xC0000081, star_val)

    // Use deferred run pattern: set flag for kernel_main to call iretq_to_user
    // (iretq_to_user must be called from top-level due to GPR zeroing on return)
    volatile_write_u64(RUN_PENDING, 1)
    volatile_write_u64(RUN_PENDING + 8, entry)
    volatile_write_u64(RUN_PENDING + 16, user_rsp)
    volatile_write_u64(0x6FC04, 0x7F0000) // TSS RSP0
    cprintln("  ELF queued for Ring 3 execution", GREEN_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Process Management v2 (Sprint B6)
// Fork, exec, waitpid, exit with proper cleanup
// ═══════════════════════════════════════════════

const PROC_TABLE_V2: i64 = 0x8C0000  // 16 procs × 256 bytes (moved from 0x890000 to avoid VQ_RX_BASE conflict)
// Per proc: +0=state, +8=pid, +16=ppid, +24=entry, +32=user_rsp,
//           +40=kernel_rsp, +48=page_table, +56=exit_code, +64=name[32]

const PROC_STATE_FREE: i64 = 0
const PROC_STATE_READY: i64 = 1
const PROC_STATE_RUNNING: i64 = 2
const PROC_STATE_BLOCKED: i64 = 3
const PROC_STATE_ZOMBIE: i64 = 4
const PROC_V2_MAX: i64 = 16
const PROC_V2_SIZE: i64 = 256

@kernel fn proc_v2_init() {
    let mut i: i64 = 0
    while i < PROC_V2_MAX * PROC_V2_SIZE {
        volatile_write_u8(PROC_TABLE_V2 + i, 0)
        i = i + 1
    }
    // PID 0 = kernel/idle
    volatile_write_u64(PROC_TABLE_V2, PROC_STATE_RUNNING) // state
    volatile_write_u64(PROC_TABLE_V2 + 8, 0)  // pid
    volatile_write_u64(PROC_TABLE_V2 + 16, 0) // ppid
    frame_mark_used(PROC_TABLE_V2 / FRAME_SIZE)
}

@kernel fn proc_v2_alloc() -> i64 {
    let mut pid: i64 = 1
    while pid < PROC_V2_MAX {
        let state = volatile_read_u64(PROC_TABLE_V2 + pid * PROC_V2_SIZE)
        if state == PROC_STATE_FREE { return pid }
        pid = pid + 1
    }
    -1
}

@kernel fn proc_v2_set(pid: i64, field: i64, val: i64) {
    volatile_write_u64(PROC_TABLE_V2 + pid * PROC_V2_SIZE + field, val)
}

@kernel fn proc_v2_get(pid: i64, field: i64) -> i64 {
    volatile_read_u64(PROC_TABLE_V2 + pid * PROC_V2_SIZE + field)
}

@kernel fn proc_v2_fork(parent_pid: i64) -> i64 {
    let child_pid = proc_v2_alloc()
    if child_pid < 0 { return -1 }

    // Copy parent state to child
    proc_v2_set(child_pid, 0, PROC_STATE_READY)
    proc_v2_set(child_pid, 8, child_pid) // pid
    proc_v2_set(child_pid, 16, parent_pid) // ppid
    proc_v2_set(child_pid, 24, proc_v2_get(parent_pid, 24)) // entry
    proc_v2_set(child_pid, 56, 0) // exit_code

    // Allocate kernel stack for child
    let stack_frame = frame_alloc()
    if stack_frame != -1 {
        let stack_addr = stack_frame * FRAME_SIZE + FRAME_SIZE // top of stack
        proc_v2_set(child_pid, 40, stack_addr)
    }

    child_pid
}

@kernel fn proc_v2_exit(pid: i64, code: i64) {
    proc_v2_set(pid, 0, PROC_STATE_ZOMBIE)
    proc_v2_set(pid, 56, code)
    // TODO: signal parent, free resources
}

@kernel fn proc_v2_waitpid(parent_pid: i64, child_pid: i64) -> i64 {
    // Check if child is zombie
    let state = proc_v2_get(child_pid, 0)
    if state == PROC_STATE_ZOMBIE {
        let code = proc_v2_get(child_pid, 56)
        proc_v2_set(child_pid, 0, PROC_STATE_FREE) // Reap
        return code
    }
    -1 // Not ready yet
}

@kernel fn cmd_proc_v2() {
    cprintln("Process Table v2:", YELLOW_ON_BLACK)
    let mut pid: i64 = 0
    while pid < PROC_V2_MAX {
        let state = proc_v2_get(pid, 0)
        if state != PROC_STATE_FREE {
            cprint("  PID ", WHITE_ON_BLACK)
            cprint_decimal(pid, CYAN_ON_BLACK)
            cprint(" PPID=", WHITE_ON_BLACK)
            cprint_decimal(proc_v2_get(pid, 16), CYAN_ON_BLACK)
            cprint(" state=", WHITE_ON_BLACK)
            if state == PROC_STATE_READY { cprint("READY", GREEN_ON_BLACK) }
            else if state == PROC_STATE_RUNNING { cprint("RUNNING", CYAN_ON_BLACK) }
            else if state == PROC_STATE_BLOCKED { cprint("BLOCKED", YELLOW_ON_BLACK) }
            else if state == PROC_STATE_ZOMBIE { cprint("ZOMBIE", RED_ON_BLACK) }
            console_putchar(10, WHITE_ON_BLACK)
        }
        pid = pid + 1
    }
}

@kernel fn cmd_fork_test() {
    cprintln("Fork test:", YELLOW_ON_BLACK)
    let child = proc_v2_fork(0)
    if child >= 0 {
        cprint("  Forked child PID ", WHITE_ON_BLACK)
        cprint_decimal(child, GREEN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        // Simulate child exit
        proc_v2_exit(child, 42)
        let code = proc_v2_waitpid(0, child)
        cprint("  Child exited with code ", WHITE_ON_BLACK)
        cprint_decimal(code, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    } else {
        cprintln("  Fork failed: no free PID", RED_ON_BLACK)
    }
}

// ═══════════════════════════════════════════════
// PS/2 Keyboard Driver (Sprint B7)
// Uses port_inb(0x60) for scancode, IRQ1
// ═══════════════════════════════════════════════

const KB_DATA_PORT: i64 = 0x60
const KB_STATUS_PORT: i64 = 0x64
const KB_BUFFER: i64 = 0x892000  // 256-byte ring buffer
// +0: head, +8: tail, +16: buffer[256]

@kernel fn kb_init() {
    volatile_write_u64(KB_BUFFER, 0)      // head = 0
    volatile_write_u64(KB_BUFFER + 8, 0)  // tail = 0
    frame_mark_used(KB_BUFFER / FRAME_SIZE)
}

@kernel fn kb_push_char(ch: i64) {
    let tail = volatile_read_u64(KB_BUFFER + 8)
    let new_tail = (tail + 1) % 256
    let head = volatile_read_u64(KB_BUFFER)
    if new_tail != head { // Not full
        volatile_write_u8(KB_BUFFER + 16 + tail, ch)
        volatile_write_u64(KB_BUFFER + 8, new_tail)
    }
}

@kernel fn kb_pop_char() -> i64 {
    let head = volatile_read_u64(KB_BUFFER)
    let tail = volatile_read_u64(KB_BUFFER + 8)
    if head == tail { return -1 } // Empty
    let ch = volatile_read_u8(KB_BUFFER + 16 + head)
    volatile_write_u64(KB_BUFFER, (head + 1) % 256)
    ch
}

@kernel fn kb_has_char() -> i64 {
    let head = volatile_read_u64(KB_BUFFER)
    let tail = volatile_read_u64(KB_BUFFER + 8)
    if head != tail { 1 } else { 0 }
}

// Scancode set 1 → ASCII (basic mapping)
@kernel fn scancode_to_ascii(sc: i64) -> i64 {
    // Row 1: 1234567890-=
    if sc == 0x02 { return 49 } // '1'
    if sc == 0x03 { return 50 } // '2'
    if sc == 0x04 { return 51 } // '3'
    if sc == 0x05 { return 52 } // '4'
    if sc == 0x06 { return 53 } // '5'
    if sc == 0x07 { return 54 } // '6'
    if sc == 0x08 { return 55 } // '7'
    if sc == 0x09 { return 56 } // '8'
    if sc == 0x0A { return 57 } // '9'
    if sc == 0x0B { return 48 } // '0'
    if sc == 0x0C { return 45 } // '-'
    if sc == 0x0D { return 61 } // '='
    // Row 2: qwertyuiop
    if sc == 0x10 { return 113 }
    if sc == 0x11 { return 119 }
    if sc == 0x12 { return 101 }
    if sc == 0x13 { return 114 }
    if sc == 0x14 { return 116 }
    if sc == 0x15 { return 121 }
    if sc == 0x16 { return 117 }
    if sc == 0x17 { return 105 }
    if sc == 0x18 { return 111 }
    if sc == 0x19 { return 112 }
    // Row 3: asdfghjkl
    if sc == 0x1E { return 97 }
    if sc == 0x1F { return 115 }
    if sc == 0x20 { return 100 }
    if sc == 0x21 { return 102 }
    if sc == 0x22 { return 103 }
    if sc == 0x23 { return 104 }
    if sc == 0x24 { return 106 }
    if sc == 0x25 { return 107 }
    if sc == 0x26 { return 108 }
    // Row 4: zxcvbnm
    if sc == 0x2C { return 122 }
    if sc == 0x2D { return 120 }
    if sc == 0x2E { return 99 }
    if sc == 0x2F { return 118 }
    if sc == 0x30 { return 98 }
    if sc == 0x31 { return 110 }
    if sc == 0x32 { return 109 }
    // Special
    if sc == 0x1C { return 10 }  // Enter
    if sc == 0x39 { return 32 }  // Space
    if sc == 0x0E { return 8 }   // Backspace
    if sc == 0x01 { return 27 }  // Escape
    if sc == 0x34 { return 46 }  // '.'
    if sc == 0x33 { return 44 }  // ','
    if sc == 0x35 { return 47 }  // '/'
    0 // Unknown
}

@kernel fn kb_handle_irq() {
    // Read scancode from PS/2 data port
    let sc = port_inb(KB_DATA_PORT)
    // Only process make codes (bit 7 = 0)
    if sc < 0x80 {
        let ascii = scancode_to_ascii(sc)
        if ascii > 0 {
            kb_push_char(ascii)
        }
    }
}

@kernel fn cmd_kb_test() {
    cprintln("Keyboard Buffer:", YELLOW_ON_BLACK)
    let head = volatile_read_u64(KB_BUFFER)
    let tail = volatile_read_u64(KB_BUFFER + 8)
    cprint("  Head: ", WHITE_ON_BLACK)
    cprint_decimal(head, CYAN_ON_BLACK)
    cprint("  Tail: ", WHITE_ON_BLACK)
    cprint_decimal(tail, CYAN_ON_BLACK)
    let buffered = if tail >= head { tail - head } else { 256 - head + tail }
    cprint("  Buffered: ", WHITE_ON_BLACK)
    cprint_decimal(buffered, CYAN_ON_BLACK)
    cprintln(" chars", WHITE_ON_BLACK)

    // Drain and print
    let mut count: i64 = 0
    while kb_has_char() == 1 && count < 64 {
        let ch = kb_pop_char()
        if ch > 31 && ch < 127 { console_putchar(ch, GREEN_ON_BLACK) }
        count = count + 1
    }
    if count > 0 { console_putchar(10, WHITE_ON_BLACK) }
}

// ═══════════════════════════════════════════════
// USB XHCI Detection (Sprint B8)
// ═══════════════════════════════════════════════

@kernel fn usb_find_xhci() -> i64 {
    let mut dev: i64 = 0
    while dev < 32 {
        let id = pci_read32(0, dev, 0, 0)
        if id != 0xFFFFFFFF && id != 0 {
            let cl = pci_read32(0, dev, 0, 8)
            let class = (cl >> 24) & 0xFF
            let subclass = (cl >> 16) & 0xFF
            let progif = (cl >> 8) & 0xFF
            // USB: class 0x0C, subclass 0x03, progif 0x30=XHCI
            if class == 0x0C && subclass == 0x03 && progif == 0x30 { return dev }
        }
        dev = dev + 1
    }
    -1
}

@kernel fn cmd_lsusb() {
    cprintln("USB Controllers:", YELLOW_ON_BLACK)
    let mut dev: i64 = 0
    let mut found: i64 = 0
    while dev < 32 {
        let id = pci_read32(0, dev, 0, 0)
        if id != 0xFFFFFFFF && id != 0 {
            let cl = pci_read32(0, dev, 0, 8)
            let class = (cl >> 24) & 0xFF
            let subclass = (cl >> 16) & 0xFF
            let progif = (cl >> 8) & 0xFF
            if class == 0x0C && subclass == 0x03 {
                cprint("  PCI ", WHITE_ON_BLACK)
                cprint_decimal(dev, CYAN_ON_BLACK)
                cprint(": USB ", WHITE_ON_BLACK)
                if progif == 0x00 { cprint("UHCI", WHITE_ON_BLACK) }
                else if progif == 0x10 { cprint("OHCI", WHITE_ON_BLACK) }
                else if progif == 0x20 { cprint("EHCI", WHITE_ON_BLACK) }
                else if progif == 0x30 { cprint("XHCI", GREEN_ON_BLACK) }
                else { cprint("Unknown", RED_ON_BLACK) }
                let vid = id & 0xFFFF
                let did = (id >> 16) & 0xFFFF
                cprint(" (", WHITE_ON_BLACK)
                cprint_hex(vid, 4, CYAN_ON_BLACK)
                cprint(":", WHITE_ON_BLACK)
                cprint_hex(did, 4, CYAN_ON_BLACK)
                cprintln(")", WHITE_ON_BLACK)

                // Read BAR0 for MMIO base
                let bar0 = pci_read32(0, dev, 0, 0x10)
                if bar0 != 0 {
                    cprint("    BAR0: 0x", WHITE_ON_BLACK)
                    cprint_hex(bar0 & 0xFFFFF000, 8, CYAN_ON_BLACK)
                    console_putchar(10, WHITE_ON_BLACK)
                }
                found = found + 1
            }
        }
        dev = dev + 1
    }
    if found == 0 { cprintln("  No USB controllers found", YELLOW_ON_BLACK) }
}

// XHCI Controller Initialization
const XHCI_STATE: i64 = 0x89A000
// +0: bar_addr, +8: cap_length, +16: max_slots, +24: max_ports, +32: initialized

@kernel fn xhci_init() -> i64 {
    let dev = usb_find_xhci()
    if dev == -1 { return -1 }

    // Enable PCI bus master + memory space
    let cmd = pci_read32(0, dev, 0, 0x04)
    pci_write32(0, dev, 0, 0x04, cmd | 0x06)

    // Get BAR0 (MMIO)
    let bar0 = pci_read32(0, dev, 0, 0x10)
    if bar0 & 1 != 0 { return -2 } // Not MMIO
    let base = bar0 & 0xFFFFF000

    // Map MMIO pages
    map_page(base, base, PAGE_PRESENT | PAGE_WRITABLE)
    map_page(base + 0x1000, base + 0x1000, PAGE_PRESENT | PAGE_WRITABLE)

    volatile_write_u64(XHCI_STATE, base)

    // Read CAPLENGTH (byte at offset 0)
    let cap_length = volatile_read_u8(base) & 0xFF
    volatile_write_u64(XHCI_STATE + 8, cap_length)

    // Read HCSPARAMS1 (offset 0x04)
    let hcsparams1 = volatile_read_u32(base + 4)
    let max_slots = hcsparams1 & 0xFF
    let max_ports = (hcsparams1 >> 24) & 0xFF
    volatile_write_u64(XHCI_STATE + 16, max_slots)
    volatile_write_u64(XHCI_STATE + 24, max_ports)

    // Operational registers at base + cap_length
    let op_base = base + cap_length

    // Read USBSTS — check if halted
    let usbsts = volatile_read_u32(op_base + 0x04)
    let halted = usbsts & 1

    // If running, halt first
    if halted == 0 {
        let usbcmd = volatile_read_u32(op_base)
        volatile_write_u32(op_base, usbcmd & 0xFFFFFFFE) // Clear RS bit
        // Wait for HCHalted
        let mut wait: i64 = 100000
        while volatile_read_u32(op_base + 0x04) & 1 == 0 && wait > 0 {
            pause()
            wait = wait - 1
        }
    }

    // Reset controller
    volatile_write_u32(op_base, 0x02) // HCRST
    let mut wait: i64 = 100000
    while volatile_read_u32(op_base) & 0x02 != 0 && wait > 0 {
        pause()
        wait = wait - 1
    }

    // Check port status
    let port_base = op_base + 0x400
    let mut connected: i64 = 0
    let mut p: i64 = 0
    while p < max_ports {
        let portsc = volatile_read_u32(port_base + p * 0x10)
        let ccs = portsc & 1 // Current Connect Status
        if ccs != 0 { connected = connected + 1 }
        p = p + 1
    }

    volatile_write_u64(XHCI_STATE + 32, 1) // initialized
    frame_mark_used(XHCI_STATE / FRAME_SIZE)
    connected
}

@kernel fn cmd_xhci_info() {
    cprintln("XHCI Controller:", YELLOW_ON_BLACK)
    let result = xhci_init()
    if result < 0 {
        cprintln("  No XHCI controller found", RED_ON_BLACK)
        return
    }
    let base = volatile_read_u64(XHCI_STATE)
    let cap_len = volatile_read_u64(XHCI_STATE + 8)
    let max_slots = volatile_read_u64(XHCI_STATE + 16)
    let max_ports = volatile_read_u64(XHCI_STATE + 24)

    cprint("  BAR0: 0x", WHITE_ON_BLACK)
    cprint_hex(base, 8, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  CAPLENGTH: ", WHITE_ON_BLACK)
    cprint_decimal(cap_len, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Max Slots: ", WHITE_ON_BLACK)
    cprint_decimal(max_slots, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Max Ports: ", WHITE_ON_BLACK)
    cprint_decimal(max_ports, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Connected: ", WHITE_ON_BLACK)
    cprint_decimal(result, if result > 0 { GREEN_ON_BLACK } else { YELLOW_ON_BLACK })
    cprintln(" device(s)", WHITE_ON_BLACK)

    // Show per-port status
    let op_base = base + cap_len
    let port_base = op_base + 0x400
    let mut p: i64 = 0
    while p < max_ports {
        let portsc = volatile_read_u32(port_base + p * 0x10)
        let ccs = portsc & 1
        let ped = (portsc >> 1) & 1
        let speed = (portsc >> 10) & 0xF
        if ccs != 0 {
            cprint("  Port ", WHITE_ON_BLACK)
            cprint_decimal(p + 1, CYAN_ON_BLACK)
            cprint(": CONNECTED", GREEN_ON_BLACK)
            cprint(" speed=", WHITE_ON_BLACK)
            if speed == 1 { cprint("Full(12M)", WHITE_ON_BLACK) }
            else if speed == 2 { cprint("Low(1.5M)", WHITE_ON_BLACK) }
            else if speed == 3 { cprint("High(480M)", WHITE_ON_BLACK) }
            else if speed == 4 { cprint("Super(5G)", CYAN_ON_BLACK) }
            else { cprint_decimal(speed, WHITE_ON_BLACK) }
            console_putchar(10, WHITE_ON_BLACK)
        }
        p = p + 1
    }
}

// ═══════════════════════════════════════════════
// XHCI Full Init + Device Enumeration (Fix 6)
// DCBAA, Command Ring, Event Ring, Enable Slot,
// Address Device, Control Transfers, Mass Storage
// ═══════════════════════════════════════════════

// XHCI extended state (at XHCI_STATE + 64)
// +64: op_base
// +72: dcbaa_addr
// +80: cmd_ring_addr
// +88: evt_ring_addr
// +96: erst_addr (Event Ring Segment Table)
// +104: cmd_ring_enqueue (TRB index)
// +112: evt_ring_dequeue (TRB index)
// +120: cmd_ring_cycle (cycle bit)
// +128: evt_ring_cycle
// +136: slot_count (enabled slots)

const XHCI_DCBAA: i64 = 0x89C000       // DCBAA: 256 entries × 8 bytes = 2KB
const XHCI_CMD_RING: i64 = 0x89D000    // Command Ring: 64 TRBs × 16 bytes = 1KB
const XHCI_EVT_RING: i64 = 0x89E000    // Event Ring: 64 TRBs × 16 bytes = 1KB
const XHCI_ERST: i64 = 0x89F000        // Event Ring Segment Table: 1 entry × 16 bytes
const XHCI_DEV_CTX: i64 = 0x8A0000     // Device Contexts: 8 slots × 2KB = 16KB
const XHCI_INPUT_CTX: i64 = 0x8A4000   // Input Context: 2KB
const XHCI_XFER_BUF: i64 = 0x8A5000    // Transfer buffer: 4KB
const XHCI_TRB_SIZE: i64 = 16
const XHCI_CMD_RING_SIZE: i64 = 64
const XHCI_EVT_RING_SIZE: i64 = 64

// TRB types
const TRB_LINK: i64 = 6
const TRB_ENABLE_SLOT: i64 = 9
const TRB_ADDRESS_DEVICE: i64 = 11
const TRB_CONFIGURE_EP: i64 = 12
const TRB_NO_OP: i64 = 23
const TRB_TRANSFER_EVENT: i64 = 32
const TRB_CMD_COMPLETION: i64 = 33
const TRB_PORT_STATUS: i64 = 34

// Completion codes
const CC_SUCCESS: i64 = 1

@kernel fn xhci_state_write(off: i64, val: i64) {
    volatile_write_u64(XHCI_STATE + off, val)
}
@kernel fn xhci_state_read(off: i64) -> i64 {
    volatile_read_u64(XHCI_STATE + off)
}

@kernel fn xhci_write_trb(base: i64, idx: i64, dw0: i64, dw1: i64, dw2: i64, dw3: i64) {
    let off = base + idx * XHCI_TRB_SIZE
    volatile_write_u32(off, dw0)
    volatile_write_u32(off + 4, dw1)
    volatile_write_u32(off + 8, dw2)
    volatile_write_u32(off + 12, dw3)
}

@kernel fn xhci_read_trb_dw(base: i64, idx: i64, dw_off: i64) -> i64 {
    volatile_read_u32(base + idx * XHCI_TRB_SIZE + dw_off * 4)
}

@kernel fn xhci_full_init() -> i64 {
    // Step 1: Run xhci_init() first (halt, reset, read caps)
    let connected = xhci_init()
    if connected < 0 { return connected }

    let base = xhci_state_read(0)
    let cap_len = xhci_state_read(8)
    let max_slots = xhci_state_read(16)
    let op_base = base + cap_len
    xhci_state_write(64, op_base)

    // Step 2: Map XHCI memory pages
    let mut pg: i64 = XHCI_DCBAA
    while pg < XHCI_XFER_BUF + 0x1000 {
        map_page(pg, pg, PAGE_PRESENT | PAGE_WRITABLE)
        frame_mark_used(pg / FRAME_SIZE)
        pg = pg + FRAME_SIZE
    }

    // Step 3: Zero all XHCI buffers
    let mut i: i64 = 0
    while i < (XHCI_XFER_BUF + 0x1000 - XHCI_DCBAA) {
        volatile_write_u8(XHCI_DCBAA + i, 0)
        i = i + 1
    }

    // Step 4: Set MaxSlotsEn in CONFIG register (op_base + 0x38)
    let use_slots = if max_slots > 8 { 8 } else { max_slots }
    volatile_write_u32(op_base + 0x38, use_slots)

    // Step 5: Set DCBAAP (op_base + 0x30, 64-bit)
    volatile_write_u32(op_base + 0x30, XHCI_DCBAA & 0xFFFFFFFF)
    volatile_write_u32(op_base + 0x34, 0)
    xhci_state_write(72, XHCI_DCBAA)

    // Step 6: Set up Command Ring
    // Write Link TRB at last entry (points back to start, toggle cycle)
    xhci_write_trb(XHCI_CMD_RING, XHCI_CMD_RING_SIZE - 1,
        XHCI_CMD_RING & 0xFFFFFFFF, 0, 0,
        (TRB_LINK << 10) | 0x02) // Type=Link, Toggle Cycle=1
    // Set CRCR (op_base + 0x18, 64-bit) — cycle bit = 1
    volatile_write_u32(op_base + 0x18, (XHCI_CMD_RING & 0xFFFFFFFF) | 1)
    volatile_write_u32(op_base + 0x1C, 0)
    xhci_state_write(80, XHCI_CMD_RING)
    xhci_state_write(104, 0)  // enqueue index
    xhci_state_write(120, 1)  // cycle bit

    // Step 7: Set up Event Ring
    // ERST entry: base address (8 bytes) + ring size (4 bytes) + reserved (4 bytes)
    volatile_write_u32(XHCI_ERST, XHCI_EVT_RING & 0xFFFFFFFF)
    volatile_write_u32(XHCI_ERST + 4, 0)
    volatile_write_u32(XHCI_ERST + 8, XHCI_EVT_RING_SIZE)
    volatile_write_u32(XHCI_ERST + 12, 0)
    xhci_state_write(88, XHCI_EVT_RING)
    xhci_state_write(96, XHCI_ERST)
    xhci_state_write(112, 0) // dequeue index
    xhci_state_write(128, 1) // cycle bit

    // Runtime registers at base + RTSOFF (from RTSOFF register at cap offset 0x18)
    let rtsoff = volatile_read_u32(base + 0x18) & 0xFFFFFFE0
    let rt_base = base + rtsoff
    // Map runtime register page
    map_page(rt_base, rt_base, PAGE_PRESENT | PAGE_WRITABLE)

    // Interrupter 0 registers at rt_base + 0x20 (each interrupter = 0x20 bytes)
    let ir0 = rt_base + 0x20

    // ERSTSZ: number of segments = 1
    volatile_write_u32(ir0 + 0x08, 1)
    // ERDP: dequeue pointer (event ring base, cycle state)
    volatile_write_u32(ir0 + 0x18, XHCI_EVT_RING & 0xFFFFFFFF)
    volatile_write_u32(ir0 + 0x1C, 0)
    // ERSTBA: segment table base address
    volatile_write_u32(ir0 + 0x10, XHCI_ERST & 0xFFFFFFFF)
    volatile_write_u32(ir0 + 0x14, 0)
    // IMAN: enable interrupt
    volatile_write_u32(ir0, volatile_read_u32(ir0) | 0x02)

    // Step 8: Start controller (USBCMD.RS = 1)
    let usbcmd = volatile_read_u32(op_base)
    volatile_write_u32(op_base, usbcmd | 0x01 | 0x04) // RS + INTE

    // Wait for controller not halted
    let mut wait: i64 = 100000
    while volatile_read_u32(op_base + 0x04) & 1 != 0 && wait > 0 {
        pause()
        wait = wait - 1
    }

    xhci_state_write(136, 0) // slot_count = 0

    // Wait a bit for devices to settle after controller start
    // Note: can't use sleep_ms here — IRQs may not be enabled yet
    delay_us(100000) // 100ms via TSC busy-wait

    // Re-scan ports after controller is running
    // For each port with CCS=1, issue a port reset (PR bit = bit 4)
    let max_ports = xhci_state_read(24)
    let port_base = op_base + 0x400
    let mut connected2: i64 = 0
    let mut p: i64 = 0
    while p < max_ports {
        let portsc = volatile_read_u32(port_base + p * 0x10)
        let ccs = portsc & 1  // Current Connect Status
        if ccs != 0 {
            // Port has a device — issue warm/hot reset
            // Write PR (bit 4) to trigger reset, preserve RW1S bits
            volatile_write_u32(port_base + p * 0x10, (portsc & 0x0E01C3E0) | (1 << 4))
            // Wait for reset to complete (PRC = bit 21 set)
            let mut rw: i64 = 100000
            while rw > 0 {
                let ps = volatile_read_u32(port_base + p * 0x10)
                if (ps >> 21) & 1 != 0 { rw = 0 }  // PRC set = reset complete
                else { pause(); rw = rw - 1 }
            }
            // Clear PRC by writing 1 to bit 21
            let ps2 = volatile_read_u32(port_base + p * 0x10)
            volatile_write_u32(port_base + p * 0x10, (ps2 & 0x0E01C3E0) | (1 << 21))
            connected2 = connected2 + 1
        }
        p = p + 1
    }

    println("[XHCI] Controller running")
    if connected2 > connected { connected2 } else { connected }
}

@kernel fn xhci_ring_doorbell(slot: i64, target: i64) {
    let base = xhci_state_read(0)
    let cap_len = xhci_state_read(8)
    // Doorbell array at base + DBOFF (cap offset 0x14)
    let dboff = volatile_read_u32(base + 0x14) & 0xFFFFFFFC
    let db_base = base + dboff
    map_page(db_base, db_base, PAGE_PRESENT | PAGE_WRITABLE)
    volatile_write_u32(db_base + slot * 4, target)
}

@kernel fn xhci_submit_command(dw0: i64, dw1: i64, dw2: i64, trb_type: i64) -> i64 {
    let idx = xhci_state_read(104)
    let cycle = xhci_state_read(120)

    // Write command TRB
    let dw3 = (trb_type << 10) | (cycle & 1)
    xhci_write_trb(XHCI_CMD_RING, idx, dw0, dw1, dw2, dw3)

    // Advance enqueue pointer
    let next = idx + 1
    if next >= XHCI_CMD_RING_SIZE - 1 {
        // Wrap: toggle cycle in link TRB, reset index
        let link_dw3 = xhci_read_trb_dw(XHCI_CMD_RING, XHCI_CMD_RING_SIZE - 1, 3)
        xhci_write_trb(XHCI_CMD_RING, XHCI_CMD_RING_SIZE - 1,
            XHCI_CMD_RING & 0xFFFFFFFF, 0, 0,
            (link_dw3 & 0xFFFFFFFE) | (cycle & 1))
        xhci_state_write(104, 0)
        xhci_state_write(120, 1 - cycle) // toggle
    } else {
        xhci_state_write(104, next)
    }

    // Ring doorbell 0 (host controller) target 0 (command ring)
    xhci_ring_doorbell(0, 0)
    println("[XHCI] Doorbell rung, polling event ring...")

    // Poll event ring for Command Completion Event (skip Port Status Change Events)
    let mut cur_evt_idx = xhci_state_read(112)
    let mut cur_evt_cycle = xhci_state_read(128)
    let mut timeout: i64 = 2000000
    while timeout > 0 {
        let dw3_evt = xhci_read_trb_dw(XHCI_EVT_RING, cur_evt_idx, 3)
        let c_bit = dw3_evt & 1
        if c_bit == (cur_evt_cycle & 1) {
            // Event ready
            let trb_type_evt = (dw3_evt >> 10) & 0x3F
            let cc = (xhci_read_trb_dw(XHCI_EVT_RING, cur_evt_idx, 2) >> 24) & 0xFF
            let slot_id = (dw3_evt >> 24) & 0xFF

            // Advance event dequeue
            let next_evt = cur_evt_idx + 1
            if next_evt >= XHCI_EVT_RING_SIZE {
                cur_evt_idx = 0
                cur_evt_cycle = 1 - cur_evt_cycle
            } else {
                cur_evt_idx = next_evt
            }
            // Save state
            xhci_state_write(112, cur_evt_idx)
            xhci_state_write(128, cur_evt_cycle)

            // Update ERDP
            let base = xhci_state_read(0)
            let rtsoff = volatile_read_u32(base + 0x18) & 0xFFFFFFE0
            let ir0 = base + rtsoff + 0x20
            let new_erdp = XHCI_EVT_RING + cur_evt_idx * XHCI_TRB_SIZE
            volatile_write_u32(ir0 + 0x18, (new_erdp & 0xFFFFFFFF) | 0x08) // EHB
            volatile_write_u32(ir0 + 0x1C, 0)

            // Only process Command Completion Events (type 33)
            if trb_type_evt == TRB_CMD_COMPLETION {
                if cc == CC_SUCCESS {
                    return slot_id
                }
                return -(cc)
            }
            // Skip non-command events (Port Status Change = 34, etc.) and continue
            // Don't decrement timeout for skipped events
        }
        pause()
        timeout = timeout - 1
    }
    -99 // timeout
}

@kernel fn xhci_enable_slot() -> i64 {
    // Send Enable Slot command, returns slot_id or negative error
    println("[XHCI] Submitting Enable Slot command...")
    let result = xhci_submit_command(0, 0, 0, TRB_ENABLE_SLOT)
    println("[XHCI] Enable Slot result received")
    if result > 0 {
        let slots = xhci_state_read(136) + 1
        xhci_state_write(136, slots)
    }
    result
}

// Extended XHCI memory layout for USB mass storage
const XHCI_EP0_RING: i64 = 0x8A6000     // EP0 transfer ring: 32 TRBs
const XHCI_BULK_IN_RING: i64 = 0x8A7000 // Bulk IN transfer ring: 32 TRBs
const XHCI_BULK_OUT_RING: i64 = 0x8A8000 // Bulk OUT transfer ring: 32 TRBs
const XHCI_DATA_BUF: i64 = 0x8A9000     // Data buffer for control/bulk transfers: 8KB
const XHCI_EP0_RING_SIZE: i64 = 32
const XHCI_BULK_RING_SIZE: i64 = 32

// USB extended state (XHCI_STATE + 144...)
// +144: slot_id (for current device)
// +152: max_packet_size (EP0)
// +160: bulk_in_ep (endpoint address, e.g., 0x81)
// +168: bulk_out_ep (endpoint address, e.g., 0x02)
// +176: ep0_enqueue
// +184: ep0_cycle
// +192: bulk_in_enqueue
// +200: bulk_in_cycle
// +208: bulk_out_enqueue
// +216: bulk_out_cycle
// +224: usb_mass_storage_ready (1 if SCSI mass storage detected)

// TRB types for transfers
const TRB_NORMAL: i64 = 1
const TRB_SETUP: i64 = 2
const TRB_DATA: i64 = 3
const TRB_STATUS: i64 = 4

// USB request types
const USB_DIR_IN: i64 = 0x80
const USB_DIR_OUT: i64 = 0x00
const USB_REQ_GET_DESCRIPTOR: i64 = 6
const USB_REQ_SET_CONFIGURATION: i64 = 9
const USB_DESC_DEVICE: i64 = 1
const USB_DESC_CONFIGURATION: i64 = 2

// USB Mass Storage class
const USB_CLASS_MASS_STORAGE: i64 = 0x08
const USB_SUBCLASS_SCSI: i64 = 0x06
const USB_PROTOCOL_BOT: i64 = 0x50

// SCSI commands
const SCSI_INQUIRY: i64 = 0x12
const SCSI_TEST_UNIT_READY: i64 = 0x00
const SCSI_READ_CAPACITY: i64 = 0x25
const SCSI_READ_10: i64 = 0x28
const SCSI_WRITE_10: i64 = 0x2A

// CBW/CSW signatures
const CBW_SIGNATURE: i64 = 0x43425355
const CSW_SIGNATURE: i64 = 0x53425355

@kernel fn xhci_address_device(slot_id: i64, port_num: i64, speed: i64) -> i64 {
    println("[XHCI] Address Device: setup input context...")
    let ictx = XHCI_INPUT_CTX
    // Map extra pages for EP0 ring, bulk rings, data buffer
    let mut pg: i64 = XHCI_EP0_RING
    while pg < XHCI_DATA_BUF + 0x2000 {
        map_page(pg, pg, PAGE_PRESENT | PAGE_WRITABLE)
        frame_mark_used(pg / FRAME_SIZE)
        pg = pg + FRAME_SIZE
    }
    // Zero all
    let mut i: i64 = 0
    while i < 2048 { volatile_write_u8(ictx + i, 0); i = i + 1 }
    i = 0
    while i < 0x3000 { volatile_write_u8(XHCI_EP0_RING + i, 0); i = i + 1 }

    // Check Context Size: HCCPARAMS1 bit 2 (CSZ)
    let base = xhci_state_read(0)
    let hccparams1 = volatile_read_u32(base + 0x10)
    let csz = (hccparams1 >> 2) & 1 // 0=32-byte, 1=64-byte contexts
    let ctx_size = if csz == 1 { 64 } else { 32 }
    println("[XHCI] Context size: 32 or 64 bytes")

    // Input Control Context: Add Slot (A0) + EP0 (A1)
    // Add Context Flags at offset 4 of Input Control Context
    volatile_write_u32(ictx + 4, 0x03)

    // Slot Context (at offset ctx_size from start of Input Context)
    let slot_ctx = ictx + ctx_size
    let speed_val = if speed == 0 { 3 } else { speed }
    // DW0: Route String=0, Speed (bits 23:20), Context Entries=1 (bits 31:27)
    volatile_write_u32(slot_ctx, (1 << 27) | (speed_val << 20))
    // DW1: Root Hub Port Number (bits 23:16)
    volatile_write_u32(slot_ctx + 4, (port_num << 16) & 0xFF0000)

    // EP0 Context (at offset 2 * ctx_size from start)
    let ep0_ctx = ictx + ctx_size * 2
    let max_pkt = if speed_val == 1 { 8 }
                  else if speed_val == 2 { 8 }
                  else if speed_val == 3 { 64 }
                  else { 512 }
    // DW1: CErr=3 (bits 2:1), EPType=4 (bits 5:3), MaxPacketSize (bits 31:16)
    volatile_write_u32(ep0_ctx + 4, (3 << 1) | (4 << 3) | (max_pkt << 16))
    // DW2-DW3: TR Dequeue Pointer (EP0 ring) with DCS=1
    volatile_write_u32(ep0_ctx + 8, (XHCI_EP0_RING & 0xFFFFFFFF) | 1)
    volatile_write_u32(ep0_ctx + 12, 0)
    // DW4: Average TRB Length = 8 (for control)
    volatile_write_u32(ep0_ctx + 16, 8)

    // Write Link TRB at end of EP0 ring
    xhci_write_trb(XHCI_EP0_RING, XHCI_EP0_RING_SIZE - 1,
        XHCI_EP0_RING & 0xFFFFFFFF, 0, 0, (TRB_LINK << 10) | 0x02)

    // Output Device Context (allocate per context size: 32 or 64 bytes × 32 entries = 1KB or 2KB)
    let dev_ctx_sz = ctx_size * 32 // Slot + 31 EP contexts
    let out_ctx = XHCI_DEV_CTX + (slot_id - 1) * dev_ctx_sz
    // Zero output context
    i = 0
    while i < dev_ctx_sz { volatile_write_u8(out_ctx + i, 0); i = i + 1 }
    volatile_write_u64(XHCI_DCBAA + slot_id * 8, out_ctx)
    println("[XHCI] DCBAA + output context set")

    // Save state
    xhci_state_write(144, slot_id)
    xhci_state_write(152, max_pkt)
    xhci_state_write(176, 0)  // ep0_enqueue = 0
    xhci_state_write(184, 1)  // ep0_cycle = 1

    // Submit Address Device command
    println("[XHCI] Submitting Address Device command...")
    let idx = xhci_state_read(104)
    let cycle = xhci_state_read(120)
    // DW0: Input Context pointer (low 32), must be 16-byte aligned
    // DW1: Input Context pointer (high 32) = 0
    // DW2: reserved = 0
    // DW3: Slot ID [31:24] | BSR [9] = 0 | Type [15:10] = 11 | C [0]
    let dw3 = ((slot_id & 0xFF) << 24) | (TRB_ADDRESS_DEVICE << 10) | (cycle & 1)
    xhci_write_trb(XHCI_CMD_RING, idx, ictx & 0xFFFFFFFF, 0, 0, dw3)
    println("[XHCI] TRB written to cmd ring")

    let next = idx + 1
    if next >= XHCI_CMD_RING_SIZE - 1 {
        let link_dw3 = xhci_read_trb_dw(XHCI_CMD_RING, XHCI_CMD_RING_SIZE - 1, 3)
        xhci_write_trb(XHCI_CMD_RING, XHCI_CMD_RING_SIZE - 1,
            XHCI_CMD_RING & 0xFFFFFFFF, 0, 0, (link_dw3 & 0xFFFFFFFE) | (cycle & 1))
        xhci_state_write(104, 0)
        xhci_state_write(120, 1 - cycle)
    } else {
        xhci_state_write(104, next)
    }

    xhci_ring_doorbell(0, 0)
    println("[XHCI] Doorbell rung for Address Device")

    // Poll event ring for completion — may get Port Status Change Events first
    let evt_idx = xhci_state_read(112)
    let evt_cycle = xhci_state_read(128)
    let mut timeout: i64 = 2000000
    let mut cur_evt = evt_idx
    let mut cur_cycle = evt_cycle
    while timeout > 0 {
        let dw3_evt = xhci_read_trb_dw(XHCI_EVT_RING, cur_evt, 3)
        if (dw3_evt & 1) == (cur_cycle & 1) {
            let evt_type = (dw3_evt >> 10) & 0x3F
            let cc = (xhci_read_trb_dw(XHCI_EVT_RING, cur_evt, 2) >> 24) & 0xFF
            // Advance event dequeue
            let next_evt = cur_evt + 1
            if next_evt >= XHCI_EVT_RING_SIZE {
                cur_evt = 0
                cur_cycle = 1 - cur_cycle
            } else {
                cur_evt = next_evt
            }
            // Update ERDP
            let base = xhci_state_read(0)
            let rtsoff = volatile_read_u32(base + 0x18) & 0xFFFFFFE0
            let ir0 = base + rtsoff + 0x20
            volatile_write_u32(ir0 + 0x18, ((XHCI_EVT_RING + cur_evt * XHCI_TRB_SIZE) & 0xFFFFFFFF) | 0x08)
            volatile_write_u32(ir0 + 0x1C, 0)
            // Save updated event ring state
            xhci_state_write(112, cur_evt)
            xhci_state_write(128, cur_cycle)

            if evt_type == TRB_CMD_COMPLETION {
                // Command Completion Event — this is what we want
                println("[XHCI] Address Device completion received")
                if cc == CC_SUCCESS { return 0 }
                println("[XHCI] Address Device failed with CC")
                return -(cc)
            }
            // Port Status Change or other event — skip and continue polling
            println("[XHCI] Skipping non-command event, continuing...")
        } else {
            pause()
            timeout = timeout - 1
        }
    }
    println("[XHCI] Address Device timeout!")
    -99
}

// ── USB Control Transfer (Setup → Data → Status TRBs) ──

@kernel fn xhci_control_transfer(slot_id: i64, bm_request: i64, b_request: i64,
                                  w_value: i64, w_index: i64, w_length: i64,
                                  data_buf: i64, direction: i64) -> i64 {
    let enq = xhci_state_read(176)
    let cycle = xhci_state_read(184)

    // Setup TRB (8 bytes of setup packet in DW0-DW1)
    let setup_lo = (bm_request & 0xFF) | ((b_request & 0xFF) << 8) | ((w_value & 0xFFFF) << 16)
    let setup_hi = (w_index & 0xFFFF) | ((w_length & 0xFFFF) << 16)
    // DW2: TRB Transfer Length = 8 (setup packet always 8 bytes)
    // DW3: TRT(16:17) = 3 (IN data stage) or 2 (OUT data stage) or 0 (no data), IDT=1(6), Type=Setup
    let trt = if w_length == 0 { 0 } else if direction == USB_DIR_IN { 3 } else { 2 }
    let setup_dw3 = (TRB_SETUP << 10) | (1 << 6) | (trt << 16) | (cycle & 1)
    xhci_write_trb(XHCI_EP0_RING, enq, setup_lo, setup_hi, 8, setup_dw3)
    let mut idx = enq + 1

    // Data TRB (if w_length > 0)
    if w_length > 0 {
        let data_dir = if direction == USB_DIR_IN { 1 } else { 0 } // DIR bit in DW3[16]
        let data_dw3 = (TRB_DATA << 10) | (data_dir << 16) | (cycle & 1)
        xhci_write_trb(XHCI_EP0_RING, idx, data_buf & 0xFFFFFFFF, 0, w_length, data_dw3)
        idx = idx + 1
    }

    // Status TRB
    let status_dir = if w_length == 0 || direction == USB_DIR_OUT { 1 } else { 0 }
    let status_dw3 = (TRB_STATUS << 10) | (status_dir << 16) | (1 << 5) | (cycle & 1) // IOC=1
    xhci_write_trb(XHCI_EP0_RING, idx, 0, 0, 0, status_dw3)
    idx = idx + 1

    // Handle wrap
    if idx >= XHCI_EP0_RING_SIZE - 1 {
        let link_dw3 = xhci_read_trb_dw(XHCI_EP0_RING, XHCI_EP0_RING_SIZE - 1, 3)
        xhci_write_trb(XHCI_EP0_RING, XHCI_EP0_RING_SIZE - 1,
            XHCI_EP0_RING & 0xFFFFFFFF, 0, 0, (link_dw3 & 0xFFFFFFFE) | (cycle & 1))
        xhci_state_write(176, 0)
        xhci_state_write(184, 1 - cycle)
    } else {
        xhci_state_write(176, idx)
    }

    // Ring EP0 doorbell (slot_id, target=1 for EP0)
    xhci_ring_doorbell(slot_id, 1)

    // Poll for Transfer Event completion (skip Port Status Change Events)
    let mut xfer_evt_idx = xhci_state_read(112)
    let mut xfer_evt_cycle = xhci_state_read(128)
    let mut timeout: i64 = 2000000
    while timeout > 0 {
        let dw3_evt = xhci_read_trb_dw(XHCI_EVT_RING, xfer_evt_idx, 3)
        if (dw3_evt & 1) == (xfer_evt_cycle & 1) {
            let evt_type = (dw3_evt >> 10) & 0x3F
            let cc = (xhci_read_trb_dw(XHCI_EVT_RING, xfer_evt_idx, 2) >> 24) & 0xFF
            let residual = xhci_read_trb_dw(XHCI_EVT_RING, xfer_evt_idx, 2) & 0xFFFFFF
            // Advance
            let next_evt = xfer_evt_idx + 1
            if next_evt >= XHCI_EVT_RING_SIZE {
                xfer_evt_idx = 0
                xfer_evt_cycle = 1 - xfer_evt_cycle
            } else {
                xfer_evt_idx = next_evt
            }
            xhci_state_write(112, xfer_evt_idx)
            xhci_state_write(128, xfer_evt_cycle)
            // Update ERDP
            let base = xhci_state_read(0)
            let rtsoff = volatile_read_u32(base + 0x18) & 0xFFFFFFE0
            let ir0 = base + rtsoff + 0x20
            volatile_write_u32(ir0 + 0x18, ((XHCI_EVT_RING + xfer_evt_idx * XHCI_TRB_SIZE) & 0xFFFFFFFF) | 0x08)
            volatile_write_u32(ir0 + 0x1C, 0)
            // Only process Transfer Events (type 32) or Command Completion (type 33)
            if evt_type == TRB_TRANSFER_EVENT || evt_type == TRB_CMD_COMPLETION {
                if cc == CC_SUCCESS || cc == 13 { return w_length - residual }
                return -(cc)
            }
            // Skip other event types
        } else {
            pause()
            timeout = timeout - 1
        }
    }
    -99
}

@kernel fn usb_get_descriptor(slot_id: i64, desc_type: i64, desc_idx: i64, length: i64) -> i64 {
    // Zero data buffer
    let mut i: i64 = 0
    while i < length && i < 4096 { volatile_write_u8(XHCI_DATA_BUF + i, 0); i = i + 1 }
    xhci_control_transfer(slot_id, USB_DIR_IN, USB_REQ_GET_DESCRIPTOR,
        (desc_type << 8) | desc_idx, 0, length, XHCI_DATA_BUF, USB_DIR_IN)
}

@kernel fn usb_set_configuration(slot_id: i64, config_val: i64) -> i64 {
    xhci_control_transfer(slot_id, USB_DIR_OUT, USB_REQ_SET_CONFIGURATION,
        config_val, 0, 0, 0, USB_DIR_OUT)
}

// ── USB Mass Storage Detection ──

@kernel fn usb_find_mass_storage() -> i64 {
    // Parse configuration descriptor to find mass storage interface
    // Config descriptor at XHCI_DATA_BUF (after GET_DESCRIPTOR config)
    let total_len = volatile_read_u8(XHCI_DATA_BUF + 2) | (volatile_read_u8(XHCI_DATA_BUF + 3) << 8)
    let mut offset: i64 = 0
    while offset + 2 < total_len && offset < 4096 {
        let desc_len = volatile_read_u8(XHCI_DATA_BUF + offset)
        let desc_type = volatile_read_u8(XHCI_DATA_BUF + offset + 1)
        if desc_len < 2 { return -1 } // invalid
        // Interface descriptor: type = 4, length >= 9
        if desc_type == 4 && desc_len >= 9 {
            let iface_class = volatile_read_u8(XHCI_DATA_BUF + offset + 5)
            let iface_subclass = volatile_read_u8(XHCI_DATA_BUF + offset + 6)
            let iface_protocol = volatile_read_u8(XHCI_DATA_BUF + offset + 7)
            if iface_class == USB_CLASS_MASS_STORAGE && iface_subclass == USB_SUBCLASS_SCSI && iface_protocol == USB_PROTOCOL_BOT {
                // Found! Now find bulk endpoints
                let ep_offset = offset + desc_len
                let mut ep_off = ep_offset
                while ep_off + 2 < total_len && ep_off < 4096 {
                    let ep_len = volatile_read_u8(XHCI_DATA_BUF + ep_off)
                    let ep_type = volatile_read_u8(XHCI_DATA_BUF + ep_off + 1)
                    if ep_type == 4 { ep_off = total_len } // next interface, stop
                    else if ep_type == 5 && ep_len >= 7 {
                        // Endpoint descriptor
                        let ep_addr = volatile_read_u8(XHCI_DATA_BUF + ep_off + 2)
                        let ep_attr = volatile_read_u8(XHCI_DATA_BUF + ep_off + 3)
                        if (ep_attr & 0x03) == 2 { // Bulk transfer type
                            if (ep_addr & 0x80) != 0 {
                                xhci_state_write(160, ep_addr) // Bulk IN
                            } else {
                                xhci_state_write(168, ep_addr) // Bulk OUT
                            }
                        }
                    }
                    ep_off = ep_off + ep_len
                }
                return 0 // found
            }
        }
        offset = offset + desc_len
    }
    -1 // not found
}

// ── SCSI via Bulk-Only Transport (BOT) ──

@kernel fn usb_bot_cbw(tag: i64, data_len: i64, direction: i64, lun: i64, cb_len: i64, cb: i64) {
    // Build CBW at XHCI_DATA_BUF + 4096 (31 bytes)
    let cbw = XHCI_DATA_BUF + 4096
    volatile_write_u32(cbw, CBW_SIGNATURE)  // dCBWSignature
    volatile_write_u32(cbw + 4, tag)         // dCBWTag
    volatile_write_u32(cbw + 8, data_len)    // dCBWDataTransferLength
    volatile_write_u8(cbw + 12, direction)   // bmCBWFlags (0x80=IN, 0x00=OUT)
    volatile_write_u8(cbw + 13, lun)         // bCBWLUN
    volatile_write_u8(cbw + 14, cb_len)      // bCBWCBLength
    // Copy command block (up to 16 bytes)
    let mut i: i64 = 0
    while i < 16 {
        if i < cb_len {
            volatile_write_u8(cbw + 15 + i, volatile_read_u8(cb + i))
        } else {
            volatile_write_u8(cbw + 15 + i, 0)
        }
        i = i + 1
    }
}

@kernel fn usb_scsi_test_unit_ready() -> i64 {
    // Build SCSI TEST UNIT READY command (6 bytes, all zeros except opcode)
    let cmd = XHCI_DATA_BUF + 5000
    let mut i: i64 = 0
    while i < 16 { volatile_write_u8(cmd + i, 0); i = i + 1 }
    volatile_write_u8(cmd, SCSI_TEST_UNIT_READY) // opcode 0x00
    usb_bot_command(cmd, 6, 0, 0, 0x80)
}

// ── cmd_usb_init: Full USB enumeration ──

@kernel fn cmd_usb_init() {
    println("[USB] cmd_usb_init starting...")
    cprintln("USB Init (XHCI):", YELLOW_ON_BLACK)
    let connected = xhci_full_init()
    if connected < 0 {
        println("[USB] XHCI init failed")
        cprint("  XHCI init failed: ", RED_ON_BLACK)
        cprint_decimal(connected, RED_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        return
    }
    println("[USB] XHCI running, checking devices...")

    // Debug: dump all port status registers
    let dbg_base = xhci_state_read(0)
    let dbg_cap = xhci_state_read(8)
    let dbg_op = dbg_base + dbg_cap
    let dbg_ports = xhci_state_read(24)
    let dbg_port_base = dbg_op + 0x400
    let mut dp: i64 = 0
    while dp < dbg_ports && dp < 8 {
        let ps = volatile_read_u32(dbg_port_base + dp * 0x10)
        if ps != 0 {
            println("[USB] Port PORTSC non-zero")
        }
        dp = dp + 1
    }

    cprint("  Controller running, ", GREEN_ON_BLACK)
    cprint_decimal(connected, CYAN_ON_BLACK)
    cprintln(" device(s) connected", WHITE_ON_BLACK)

    if connected == 0 {
        println("[USB] No devices connected, trying xhci command test...")
        // Try NoOp command to test command ring works
        let noop = xhci_submit_command(0, 0, 0, TRB_NO_OP)
        if noop >= 0 {
            println("[USB] NoOp command succeeded")
        } else {
            println("[USB] NoOp command failed/timeout")
        }
        cprintln("  No devices to enumerate", YELLOW_ON_BLACK)
        return
    }
    println("[USB] Proceeding to enumerate...")

    // Enable slot
    let slot = xhci_enable_slot()
    println("[USB] Enable slot returned")
    if slot <= 0 {
        println("[USB] Enable slot failed or returned 0")
        cprint("  Enable slot failed: ", RED_ON_BLACK)
        cprint_decimal(slot, RED_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        return
    }
    println("[USB] Slot enabled successfully")
    println("[USB] About to call xhci_address_device...")

    // Find first connected port
    let op_base = xhci_state_read(64)
    let max_ports = xhci_state_read(24)
    let port_base = op_base + 0x400
    let mut port: i64 = 0
    let mut port_speed: i64 = 0
    let mut found_port: i64 = 0
    while port < max_ports && found_port == 0 {
        let portsc = volatile_read_u32(port_base + port * 0x10)
        if portsc & 1 != 0 {
            port_speed = (portsc >> 10) & 0xF
            found_port = port + 1
        }
        port = port + 1
    }
    if found_port == 0 {
        cprintln("  No connected port found", RED_ON_BLACK)
        return
    }
    cprint("  Port ", WHITE_ON_BLACK)
    cprint_decimal(found_port, CYAN_ON_BLACK)
    cprint(" speed=", WHITE_ON_BLACK)
    if port_speed == 3 { cprint("High(480M)", WHITE_ON_BLACK) }
    else if port_speed == 4 { cprint("Super(5G)", CYAN_ON_BLACK) }
    else { cprint_decimal(port_speed, WHITE_ON_BLACK) }
    console_putchar(10, WHITE_ON_BLACK)

    // Address device
    let addr = xhci_address_device(slot, found_port, port_speed)
    if addr < 0 {
        cprint("  Address device failed: ", RED_ON_BLACK)
        cprint_decimal(addr, RED_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        return
    }
    println("[USB] Device addressed OK")

    // GET_DESCRIPTOR (device, 18 bytes)
    println("[USB] GET_DESCRIPTOR device...")
    let dev_desc = usb_get_descriptor(slot, USB_DESC_DEVICE, 0, 18)
    println("[USB] GET_DESCRIPTOR returned")
    if dev_desc >= 0 {
        let vid = volatile_read_u8(XHCI_DATA_BUF + 8) | (volatile_read_u8(XHCI_DATA_BUF + 9) << 8)
        let pid = volatile_read_u8(XHCI_DATA_BUF + 10) | (volatile_read_u8(XHCI_DATA_BUF + 11) << 8)
        let dev_class = volatile_read_u8(XHCI_DATA_BUF + 4)
        let num_configs = volatile_read_u8(XHCI_DATA_BUF + 17)
        cprint("  VID:PID = ", WHITE_ON_BLACK)
        cprint_hex(vid, 4, CYAN_ON_BLACK)
        cprint(":", WHITE_ON_BLACK)
        cprint_hex(pid, 4, CYAN_ON_BLACK)
        cprint("  class=", WHITE_ON_BLACK)
        cprint_hex(dev_class, 2, CYAN_ON_BLACK)
        cprint("  configs=", WHITE_ON_BLACK)
        cprint_decimal(num_configs, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    } else {
        println("[USB] GET_DESCRIPTOR(device) FAILED")
        return
    }

    // GET_DESCRIPTOR (config, 255 bytes)
    println("[USB] GET_DESCRIPTOR config...")
    let cfg_desc = usb_get_descriptor(slot, USB_DESC_CONFIGURATION, 0, 255)
    println("[USB] Config descriptor returned")
    if cfg_desc >= 0 {
        println("[USB] Config descriptor OK")
        let cfg_val = volatile_read_u8(XHCI_DATA_BUF + 5)
        let num_ifaces = volatile_read_u8(XHCI_DATA_BUF + 4)
        println("[USB] SET_CONFIGURATION...")
        let set_cfg = usb_set_configuration(slot, cfg_val)
        if set_cfg >= 0 {
            println("[USB] Configuration set OK")
        } else {
            println("[USB] SET_CONFIGURATION failed")
        }

        // Find mass storage interface
        println("[USB] Finding mass storage interface...")
        let ms = usb_find_mass_storage()
        if ms == 0 {
            let bulk_in = xhci_state_read(160)
            let bulk_out = xhci_state_read(168)
            cprintln("  Mass Storage (SCSI/BOT) detected", GREEN_ON_BLACK)
            cprint("  Bulk IN: EP", WHITE_ON_BLACK)
            cprint_hex(bulk_in, 2, CYAN_ON_BLACK)
            cprint("  Bulk OUT: EP", WHITE_ON_BLACK)
            cprint_hex(bulk_out, 2, CYAN_ON_BLACK)
            console_putchar(10, WHITE_ON_BLACK)
            xhci_state_write(224, 1) // mass storage ready
        } else {
            println("[USB] No mass storage interface found")
        }
    } else {
        println("[USB] Config descriptor FAILED")
    }

    // Boot complete
    // If mass storage detected, configure bulk endpoints and probe SCSI
    if xhci_state_read(224) == 1 {
        println("[USB] Configuring bulk endpoints...")
        let cfg_ep = xhci_configure_bulk_endpoints(slot)
        if cfg_ep >= 0 {
            println("[USB] Bulk endpoints configured")
            // SCSI TEST UNIT READY
            println("[USB] SCSI TEST_UNIT_READY...")
            let tur = usb_scsi_test_unit_ready()
            if tur >= 0 {
                println("[USB] Device ready")
            } else {
                println("[USB] TEST_UNIT_READY failed (retrying...)")
                delay_us(100000)
                let tur2 = usb_scsi_test_unit_ready()
                if tur2 < 0 { println("[USB] Device not ready") }
            }
            // SCSI INQUIRY
            println("[USB] SCSI INQUIRY...")
            let inq = usb_scsi_inquiry_full()
            if inq >= 0 {
                println("[USB] SCSI INQUIRY OK")
            } else {
                println("[USB] SCSI INQUIRY failed")
            }
            // SCSI READ CAPACITY
            println("[USB] SCSI READ_CAPACITY...")
            let cap = usb_scsi_read_capacity_full()
            if cap >= 0 {
                println("[USB] READ_CAPACITY OK")
                // Register as block device 2 (USB)
                let usb_sectors = xhci_state_read(232)
                let usb_sector_sz = xhci_state_read(240)
                blk_register(2, 3, usb_sectors, usb_sector_sz) // type 3 = USB
                println("[USB] Registered as block device 2")
                // Try FAT32 mount
                let mnt = fat32_mount(2)
                if mnt == 0 {
                    println("[USB-FAT32] Mounted from USB!")
                } else {
                    println("[USB-FAT32] No FAT32 on USB (or mount failed)")
                }
            } else {
                println("[USB] READ_CAPACITY failed")
            }
        } else {
            println("[USB] Configure bulk endpoints failed")
        }
    }

    println("[USB] Enumeration complete")
}

// ── Sprint C3: XHCI Bulk Endpoint Configuration ──

@kernel fn xhci_configure_bulk_endpoints(slot_id: i64) -> i64 {
    let bulk_in_ep = xhci_state_read(160)  // e.g., 0x81
    let bulk_out_ep = xhci_state_read(168) // e.g., 0x02
    if bulk_in_ep == 0 || bulk_out_ep == 0 { return -1 }

    // DCI (Device Context Index) = 2 * ep_num + direction
    // For IN endpoint 0x81: ep_num=1, dir=1 → DCI = 2*1 + 1 = 3
    // For OUT endpoint 0x02: ep_num=2, dir=0 → DCI = 2*2 + 0 = 4
    let in_ep_num = bulk_in_ep & 0x0F
    let out_ep_num = bulk_out_ep & 0x0F
    let in_dci = in_ep_num * 2 + 1
    let out_dci = out_ep_num * 2

    // Check context size
    let base = xhci_state_read(0)
    let hccparams1 = volatile_read_u32(base + 0x10)
    let csz = (hccparams1 >> 2) & 1
    let ctx_size = if csz == 1 { 64 } else { 32 }

    // Build Input Context for Configure Endpoint
    let ictx = XHCI_INPUT_CTX
    let mut i: i64 = 0
    while i < 2048 { volatile_write_u8(ictx + i, 0); i = i + 1 }

    // Zero bulk transfer rings
    i = 0
    while i < 0x1000 { volatile_write_u8(XHCI_BULK_IN_RING + i, 0); i = i + 1 }
    i = 0
    while i < 0x1000 { volatile_write_u8(XHCI_BULK_OUT_RING + i, 0); i = i + 1 }

    // Write Link TRBs at end of bulk rings
    xhci_write_trb(XHCI_BULK_IN_RING, XHCI_BULK_RING_SIZE - 1,
        XHCI_BULK_IN_RING & 0xFFFFFFFF, 0, 0, (TRB_LINK << 10) | 0x02)
    xhci_write_trb(XHCI_BULK_OUT_RING, XHCI_BULK_RING_SIZE - 1,
        XHCI_BULK_OUT_RING & 0xFFFFFFFF, 0, 0, (TRB_LINK << 10) | 0x02)

    // Input Control Context: Add flags for Slot + EP contexts
    // Add Context Flags: bit 0 (Slot) + bit for each endpoint DCI
    let add_flags = 1 | (1 << in_dci) | (1 << out_dci)
    volatile_write_u32(ictx + 4, add_flags)

    // Slot Context (at ctx_size offset): update Context Entries to max DCI
    let slot_ctx = ictx + ctx_size
    let max_dci = if in_dci > out_dci { in_dci } else { out_dci }
    // Copy existing slot context DW0 but update Context Entries field
    let speed_val = 3 // High speed default (from address device)
    volatile_write_u32(slot_ctx, (max_dci << 27) | (speed_val << 20))

    // Bulk IN Endpoint Context (at ctx_size * (in_dci + 1) offset)
    let in_ctx = ictx + ctx_size * (in_dci + 1)
    // DW1: CErr=3, EPType=6 (Bulk IN), MaxPacketSize=512
    volatile_write_u32(in_ctx + 4, (3 << 1) | (6 << 3) | (512 << 16))
    // DW2-DW3: TR Dequeue Pointer with DCS=1
    volatile_write_u32(in_ctx + 8, (XHCI_BULK_IN_RING & 0xFFFFFFFF) | 1)
    volatile_write_u32(in_ctx + 12, 0)
    // DW4: Average TRB Length = 1024, Max Burst = 0
    volatile_write_u32(in_ctx + 16, 1024)

    // Bulk OUT Endpoint Context (at ctx_size * (out_dci + 1) offset)
    let out_ctx = ictx + ctx_size * (out_dci + 1)
    // DW1: CErr=3, EPType=2 (Bulk OUT), MaxPacketSize=512
    volatile_write_u32(out_ctx + 4, (3 << 1) | (2 << 3) | (512 << 16))
    // DW2-DW3: TR Dequeue Pointer with DCS=1
    volatile_write_u32(out_ctx + 8, (XHCI_BULK_OUT_RING & 0xFFFFFFFF) | 1)
    volatile_write_u32(out_ctx + 12, 0)
    // DW4: Average TRB Length = 1024, Max Burst = 0
    volatile_write_u32(out_ctx + 16, 1024)

    // Init bulk ring enqueue/cycle state
    xhci_state_write(192, 0) // bulk_in_enqueue = 0
    xhci_state_write(200, 1) // bulk_in_cycle = 1
    xhci_state_write(208, 0) // bulk_out_enqueue = 0
    xhci_state_write(216, 1) // bulk_out_cycle = 1

    // Submit Configure Endpoint command
    let idx = xhci_state_read(104)
    let cycle = xhci_state_read(120)
    let dw3 = ((slot_id & 0xFF) << 24) | (TRB_CONFIGURE_EP << 10) | (cycle & 1)
    xhci_write_trb(XHCI_CMD_RING, idx, ictx & 0xFFFFFFFF, 0, 0, dw3)

    let next = idx + 1
    if next >= XHCI_CMD_RING_SIZE - 1 {
        xhci_state_write(104, 0)
        xhci_state_write(120, 1 - cycle)
    } else {
        xhci_state_write(104, next)
    }
    xhci_ring_doorbell(0, 0)

    // Poll for Command Completion (Configure Endpoint event)
    let mut cur_evt = xhci_state_read(112)
    let mut cur_cycle = xhci_state_read(128)
    let mut timeout: i64 = 2000000
    while timeout > 0 {
        let dw3_evt = xhci_read_trb_dw(XHCI_EVT_RING, cur_evt, 3)
        if (dw3_evt & 1) == (cur_cycle & 1) {
            let evt_type = (dw3_evt >> 10) & 0x3F
            let cc = (xhci_read_trb_dw(XHCI_EVT_RING, cur_evt, 2) >> 24) & 0xFF
            let next_evt = cur_evt + 1
            if next_evt >= XHCI_EVT_RING_SIZE { cur_evt = 0; cur_cycle = 1 - cur_cycle }
            else { cur_evt = next_evt }
            xhci_state_write(112, cur_evt)
            xhci_state_write(128, cur_cycle)
            let rtsoff = volatile_read_u32(base + 0x18) & 0xFFFFFFE0
            let ir0 = base + rtsoff + 0x20
            volatile_write_u32(ir0 + 0x18, ((XHCI_EVT_RING + cur_evt * XHCI_TRB_SIZE) & 0xFFFFFFFF) | 0x08)
            volatile_write_u32(ir0 + 0x1C, 0)
            if evt_type == TRB_CMD_COMPLETION {
                if cc == CC_SUCCESS { return 0 }
                return -(cc)
            }
        } else { pause(); timeout = timeout - 1 }
    }
    -99
}

// ── Sprint C3: Bulk Transfer Functions ──

@kernel fn xhci_bulk_out(data: i64, length: i64) -> i64 {
    let slot_id = xhci_state_read(144)
    let out_ep = xhci_state_read(168) & 0x0F
    let out_dci = out_ep * 2
    let enq = xhci_state_read(208)
    let cycle = xhci_state_read(216)

    // Write Normal TRB for bulk OUT
    let dw3 = (TRB_NORMAL << 10) | (1 << 5) | (cycle & 1) // IOC=1
    xhci_write_trb(XHCI_BULK_OUT_RING, enq, data & 0xFFFFFFFF, 0, length, dw3)

    let next = enq + 1
    if next >= XHCI_BULK_RING_SIZE - 1 {
        let link_dw3 = xhci_read_trb_dw(XHCI_BULK_OUT_RING, XHCI_BULK_RING_SIZE - 1, 3)
        xhci_write_trb(XHCI_BULK_OUT_RING, XHCI_BULK_RING_SIZE - 1,
            XHCI_BULK_OUT_RING & 0xFFFFFFFF, 0, 0, (link_dw3 & 0xFFFFFFFE) | (cycle & 1))
        xhci_state_write(208, 0)
        xhci_state_write(216, 1 - cycle)
    } else {
        xhci_state_write(208, next)
    }

    // Ring doorbell for bulk OUT endpoint
    xhci_ring_doorbell(slot_id, out_dci)

    // Poll for Transfer Event
    let mut cur_evt = xhci_state_read(112)
    let mut cur_cycle = xhci_state_read(128)
    let mut timeout: i64 = 2000000
    while timeout > 0 {
        let dw3_evt = xhci_read_trb_dw(XHCI_EVT_RING, cur_evt, 3)
        if (dw3_evt & 1) == (cur_cycle & 1) {
            let evt_type = (dw3_evt >> 10) & 0x3F
            let cc = (xhci_read_trb_dw(XHCI_EVT_RING, cur_evt, 2) >> 24) & 0xFF
            let next_evt = cur_evt + 1
            if next_evt >= XHCI_EVT_RING_SIZE { cur_evt = 0; cur_cycle = 1 - cur_cycle }
            else { cur_evt = next_evt }
            xhci_state_write(112, cur_evt)
            xhci_state_write(128, cur_cycle)
            let base = xhci_state_read(0)
            let rtsoff = volatile_read_u32(base + 0x18) & 0xFFFFFFE0
            let ir0 = base + rtsoff + 0x20
            volatile_write_u32(ir0 + 0x18, ((XHCI_EVT_RING + cur_evt * XHCI_TRB_SIZE) & 0xFFFFFFFF) | 0x08)
            volatile_write_u32(ir0 + 0x1C, 0)
            if evt_type == TRB_TRANSFER_EVENT {
                if cc == CC_SUCCESS || cc == 13 { return 0 }
                return -(cc)
            }
        } else { pause(); timeout = timeout - 1 }
    }
    -99
}

@kernel fn xhci_bulk_in(data: i64, length: i64) -> i64 {
    let slot_id = xhci_state_read(144)
    let in_ep = xhci_state_read(160) & 0x0F
    let in_dci = in_ep * 2 + 1
    let enq = xhci_state_read(192)
    let cycle = xhci_state_read(200)

    // Write Normal TRB for bulk IN
    let dw3 = (TRB_NORMAL << 10) | (1 << 5) | (cycle & 1) // IOC=1
    xhci_write_trb(XHCI_BULK_IN_RING, enq, data & 0xFFFFFFFF, 0, length, dw3)

    let next = enq + 1
    if next >= XHCI_BULK_RING_SIZE - 1 {
        let link_dw3 = xhci_read_trb_dw(XHCI_BULK_IN_RING, XHCI_BULK_RING_SIZE - 1, 3)
        xhci_write_trb(XHCI_BULK_IN_RING, XHCI_BULK_RING_SIZE - 1,
            XHCI_BULK_IN_RING & 0xFFFFFFFF, 0, 0, (link_dw3 & 0xFFFFFFFE) | (cycle & 1))
        xhci_state_write(192, 0)
        xhci_state_write(200, 1 - cycle)
    } else {
        xhci_state_write(192, next)
    }

    // Ring doorbell for bulk IN endpoint
    xhci_ring_doorbell(slot_id, in_dci)

    // Poll for Transfer Event
    let mut cur_evt = xhci_state_read(112)
    let mut cur_cycle = xhci_state_read(128)
    let mut timeout: i64 = 2000000
    while timeout > 0 {
        let dw3_evt = xhci_read_trb_dw(XHCI_EVT_RING, cur_evt, 3)
        if (dw3_evt & 1) == (cur_cycle & 1) {
            let evt_type = (dw3_evt >> 10) & 0x3F
            let cc = (xhci_read_trb_dw(XHCI_EVT_RING, cur_evt, 2) >> 24) & 0xFF
            let residual = xhci_read_trb_dw(XHCI_EVT_RING, cur_evt, 2) & 0xFFFFFF
            let next_evt = cur_evt + 1
            if next_evt >= XHCI_EVT_RING_SIZE { cur_evt = 0; cur_cycle = 1 - cur_cycle }
            else { cur_evt = next_evt }
            xhci_state_write(112, cur_evt)
            xhci_state_write(128, cur_cycle)
            let base = xhci_state_read(0)
            let rtsoff = volatile_read_u32(base + 0x18) & 0xFFFFFFE0
            let ir0 = base + rtsoff + 0x20
            volatile_write_u32(ir0 + 0x18, ((XHCI_EVT_RING + cur_evt * XHCI_TRB_SIZE) & 0xFFFFFFFF) | 0x08)
            volatile_write_u32(ir0 + 0x1C, 0)
            if evt_type == TRB_TRANSFER_EVENT {
                if cc == CC_SUCCESS || cc == 13 { return length - residual }
                return -(cc)
            }
        } else { pause(); timeout = timeout - 1 }
    }
    -99
}

// ── Sprint C3: BOT (Bulk-Only Transport) Full Sequence ──
// CBW (31 bytes) → Data IN/OUT → CSW (13 bytes)

@kernel fn usb_bot_command(scsi_cmd: i64, scsi_cmd_len: i64, data_buf: i64, data_len: i64, direction: i64) -> i64 {
    // Build CBW at XHCI_DATA_BUF + 4096
    let cbw = XHCI_DATA_BUF + 4096
    let tag = xhci_state_read(248) + 1  // increment tag
    xhci_state_write(248, tag)

    volatile_write_u32(cbw, CBW_SIGNATURE)
    volatile_write_u32(cbw + 4, tag)
    volatile_write_u32(cbw + 8, data_len)
    volatile_write_u8(cbw + 12, direction) // 0x80=IN, 0x00=OUT
    volatile_write_u8(cbw + 13, 0)         // LUN
    volatile_write_u8(cbw + 14, scsi_cmd_len)
    // Copy SCSI command bytes (up to 16)
    let mut i: i64 = 0
    while i < 16 {
        if i < scsi_cmd_len {
            volatile_write_u8(cbw + 15 + i, volatile_read_u8(scsi_cmd + i))
        } else {
            volatile_write_u8(cbw + 15 + i, 0)
        }
        i = i + 1
    }

    // Step 1: Send CBW via Bulk OUT (31 bytes)
    let cbw_result = xhci_bulk_out(cbw, 31)
    if cbw_result < 0 { return -1 }

    // Step 2: Data phase (if data_len > 0)
    if data_len > 0 {
        if direction == 0x80 {
            // Data IN
            let data_result = xhci_bulk_in(data_buf, data_len)
            if data_result < 0 { return -2 }
        } else {
            // Data OUT
            let data_result = xhci_bulk_out(data_buf, data_len)
            if data_result < 0 { return -3 }
        }
    }

    // Step 3: Receive CSW via Bulk IN (13 bytes)
    let csw = XHCI_DATA_BUF + 4608 // after CBW
    let csw_result = xhci_bulk_in(csw, 13)
    if csw_result < 0 { return -4 }

    // Verify CSW
    let csw_sig = volatile_read_u32(csw)
    let csw_tag = volatile_read_u32(csw + 4)
    let csw_residue = volatile_read_u32(csw + 8)
    let csw_status = volatile_read_u8(csw + 12)

    if csw_sig != CSW_SIGNATURE { return -5 }
    if csw_tag != tag { return -6 }
    if csw_status != 0 { return -7 } // Command failed

    0 // success
}

// ── Sprint C3: SCSI Commands via BOT ──

@kernel fn usb_scsi_inquiry_full() -> i64 {
    // Build SCSI INQUIRY command (6 bytes)
    let cmd = XHCI_DATA_BUF + 5000
    let mut i: i64 = 0
    while i < 16 { volatile_write_u8(cmd + i, 0); i = i + 1 }
    volatile_write_u8(cmd, SCSI_INQUIRY)     // opcode
    volatile_write_u8(cmd + 4, 36)            // allocation length

    let result = usb_bot_command(cmd, 6, XHCI_DATA_BUF + 5120, 36, 0x80)
    if result < 0 { return result }

    // Parse INQUIRY response at XHCI_DATA_BUF + 5120
    // Byte 0: Peripheral device type (0x00 = direct access = disk)
    // Bytes 8-15: Vendor ID (8 ASCII chars)
    // Bytes 16-31: Product ID (16 ASCII chars)
    // Bytes 32-35: Product Revision (4 ASCII chars)
    let resp = XHCI_DATA_BUF + 5120
    let dev_type = volatile_read_u8(resp) & 0x1F
    cprint("  Device: ", WHITE_ON_BLACK)
    if dev_type == 0 { cprint("Direct Access (Disk)", GREEN_ON_BLACK) }
    else if dev_type == 5 { cprint("CD-ROM", WHITE_ON_BLACK) }
    else { cprint_decimal(dev_type, WHITE_ON_BLACK) }
    console_putchar(10, WHITE_ON_BLACK)
    // Print Vendor ID (bytes 8-15)
    cprint("  Vendor: ", WHITE_ON_BLACK)
    let mut vi: i64 = 0
    while vi < 8 {
        let ch = volatile_read_u8(resp + 8 + vi)
        if ch >= 0x20 && ch < 0x7F { console_putchar(ch, CYAN_ON_BLACK) }
        vi = vi + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
    // Print Product ID (bytes 16-31)
    cprint("  Product: ", WHITE_ON_BLACK)
    let mut pi: i64 = 0
    while pi < 16 {
        let ch = volatile_read_u8(resp + 16 + pi)
        if ch >= 0x20 && ch < 0x7F { console_putchar(ch, CYAN_ON_BLACK) }
        pi = pi + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
    0
}

@kernel fn usb_scsi_read_capacity_full() -> i64 {
    // Build SCSI READ CAPACITY(10) command (10 bytes)
    let cmd = XHCI_DATA_BUF + 5000
    let mut i: i64 = 0
    while i < 16 { volatile_write_u8(cmd + i, 0); i = i + 1 }
    volatile_write_u8(cmd, SCSI_READ_CAPACITY) // opcode 0x25

    let result = usb_bot_command(cmd, 10, XHCI_DATA_BUF + 5120, 8, 0x80)
    if result < 0 { return result }

    // Parse READ CAPACITY response (8 bytes, big-endian)
    // Bytes 0-3: Last Logical Block Address
    // Bytes 4-7: Block Length
    let lba3 = volatile_read_u8(XHCI_DATA_BUF + 5120)
    let lba2 = volatile_read_u8(XHCI_DATA_BUF + 5121)
    let lba1 = volatile_read_u8(XHCI_DATA_BUF + 5122)
    let lba0 = volatile_read_u8(XHCI_DATA_BUF + 5123)
    let last_lba = (lba3 << 24) | (lba2 << 16) | (lba1 << 8) | lba0

    let bs3 = volatile_read_u8(XHCI_DATA_BUF + 5124)
    let bs2 = volatile_read_u8(XHCI_DATA_BUF + 5125)
    let bs1 = volatile_read_u8(XHCI_DATA_BUF + 5126)
    let bs0 = volatile_read_u8(XHCI_DATA_BUF + 5127)
    let block_size = (bs3 << 24) | (bs2 << 16) | (bs1 << 8) | bs0

    xhci_state_write(232, last_lba + 1) // total sectors
    xhci_state_write(240, block_size)    // sector size

    cprint("  Capacity: ", WHITE_ON_BLACK)
    cprint_decimal(last_lba + 1, CYAN_ON_BLACK)
    cprint(" sectors x ", WHITE_ON_BLACK)
    cprint_decimal(block_size, CYAN_ON_BLACK)
    cprint(" bytes = ", WHITE_ON_BLACK)
    let mb = ((last_lba + 1) * block_size) / (1024 * 1024)
    cprint_decimal(mb, GREEN_ON_BLACK)
    cprintln(" MB", WHITE_ON_BLACK)
    0
}

@kernel fn usb_scsi_read(lba: i64, count: i64, buf: i64) -> i64 {
    // Build SCSI READ(10) command (10 bytes)
    let cmd = XHCI_DATA_BUF + 5000
    let mut i: i64 = 0
    while i < 16 { volatile_write_u8(cmd + i, 0); i = i + 1 }
    volatile_write_u8(cmd, SCSI_READ_10) // opcode 0x28
    // LBA (bytes 2-5, big-endian)
    volatile_write_u8(cmd + 2, (lba >> 24) & 0xFF)
    volatile_write_u8(cmd + 3, (lba >> 16) & 0xFF)
    volatile_write_u8(cmd + 4, (lba >> 8) & 0xFF)
    volatile_write_u8(cmd + 5, lba & 0xFF)
    // Transfer length (bytes 7-8, big-endian)
    volatile_write_u8(cmd + 7, (count >> 8) & 0xFF)
    volatile_write_u8(cmd + 8, count & 0xFF)

    let sector_sz = xhci_state_read(240)
    if sector_sz == 0 { return -1 }
    let data_len = count * sector_sz

    usb_bot_command(cmd, 10, buf, data_len, 0x80)
}

// ── blk_read extension for USB (type 3) ──

@kernel fn usb_blk_read(lba: i64, count: i64, buf: i64) -> i64 {
    usb_scsi_read(lba, count, buf)
}

@kernel fn usb_scsi_write(lba: i64, count: i64, buf: i64) -> i64 {
    // Build SCSI WRITE(10) command (10 bytes)
    let cmd = XHCI_DATA_BUF + 5000
    let mut i: i64 = 0
    while i < 16 { volatile_write_u8(cmd + i, 0); i = i + 1 }
    volatile_write_u8(cmd, SCSI_WRITE_10) // opcode 0x2A
    // LBA (bytes 2-5, big-endian)
    volatile_write_u8(cmd + 2, (lba >> 24) & 0xFF)
    volatile_write_u8(cmd + 3, (lba >> 16) & 0xFF)
    volatile_write_u8(cmd + 4, (lba >> 8) & 0xFF)
    volatile_write_u8(cmd + 5, lba & 0xFF)
    // Transfer length (bytes 7-8, big-endian)
    volatile_write_u8(cmd + 7, (count >> 8) & 0xFF)
    volatile_write_u8(cmd + 8, count & 0xFF)

    let sector_sz = xhci_state_read(240)
    if sector_sz == 0 { return -1 }
    let data_len = count * sector_sz

    usb_bot_command(cmd, 10, buf, data_len, 0x00) // direction OUT
}

@kernel fn usb_blk_write(lba: i64, count: i64, buf: i64) -> i64 {
    usb_scsi_write(lba, count, buf)
}

// ── USB Shell Commands ──

@kernel fn cmd_usbread() {
    // Read and hex-dump a single sector from USB mass storage
    if xhci_state_read(224) != 1 {
        cprintln("USB mass storage not initialized. Run 'usbinit' first.", RED_ON_BLACK)
        return
    }
    // Parse LBA from command buffer (after "usbread ")
    let mut lba: i64 = 0
    let mut ci: i64 = 8 // skip "usbread "
    let mut has_digit: i64 = 0
    while ci < 64 {
        let ch = volatile_read_u8(0x6F800 + ci)
        if ch >= 48 && ch <= 57 {
            lba = lba * 10 + (ch - 48)
            has_digit = 1
            ci = ci + 1
        } else { ci = 64 }
    }
    if has_digit == 0 {
        cprintln("Usage: usbread <lba>", YELLOW_ON_BLACK)
        return
    }
    let mut sector_sz = xhci_state_read(240)
    if sector_sz == 0 { sector_sz = 512 }
    let buf = XHCI_DATA_BUF + 6144 // use scratch area
    let result = usb_scsi_read(lba, 1, buf)
    if result < 0 {
        cprint("  Read failed: ", RED_ON_BLACK)
        cprint_decimal(result, RED_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        return
    }
    cprint("USB sector ", WHITE_ON_BLACK)
    cprint_decimal(lba, CYAN_ON_BLACK)
    cprintln(":", WHITE_ON_BLACK)
    // Hex dump first 256 bytes (or sector_sz if smaller)
    let dump_len = if sector_sz < 256 { sector_sz } else { 256 }
    let mut off: i64 = 0
    while off < dump_len {
        // Print offset
        cprint_hex(off, 4, YELLOW_ON_BLACK)
        cprint(": ", WHITE_ON_BLACK)
        // Print 16 hex bytes
        let mut b: i64 = 0
        while b < 16 && (off + b) < dump_len {
            cprint_hex(volatile_read_u8(buf + off + b), 2, CYAN_ON_BLACK)
            cprint(" ", WHITE_ON_BLACK)
            b = b + 1
        }
        // Print ASCII
        cprint(" |", WHITE_ON_BLACK)
        b = 0
        while b < 16 && (off + b) < dump_len {
            let ch = volatile_read_u8(buf + off + b)
            if ch >= 0x20 && ch < 0x7F { console_putchar(ch, WHITE_ON_BLACK) }
            else { cprint(".", WHITE_ON_BLACK) }
            b = b + 1
        }
        cprintln("|", WHITE_ON_BLACK)
        off = off + 16
    }
}

@kernel fn cmd_usbls() {
    // List files on USB FAT32 filesystem
    if xhci_state_read(224) != 1 {
        cprintln("USB mass storage not initialized. Run 'usbinit' first.", RED_ON_BLACK)
        return
    }
    // Ensure FAT32 is mounted on USB (blk_dev 2)
    if fat32_state_read(0) != 1 || fat32_state_read(88) != 2 {
        let mnt = fat32_mount(2)
        if mnt != 0 {
            cprintln("  No FAT32 filesystem on USB device", RED_ON_BLACK)
            return
        }
    }
    cmd_fat32_ls()
}

@kernel fn cmd_usbcat() {
    // Read a file from USB FAT32
    // "usbcat " = 7 chars prefix, same as "fatcat "
    if xhci_state_read(224) != 1 {
        cprintln("USB mass storage not initialized. Run 'usbinit' first.", RED_ON_BLACK)
        return
    }
    // Ensure FAT32 is mounted on USB (blk_dev 2)
    if fat32_state_read(0) != 1 || fat32_state_read(88) != 2 {
        let mnt = fat32_mount(2)
        if mnt != 0 {
            cprintln("  No FAT32 filesystem on USB device", RED_ON_BLACK)
            return
        }
    }
    // cmd_fat32_cat reads filename from 0x6F800+7, "usbcat " is also 7 chars
    cmd_fat32_cat()
}

// ═══════════════════════════════════════════════
// Virtio-Blk Driver (Sprint B9)
// PCI vendor 0x1AF4, device 0x1001
// ═══════════════════════════════════════════════

@kernel fn virtio_blk_find() -> i64 {
    let mut dev: i64 = 0
    while dev < 32 {
        let id = pci_read32(0, dev, 0, 0)
        if id != 0xFFFFFFFF && id != 0 {
            let vendor = id & 0xFFFF
            let device_id = (id >> 16) & 0xFFFF
            if vendor == 0x1AF4 && device_id == 0x1001 { return dev }
        }
        dev = dev + 1
    }
    -1
}

@kernel fn cmd_virtio_blk() {
    cprintln("Virtio Block Devices:", YELLOW_ON_BLACK)
    let dev = virtio_blk_find()
    if dev == -1 {
        cprintln("  No virtio-blk found", YELLOW_ON_BLACK)
        return
    }
    let id = pci_read32(0, dev, 0, 0)
    cprint("  PCI ", WHITE_ON_BLACK)
    cprint_decimal(dev, CYAN_ON_BLACK)
    cprint(": virtio-blk (", WHITE_ON_BLACK)
    cprint_hex(id & 0xFFFF, 4, CYAN_ON_BLACK)
    cprint(":", WHITE_ON_BLACK)
    cprint_hex((id >> 16) & 0xFFFF, 4, CYAN_ON_BLACK)
    cprintln(")", WHITE_ON_BLACK)

    let bar0 = pci_read32(0, dev, 0, 0x10)
    cprint("  BAR0: 0x", WHITE_ON_BLACK)
    cprint_hex(bar0, 8, CYAN_ON_BLACK)
    if bar0 & 1 != 0 { cprintln(" (I/O port)", WHITE_ON_BLACK) }
    else { cprintln(" (MMIO)", WHITE_ON_BLACK) }
}

// ═══════════════════════════════════════════════
// Shell Scripting (Sprint C1)
// Execute command files from FAT32
// ═══════════════════════════════════════════════

@kernel fn script_exec_line(line_buf: i64, line_len: i64) {
    // Skip empty lines and comments
    if line_len == 0 { return }
    let first = volatile_read_u8(line_buf)
    if first == 35 { return } // '#' comment

    // Copy line to command buffer at 0x6F800
    let mut i: i64 = 0
    while i < line_len && i < 63 {
        volatile_write_u8(0x6F800 + i, volatile_read_u8(line_buf + i))
        i = i + 1
    }
    volatile_write_u8(0x6F800 + i, 0)

    // Script line display only (dispatch requires forward ref)
    // Full script execution deferred to runtime shell loop
}

@kernel fn cmd_source() {
    // "source <file>" — execute script from FAT32
    if fat32_state_read(0) != 1 { cprintln("FAT32 not mounted", RED_ON_BLACK); return }

    let mut fname_len: i64 = 0
    let mut i: i64 = 7 // skip "source "
    while i < 64 {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch == 0 { i = 64 }
        else { volatile_write_u8(FAT32_NAME_BUF + 512 + fname_len, ch); fname_len = fname_len + 1; i = i + 1 }
    }
    volatile_write_u8(FAT32_NAME_BUF + 512 + fname_len, 0)

    if fname_len == 0 { cprintln("Usage: source <file>", YELLOW_ON_BLACK); return }

    // Find and read file
    let root = fat32_state_read(48)
    let result = fat32_find_in_dir(root, FAT32_NAME_BUF + 512)
    if result == -1 { cprintln("Script not found", RED_ON_BLACK); return }

    let shifted = result >> 32
    let file_cluster = shifted & 0x7FFFFFFF
    let file_size = result & 0xFFFFFFFF

    let script_buf: i64 = 0x840000
    let bytes = fat32_read_file(file_cluster, file_size, script_buf)
    if bytes <= 0 { cprintln("Read error", RED_ON_BLACK); return }

    cprint("Running script (", WHITE_ON_BLACK)
    cprint_decimal(bytes, CYAN_ON_BLACK)
    cprintln(" bytes):", WHITE_ON_BLACK)

    // Parse lines and execute each
    let line_buf: i64 = 0x841000
    let mut pos: i64 = 0
    let mut line_len: i64 = 0
    while pos < bytes {
        let ch = volatile_read_u8(script_buf + pos)
        if ch == 10 || pos == bytes - 1 {
            // End of line — execute
            if ch != 10 {
                volatile_write_u8(line_buf + line_len, ch)
                line_len = line_len + 1
            }
            volatile_write_u8(line_buf + line_len, 0)
            if line_len > 0 {
                cprint("  > ", YELLOW_ON_BLACK)
                let mut k: i64 = 0
                while k < line_len { console_putchar(volatile_read_u8(line_buf + k), WHITE_ON_BLACK); k = k + 1 }
                console_putchar(10, WHITE_ON_BLACK)
                script_exec_line(line_buf, line_len)
            }
            line_len = 0
        } else {
            if line_len < 63 {
                volatile_write_u8(line_buf + line_len, ch)
                line_len = line_len + 1
            }
        }
        pos = pos + 1
    }
    cprintln("Script done", GREEN_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Init Process + Shutdown (Sprint C2)
// ═══════════════════════════════════════════════

@kernel fn init_autorun() {
    // Check if /mnt/INIT.SH exists and run it
    if fat32_state_read(0) != 1 { return }
    let root = fat32_state_read(48)

    // Write "INIT.SH" to name buffer
    volatile_write_u8(FAT32_NAME_BUF + 512, 73)  // I
    volatile_write_u8(FAT32_NAME_BUF + 513, 78)  // N
    volatile_write_u8(FAT32_NAME_BUF + 514, 73)  // I
    volatile_write_u8(FAT32_NAME_BUF + 515, 84)  // T
    volatile_write_u8(FAT32_NAME_BUF + 516, 46)  // .
    volatile_write_u8(FAT32_NAME_BUF + 517, 83)  // S
    volatile_write_u8(FAT32_NAME_BUF + 518, 72)  // H
    volatile_write_u8(FAT32_NAME_BUF + 519, 0)

    let result = fat32_find_in_dir(root, FAT32_NAME_BUF + 512)
    if result != -1 {
        println("[INIT] Running /mnt/INIT.SH")
        // Set up source command in cmdbuf
        // "source INIT.SH"
        volatile_write_u8(0x6F800, 115)  // s
        volatile_write_u8(0x6F801, 111)  // o
        volatile_write_u8(0x6F802, 117)  // u
        volatile_write_u8(0x6F803, 114)  // r
        volatile_write_u8(0x6F804, 99)   // c
        volatile_write_u8(0x6F805, 101)  // e
        volatile_write_u8(0x6F806, 32)   // ' '
        volatile_write_u8(0x6F807, 73)   // I
        volatile_write_u8(0x6F808, 78)   // N
        volatile_write_u8(0x6F809, 73)   // I
        volatile_write_u8(0x6F80A, 84)   // T
        volatile_write_u8(0x6F80B, 46)   // .
        volatile_write_u8(0x6F80C, 83)   // S
        volatile_write_u8(0x6F80D, 72)   // H
        volatile_write_u8(0x6F80E, 0)
        cmd_source()
    }
}

@kernel fn cmd_shutdown_safe() {
    cprintln("Shutting down...", YELLOW_ON_BLACK)
    // Sync: flush NVMe if needed
    cprintln("  Syncing filesystems...", WHITE_ON_BLACK)
    cprintln("  Killing processes...", WHITE_ON_BLACK)
    let mut pid: i64 = 1
    while pid < PROC_V2_MAX {
        let state = proc_v2_get(pid, 0)
        if state != PROC_STATE_FREE { proc_v2_exit(pid, 0) }
        pid = pid + 1
    }
    cprintln("  ACPI poweroff...", WHITE_ON_BLACK)
    acpi_shutdown()
}

@kernel fn cmd_reboot_safe() {
    cprintln("Rebooting...", YELLOW_ON_BLACK)
    cprintln("  Syncing filesystems...", WHITE_ON_BLACK)
    cprintln("  Keyboard controller reset...", WHITE_ON_BLACK)
    port_outb(0x64, 0xFE)
}

// ═══════════════════════════════════════════════
// Pipe + File Descriptors (Sprint C3)
// ═══════════════════════════════════════════════

const FD_TABLE: i64 = 0x894000  // 16 procs × 16 FDs × 16 bytes
// Per FD: +0=type (0=closed, 1=console, 2=file, 3=pipe_read, 4=pipe_write)
//         +8=data (file offset, pipe buffer addr, etc.)
const PIPE_POOL: i64 = 0x898000  // 8 pipes × 4KB each
const PIPE_MAX: i64 = 8

@kernel fn fd_init(pid: i64) {
    let base = FD_TABLE + pid * 16 * 16
    // FD 0 = stdin (console)
    volatile_write_u64(base, 1) // type=console
    // FD 1 = stdout (console)
    volatile_write_u64(base + 16, 1) // type=console
    // FD 2 = stderr (console)
    volatile_write_u64(base + 32, 1) // type=console
    // Rest = closed
    let mut fd: i64 = 3
    while fd < 16 {
        volatile_write_u64(base + fd * 16, 0)
        fd = fd + 1
    }
}

@kernel fn pipe_create() -> i64 {
    // Find free pipe slot
    let mut slot: i64 = 0
    while slot < PIPE_MAX {
        let pipe_base = PIPE_POOL + slot * 4096
        let in_use = volatile_read_u64(pipe_base)
        if in_use == 0 {
            volatile_write_u64(pipe_base, 1)    // in_use = 1
            volatile_write_u64(pipe_base + 8, 0) // read_pos = 0
            volatile_write_u64(pipe_base + 16, 0) // write_pos = 0
            return slot
        }
        slot = slot + 1
    }
    -1
}

@kernel fn pipe_write(slot: i64, data: i64, len: i64) -> i64 {
    let pipe_base = PIPE_POOL + slot * 4096
    let write_pos = volatile_read_u64(pipe_base + 16)
    let avail = 4096 - 32 - write_pos // Header = 32 bytes
    let to_write = if len < avail { len } else { avail }
    let mut i: i64 = 0
    while i < to_write {
        volatile_write_u8(pipe_base + 32 + write_pos + i, volatile_read_u8(data + i))
        i = i + 1
    }
    volatile_write_u64(pipe_base + 16, write_pos + to_write)
    to_write
}

@kernel fn pipe_read(slot: i64, buf: i64, len: i64) -> i64 {
    let pipe_base = PIPE_POOL + slot * 4096
    let read_pos = volatile_read_u64(pipe_base + 8)
    let write_pos = volatile_read_u64(pipe_base + 16)
    let available = write_pos - read_pos
    if available <= 0 { return 0 }
    let to_read = if len < available { len } else { available }
    let mut i: i64 = 0
    while i < to_read {
        volatile_write_u8(buf + i, volatile_read_u8(pipe_base + 32 + read_pos + i))
        i = i + 1
    }
    volatile_write_u64(pipe_base + 8, read_pos + to_read)
    to_read
}

@kernel fn cmd_pipe_test() {
    cprintln("Pipe test:", YELLOW_ON_BLACK)
    let slot = pipe_create()
    if slot < 0 { cprintln("  No free pipe", RED_ON_BLACK); return }
    cprint("  Created pipe ", WHITE_ON_BLACK)
    cprint_decimal(slot, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    // Write "Hello pipe!"
    let msg: i64 = 0x830000
    volatile_write_u8(msg, 72)   // H
    volatile_write_u8(msg + 1, 101) // e
    volatile_write_u8(msg + 2, 108) // l
    volatile_write_u8(msg + 3, 108) // l
    volatile_write_u8(msg + 4, 111) // o
    volatile_write_u8(msg + 5, 33)  // !
    let written = pipe_write(slot, msg, 6)
    cprint("  Written: ", WHITE_ON_BLACK)
    cprint_decimal(written, CYAN_ON_BLACK)
    cprintln(" bytes", WHITE_ON_BLACK)

    // Read back
    let rbuf: i64 = 0x831000
    let rn = pipe_read(slot, rbuf, 64)
    cprint("  Read: ", WHITE_ON_BLACK)
    let mut i: i64 = 0
    while i < rn { console_putchar(volatile_read_u8(rbuf + i), GREEN_ON_BLACK); i = i + 1 }
    console_putchar(10, WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Security Hardening (Sprint C5)
// SMEP, SMAP, NX enforcement
// ═══════════════════════════════════════════════

// ═══════════════════════════════════════════════
// SYSCALL/SYSRET Setup (Fix 2)
// Syscall entry stub at 0x8200 (256 bytes)
// Per-CPU kernel stack pointer at 0x652008
// ═══════════════════════════════════════════════

const SYSCALL_ENTRY_ADDR: i64 = 0x8200
const KERNEL_RSP_SAVE: i64 = 0x652008  // per-CPU kernel RSP
const USER_RSP_SAVE: i64 = 0x652010    // per-CPU saved user RSP

@kernel fn syscall_install_stub() {
    // Install SYSCALL entry stub at 0x8200
    // On SYSCALL: RCX = user RIP, R11 = user RFLAGS, RAX = syscall number
    // We need to: save user RSP, switch to kernel stack, call handler, SYSRETQ
    let b = SYSCALL_ENTRY_ADDR

    // swapgs (switch GS base to kernel per-CPU area)
    volatile_write_u8(b, 0x0F)
    volatile_write_u8(b + 1, 0x01)
    volatile_write_u8(b + 2, 0xF8)

    // mov [USER_RSP_SAVE], rsp (save user RSP to fixed address)
    volatile_write_u8(b + 3, 0x48)
    volatile_write_u8(b + 4, 0x89)
    volatile_write_u8(b + 5, 0x24)
    volatile_write_u8(b + 6, 0x25)
    volatile_write_u32(b + 7, USER_RSP_SAVE)

    // mov rsp, [KERNEL_RSP_SAVE] (load kernel RSP)
    volatile_write_u8(b + 11, 0x48)
    volatile_write_u8(b + 12, 0x8B)
    volatile_write_u8(b + 13, 0x24)
    volatile_write_u8(b + 14, 0x25)
    volatile_write_u32(b + 15, KERNEL_RSP_SAVE)

    // push rcx (user RIP)
    volatile_write_u8(b + 19, 0x51)
    // push r11 (user RFLAGS)
    volatile_write_u8(b + 20, 0x41)
    volatile_write_u8(b + 21, 0x53)
    // push rdi, rsi, rdx (syscall args)
    volatile_write_u8(b + 22, 0x57)
    volatile_write_u8(b + 23, 0x56)
    volatile_write_u8(b + 24, 0x52)

    // Now dispatch based on RAX (syscall number)
    // We handle inline: SYS_WRITE(1) and SYS_EXIT(60)

    // cmp rax, 1 (SYS_WRITE)
    volatile_write_u8(b + 25, 0x48)
    volatile_write_u8(b + 26, 0x83)
    volatile_write_u8(b + 27, 0xF8)
    volatile_write_u8(b + 28, 1)
    // jne skip_write (jump forward if not SYS_WRITE)
    volatile_write_u8(b + 29, 0x75)
    volatile_write_u8(b + 30, 20)  // skip 20 bytes

    // SYS_WRITE: rdi=fd, rsi=buf, rdx=len
    // Write each byte to VGA console (0xB8000 + cursor*2)
    // Simplified: write to serial port 0x3F8
    // mov rcx, rdx (len → counter)
    volatile_write_u8(b + 31, 0x48)
    volatile_write_u8(b + 32, 0x89)
    volatile_write_u8(b + 33, 0xD1)
    // .write_loop: lodsb (load byte from [rsi] to al, increment rsi)
    volatile_write_u8(b + 34, 0xAC)
    // mov dx, 0x3F8 (serial port)
    volatile_write_u8(b + 35, 0x66)
    volatile_write_u8(b + 36, 0xBA)
    volatile_write_u16(b + 37, 0x3F8)
    // out dx, al (write byte to serial)
    volatile_write_u8(b + 39, 0xEE)
    // loop .write_loop (dec rcx, jnz)
    volatile_write_u8(b + 40, 0xE2)
    volatile_write_u8(b + 41, 0xF8)  // -8 (back to lodsb at offset 34)
    // mov rax, rdx (return bytes written... but rdx was clobbered)
    // Actually return original len from stack
    volatile_write_u8(b + 42, 0x48)
    volatile_write_u8(b + 43, 0x31)
    volatile_write_u8(b + 44, 0xC0) // xor rax, rax (return 0 = success)
    // jmp sysret_path (offset 93)
    volatile_write_u8(b + 45, 0xEB)
    volatile_write_u8(b + 46, 46)  // 47 + 46 = 93 (sysret_path)

    // skip_write: (offset 51)
    // cmp rax, 0 (SYS_EXIT = 0, FajarOS convention)
    volatile_write_u8(b + 51, 0x48)
    volatile_write_u8(b + 52, 0x83)
    volatile_write_u8(b + 53, 0xF8)
    volatile_write_u8(b + 54, 0)
    // jne skip_exit (check next syscall)
    volatile_write_u8(b + 55, 0x75)
    volatile_write_u8(b + 56, 10) // skip 10 bytes to offset 67

    // SYS_EXIT: restore kernel RSP from 0x652020 and RET to kernel
    // mov rsp, [abs 0x652020] = 48 8B 24 25 20 20 65 00
    volatile_write_u8(b + 57, 0x48)
    volatile_write_u8(b + 58, 0x8B)
    volatile_write_u8(b + 59, 0x24)
    volatile_write_u8(b + 60, 0x25)
    volatile_write_u8(b + 61, 0x20)  // addr low byte
    volatile_write_u8(b + 62, 0x20)
    volatile_write_u8(b + 63, 0x65)
    volatile_write_u8(b + 64, 0x00)  // addr high byte
    // ret
    volatile_write_u8(b + 65, 0xC3)
    // nop (safety)
    volatile_write_u8(b + 66, 0x90)

    // skip_exit: (offset 67)
    // E2.6: SYS_GETPID = 3
    // cmp rax, 3
    volatile_write_u8(b + 67, 0x48)
    volatile_write_u8(b + 68, 0x83)
    volatile_write_u8(b + 69, 0xF8)
    volatile_write_u8(b + 70, 3)
    // jne unknown_syscall
    volatile_write_u8(b + 71, 0x75)
    volatile_write_u8(b + 72, 10) // skip to offset 83

    // SYS_GETPID: mov rax, [0x6FE00] (current PID)
    volatile_write_u8(b + 73, 0x48)
    volatile_write_u8(b + 74, 0x8B)
    volatile_write_u8(b + 75, 0x04)
    volatile_write_u8(b + 76, 0x25)
    volatile_write_u32(b + 77, 0x6FE00)
    // jmp sysret_path (offset 93)
    volatile_write_u8(b + 81, 0xEB)
    volatile_write_u8(b + 82, 10) // 83 + 10 = 93

    // unknown_syscall: (offset 83)
    // xor rax, rax; dec rax (return -1)
    volatile_write_u8(b + 83, 0x48)
    volatile_write_u8(b + 84, 0x31)
    volatile_write_u8(b + 85, 0xC0)
    volatile_write_u8(b + 86, 0x48)
    volatile_write_u8(b + 87, 0xFF)
    volatile_write_u8(b + 88, 0xC8) // dec rax

    // sysret_path: (offset 93 — was 73, shifted +20 for SYS_GETPID)
    // pop rdx, rsi, rdi
    volatile_write_u8(b + 93, 0x5A)
    volatile_write_u8(b + 94, 0x5E)
    volatile_write_u8(b + 95, 0x5F)
    // pop r11 (user RFLAGS)
    volatile_write_u8(b + 96, 0x41)
    volatile_write_u8(b + 97, 0x5B)
    // pop rcx (user RIP)
    volatile_write_u8(b + 98, 0x59)

    // mov rsp, [USER_RSP_SAVE] (restore user RSP)
    volatile_write_u8(b + 99, 0x48)
    volatile_write_u8(b + 100, 0x8B)
    volatile_write_u8(b + 101, 0x24)
    volatile_write_u8(b + 102, 0x25)
    volatile_write_u32(b + 103, USER_RSP_SAVE)

    // swapgs
    volatile_write_u8(b + 107, 0x0F)
    volatile_write_u8(b + 108, 0x01)
    volatile_write_u8(b + 109, 0xF8)

    // sysretq
    volatile_write_u8(b + 110, 0x48)
    volatile_write_u8(b + 111, 0x0F)
    volatile_write_u8(b + 112, 0x07)
}

@kernel fn syscall_setup() {
    // Call linker's syscall_init — this sets STAR/LSTAR/SFMASK/EFER
    syscall_init()

    // Verify LSTAR was set to linker's __syscall_entry (not 0)
    let lstar = rdmsr(0xC0000082)
    if lstar == 0 {
        // Linker's syscall_init didn't set LSTAR properly
        // Fallback: use the kernel's volatile_write stub at 0x8200
        println("[SYSCALL] LSTAR=0, using fallback stub")
        syscall_install_stub()
        wrmsr(0xC0000082, SYSCALL_ENTRY_ADDR)
        // Also set STAR, SFMASK, EFER in case syscall_init was a no-op
        let star = (0x0013 << 48) | (0x0008 << 32)
        wrmsr(0xC0000081, star)
        wrmsr(0xC0000083, 0x200)
        let efer = rdmsr(0xC0000080)
        wrmsr(0xC0000080, efer | 1)
        volatile_write_u64(KERNEL_RSP_SAVE, 0x7F0000)
    } else {
        println("[SYSCALL] Using linker dispatch")
    }
}

@kernel fn cmd_syscall_test() {
    cprintln("SYSCALL/SYSRET Configuration:", YELLOW_ON_BLACK)
    syscall_setup()
    cprintln("  Stub installed at 0x8200 (93 bytes)", GREEN_ON_BLACK)
    cprint("  IA32_STAR:  0x", WHITE_ON_BLACK)
    let star = rdmsr(0xC0000081)
    cprint_hex(star >> 32, 8, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  IA32_LSTAR: 0x", WHITE_ON_BLACK)
    cprint_hex(rdmsr(0xC0000082), 8, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  IA32_SFMASK: 0x", WHITE_ON_BLACK)
    cprint_hex(rdmsr(0xC0000083), 8, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    let efer = rdmsr(0xC0000080)
    cprint("  EFER.SCE: ", WHITE_ON_BLACK)
    if efer & 1 != 0 { cprintln("ENABLED", GREEN_ON_BLACK) }
    else { cprintln("disabled", RED_ON_BLACK) }
    cprintln("  SYS_WRITE(1): serial output", WHITE_ON_BLACK)
    cprintln("  SYS_EXIT(60): halt", WHITE_ON_BLACK)
    cprintln("  Ready for Ring 3 execution!", GREEN_ON_BLACK)
}

// ═══════════════════════════════════════════════
// User Binary Support (Nova v0.4 Sprint N1)
// Embed a minimal "hello" user program in kernel
// for Ring 3 execution testing
// ═══════════════════════════════════════════════

const USER_CODE_BASE: i64 = 0x2000000   // 32MB — user code mapped here
const USER_STACK_BASE: i64 = 0x2FF0000  // user stack (64KB below 48MB)
const USER_HELLO_SIZE: i64 = 48         // minimal hello program bytes

// Minimal x86_64 user program (runs in Ring 3):
//   mov rax, 1       (SYS_WRITE)
//   mov rdi, 1       (fd=stdout)
//   mov rsi, msg     (buffer address)
//   mov rdx, 14      (length)
//   syscall
//   mov rax, 60      (SYS_EXIT)
//   xor rdi, rdi     (code=0)
//   syscall
//   msg: "Hello Ring 3!\n"
@kernel fn user_install_hello() {
    // Map user code page
    let frame = frame_alloc()
    if frame == -1 { return }
    map_page(USER_CODE_BASE, frame * FRAME_SIZE, PAGE_PRESENT | PAGE_WRITABLE | PAGE_USER)

    let base = USER_CODE_BASE
    // mov rax, 1 (SYS_WRITE)
    volatile_write_u8(base + 0, 0x48)
    volatile_write_u8(base + 1, 0xC7)
    volatile_write_u8(base + 2, 0xC0)
    volatile_write_u32(base + 3, 1)
    // mov rdi, 1 (fd=stdout)
    volatile_write_u8(base + 7, 0x48)
    volatile_write_u8(base + 8, 0xC7)
    volatile_write_u8(base + 9, 0xC7)
    volatile_write_u32(base + 10, 1)
    // mov rsi, msg_addr (base + 34)
    volatile_write_u8(base + 14, 0x48)
    volatile_write_u8(base + 15, 0xC7)
    volatile_write_u8(base + 16, 0xC6)
    volatile_write_u32(base + 17, USER_CODE_BASE + 34)
    // mov rdx, 14 (len)
    volatile_write_u8(base + 21, 0x48)
    volatile_write_u8(base + 22, 0xC7)
    volatile_write_u8(base + 23, 0xC2)
    volatile_write_u32(base + 24, 14)
    // syscall
    volatile_write_u8(base + 28, 0x0F)
    volatile_write_u8(base + 29, 0x05)
    // mov rax, 60 (SYS_EXIT)
    volatile_write_u8(base + 30, 0xB8)
    volatile_write_u32(base + 31, 60)
    // xor edi, edi
    volatile_write_u8(base + 35, 0x31)
    volatile_write_u8(base + 36, 0xFF)
    // syscall
    volatile_write_u8(base + 37, 0x0F)
    volatile_write_u8(base + 38, 0x05)
    // msg: "Hello Ring 3!\n" at offset 34... wait, we overwrote at 35
    // Fix layout: put message AFTER the exit syscall (offset 39)
}

// Corrected layout with message after code
@kernel fn user_install_hello_v2() {
    // USER_CODE_BASE (0x2000000) is within the 2MB identity-mapped region.
    // Just set PAGE_USER on the huge page and write code directly.
    map_page(USER_CODE_BASE, 0, PAGE_PRESENT | PAGE_WRITABLE | PAGE_USER)
    map_page(USER_STACK_BASE, 0, PAGE_PRESENT | PAGE_WRITABLE | PAGE_USER)

    let b = USER_CODE_BASE
    let msg_addr = b + 40
    let msg_len: i64 = 14

    // mov eax, 1 (SYS_WRITE = 1)
    volatile_write_u8(b, 0xB8)
    volatile_write_u32(b + 1, 1)
    // mov edi, 1 (stdout)
    volatile_write_u8(b + 5, 0xBF)
    volatile_write_u32(b + 6, 1)
    // mov esi, msg_addr (32-bit — user space is in low 48MB)
    volatile_write_u8(b + 10, 0xBE)
    volatile_write_u32(b + 11, msg_addr)
    // mov edx, msg_len
    volatile_write_u8(b + 15, 0xBA)
    volatile_write_u32(b + 16, msg_len)
    // syscall
    volatile_write_u8(b + 20, 0x0F)
    volatile_write_u8(b + 21, 0x05)
    // mov eax, 60 (SYS_EXIT = 60)
    volatile_write_u8(b + 22, 0xB8)
    volatile_write_u32(b + 23, 0)  // SYS_EXIT = 0 (FajarOS convention)
    // xor edi, edi (exit code 0)
    volatile_write_u8(b + 27, 0x31)
    volatile_write_u8(b + 28, 0xFF)
    // syscall
    volatile_write_u8(b + 29, 0x0F)
    volatile_write_u8(b + 30, 0x05)
    // hlt (safety — should never reach)
    volatile_write_u8(b + 31, 0xF4)

    // Message: "Hello Ring 3!\n" at offset 40
    volatile_write_u8(msg_addr, 72)   // H
    volatile_write_u8(msg_addr + 1, 101) // e
    volatile_write_u8(msg_addr + 2, 108) // l
    volatile_write_u8(msg_addr + 3, 108) // l
    volatile_write_u8(msg_addr + 4, 111) // o
    volatile_write_u8(msg_addr + 5, 32)  // ' '
    volatile_write_u8(msg_addr + 6, 82)  // R
    volatile_write_u8(msg_addr + 7, 105) // i
    volatile_write_u8(msg_addr + 8, 110) // n
    volatile_write_u8(msg_addr + 9, 103) // g
    volatile_write_u8(msg_addr + 10, 32) // ' '
    volatile_write_u8(msg_addr + 11, 51) // 3
    volatile_write_u8(msg_addr + 12, 33) // !
    volatile_write_u8(msg_addr + 13, 10) // \n
}

@kernel fn user_install_program(addr: i64, msg_start: i64, msg_bytes: i64) {
    // Generic user program installer: SYS_WRITE(msg) + SYS_EXIT(0)
    map_page(addr, 0, PAGE_PRESENT | PAGE_WRITABLE | PAGE_USER)

    let b = addr
    let msg_addr = b + 40

    // mov eax, 1 (SYS_WRITE)
    volatile_write_u8(b, 0xB8)
    volatile_write_u32(b + 1, 1)
    // mov edi, 1 (stdout)
    volatile_write_u8(b + 5, 0xBF)
    volatile_write_u32(b + 6, 1)
    // mov esi, msg_addr
    volatile_write_u8(b + 10, 0xBE)
    volatile_write_u32(b + 11, msg_addr)
    // mov edx, msg_len
    volatile_write_u8(b + 15, 0xBA)
    volatile_write_u32(b + 16, msg_bytes)
    // syscall
    volatile_write_u8(b + 20, 0x0F)
    volatile_write_u8(b + 21, 0x05)
    // mov eax, 60 (SYS_EXIT)
    volatile_write_u8(b + 22, 0xB8)
    volatile_write_u32(b + 23, 0)  // SYS_EXIT = 0 (FajarOS convention)
    // xor edi, edi
    volatile_write_u8(b + 27, 0x31)
    volatile_write_u8(b + 28, 0xFF)
    // syscall
    volatile_write_u8(b + 29, 0x0F)
    volatile_write_u8(b + 30, 0x05)
    // nop
    volatile_write_u8(b + 31, 0x90)

    // Copy message bytes
    let mut i: i64 = 0
    while i < msg_bytes {
        volatile_write_u8(msg_addr + i, volatile_read_u8(msg_start + i))
        i = i + 1
    }
}

@kernel fn cmd_run_hello() {
    cprintln("Installing user hello program...", YELLOW_ON_BLACK)
    user_install_hello_v2()
    cprintln("  Code:  32 bytes at 0x2000000", WHITE_ON_BLACK)
    cprintln("  Stack: 4KB at 0x2FF0000", WHITE_ON_BLACK)
    cprintln("  Entry: 0x2000000", WHITE_ON_BLACK)
    cprintln("  Transitioning to Ring 3...", YELLOW_ON_BLACK)
    println("[RING3] Entering user mode")

    // Transition to Ring 3 via IRETQ
    // User code will SYSCALL(SYS_WRITE) → serial output → SYSCALL(SYS_EXIT) → halt
    iretq_to_user(USER_CODE_BASE, USER_STACK_BASE + 0xFF0, 0x202)

    // We reach here only if user program returns (SYS_EXIT halts, so we won't)
    println("[RING3] User program returned")
    cprintln("  User program completed", GREEN_ON_BLACK)
}

@kernel fn cmd_run_fajaros() {
    // Second user program: prints "FajarOS Nova!\n"
    let msg_buf: i64 = 0x830500
    volatile_write_u8(msg_buf, 70)      // F
    volatile_write_u8(msg_buf + 1, 97)  // a
    volatile_write_u8(msg_buf + 2, 106) // j
    volatile_write_u8(msg_buf + 3, 97)  // a
    volatile_write_u8(msg_buf + 4, 114) // r
    volatile_write_u8(msg_buf + 5, 79)  // O
    volatile_write_u8(msg_buf + 6, 83)  // S
    volatile_write_u8(msg_buf + 7, 32)  // ' '
    volatile_write_u8(msg_buf + 8, 78)  // N
    volatile_write_u8(msg_buf + 9, 111) // o
    volatile_write_u8(msg_buf + 10, 118) // v
    volatile_write_u8(msg_buf + 11, 97)  // a
    volatile_write_u8(msg_buf + 12, 33)  // !
    volatile_write_u8(msg_buf + 13, 10)  // \n

    // Install at different address (0x2001000)
    cprintln("Installing user 'FajarOS' program...", YELLOW_ON_BLACK)
    user_install_program(0x2001000, msg_buf, 14)
    map_page(0x2F00000, 0, PAGE_PRESENT | PAGE_WRITABLE | PAGE_USER)
    volatile_write_u64(0x6FC04, 0x7F0000)
    println("[RING3] Running program 2: FajarOS Nova!")
    iretq_to_user(0x2001000, 0x2F00FF0, 0x202)
}

