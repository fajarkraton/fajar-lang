@kernel fn cmd_history() {
    let count = volatile_read(0x6FC00)
    if count == 0 { cprintln("(no history)", WHITE_ON_BLACK); return }
    let mut i: i64 = 0
    while i < count {
        cprint("  ", WHITE_ON_BLACK)
        cprint_decimal(i + 1, YELLOW_ON_BLACK)
        cprint("  ", WHITE_ON_BLACK)
        let slot = HIST_BASE + i * HIST_SLOT_SIZE
        let mut j: i64 = 0
        while volatile_read_u8(slot + j) != 0 && j < 63 {
            console_putchar(volatile_read_u8(slot + j), WHITE_ON_BLACK)
            j = j + 1
        }
        console_putchar(10, WHITE_ON_BLACK)
        i = i + 1
    }
}

@kernel fn cmd_xxd() {
    // xxd <file> — hex dump of file contents
    let len = cmdbuf_len()
    if len <= 4 { cprintln("Usage: xxd <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(4)
    if idx == -1 { cprintln("xxd: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    if size == 0 { cprintln("(empty)", WHITE_ON_BLACK); return }
    let mut off: i64 = 0
    while off < size && off < 128 {
        // Offset
        cprint_hex(off, 4, YELLOW_ON_BLACK)
        cprint(": ", WHITE_ON_BLACK)
        // Hex bytes (16 per line)
        let mut i: i64 = 0
        while i < 16 {
            if off + i < size {
                cprint_hex(volatile_read_u8(data_ptr + off + i), 2, CYAN_ON_BLACK)
                console_putchar(32, WHITE_ON_BLACK)
            } else {
                cprint("   ", WHITE_ON_BLACK)
            }
            i = i + 1
        }
        cprint(" ", WHITE_ON_BLACK)
        // ASCII
        i = 0
        while i < 16 && off + i < size {
            let ch = volatile_read_u8(data_ptr + off + i)
            if ch >= 32 && ch < 127 { console_putchar(ch, GREEN_ON_BLACK) }
            else { console_putchar(46, WHITE_ON_BLACK) }
            i = i + 1
        }
        console_putchar(10, WHITE_ON_BLACK)
        off = off + 16
    }
}

@kernel fn cmd_top() {
    cprintln("PID  STATE      TICKS    CPU", YELLOW_ON_BLACK)
    cprintln("---  ---------  -------  ---", WHITE_ON_BLACK)
    let total_ticks = read_timer_ticks()
    let mut i: i64 = 0
    while i < 16 {
        let base = 0x600000 + i * 256
        let state = volatile_read(base + 8)
        if state != 0 {
            cprint_decimal(i, CYAN_ON_BLACK)
            cprint("    ", WHITE_ON_BLACK)
            if state == 1 { cprint("ready    ", WHITE_ON_BLACK) }
            else if state == 2 { cprint("RUNNING  ", GREEN_ON_BLACK) }
            else if state == 3 { cprint("blocked  ", YELLOW_ON_BLACK) }
            else { cprint("unknown  ", RED_ON_BLACK) }
            cprint("  ", WHITE_ON_BLACK)
            let ticks = volatile_read(base + 32)
            cprint_decimal(ticks, WHITE_ON_BLACK)
            cprint("    ", WHITE_ON_BLACK)
            if total_ticks > 0 {
                cprint_decimal(ticks * 100 / (total_ticks + 1), CYAN_ON_BLACK)
                console_putchar(37, WHITE_ON_BLACK) // '%'
            }
            console_putchar(10, WHITE_ON_BLACK)
        }
        i = i + 1
    }
}

@kernel fn cmd_append() {
    // append <file> <text> — append text to existing file
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: append <file> <text>", YELLOW_ON_BLACK); return }
    // Find space after "append "
    let mut sp: i64 = 7
    while sp < len && volatile_read_u8(0x6F800 + sp) != 32 { sp = sp + 1 }
    if sp >= len - 1 { cprintln("Usage: append <file> <text>", YELLOW_ON_BLACK); return }
    let name_len = sp - 7
    // Find file
    let count = volatile_read(FS_BASE)
    let mut idx: i64 = -1
    let mut fi: i64 = 0
    while fi < count && idx == -1 {
        let addr = ramfs_entry_addr(fi)
        let mut match_ok: i64 = 1
        let mut j: i64 = 0
        while j < name_len && match_ok == 1 {
            if volatile_read_u8(addr + j) != volatile_read_u8(0x6F800 + 7 + j) { match_ok = 0 }
            j = j + 1
        }
        if match_ok == 1 && volatile_read_u8(addr + name_len) == 0 { idx = fi }
        fi = fi + 1
    }
    if idx == -1 { cprintln("append: file not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let old_size = volatile_read(addr + 32)
    let old_ptr = volatile_read(addr + 40)
    let text_start = sp + 1
    let text_len = len - text_start
    // Allocate new data area and copy old + new
    let new_ptr = volatile_read(FS_BASE + 8)
    let mut i: i64 = 0
    while i < old_size {
        volatile_write_u8(new_ptr + i, volatile_read_u8(old_ptr + i))
        i = i + 1
    }
    i = 0
    while i < text_len {
        volatile_write_u8(new_ptr + old_size + i, volatile_read_u8(0x6F800 + text_start + i))
        i = i + 1
    }
    volatile_write(addr + 32, old_size + text_len)
    volatile_write(addr + 40, new_ptr)
    volatile_write(FS_BASE + 8, new_ptr + old_size + text_len)
}

@kernel fn cmd_cp() {
    // cp <src> <dst> — copy file
    let len = cmdbuf_len()
    if len <= 3 { cprintln("Usage: cp <src> <dst>", YELLOW_ON_BLACK); return }
    // Find space between src and dst
    let mut sp: i64 = 3
    while sp < len && volatile_read_u8(0x6F800 + sp) != 32 { sp = sp + 1 }
    if sp >= len - 1 { cprintln("Usage: cp <src> <dst>", YELLOW_ON_BLACK); return }
    let src_len = sp - 3
    let dst_start = sp + 1
    let dst_len = len - dst_start
    // Find source file
    let count = volatile_read(FS_BASE)
    let mut src_idx: i64 = -1
    let mut fi: i64 = 0
    while fi < count && src_idx == -1 {
        let addr = ramfs_entry_addr(fi)
        let mut match_ok: i64 = 1
        let mut j: i64 = 0
        while j < src_len && match_ok == 1 {
            if volatile_read_u8(addr + j) != volatile_read_u8(0x6F800 + 3 + j) { match_ok = 0 }
            j = j + 1
        }
        if match_ok == 1 && volatile_read_u8(addr + src_len) == 0 { src_idx = fi }
        fi = fi + 1
    }
    if src_idx == -1 { cprintln("cp: source not found", RED_ON_BLACK); return }
    // Create destination
    if count >= FS_MAX_FILES { cprintln("cp: filesystem full", RED_ON_BLACK); return }
    let src_addr = ramfs_entry_addr(src_idx)
    let src_size = volatile_read(src_addr + 32)
    let src_data = volatile_read(src_addr + 40)
    let dst_idx = count
    let dst_addr = ramfs_entry_addr(dst_idx)
    // Copy name
    let mut i: i64 = 0
    while i < dst_len && i < 31 {
        volatile_write_u8(dst_addr + i, volatile_read_u8(0x6F800 + dst_start + i))
        i = i + 1
    }
    volatile_write_u8(dst_addr + i, 0)
    // Copy data
    let new_ptr = volatile_read(FS_BASE + 8)
    i = 0
    while i < src_size {
        volatile_write_u8(new_ptr + i, volatile_read_u8(src_data + i))
        i = i + 1
    }
    volatile_write(dst_addr + 32, src_size)
    volatile_write(dst_addr + 40, new_ptr)
    volatile_write(dst_addr + 48, 1) // file
    volatile_write(FS_BASE, count + 1)
    volatile_write(FS_BASE + 8, new_ptr + src_size)
}

@kernel fn cmd_time() {
    // time — run a benchmark and show elapsed
    cprint("Timing 100K loop... ", WHITE_ON_BLACK)
    let t0 = rdtsc()
    let mut i: i64 = 0
    let mut acc: i64 = 0
    while i < 100000 { acc = acc + i; i = i + 1 }
    let t1 = rdtsc()
    let cycles = t1 - t0
    cprint_decimal(cycles, CYAN_ON_BLACK)
    cprint(" cycles (", WHITE_ON_BLACK)
    cprint_decimal(cycles / 1000, CYAN_ON_BLACK)
    cprintln("K)", WHITE_ON_BLACK)
}

@kernel fn cmd_factor() {
    // factor <N> — factorize a number
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: factor <N>", YELLOW_ON_BLACK); return }
    let mut n: i64 = 0
    let mut i: i64 = 7
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48) }
        i = i + 1
    }
    if n <= 1 { cprintln("factor: need N > 1", YELLOW_ON_BLACK); return }
    cprint_decimal(n, WHITE_ON_BLACK)
    cprint(": ", WHITE_ON_BLACK)
    let mut d: i64 = 2
    let mut val = n
    while d * d <= val {
        while val % d == 0 {
            cprint_decimal(d, CYAN_ON_BLACK)
            console_putchar(32, WHITE_ON_BLACK)
            val = val / d
        }
        d = d + 1
    }
    if val > 1 { cprint_decimal(val, CYAN_ON_BLACK) }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_prime() {
    // prime <N> — check if N is prime
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: prime <N>", YELLOW_ON_BLACK); return }
    let mut n: i64 = 0
    let mut i: i64 = 6
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48) }
        i = i + 1
    }
    if n <= 1 { cprintln("Not prime", RED_ON_BLACK); return }
    let mut is_prime: i64 = 1
    let mut d: i64 = 2
    while d * d <= n {
        if n % d == 0 { is_prime = 0 }
        d = d + 1
    }
    cprint_decimal(n, WHITE_ON_BLACK)
    if is_prime == 1 { cprintln(" is PRIME", GREEN_ON_BLACK) }
    else { cprintln(" is not prime", RED_ON_BLACK) }
}

