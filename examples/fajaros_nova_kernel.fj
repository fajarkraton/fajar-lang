@kernel fn cmd_cpuinfo() {
    let ecx1 = cpuid_ecx(1)
    let edx1 = cpuid_edx(1)
    let ebx7 = cpuid_ebx(7)
    cprintln("CPU Features:", YELLOW_ON_BLACK)
    if (edx1 & (1 << 0)) != 0 { cprintln("  FPU", WHITE_ON_BLACK) }
    if (edx1 & (1 << 25)) != 0 { cprintln("  SSE", WHITE_ON_BLACK) }
    if (edx1 & (1 << 26)) != 0 { cprintln("  SSE2", WHITE_ON_BLACK) }
    if (ecx1 & (1 << 20)) != 0 { cprintln("  SSE4.2", WHITE_ON_BLACK) }
    if (ecx1 & (1 << 28)) != 0 { cprintln("  AVX", WHITE_ON_BLACK) }
    if (ebx7 & (1 << 5)) != 0 { cprintln("  AVX2", WHITE_ON_BLACK) }
    if (edx1 & (1 << 9)) != 0 { cprintln("  APIC", WHITE_ON_BLACK) }
}

@kernel fn cmd_meminfo() {
    cprintln("Memory:", YELLOW_ON_BLACK)
    cprintln("  Total mapped: 128 MB (identity)", WHITE_ON_BLACK)
    cprintln("  Kernel:  0x100000 (1 MB)", WHITE_ON_BLACK)
    cprintln("  Heap:    0x400000 - 0x7000000 (108 MB)", WHITE_ON_BLACK)
    cprintln("  Stack:   0x7F00000 (127 MB)", WHITE_ON_BLACK)
    cprintln("  ProcTbl: 0x600000 (4 KB)", WHITE_ON_BLACK)
}

@kernel fn pci_class_name(class: i64, subclass: i64) {
    if class == 0x00 { cprint("Legacy", WHITE_ON_BLACK) }
    else if class == 0x01 {
        cprint("Storage", WHITE_ON_BLACK)
        if subclass == 0x01 { cprint("/IDE", CYAN_ON_BLACK) }
        else if subclass == 0x06 { cprint("/SATA", CYAN_ON_BLACK) }
        else if subclass == 0x08 { cprint("/NVMe", GREEN_ON_BLACK) }
    }
    else if class == 0x02 {
        cprint("Network", WHITE_ON_BLACK)
        if subclass == 0x00 { cprint("/Ethernet", CYAN_ON_BLACK) }
        else if subclass == 0x80 { cprint("/Other", CYAN_ON_BLACK) }
    }
    else if class == 0x03 {
        cprint("Display", WHITE_ON_BLACK)
        if subclass == 0x00 { cprint("/VGA", CYAN_ON_BLACK) }
        else if subclass == 0x02 { cprint("/3D", CYAN_ON_BLACK) }
    }
    else if class == 0x04 { cprint("Multimedia", WHITE_ON_BLACK) }
    else if class == 0x05 { cprint("Memory", WHITE_ON_BLACK) }
    else if class == 0x06 {
        cprint("Bridge", WHITE_ON_BLACK)
        if subclass == 0x00 { cprint("/Host", CYAN_ON_BLACK) }
        else if subclass == 0x01 { cprint("/ISA", CYAN_ON_BLACK) }
        else if subclass == 0x04 { cprint("/PCI", CYAN_ON_BLACK) }
    }
    else if class == 0x07 { cprint("Serial", WHITE_ON_BLACK) }
    else if class == 0x08 { cprint("System", WHITE_ON_BLACK) }
    else if class == 0x0C {
        cprint("Serial Bus", WHITE_ON_BLACK)
        if subclass == 0x03 { cprint("/USB", CYAN_ON_BLACK) }
    }
    else { cprint("Unknown", WHITE_ON_BLACK) }
}

@kernel fn cmd_lspci() {
    cprintln("PCI Devices:", YELLOW_ON_BLACK)
    let mut dev: i64 = 0
    let mut found: i64 = 0
    while dev < 32 {
        let id = pci_read32(0, dev, 0, 0)
        if id != 0xFFFFFFFF && id != 0 {
            cprint("  ", WHITE_ON_BLACK)
            cprint_hex(id & 0xFFFF, 4, CYAN_ON_BLACK)
            console_putchar(58, WHITE_ON_BLACK)
            cprint_hex((id >> 16) & 0xFFFF, 4, CYAN_ON_BLACK)
            let cl = pci_read32(0, dev, 0, 8)
            let class = (cl >> 24) & 0xFF
            let subclass = (cl >> 16) & 0xFF
            cprint(" ", WHITE_ON_BLACK)
            pci_class_name(class, subclass)
            console_putchar(10, WHITE_ON_BLACK)
            found = found + 1
        }
        dev = dev + 1
    }
    cprint("Total: ", GREEN_ON_BLACK)
    cprint_decimal(found, GREEN_ON_BLACK)
    cprintln(" devices", GREEN_ON_BLACK)
}

@kernel fn cmd_lspci_v() {
    // lspci -v — verbose with BAR info
    cprintln("PCI Devices (verbose):", YELLOW_ON_BLACK)
    let mut dev: i64 = 0
    while dev < 32 {
        let id = pci_read32(0, dev, 0, 0)
        if id != 0xFFFFFFFF && id != 0 {
            let cl = pci_read32(0, dev, 0, 8)
            let class = (cl >> 24) & 0xFF
            let subclass = (cl >> 16) & 0xFF
            cprint("  Dev ", WHITE_ON_BLACK)
            cprint_decimal(dev, CYAN_ON_BLACK)
            cprint(": ", WHITE_ON_BLACK)
            cprint_hex(id & 0xFFFF, 4, CYAN_ON_BLACK)
            console_putchar(58, WHITE_ON_BLACK)
            cprint_hex((id >> 16) & 0xFFFF, 4, CYAN_ON_BLACK)
            cprint(" ", WHITE_ON_BLACK)
            pci_class_name(class, subclass)
            console_putchar(10, WHITE_ON_BLACK)
            // Read BARs (offset 0x10-0x24, 6 BARs)
            let mut bar: i64 = 0
            while bar < 6 {
                let bar_val = pci_read32(0, dev, 0, 0x10 + bar * 4)
                if bar_val != 0 {
                    cprint("    BAR", WHITE_ON_BLACK)
                    cprint_decimal(bar, WHITE_ON_BLACK)
                    cprint(": 0x", WHITE_ON_BLACK)
                    cprint_hex(bar_val, 8, CYAN_ON_BLACK)
                    if (bar_val & 1) == 1 {
                        cprint(" (I/O port ", YELLOW_ON_BLACK)
                        cprint_hex(bar_val & 0xFFFFFFFC, 4, YELLOW_ON_BLACK)
                        cprintln(")", WHITE_ON_BLACK)
                    } else {
                        let bar_type = (bar_val >> 1) & 3
                        if bar_type == 0 { cprint(" (MMIO 32-bit)", YELLOW_ON_BLACK) }
                        else if bar_type == 2 { cprint(" (MMIO 64-bit)", YELLOW_ON_BLACK) }
                        console_putchar(10, WHITE_ON_BLACK)
                    }
                }
                bar = bar + 1
            }
            // Read interrupt line
            let int_reg = pci_read32(0, dev, 0, 0x3C)
            let irq = int_reg & 0xFF
            if irq != 0 && irq != 0xFF {
                cprint("    IRQ: ", WHITE_ON_BLACK)
                cprint_decimal(irq, CYAN_ON_BLACK)
                console_putchar(10, WHITE_ON_BLACK)
            }
        }
        dev = dev + 1
    }
}

// ═══════════════════════════════════════════════
// Slab Allocator (Phase 2 Sprint 6)
// Pre-sized caches: 32, 64, 128, 256, 512, 1024
// Each slab: bitmap + objects at fixed addresses
// ═══════════════════════════════════════════════

const SLAB_BASE: i64 = 0x590000
const SLAB_SIZES: i64 = 6  // 32, 64, 128, 256, 512, 1024

@kernel fn slab_init() {
    // Initialize slab metadata at SLAB_BASE
    // Each slab: offset +0: object_size, +8: capacity, +16: used, +24: bitmap_addr, +32: data_addr
    let mut i: i64 = 0
    let sizes: [i64; 6] = [32, 64, 128, 256, 512, 1024]
    let mut data_off: i64 = SLAB_BASE + 256  // data starts after metadata
    while i < SLAB_SIZES {
        let meta = SLAB_BASE + i * 40
        let obj_size = sizes[i]
        let capacity = 4096 / obj_size  // one page worth
        volatile_write(meta, obj_size)
        volatile_write(meta + 8, capacity)
        volatile_write(meta + 16, 0)      // used = 0
        volatile_write(meta + 24, data_off) // bitmap
        volatile_write(meta + 32, data_off + capacity) // data
        // Clear bitmap
        let mut j: i64 = 0
        while j < capacity { volatile_write_u8(data_off + j, 0); j = j + 1 }
        data_off = data_off + capacity + capacity * obj_size
        i = i + 1
    }
}

@kernel fn slab_alloc(size: i64) -> i64 {
    // Find smallest slab that fits
    let sizes: [i64; 6] = [32, 64, 128, 256, 512, 1024]
    let mut i: i64 = 0
    while i < SLAB_SIZES {
        if sizes[i] >= size {
            let meta = SLAB_BASE + i * 40
            let capacity = volatile_read(meta + 8)
            let used = volatile_read(meta + 16)
            if used < capacity {
                let bitmap = volatile_read(meta + 24)
                let data = volatile_read(meta + 32)
                // Find free slot
                let mut j: i64 = 0
                while j < capacity {
                    if volatile_read_u8(bitmap + j) == 0 {
                        volatile_write_u8(bitmap + j, 1)
                        volatile_write(meta + 16, used + 1)
                        return data + j * sizes[i]
                    }
                    j = j + 1
                }
            }
        }
        i = i + 1
    }
    -1  // No suitable slab
}

@kernel fn slab_free(ptr: i64, size: i64) {
    let sizes: [i64; 6] = [32, 64, 128, 256, 512, 1024]
    let mut i: i64 = 0
    while i < SLAB_SIZES {
        if sizes[i] >= size {
            let meta = SLAB_BASE + i * 40
            let data = volatile_read(meta + 32)
            let bitmap = volatile_read(meta + 24)
            let slot = (ptr - data) / sizes[i]
            if slot >= 0 && slot < volatile_read(meta + 8) {
                volatile_write_u8(bitmap + slot, 0)
                let used = volatile_read(meta + 16)
                if used > 0 { volatile_write(meta + 16, used - 1) }
            }
            return
        }
        i = i + 1
    }
}

@kernel fn cmd_slab() {
    cprintln("Slab Allocator:", YELLOW_ON_BLACK)
    let sizes: [i64; 6] = [32, 64, 128, 256, 512, 1024]
    let mut i: i64 = 0
    while i < SLAB_SIZES {
        let meta = SLAB_BASE + i * 40
        let obj_size = volatile_read(meta)
        let capacity = volatile_read(meta + 8)
        let used = volatile_read(meta + 16)
        cprint("  ", WHITE_ON_BLACK)
        cprint_decimal(obj_size, CYAN_ON_BLACK)
        cprint("B: ", WHITE_ON_BLACK)
        cprint_decimal(used, WHITE_ON_BLACK)
        cprint("/", WHITE_ON_BLACK)
        cprint_decimal(capacity, WHITE_ON_BLACK)
        cprintln(" used", WHITE_ON_BLACK)
        i = i + 1
    }
}

// ═══════════════════════════════════════════════
// MNIST Digit Display (Phase 9)
// ═══════════════════════════════════════════════

@kernel fn cmd_digit() {
    // digit <N> — display digit N as ASCII art (28x28)
    let len = cmdbuf_len()
    let mut n: i64 = 0
    if len > 6 {
        n = volatile_read_u8(0x6F800 + 6) - 48
    }
    if n < 0 || n > 9 { n = 0 }
    cprintln("MNIST Digit Display:", YELLOW_ON_BLACK)
    cprint("  Digit: ", WHITE_ON_BLACK)
    cprint_decimal(n, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    // Generate a simple digit pattern (7x7 ASCII art)
    // Each digit has a hardcoded 7-line pattern
    if n == 0 {
        cprintln("   ###  ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("   ###  ", WHITE_ON_BLACK)
    } else if n == 1 {
        cprintln("    #   ", WHITE_ON_BLACK)
        cprintln("   ##   ", WHITE_ON_BLACK)
        cprintln("    #   ", WHITE_ON_BLACK)
        cprintln("    #   ", WHITE_ON_BLACK)
        cprintln("    #   ", WHITE_ON_BLACK)
        cprintln("    #   ", WHITE_ON_BLACK)
        cprintln("   ###  ", WHITE_ON_BLACK)
    } else if n == 2 {
        cprintln("   ###  ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("    ##  ", WHITE_ON_BLACK)
        cprintln("   #    ", WHITE_ON_BLACK)
        cprintln("  #     ", WHITE_ON_BLACK)
        cprintln("  ##### ", WHITE_ON_BLACK)
    } else if n == 3 {
        cprintln("   ###  ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("    ##  ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("   ###  ", WHITE_ON_BLACK)
    } else if n == 4 {
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  ##### ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
    } else if n == 5 {
        cprintln("  ##### ", WHITE_ON_BLACK)
        cprintln("  #     ", WHITE_ON_BLACK)
        cprintln("  ####  ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("   ###  ", WHITE_ON_BLACK)
    } else if n == 6 {
        cprintln("   ###  ", WHITE_ON_BLACK)
        cprintln("  #     ", WHITE_ON_BLACK)
        cprintln("  ####  ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("   ###  ", WHITE_ON_BLACK)
    } else if n == 7 {
        cprintln("  ##### ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("     #  ", WHITE_ON_BLACK)
        cprintln("    #   ", WHITE_ON_BLACK)
        cprintln("   #    ", WHITE_ON_BLACK)
        cprintln("   #    ", WHITE_ON_BLACK)
        cprintln("   #    ", WHITE_ON_BLACK)
    } else if n == 8 {
        cprintln("   ###  ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("   ###  ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("   ###  ", WHITE_ON_BLACK)
    } else {
        cprintln("   ###  ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("   #### ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("   ###  ", WHITE_ON_BLACK)
    }
    cprintln("  (ASCII art — real MNIST uses 28x28)", YELLOW_ON_BLACK)
}

// ═══════════════════════════════════════════════
// MNIST Classifier (Phase 9 Sprint 25-26)
// Simple 10-class integer perceptron
// Weights stored in ramfs, loaded into volatile memory
// ═══════════════════════════════════════════════

const MNIST_WEIGHTS: i64 = 0x550000  // 10 classes × 49 weights = 490 i64 values
const MNIST_PIXELS: i64 = 0x560000   // 7×7 = 49 pixel values per digit

@kernel fn mnist_init_weights() {
    // Hardcoded 7×7 feature weights for digits 0-9
    // Each digit has 49 weight values (positive=expects dark, negative=expects light)
    // Simplified perceptron trained on 7×7 digit patterns

    // Digit 0: ring shape (high outer, low center)
    let w0: [i64; 10] = [3, 5, 5, 5, 5, 5, 3, 5, -3, -3, -3, -3, -3, 5, 5, -3, 0, 0, 0, -3, 5, 5, -3, 0, 0, 0, -3, 5, 5, -3, 0, 0, 0, -3, 5, 5, -3, -3, -3, -3, -3, 5, 3, 5, 5, 5, 5, 5, 3]
    // Digit 1: vertical stripe
    let w1: [i64; 10] = [-3, -3, 5, 5, -3, -3, -3, -3, 3, 5, 5, -3, -3, -3, -3, -3, 5, 5, -3, -3, -3, -3, -3, 5, 5, -3, -3, -3, -3, -3, 5, 5, -3, -3, -3, -3, -3, 5, 5, -3, -3, -3, -3, 3, 5, 5, 5, 3, -3]

    // Store weights for all classes at MNIST_WEIGHTS
    // Class 0 weights at offset 0, class 1 at offset 49*8, etc.
    let mut i: i64 = 0
    while i < 10 { volatile_write(MNIST_WEIGHTS + i * 8, w0[i]); i = i + 1 }
    i = 0
    while i < 10 { volatile_write(MNIST_WEIGHTS + 49 * 8 + i * 8, w1[i]); i = i + 1 }
    // Remaining classes: simple bias patterns
    let mut cls: i64 = 2
    while cls < 10 {
        let mut j: i64 = 0
        while j < 49 {
            // Create distinct weight pattern for each class
            let row = j / 7
            let col = j % 7
            let mut w: i64 = -2
            if cls == 2 && (row == 0 || row == 3 || row == 6 || (col == 6 && row < 3) || (col == 0 && row > 3)) { w = 5 }
            if cls == 3 && (row == 0 || row == 3 || row == 6 || col == 6) { w = 5 }
            if cls == 4 && ((row < 4 && col == 0) || (row < 4 && col == 6) || row == 3 || (row >= 3 && col == 6)) { w = 5 }
            if cls == 5 && (row == 0 || (row < 3 && col == 0) || row == 3 || (row > 3 && col == 6) || row == 6) { w = 5 }
            if cls == 6 && (row == 0 || col == 0 || row == 3 || row == 6 || (row > 3 && col == 6)) { w = 5 }
            if cls == 7 && (row == 0 || col == 6) { w = 5 }
            if cls == 8 && (row == 0 || row == 3 || row == 6 || col == 0 || col == 6) { w = 5 }
            if cls == 9 && (row == 0 || row == 3 || col == 0 || col == 6 || (row > 3 && col == 6)) { w = 5 }
            volatile_write(MNIST_WEIGHTS + cls * 49 * 8 + j * 8, w)
            j = j + 1
        }
        cls = cls + 1
    }
}

@kernel fn mnist_create_test_digit(digit: i64) {
    // Create a 7×7 pixel pattern for the given digit at MNIST_PIXELS
    let mut j: i64 = 0
    while j < 49 {
        let row = j / 7
        let col = j % 7
        let mut px: i64 = 0  // 0=light, 1=dark
        if digit == 0 && ((row == 0 || row == 6) && col >= 1 && col <= 5 || (col == 0 || col == 6) && row >= 1 && row <= 5) { px = 1 }
        if digit == 1 && (col == 3 || col == 4) { px = 1 }
        if digit == 2 && (row == 0 || (row < 3 && col == 6) || row == 3 || (row > 3 && col == 0) || row == 6) { px = 1 }
        if digit == 3 && (row == 0 || row == 3 || row == 6 || col == 6) { px = 1 }
        if digit == 4 && ((row < 4 && (col == 0 || col == 6)) || row == 3 || (row > 3 && col == 6)) { px = 1 }
        if digit == 5 && (row == 0 || (row < 3 && col == 0) || row == 3 || (row > 3 && col == 6) || row == 6) { px = 1 }
        if digit == 6 && (row == 0 || col == 0 || row == 3 || row == 6 || (row > 3 && col == 6)) { px = 1 }
        if digit == 7 && (row == 0 || col == 6) { px = 1 }
        if digit == 8 && (row == 0 || row == 3 || row == 6 || col == 0 || col == 6) { px = 1 }
        if digit == 9 && (row == 0 || row == 3 || col == 0 || col == 6 || (row > 3 && col == 6)) { px = 1 }
        volatile_write(MNIST_PIXELS + j * 8, px)
        j = j + 1
    }
}

@kernel fn mnist_classify() -> i64 {
    // Classify the digit at MNIST_PIXELS using weights at MNIST_WEIGHTS
    // Returns predicted class (0-9)
    let mut best_class: i64 = 0
    let mut best_score: i64 = -99999
    let mut cls: i64 = 0
    while cls < 10 {
        let mut score: i64 = 0
        let mut j: i64 = 0
        while j < 49 {
            let pixel = volatile_read(MNIST_PIXELS + j * 8)
            let weight = volatile_read(MNIST_WEIGHTS + cls * 49 * 8 + j * 8)
            score = score + pixel * weight
            j = j + 1
        }
        if score > best_score {
            best_score = score
            best_class = cls
        }
        cls = cls + 1
    }
    best_class
}

@kernel fn cmd_classify() {
    // classify <digit> — classify a digit
    let len = cmdbuf_len()
    let mut d: i64 = 0
    if len > 9 { d = volatile_read_u8(0x6F800 + 9) - 48 }
    if d < 0 || d > 9 { d = 0 }

    mnist_create_test_digit(d)
    let t0 = rdtsc()
    let pred = mnist_classify()
    let t1 = rdtsc()

    cprint("Input: ", WHITE_ON_BLACK)
    cprint_decimal(d, CYAN_ON_BLACK)
    cprint("  Predicted: ", WHITE_ON_BLACK)
    cprint_decimal(pred, CYAN_ON_BLACK)
    if pred == d {
        cprintln("  CORRECT", GREEN_ON_BLACK)
    } else {
        cprintln("  WRONG", RED_ON_BLACK)
    }
    cprint("Inference: ", WHITE_ON_BLACK)
    cprint_decimal(t1 - t0, CYAN_ON_BLACK)
    cprintln(" cycles", WHITE_ON_BLACK)
}

@kernel fn cmd_mnist_all() {
    // Batch inference on all 10 digits
    cprintln("MNIST Batch Inference (7x7 perceptron):", YELLOW_ON_BLACK)
    cprintln("  Digit  Predicted  Result   Cycles", WHITE_ON_BLACK)
    cprintln("  ─────  ─────────  ──────   ──────", WHITE_ON_BLACK)
    let mut correct: i64 = 0
    let mut total_cycles: i64 = 0
    let mut d: i64 = 0
    while d < 10 {
        mnist_create_test_digit(d)
        let t0 = rdtsc()
        let pred = mnist_classify()
        let t1 = rdtsc()
        let cycles = t1 - t0
        total_cycles = total_cycles + cycles

        cprint("  ", WHITE_ON_BLACK)
        cprint_decimal(d, WHITE_ON_BLACK)
        cprint("      ", WHITE_ON_BLACK)
        cprint_decimal(pred, CYAN_ON_BLACK)
        if pred == d {
            cprint("          OK", GREEN_ON_BLACK)
            correct = correct + 1
        } else {
            cprint("          MISS", RED_ON_BLACK)
        }
        cprint("     ", WHITE_ON_BLACK)
        cprint_decimal(cycles, WHITE_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        d = d + 1
    }
    cprintln("  ─────────────────────────────────", WHITE_ON_BLACK)
    cprint("  Accuracy: ", WHITE_ON_BLACK)
    cprint_decimal(correct, CYAN_ON_BLACK)
    cprintln("/10", WHITE_ON_BLACK)
    cprint("  Avg: ", WHITE_ON_BLACK)
    cprint_decimal(total_cycles / 10, CYAN_ON_BLACK)
    cprintln(" cycles/inference", WHITE_ON_BLACK)
}

@kernel fn cmd_ps() {
    cprintln("Processes:", YELLOW_ON_BLACK)
    cprintln("  PID  STATE    TICKS", WHITE_ON_BLACK)
    let mut i: i64 = 0
    while i < 16 {
        let base = 0x600000 + i * 256
        let state = volatile_read(base + 8)
        if state != 0 {
            cprint("  ", WHITE_ON_BLACK)
            cprint_decimal(i, CYAN_ON_BLACK)
            if state == 1 { cprint("    ready    ", WHITE_ON_BLACK) }
            else if state == 2 { cprint("    running  ", GREEN_ON_BLACK) }
            else { cprint("    blocked  ", YELLOW_ON_BLACK) }
            cprint_decimal(volatile_read(base + 32), WHITE_ON_BLACK)
            console_putchar(10, WHITE_ON_BLACK)
        }
        i = i + 1
    }
}

@kernel fn cmd_clear() {
    console_init()
}

@kernel fn cmd_echo() {
    // Echo the command buffer (skip "echo " prefix = 5 chars)
    let len = cmdbuf_len()
    if len > 5 {
        let mut i: i64 = 5
        while i < len {
            console_putchar(volatile_read_u8(0x6F800 + i), WHITE_ON_BLACK)
            i = i + 1
        }
    }
    console_putchar(10, WHITE_ON_BLACK)
}

