// ═══════════════════════════════════════════════════════════════
// A2.3: Device Framework + Hot-Plug
// ═══════════════════════════════════════════════════════════════

// ── Driver registration ──

const DRIVER_REG_TABLE: i64 = 0x3370000
const DRIVER_REG_SIZE: i64 = 64
const DRIVER_REG_MAX: i64 = 16

@kernel fn driver_register(class: i64, subclass: i64, driver_id: i64, name_addr: i64) {
    let mut i: i64 = 0
    while i < DRIVER_REG_MAX {
        let entry = DRIVER_REG_TABLE + i * DRIVER_REG_SIZE
        if volatile_read_u32(entry) == 0 {
            volatile_write_u32(entry, class)
            volatile_write_u32(entry + 4, subclass)
            volatile_write_u32(entry + 8, driver_id)
            // Copy name
            let mut j: i64 = 0
            while j < 32 {
                volatile_write_u8(entry + 16 + j, volatile_read_u8(name_addr + j))
                if volatile_read_u8(name_addr + j) == 0 { break }
                j = j + 1
            }
            return
        }
        i = i + 1
    }
}

// ── Hot-plug detection (port status change interrupt) ──

@kernel fn xhci_port_change_handler() {
    let cap_len = volatile_read_u8(XHCI_BASE + XHCI_CAP_LENGTH)
    let op_base = XHCI_BASE + cap_len
    let hcsparams1 = volatile_read_u32(XHCI_BASE + XHCI_HCSPARAMS1)
    let max_ports = (hcsparams1 >> 24) & 0xFF

    let mut port: i64 = 0
    while port < max_ports {
        let portsc = op_base + 0x400 + port * 16
        let status = volatile_read_u32(portsc)
        if (status & 0x20000) != 0 { // CSC (Connect Status Change)
            // Clear change bit
            volatile_write_u32(portsc, status | 0x20000)

            if (status & 1) != 0 {
                // Device connected — enumerate
                xhci_enable_port(op_base, port)
            } else {
                // Device disconnected — clean up
                usb_device_disconnect(port)
            }
        }
        port = port + 1
    }
}

@kernel fn usb_device_disconnect(port: i64) {
    let mut i: i64 = 0
    while i < USB_DEV_MAX {
        if usb_dev_get(i, USB_OFF_PORT) == port {
            if usb_dev_get(i, USB_OFF_STATE) != 0 {
                usb_dev_set(i, USB_OFF_STATE, 0) // detached
                usb_dev_set(i, USB_OFF_DRIVER, DRIVER_NONE)
                // Free device slot
                let slot = usb_dev_get(i, USB_OFF_SLOT)
                xhci_disable_slot(slot)
            }
        }
        i = i + 1
    }
}

@kernel fn xhci_disable_slot(slot: i64) {
    // Submit Disable Slot Command TRB
    let trb = CMD_RING + 48 // next free slot (simplified)
    volatile_write_u64(trb, 0)
    volatile_write_u32(trb + 8, 0)
    volatile_write_u32(trb + 12, (TRB_DISABLE_SLOT << 10) | (slot << 24) | 1)
    xhci_ring_doorbell(0, 0)
}

// ── lsusb command ──

@kernel fn cmd_lsusb() {
    cprintln("Bus  Dev  Slot  Speed  Class  VID:PID     Driver      State", 0x0E)
    cprintln("────────────────────────────────────────────────────────────", 0x08)
    let mut i: i64 = 0
    while i < USB_DEV_MAX {
        if usb_dev_get(i, USB_OFF_STATE) != 0 {
            cprint("  0   ", 0x0F)
            cprint_decimal(i, 0x0B)
            cprint("     ", 0x0F)
            cprint_decimal(usb_dev_get(i, USB_OFF_SLOT), 0x0B)
            cprint("    ", 0x0F)
            let speed = usb_dev_get(i, USB_OFF_SPEED)
            if speed == 1 { cprint("FS   ", 0x0F) }
            else if speed == 2 { cprint("LS   ", 0x0F) }
            else if speed == 3 { cprint("HS   ", 0x0F) }
            else if speed == 4 { cprint("SS   ", 0x0A) }
            else { cprint("??   ", 0x0C) }
            cprintln("", 0x0F)
        }
        i = i + 1
    }
}

// ── Helpers ──

@kernel fn usb_dev_get(idx: i64, off: i64) -> i64 {
    volatile_read_u32(USB_DEV_TABLE + idx * USB_DEV_SIZE + off)
}

@kernel fn usb_dev_set(idx: i64, off: i64, val: i64) {
    volatile_write_u32(USB_DEV_TABLE + idx * USB_DEV_SIZE + off, val)
}

// ── Entry point ──

@kernel fn aurora_usb_main() {
    let ports = xhci_init()
    let devices = xhci_enumerate()
}
