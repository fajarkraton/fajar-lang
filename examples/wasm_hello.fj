// WebAssembly Hello World in Fajar Lang
// Compile with: fj run --wasm examples/wasm_hello.fj
use std::io::println

fn add(a: i64, b: i64) -> i64 {
    a + b
}

fn fibonacci(n: i64) -> i64 {
    if n <= 1 {
        n
    } else {
        fibonacci(n - 1) + fibonacci(n - 2)
    }
}

fn main() -> void {
    println("Hello from Fajar Lang on WebAssembly!")

    let result = add(10, 20)
    let fib10 = fibonacci(10)
}
