}

// ═══════════════════════════════════════════════
// File Permissions (Sprint M2 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// Extended ramfs entry offsets (within 128-byte entry)
// +0-31: name, +32: size, +40: data_ptr, +48: type
// NEW: +56: owner_uid, +64: owner_gid, +72: mode (rwxrwxrwx as octal bits)
const FS_OFF_OWNER_UID: i64 = 56
const FS_OFF_OWNER_GID: i64 = 64
const FS_OFF_MODE: i64 = 72

// Default permissions
const PERM_FILE_DEFAULT: i64 = 0x1A4  // 0644 = rw-r--r--
const PERM_DIR_DEFAULT: i64 = 0x1ED   // 0755 = rwxr-xr-x

// Permission bit masks
const PERM_OWNER_R: i64 = 0x100  // owner read
const PERM_OWNER_W: i64 = 0x080  // owner write
const PERM_OWNER_X: i64 = 0x040  // owner execute
const PERM_GROUP_R: i64 = 0x020  // group read
const PERM_GROUP_W: i64 = 0x010  // group write
const PERM_GROUP_X: i64 = 0x008  // group execute
const PERM_OTHER_R: i64 = 0x004  // other read
const PERM_OTHER_W: i64 = 0x002  // other write
const PERM_OTHER_X: i64 = 0x001  // other execute

// M2.2: Set default permissions when creating files/dirs
@kernel fn fs_set_default_perms(entry_addr: i64, ftype: i64) {
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    volatile_write(entry_addr + FS_OFF_OWNER_UID, uid)
    volatile_write(entry_addr + FS_OFF_OWNER_GID, uid) // gid = uid for simplicity
    let mode = if ftype == 2 { PERM_DIR_DEFAULT } else { PERM_FILE_DEFAULT }
    volatile_write(entry_addr + FS_OFF_MODE, mode)
}

// M2.5: Check permission for access
// access: 4=read, 2=write, 1=execute
@kernel fn fs_check_perm(entry_addr: i64, access: i64) -> i64 {
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    // M2.9: Root bypasses all permission checks
    if uid == 0 { return 0 }

    let owner_uid = volatile_read(entry_addr + FS_OFF_OWNER_UID)
    let owner_gid = volatile_read(entry_addr + FS_OFF_OWNER_GID)
    let mode = volatile_read(entry_addr + FS_OFF_MODE)
    let proc_gid = volatile_read(PROC_TABLE + volatile_read_u64(0x6FE00) * PROC_ENTRY_SIZE + PROC_OFF_GID)

    // Check owner permissions
    if uid == owner_uid {
        let owner_bits = (mode >> 6) & 7
        if (owner_bits & access) == access { return 0 }
        return -1
    }

    // Check group permissions
    if proc_gid == owner_gid {
        let group_bits = (mode >> 3) & 7
        if (group_bits & access) == access { return 0 }
        return -1
    }

    // Check other permissions
    let other_bits = mode & 7
    if (other_bits & access) == access { return 0 }
    -1
}

// M2.3: `chmod` command — "chmod <mode> <file>"
@kernel fn cmd_chmod() {
    let len = cmdbuf_len()
    if len <= 10 { cprintln("Usage: chmod <mode> <file>", YELLOW_ON_BLACK); return }
    // Parse octal mode (3 digits)
    let d0 = volatile_read_u8(0x6F800 + 6) - 48
    let d1 = volatile_read_u8(0x6F800 + 7) - 48
    let d2 = volatile_read_u8(0x6F800 + 8) - 48
    let mode = d0 * 64 + d1 * 8 + d2
    // Parse filename
    let fname: i64 = 0x843D00
    let mut fi: i64 = 0
    let mut pos: i64 = 10
    while pos < len && fi < 31 {
        volatile_write_u8(fname + fi, volatile_read_u8(0x6F800 + pos))
        fi = fi + 1; pos = pos + 1
    }
    volatile_write_u8(fname + fi, 0)
    let idx = ramfs_find_by_addr(fname)
    if idx < 0 { cprintln("File not found", RED_ON_BLACK); return }
    let entry = ramfs_entry_addr(idx)
    // Only owner or root can chmod
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    let owner = volatile_read(entry + FS_OFF_OWNER_UID)
    if uid != 0 && uid != owner { cprintln("Permission denied", RED_ON_BLACK); return }
    volatile_write(entry + FS_OFF_MODE, mode)
    cprint("Mode set to ", WHITE_ON_BLACK)
    cprint_decimal(d0, CYAN_ON_BLACK)
    cprint_decimal(d1, CYAN_ON_BLACK)
    cprint_decimal(d2, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// M2.4: `chown` command — "chown <uid> <file>"
@kernel fn cmd_chown() {
    let len = cmdbuf_len()
    if len <= 8 { cprintln("Usage: chown <uid> <file>", YELLOW_ON_BLACK); return }
    // Only root can chown
    if volatile_read_u64(CURRENT_UID_ADDR) != 0 { cprintln("Permission denied (root only)", RED_ON_BLACK); return }
    let new_uid = volatile_read_u8(0x6F800 + 6) - 48
    let fname: i64 = 0x843D00
    let mut fi: i64 = 0
    let mut pos: i64 = 8
    while pos < len && fi < 31 {
        volatile_write_u8(fname + fi, volatile_read_u8(0x6F800 + pos))
        fi = fi + 1; pos = pos + 1
    }
    volatile_write_u8(fname + fi, 0)
    let idx = ramfs_find_by_addr(fname)
    if idx < 0 { cprintln("File not found", RED_ON_BLACK); return }
    volatile_write(ramfs_entry_addr(idx) + FS_OFF_OWNER_UID, new_uid)
    cprint("Owner set to uid=", WHITE_ON_BLACK)
    cprint_decimal(new_uid, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// M2.8: `ls -l` long listing with permissions
@kernel fn cmd_ls_long() {
    let count = volatile_read(FS_BASE)
    let mut i: i64 = 0
    while i < count {
        let addr = ramfs_entry_addr(i)
        let ftype = volatile_read(addr + 48)
        if ftype != 0 {
            // Type indicator
            if ftype == 2 { cprint("d", CYAN_ON_BLACK) } else { cprint("-", WHITE_ON_BLACK) }
            // Permission bits
            let mode = volatile_read(addr + FS_OFF_MODE)
            if mode == 0 {
                // Legacy file (no permissions set) — show default
                cprint("rw-r--r--", WHITE_ON_BLACK)
            } else {
                fs_print_mode(mode)
            }
            cprint(" ", WHITE_ON_BLACK)
            // Owner UID
            cprint_decimal(volatile_read(addr + FS_OFF_OWNER_UID), CYAN_ON_BLACK)
            cprint(" ", WHITE_ON_BLACK)
            // Size
            let size = volatile_read(addr + 32)
            cprint_decimal(size, WHITE_ON_BLACK)
            cprint(" ", WHITE_ON_BLACK)
            // Name
            let mut j: i64 = 0
            while j < 32 {
                let ch = volatile_read_u8(addr + j)
                if ch == 0 { j = 32 } else { console_putchar(ch, GREEN_ON_BLACK); j = j + 1 }
            }
            console_putchar(10, WHITE_ON_BLACK)
        }
        i = i + 1
    }
}

// Print rwxrwxrwx from mode bits
@kernel fn fs_print_mode(mode: i64) {
    let owner = (mode >> 6) & 7
    let group = (mode >> 3) & 7
    let other = mode & 7
    fs_print_rwx(owner)
    fs_print_rwx(group)
    fs_print_rwx(other)
}

@kernel fn fs_print_rwx(bits: i64) {
    if (bits & 4) != 0 { cprint("r", WHITE_ON_BLACK) } else { cprint("-", WHITE_ON_BLACK) }
    if (bits & 2) != 0 { cprint("w", WHITE_ON_BLACK) } else { cprint("-", WHITE_ON_BLACK) }
    if (bits & 1) != 0 { cprint("x", WHITE_ON_BLACK) } else { cprint("-", WHITE_ON_BLACK) }
}

// ═══════════════════════════════════════════════
// User Sessions & Security (Sprint M3 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// Login history at 0x962000: 16 entries × 32 bytes
// Per entry: +0=uid(i64), +8=timestamp(i64), +16=action(i64: 1=login, 2=logout), +24=reserved
const LOGIN_HISTORY: i64 = 0x962000
const LOGIN_HIST_MAX: i64 = 16
const LOGIN_HIST_SIZE: i64 = 32
const LOGIN_HIST_IDX: i64 = 0x962200 // current write index

// Session timeout (ticks) — 0 = disabled
const SESSION_TIMEOUT: i64 = 0x652078
const SESSION_LAST_INPUT: i64 = 0x652080

// Setuid bit in mode (bit 11 = 0x800)
const PERM_SETUID: i64 = 0x800
const PERM_SETGID: i64 = 0x400

// M3.1: Login shell — spawn shell with user's UID
@kernel fn session_login(uid: i64) {
    volatile_write_u64(CURRENT_UID_ADDR, uid)
    let pid = volatile_read_u64(0x6FE00)
    volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_UID, uid)
    let entry = USER_TABLE + uid * USER_ENTRY_SIZE
    volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_GID, volatile_read_u64(entry + USER_OFF_GID))
    // Record login in history
    login_history_record(uid, 1)
    // Update last input time for session timeout
    volatile_write_u64(SESSION_LAST_INPUT, volatile_read_u64(0x6FE08))
}

// M3.2: `logout` command
@kernel fn cmd_logout() {
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    if uid == 0 { cprintln("Cannot logout root (use 'shutdown')", YELLOW_ON_BLACK); return }
    // Record logout
    login_history_record(uid, 2)
    // Switch back to root
    volatile_write_u64(CURRENT_UID_ADDR, 0)
    let pid = volatile_read_u64(0x6FE00)
    volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_UID, 0)
    volatile_write(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_GID, 0)
    cprintln("Logged out. Back to root.", WHITE_ON_BLACK)
}

// M3.3: Save user accounts to /etc/passwd in ramfs
@kernel fn cmd_save_passwd() {
    // Write user table to ramfs file "passwd"
    let data_buf: i64 = 0x846800
    let mut pos: i64 = 0
    let mut i: i64 = 0
    while i < USER_MAX {
        let entry = USER_TABLE + i * USER_ENTRY_SIZE
        if volatile_read_u64(entry + USER_OFF_ACTIVE) == 1 {
            // Format: uid:name:hash:gid:home
            // Write uid digit
            let uid = volatile_read_u64(entry + USER_OFF_UID)
            volatile_write_u8(data_buf + pos, 48 + (uid % 10))
            pos = pos + 1
            volatile_write_u8(data_buf + pos, 58) // ':'
            pos = pos + 1
            // Write name
            let mut j: i64 = 0
            while j < 16 {
                let ch = volatile_read_u8(entry + USER_OFF_NAME + j)
                if ch == 0 { j = 16 } else { volatile_write_u8(data_buf + pos, ch); pos = pos + 1; j = j + 1 }
            }
            volatile_write_u8(data_buf + pos, 58)
            pos = pos + 1
            // Write hash (as decimal, truncated)
            let hash = volatile_read_u64(entry + USER_OFF_PASS)
            let h_mod = hash % 10000
            volatile_write_u8(data_buf + pos, 48 + ((h_mod / 1000) % 10))
            volatile_write_u8(data_buf + pos + 1, 48 + ((h_mod / 100) % 10))
            volatile_write_u8(data_buf + pos + 2, 48 + ((h_mod / 10) % 10))
            volatile_write_u8(data_buf + pos + 3, 48 + (h_mod % 10))
            pos = pos + 4
            volatile_write_u8(data_buf + pos, 10) // newline
            pos = pos + 1
        }
        i = i + 1
    }
    volatile_write_u8(data_buf + pos, 0)
    // Write to ramfs
    ramfs_write_file_raw("passwd", data_buf, pos)
    cprint("Saved ", WHITE_ON_BLACK)
    cprint_decimal(pos, CYAN_ON_BLACK)
    cprintln(" bytes to /etc/passwd", GREEN_ON_BLACK)
}

// Helper: write raw bytes to ramfs (variant that takes addr instead of str)
@kernel fn ramfs_write_file_raw(name: str, data_addr: i64, dlen: i64) {
    let mut idx = ramfs_find(name)
    if idx == -1 { idx = ramfs_create_entry(name, 1) }
    if idx == -1 { return }
    let addr = ramfs_entry_addr(idx)
    let data_offset = volatile_read(FS_BASE + 8)
    let mut i: i64 = 0
    while i < dlen { volatile_write_u8(data_offset + i, volatile_read_u8(data_addr + i)); i = i + 1 }
    volatile_write(addr + 32, dlen)
    volatile_write(addr + 40, data_offset)
    volatile_write(addr + 48, 1)
    volatile_write(FS_BASE + 8, data_offset + dlen)
}

// M3.5: Check setuid bit on exec
@kernel fn fs_check_setuid(entry_addr: i64) -> i64 {
    let mode = volatile_read(entry_addr + FS_OFF_MODE)
    if (mode & PERM_SETUID) != 0 { return volatile_read(entry_addr + FS_OFF_OWNER_UID) }
    -1 // no setuid
}

// M3.6: `groups` command
@kernel fn cmd_groups() {
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    let entry = USER_TABLE + uid * USER_ENTRY_SIZE
    let gid = volatile_read_u64(entry + USER_OFF_GID)
    cprint("Groups: ", WHITE_ON_BLACK)
    cprint_decimal(gid, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// M3.7: Fork inherits UID/GID — update sys_fork to copy UID/GID
@kernel fn fork_copy_uid(parent_pid: i64, child_pid: i64) {
    let parent_base = PROC_TABLE + parent_pid * PROC_ENTRY_SIZE
    let child_base = PROC_TABLE + child_pid * PROC_ENTRY_SIZE
    volatile_write(child_base + PROC_OFF_UID, volatile_read(parent_base + PROC_OFF_UID))
    volatile_write(child_base + PROC_OFF_GID, volatile_read(parent_base + PROC_OFF_GID))
}

// M3.8: `last` command — show login history
@kernel fn cmd_last() {
    cprintln("Login history:", YELLOW_ON_BLACK)
    let idx = volatile_read_u64(LOGIN_HIST_IDX)
    let mut count: i64 = 0
    let mut i: i64 = 0
    while i < LOGIN_HIST_MAX {
        let slot = (idx - 1 - i + LOGIN_HIST_MAX) % LOGIN_HIST_MAX
        let entry = LOGIN_HISTORY + slot * LOGIN_HIST_SIZE
        let uid = volatile_read_u64(entry)
        let ts = volatile_read_u64(entry + 8)
        let action = volatile_read_u64(entry + 16)
        if action != 0 {
            cprint("  uid=", WHITE_ON_BLACK)
            cprint_decimal(uid, CYAN_ON_BLACK)
            cprint(" tick=", WHITE_ON_BLACK)
            cprint_decimal(ts, WHITE_ON_BLACK)
            if action == 1 { cprintln(" login", GREEN_ON_BLACK) }
            else { cprintln(" logout", YELLOW_ON_BLACK) }
            count = count + 1
        }
        i = i + 1
    }
    if count == 0 { cprintln("  (no login history)", WHITE_ON_BLACK) }
}

// Record login/logout event
@kernel fn login_history_record(uid: i64, action: i64) {
    let idx = volatile_read_u64(LOGIN_HIST_IDX)
    let entry = LOGIN_HISTORY + idx * LOGIN_HIST_SIZE
    volatile_write_u64(entry, uid)
    volatile_write_u64(entry + 8, volatile_read_u64(0x6FE08)) // tick count
    volatile_write_u64(entry + 16, action)
    volatile_write_u64(LOGIN_HIST_IDX, (idx + 1) % LOGIN_HIST_MAX)
}

// M3.9: Session timeout check (called at prompt)
@kernel fn session_check_timeout() {
    let timeout = volatile_read_u64(SESSION_TIMEOUT)
    if timeout == 0 { return } // disabled
    let uid = volatile_read_u64(CURRENT_UID_ADDR)
    if uid == 0 { return } // root never times out
    let last = volatile_read_u64(SESSION_LAST_INPUT)
    let now = volatile_read_u64(0x6FE08)
    if now - last > timeout {
        cprintln("Session timed out. Logging out.", YELLOW_ON_BLACK)
        cmd_logout()
    }
}

// Update last input time on keypress
@kernel fn session_touch() {
    volatile_write_u64(SESSION_LAST_INPUT, volatile_read_u64(0x6FE08))
}

// ═══════════════════════════════════════════════
// Directory Tree & Links (Sprint N1 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// Extended ramfs entry: +80=parent_idx(i64), +88=link_target_idx(i64), +96=link_type(i64: 0=none, 1=symlink, 2=hardlink)
const FS_OFF_PARENT: i64 = 80
const FS_OFF_LINK_TARGET: i64 = 88
const FS_OFF_LINK_TYPE: i64 = 96

const LINK_NONE: i64 = 0
const LINK_SYMLINK: i64 = 1
const LINK_HARDLINK: i64 = 2

// N1.1: Resolve hierarchical path like "/home/fajar/file.txt"
// Returns ramfs index of the final component, or -1 if not found
@kernel fn fs_resolve_path(path_addr: i64) -> i64 {
    let mut current_dir: i64 = 0 // start at root (index 0 = "/")
    let component_buf: i64 = 0x847000 // temp buffer for path component
    let mut pos: i64 = 0

    // Skip leading /
    if volatile_read_u8(path_addr) == 47 { pos = 1 }

    // Empty path after / → return root
    if volatile_read_u8(path_addr + pos) == 0 { return 0 }

    while volatile_read_u8(path_addr + pos) != 0 {
        // Extract next component (until / or end)
        let mut ci: i64 = 0
        while ci < 31 {
            let ch = volatile_read_u8(path_addr + pos)
            if ch == 47 || ch == 0 { ci = 31 } // '/' or null
            else { volatile_write_u8(component_buf + ci, ch); ci = ci + 1; pos = pos + 1 }
        }
        volatile_write_u8(component_buf + (if ci > 31 { 0 } else { ci }), 0)
        if volatile_read_u8(path_addr + pos) == 47 { pos = pos + 1 } // skip /

        // Find component in current directory
        let idx = fs_find_in_dir(current_dir, component_buf)
        if idx < 0 { return -1 } // not found

        // N1.8: Follow symlinks
        let entry = ramfs_entry_addr(idx)
        let link_type = volatile_read(entry + FS_OFF_LINK_TYPE)
        if link_type == LINK_SYMLINK {
            let target = volatile_read(entry + FS_OFF_LINK_TARGET)
            if target < 0 { return -1 }
            current_dir = target
        } else {
            current_dir = idx
        }
    }
    current_dir
}

// Find a named entry within a directory (by parent index)
@kernel fn fs_find_in_dir(parent_idx: i64, name_addr: i64) -> i64 {
    let count = volatile_read(FS_BASE)
    let mut i: i64 = 0
    while i < count {
        let addr = ramfs_entry_addr(i)
        let p = volatile_read(addr + FS_OFF_PARENT)
        if p == parent_idx || (parent_idx == 0 && p == 0) {
            // Compare name
            let mut match_ok: i64 = 1
            let mut j: i64 = 0
            let mut nlen: i64 = 0
            while nlen < 31 && volatile_read_u8(name_addr + nlen) != 0 { nlen = nlen + 1 }
            while j < nlen && match_ok == 1 {
                if volatile_read_u8(addr + j) != volatile_read_u8(name_addr + j) { match_ok = 0 }
                j = j + 1
            }
            if match_ok == 1 && volatile_read_u8(addr + nlen) == 0 { return i }
        }
        i = i + 1
    }
    -1
}

// N1.2: `mkdir -p` — create directory with parents
@kernel fn cmd_mkdir_p() {
    let len = cmdbuf_len()
    let prefix = if len > 8 && volatile_read_u8(0x6F800 + 6) == 45 { 9 } else { 6 } // "mkdir -p " or "mkdir "
    if len <= prefix { cprintln("Usage: mkdir [-p] <path>", YELLOW_ON_BLACK); return }
    let path_buf: i64 = 0x847100
    let mut fi: i64 = 0
    let mut pos: i64 = prefix
    while pos < len && fi < 63 {
        volatile_write_u8(path_buf + fi, volatile_read_u8(0x6F800 + pos))
        fi = fi + 1; pos = pos + 1
    }
    volatile_write_u8(path_buf + fi, 0)
    fs_mkdir_recursive(path_buf)
}

@kernel fn fs_mkdir_recursive(path_addr: i64) {
    let component_buf: i64 = 0x847200
    let mut pos: i64 = 0
    let mut parent: i64 = 0 // root

    if volatile_read_u8(path_addr) == 47 { pos = 1 }

    while volatile_read_u8(path_addr + pos) != 0 {
        let mut ci: i64 = 0
        while ci < 31 {
            let ch = volatile_read_u8(path_addr + pos)
            if ch == 47 || ch == 0 { ci = 31 }
            else { volatile_write_u8(component_buf + ci, ch); ci = ci + 1; pos = pos + 1 }
        }
        volatile_write_u8(component_buf + (if ci > 31 { 0 } else { ci }), 0)
        if volatile_read_u8(path_addr + pos) == 47 { pos = pos + 1 }

        let existing = fs_find_in_dir(parent, component_buf)
        if existing >= 0 {
            parent = existing
        } else {
            // Create directory
            let idx = ramfs_create_by_addr(component_buf)
            if idx >= 0 {
                let entry = ramfs_entry_addr(idx)
                volatile_write(entry + 48, 2) // type = dir
                volatile_write(entry + FS_OFF_PARENT, parent)
                fs_set_default_perms(entry, 2)
                parent = idx
            }
        }
    }
    cprintln("Directory created", GREEN_ON_BLACK)
}

// N1.4: `pwd` — show full path from root
@kernel fn cmd_pwd_full() {
    let pid = volatile_read_u64(0x6FE00)
    let cwd_addr = PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_CWD
    let mut i: i64 = 0
    let mut has_content: i64 = 0
    while i < 31 {
        let ch = volatile_read_u8(cwd_addr + i)
        if ch == 0 { i = 31 } else { console_putchar(ch, WHITE_ON_BLACK); has_content = 1; i = i + 1 }
    }
    if has_content == 0 { cprint("/", WHITE_ON_BLACK) }
    console_putchar(10, WHITE_ON_BLACK)
}

// N1.5: `ln -s <target> <link>` — create symbolic link
@kernel fn cmd_ln() {
    let len = cmdbuf_len()
    let is_symlink = len > 5 && volatile_read_u8(0x6F800 + 3) == 45 && volatile_read_u8(0x6F800 + 4) == 115 // "-s"
    let prefix = if is_symlink { 6 } else { 3 } // "ln -s " or "ln "
    if len <= prefix + 2 { cprintln("Usage: ln [-s] <target> <link>", YELLOW_ON_BLACK); return }

    let target_buf: i64 = 0x847300
    let link_buf: i64 = 0x847380
    let mut pos: i64 = prefix
    let mut ti: i64 = 0
    while pos < len && volatile_read_u8(0x6F800 + pos) != 32 && ti < 31 {
        volatile_write_u8(target_buf + ti, volatile_read_u8(0x6F800 + pos))
        ti = ti + 1; pos = pos + 1
    }
    volatile_write_u8(target_buf + ti, 0)
    pos = pos + 1 // skip space
    let mut li: i64 = 0
    while pos < len && li < 31 {
        volatile_write_u8(link_buf + li, volatile_read_u8(0x6F800 + pos))
        li = li + 1; pos = pos + 1
    }
    volatile_write_u8(link_buf + li, 0)

    // Find target
    let target_idx = ramfs_find_by_addr(target_buf)
    if target_idx < 0 && is_symlink == false { cprintln("Target not found", RED_ON_BLACK); return }

    // Create link entry
    let link_idx = ramfs_create_by_addr(link_buf)
    if link_idx < 0 { cprintln("Cannot create link", RED_ON_BLACK); return }
    let link_entry = ramfs_entry_addr(link_idx)

    if is_symlink {
        volatile_write(link_entry + FS_OFF_LINK_TYPE, LINK_SYMLINK)
        volatile_write(link_entry + FS_OFF_LINK_TARGET, target_idx)
        volatile_write(link_entry + 48, 1) // type = file (symlink behaves as file)
        cprint("Symlink: ", WHITE_ON_BLACK)
    } else {
        volatile_write(link_entry + FS_OFF_LINK_TYPE, LINK_HARDLINK)
        volatile_write(link_entry + FS_OFF_LINK_TARGET, target_idx)
        // Hard link shares data pointer + size
        let target_entry = ramfs_entry_addr(target_idx)
        volatile_write(link_entry + 32, volatile_read(target_entry + 32))
        volatile_write(link_entry + 40, volatile_read(target_entry + 40))
        volatile_write(link_entry + 48, volatile_read(target_entry + 48))
        cprint("Hardlink: ", WHITE_ON_BLACK)
    }

    let mut pi: i64 = 0
    while pi < li { console_putchar(volatile_read_u8(link_buf + pi), GREEN_ON_BLACK); pi = pi + 1 }
    cprint(" -> ", WHITE_ON_BLACK)
    pi = 0
    while pi < ti { console_putchar(volatile_read_u8(target_buf + pi), CYAN_ON_BLACK); pi = pi + 1 }
    console_putchar(10, WHITE_ON_BLACK)
}

// N1.7: `readlink` command
@kernel fn cmd_readlink() {
    let len = cmdbuf_len()
    if len <= 9 { cprintln("Usage: readlink <link>", YELLOW_ON_BLACK); return }
    let name_buf: i64 = 0x847400
    let mut ni: i64 = 0
    let mut pos: i64 = 9
    while pos < len && ni < 31 {
        volatile_write_u8(name_buf + ni, volatile_read_u8(0x6F800 + pos))
        ni = ni + 1; pos = pos + 1
    }
    volatile_write_u8(name_buf + ni, 0)
    let idx = ramfs_find_by_addr(name_buf)
    if idx < 0 { cprintln("Not found", RED_ON_BLACK); return }
    let entry = ramfs_entry_addr(idx)
    let lt = volatile_read(entry + FS_OFF_LINK_TYPE)
    if lt == LINK_NONE { cprintln("Not a link", WHITE_ON_BLACK); return }
    let target = volatile_read(entry + FS_OFF_LINK_TARGET)
    if target >= 0 {
        let te = ramfs_entry_addr(target)
        let mut i: i64 = 0
        while i < 32 {
            let ch = volatile_read_u8(te + i)
            if ch == 0 { i = 32 } else { console_putchar(ch, CYAN_ON_BLACK); i = i + 1 }
        }
    }
    console_putchar(10, WHITE_ON_BLACK)
}

// N1.9: `rmdir` command — remove empty directory
@kernel fn cmd_rmdir_v1() {
    let len = cmdbuf_len()
    if len <= 6 { cprintln("Usage: rmdir <dir>", YELLOW_ON_BLACK); return }
    let name_buf: i64 = 0x847400
    let mut ni: i64 = 0
    let mut pos: i64 = 6
    while pos < len && ni < 31 {
        volatile_write_u8(name_buf + ni, volatile_read_u8(0x6F800 + pos))
        ni = ni + 1; pos = pos + 1
    }
    volatile_write_u8(name_buf + ni, 0)
    let idx = ramfs_find_by_addr(name_buf)
    if idx < 0 { cprintln("Not found", RED_ON_BLACK); return }
    let entry = ramfs_entry_addr(idx)
    if volatile_read(entry + 48) != 2 { cprintln("Not a directory", RED_ON_BLACK); return }
    // Check empty (no children with this as parent)
    let count = volatile_read(FS_BASE)
    let mut i: i64 = 0
    let mut has_children: i64 = 0
    while i < count {
        if volatile_read(ramfs_entry_addr(i) + FS_OFF_PARENT) == idx && volatile_read(ramfs_entry_addr(i) + 48) != 0 {
            has_children = 1
        }
        i = i + 1
    }
    if has_children == 1 { cprintln("Directory not empty", RED_ON_BLACK); return }
    volatile_write_u8(entry, 0)
    volatile_write(entry + 48, 0)
    cprintln("Directory removed", GREEN_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Filesystem Journal & Crash Recovery (Sprint N2 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// Write-ahead log (WAL) at 0x970000: 64KB
// Journal header at 0x970000: +0=entry_count(i64), +8=committed(i64), +16=sequence(i64)
// Entries start at 0x970100, each 64 bytes
const JOURNAL_BASE: i64 = 0x970000
const JOURNAL_ENTRIES: i64 = 0x970100
const JOURNAL_ENTRY_SIZE: i64 = 64
const JOURNAL_MAX_ENTRIES: i64 = 1000  // 1000 × 64 = 64000 bytes (fits in 64KB)

// Journal entry: +0=type(i64), +8=inode(i64), +16=offset(i64), +24=len(i64), +32=data[32]
const JTYPE_NONE: i64 = 0
const JTYPE_CREATE: i64 = 1
const JTYPE_WRITE: i64 = 2
const JTYPE_DELETE: i64 = 3
const JTYPE_RENAME: i64 = 4
const JTYPE_CHMOD: i64 = 5

// Inode generation numbers at 0x97FC00 (256 bytes = 64 entries × 4B)
const INODE_GEN_TABLE: i64 = 0x97FC00

// Disk usage tracking
const FS_USED_BYTES: i64 = 0x97FE00
const FS_TOTAL_BYTES: i64 = 0x97FE08
const FS_DISK_FULL_THRESHOLD: i64 = 90 // refuse writes at 90% full

// N2.1: Initialize journal
@kernel fn journal_init() {
    volatile_write_u64(JOURNAL_BASE, 0)      // entry_count = 0
    volatile_write_u64(JOURNAL_BASE + 8, 1)  // committed = true
    volatile_write_u64(JOURNAL_BASE + 16, 0) // sequence = 0
    // Init disk usage: total = 832KB (ramfs data area)
    volatile_write_u64(FS_USED_BYTES, 0)
    volatile_write_u64(FS_TOTAL_BYTES, 832 * 1024)
}

// N2.2: Add journal entry
@kernel fn journal_add(jtype: i64, inode: i64, offset: i64, jlen: i64, data_addr: i64) -> i64 {
    let count = volatile_read_u64(JOURNAL_BASE)
    if count >= JOURNAL_MAX_ENTRIES { return -1 } // journal full
    let entry = JOURNAL_ENTRIES + count * JOURNAL_ENTRY_SIZE
    volatile_write_u64(entry, jtype)
    volatile_write_u64(entry + 8, inode)
    volatile_write_u64(entry + 16, offset)
    volatile_write_u64(entry + 24, jlen)
    // Copy data (max 32 bytes)
    let copy_len = if jlen < 32 { jlen } else { 32 }
    let mut i: i64 = 0
    while i < copy_len {
        volatile_write_u8(entry + 32 + i, volatile_read_u8(data_addr + i))
        i = i + 1
    }
    // Mark uncommitted
    volatile_write_u64(JOURNAL_BASE + 8, 0) // committed = false
    volatile_write_u64(JOURNAL_BASE, count + 1)
    let seq = volatile_read_u64(JOURNAL_BASE + 16)
    volatile_write_u64(JOURNAL_BASE + 16, seq + 1)
    count
}

// N2.3: Commit journal — flush entries to filesystem
@kernel fn journal_commit() {
    let count = volatile_read_u64(JOURNAL_BASE)
    if count == 0 { return }
    // Mark as committed
    volatile_write_u64(JOURNAL_BASE + 8, 1) // committed = true
    // Clear journal entries
    volatile_write_u64(JOURNAL_BASE, 0) // entry_count = 0
}

// N2.4: Replay journal on boot (if not committed)
@kernel fn journal_replay() -> i64 {
    let committed = volatile_read_u64(JOURNAL_BASE + 8)
    if committed == 1 { return 0 } // clean shutdown, nothing to replay
    let count = volatile_read_u64(JOURNAL_BASE)
    cprint("[JOURNAL] Replaying ", YELLOW_ON_BLACK)
    cprint_decimal(count, CYAN_ON_BLACK)
    cprintln(" uncommitted entries...", YELLOW_ON_BLACK)
    // Replay each entry
    let mut i: i64 = 0
    let mut replayed: i64 = 0
    while i < count {
        let entry = JOURNAL_ENTRIES + i * JOURNAL_ENTRY_SIZE
        let jtype = volatile_read_u64(entry)
        if jtype != JTYPE_NONE { replayed = replayed + 1 }
        // Replay logic would apply the operation to the filesystem
        // For now, just count and mark committed
        i = i + 1
    }
    journal_commit()
    cprint("[JOURNAL] Replayed ", GREEN_ON_BLACK)
    cprint_decimal(replayed, CYAN_ON_BLACK)
    cprintln(" entries", GREEN_ON_BLACK)
    replayed
}

// N2.5: `sync` command
@kernel fn cmd_sync_journal() {
    journal_commit()
    cprintln("Filesystem synced", GREEN_ON_BLACK)
}

// N2.6: `fsck` command — verify filesystem consistency
@kernel fn cmd_fsck() {
    cprintln("Filesystem check:", YELLOW_ON_BLACK)
    let count = volatile_read(FS_BASE)
    let mut errors: i64 = 0
    let mut files: i64 = 0
    let mut dirs: i64 = 0
    let mut links: i64 = 0
    let mut i: i64 = 0
    while i < count {
        let addr = ramfs_entry_addr(i)
        let ftype = volatile_read(addr + 48)
        if ftype == 1 { files = files + 1 }
        if ftype == 2 { dirs = dirs + 1 }
        let lt = volatile_read(addr + FS_OFF_LINK_TYPE)
        if lt == LINK_SYMLINK || lt == LINK_HARDLINK {
            links = links + 1
            // Verify link target exists
            let target = volatile_read(addr + FS_OFF_LINK_TARGET)
            if target >= count || target < 0 { errors = errors + 1 }
        }
        // Check size sanity
        let size = volatile_read(addr + 32)
        if size < 0 { errors = errors + 1 }
        i = i + 1
    }
    cprint("  Files: ", WHITE_ON_BLACK)
    cprint_decimal(files, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Dirs: ", WHITE_ON_BLACK)
    cprint_decimal(dirs, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Links: ", WHITE_ON_BLACK)
    cprint_decimal(links, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    // Journal status
    let jcount = volatile_read_u64(JOURNAL_BASE)
    let jcommit = volatile_read_u64(JOURNAL_BASE + 8)
    cprint("  Journal: ", WHITE_ON_BLACK)
    cprint_decimal(jcount, CYAN_ON_BLACK)
    cprint(" entries, ", WHITE_ON_BLACK)
    if jcommit == 1 { cprintln("committed", GREEN_ON_BLACK) }
    else { cprintln("UNCOMMITTED", RED_ON_BLACK); errors = errors + 1 }
    if errors == 0 { cprintln("  No errors found", GREEN_ON_BLACK) }
    else {
        cprint("  ", WHITE_ON_BLACK)
        cprint_decimal(errors, RED_ON_BLACK)
        cprintln(" errors found!", RED_ON_BLACK)
    }
}

// N2.7: Atomic rename via journal
@kernel fn cmd_rename() {
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: mv <old> <new>", YELLOW_ON_BLACK); return }
    let old_buf: i64 = 0x847500
    let new_buf: i64 = 0x847580
    let mut pos: i64 = 3
    let mut oi: i64 = 0
    while pos < len && volatile_read_u8(0x6F800 + pos) != 32 && oi < 31 {
        volatile_write_u8(old_buf + oi, volatile_read_u8(0x6F800 + pos))
        oi = oi + 1; pos = pos + 1
    }
    volatile_write_u8(old_buf + oi, 0)
    pos = pos + 1
    let mut ni: i64 = 0
    while pos < len && ni < 31 {
        volatile_write_u8(new_buf + ni, volatile_read_u8(0x6F800 + pos))
        ni = ni + 1; pos = pos + 1
    }
    volatile_write_u8(new_buf + ni, 0)
    let idx = ramfs_find_by_addr(old_buf)
    if idx < 0 { cprintln("File not found", RED_ON_BLACK); return }
    // Journal the rename
    journal_add(JTYPE_RENAME, idx, 0, ni, new_buf)
    // Apply rename
    let addr = ramfs_entry_addr(idx)
    let mut ri: i64 = 0
    while ri < ni { volatile_write_u8(addr + ri, volatile_read_u8(new_buf + ri)); ri = ri + 1 }
    volatile_write_u8(addr + ni, 0)
    journal_commit()
    cprintln("Renamed", GREEN_ON_BLACK)
}

// N2.8: Disk full handling
@kernel fn fs_check_disk_space(needed: i64) -> i64 {
    let used = volatile_read_u64(FS_USED_BYTES)
    let total = volatile_read_u64(FS_TOTAL_BYTES)
    if total == 0 { return 0 } // no tracking
    let usage_pct = (used * 100) / total
    if usage_pct >= FS_DISK_FULL_THRESHOLD && needed > 0 { return -1 } // disk full
    0
}

@kernel fn fs_update_usage(delta: i64) {
    let used = volatile_read_u64(FS_USED_BYTES)
    let new_used = used + delta
    if new_used >= 0 { volatile_write_u64(FS_USED_BYTES, new_used) }
}

// N2.9: Inode generation numbers
@kernel fn inode_get_gen(inode: i64) -> i64 {
    if inode < 0 || inode >= 64 { return 0 }
    let addr = INODE_GEN_TABLE + inode * 4
    volatile_read_u8(addr) + volatile_read_u8(addr + 1) * 256 + volatile_read_u8(addr + 2) * 65536 + volatile_read_u8(addr + 3) * 16777216
}

@kernel fn inode_inc_gen(inode: i64) {
    if inode >= 0 && inode < 64 {
        let generation = inode_get_gen(inode) + 1
        let addr = INODE_GEN_TABLE + inode * 4
        volatile_write_u8(addr, generation & 0xFF)
        volatile_write_u8(addr + 1, (generation >> 8) & 0xFF)
        volatile_write_u8(addr + 2, (generation >> 16) & 0xFF)
        volatile_write_u8(addr + 3, (generation >> 24) & 0xFF)
    }
}

// `df` command — show disk usage
@kernel fn cmd_df_journal() {
    cprintln("Filesystem usage:", YELLOW_ON_BLACK)
    let used = volatile_read_u64(FS_USED_BYTES)
    let total = volatile_read_u64(FS_TOTAL_BYTES)
    cprint("  Used: ", WHITE_ON_BLACK)
    cprint_decimal(used / 1024, CYAN_ON_BLACK)
    cprintln(" KB", WHITE_ON_BLACK)
    cprint("  Total: ", WHITE_ON_BLACK)
    cprint_decimal(total / 1024, CYAN_ON_BLACK)
    cprintln(" KB", WHITE_ON_BLACK)
    if total > 0 {
        cprint("  Usage: ", WHITE_ON_BLACK)
        cprint_decimal((used * 100) / total, CYAN_ON_BLACK)
        cprintln("%", WHITE_ON_BLACK)
    }
}

// ═══════════════════════════════════════════════
// Socket API (Sprint O1 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// Socket table at 0x980000: 16 sockets × 64 bytes
// Per socket: +0=state, +8=type, +16=local_port, +24=remote_ip, +32=remote_port,
//             +40=rx_buf_addr, +48=tx_buf_addr, +56=backlog
const SOCKET_TABLE: i64 = 0x980000
const SOCKET_MAX: i64 = 16
const SOCKET_ENTRY_SIZE: i64 = 64
const SOCK_OFF_STATE: i64 = 0
const SOCK_OFF_TYPE: i64 = 8
const SOCK_OFF_LOCAL_PORT: i64 = 16
const SOCK_OFF_REMOTE_IP: i64 = 24
const SOCK_OFF_REMOTE_PORT: i64 = 32
const SOCK_OFF_RX_BUF: i64 = 40
const SOCK_OFF_TX_BUF: i64 = 48
const SOCK_OFF_BACKLOG: i64 = 56

// Socket states
const SOCK_FREE: i64 = 0
const SOCK_CREATED: i64 = 1
const SOCK_BOUND: i64 = 2
const SOCK_LISTEN: i64 = 3
const SOCK_CONNECTING: i64 = 4
const SOCK_ESTABLISHED: i64 = 5
const SOCK_CLOSE_WAIT: i64 = 6
const SOCK_CLOSED: i64 = 7

// Socket types
const SOCK_STREAM: i64 = 1    // TCP
const SOCK_DGRAM: i64 = 2     // UDP

// FD type for sockets
const FD_SOCKET: i64 = 6

// Socket buffer area: 0x982000 (16 sockets × 2KB rx + 2KB tx = 64KB)
const SOCKET_BUF_BASE: i64 = 0x982000
const SOCKET_BUF_SIZE: i64 = 2048

// New syscall numbers for sockets
const SYS_SOCKET: i64 = 27
const SYS_BIND: i64 = 28
const SYS_LISTEN: i64 = 29
const SYS_ACCEPT: i64 = 30
const SYS_CONNECT_SOCK: i64 = 31

// O1.1: Initialize socket table
@kernel fn socket_init() {
    let mut i: i64 = 0
    while i < SOCKET_MAX * SOCKET_ENTRY_SIZE {
        volatile_write_u8(SOCKET_TABLE + i, 0)
        i = i + 1
    }
}

// O1.2: SYS_SOCKET(27) — create socket, return FD
@kernel fn sys_socket(sock_type: i64) -> i64 {
    // Find free socket slot
    let mut slot: i64 = -1
    let mut i: i64 = 0
    while i < SOCKET_MAX && slot == -1 {
        if volatile_read_u64(SOCKET_TABLE + i * SOCKET_ENTRY_SIZE + SOCK_OFF_STATE) == SOCK_FREE {
            slot = i
        }
        i = i + 1
    }
    if slot == -1 { return -1 }

    // Initialize socket
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_CREATED)
    volatile_write_u64(entry + SOCK_OFF_TYPE, sock_type)
    volatile_write_u64(entry + SOCK_OFF_LOCAL_PORT, 0)
    volatile_write_u64(entry + SOCK_OFF_REMOTE_IP, 0)
    volatile_write_u64(entry + SOCK_OFF_REMOTE_PORT, 0)
    // Assign buffers
    volatile_write_u64(entry + SOCK_OFF_RX_BUF, SOCKET_BUF_BASE + slot * SOCKET_BUF_SIZE * 2)
    volatile_write_u64(entry + SOCK_OFF_TX_BUF, SOCKET_BUF_BASE + slot * SOCKET_BUF_SIZE * 2 + SOCKET_BUF_SIZE)
    volatile_write_u64(entry + SOCK_OFF_BACKLOG, 0)

    // Allocate FD
    let pid = volatile_read_u64(0x6FE00)
    let fd = fd_v2_alloc(pid)
    if fd == -1 { volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_FREE); return -1 }
    fd_v2_set(pid, fd, FD_SOCKET, slot)
    fd
}

// O1.3: SYS_BIND(28) — bind socket to local port
@kernel fn sys_bind(fd: i64, port: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    if fd_v2_get_type(pid, fd) != FD_SOCKET { return -1 }
    let slot = fd_v2_get_data(pid, fd)
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    let state = volatile_read_u64(entry + SOCK_OFF_STATE)
    if state != SOCK_CREATED { return -1 }
    // Check port not already bound
    let mut i: i64 = 0
    while i < SOCKET_MAX {
        let e = SOCKET_TABLE + i * SOCKET_ENTRY_SIZE
        if volatile_read_u64(e + SOCK_OFF_STATE) != SOCK_FREE &&
           volatile_read_u64(e + SOCK_OFF_LOCAL_PORT) == port { return -2 } // port in use
        i = i + 1
    }
    volatile_write_u64(entry + SOCK_OFF_LOCAL_PORT, port)
    volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_BOUND)
    0
}

// O1.4: SYS_LISTEN(29) — mark socket as listening
@kernel fn sys_listen(fd: i64, backlog: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    if fd_v2_get_type(pid, fd) != FD_SOCKET { return -1 }
    let slot = fd_v2_get_data(pid, fd)
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    if volatile_read_u64(entry + SOCK_OFF_STATE) != SOCK_BOUND { return -1 }
    volatile_write_u64(entry + SOCK_OFF_BACKLOG, backlog)
    volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_LISTEN)
    0
}

// O1.5: SYS_ACCEPT(30) — accept incoming connection
@kernel fn sys_accept(fd: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    if fd_v2_get_type(pid, fd) != FD_SOCKET { return -1 }
    let slot = fd_v2_get_data(pid, fd)
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    if volatile_read_u64(entry + SOCK_OFF_STATE) != SOCK_LISTEN { return -1 }
    // Create new socket for the accepted connection
    let new_fd = sys_socket(SOCK_STREAM)
    if new_fd < 0 { return -1 }
    let new_slot = fd_v2_get_data(pid, new_fd)
    let new_entry = SOCKET_TABLE + new_slot * SOCKET_ENTRY_SIZE
    volatile_write_u64(new_entry + SOCK_OFF_STATE, SOCK_ESTABLISHED)
    volatile_write_u64(new_entry + SOCK_OFF_LOCAL_PORT, volatile_read_u64(entry + SOCK_OFF_LOCAL_PORT))
    // Remote IP/port would be filled by TCP stack on real connection
    new_fd
}

// O1.6: SYS_CONNECT(31) — connect to remote
@kernel fn sys_connect_sock(fd: i64, remote_ip: i64, remote_port: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    if fd_v2_get_type(pid, fd) != FD_SOCKET { return -1 }
    let slot = fd_v2_get_data(pid, fd)
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    let state = volatile_read_u64(entry + SOCK_OFF_STATE)
    if state != SOCK_CREATED && state != SOCK_BOUND { return -1 }
    volatile_write_u64(entry + SOCK_OFF_REMOTE_IP, remote_ip)
    volatile_write_u64(entry + SOCK_OFF_REMOTE_PORT, remote_port)
    volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_ESTABLISHED)
    // Assign ephemeral port if not bound
    if volatile_read_u64(entry + SOCK_OFF_LOCAL_PORT) == 0 {
        volatile_write_u64(entry + SOCK_OFF_LOCAL_PORT, 49152 + slot)
    }
    0
}

// O1.7: Socket read/write via FD (add to sys_read/sys_write)
@kernel fn socket_read(slot: i64, buf: i64, len: i64) -> i64 {
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    if volatile_read_u64(entry + SOCK_OFF_STATE) != SOCK_ESTABLISHED { return -1 }
    // Read from RX buffer (simple: first N bytes, or 0 if empty)
    let rx_buf = volatile_read_u64(entry + SOCK_OFF_RX_BUF)
    let rx_len = volatile_read_u64(rx_buf) // first 8 bytes = data length
    if rx_len == 0 { return 0 }
    let to_read = if len < rx_len { len } else { rx_len }
    let mut i: i64 = 0
    while i < to_read {
        volatile_write_u8(buf + i, volatile_read_u8(rx_buf + 8 + i))
        i = i + 1
    }
    // Shift remaining data
    let remaining = rx_len - to_read
    i = 0
    while i < remaining {
        volatile_write_u8(rx_buf + 8 + i, volatile_read_u8(rx_buf + 8 + to_read + i))
        i = i + 1
    }
    volatile_write_u64(rx_buf, remaining)
    to_read
}

@kernel fn socket_write(slot: i64, buf: i64, len: i64) -> i64 {
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    if volatile_read_u64(entry + SOCK_OFF_STATE) != SOCK_ESTABLISHED { return -1 }
    let tx_buf = volatile_read_u64(entry + SOCK_OFF_TX_BUF)
    let tx_len = volatile_read_u64(tx_buf)
    let avail = SOCKET_BUF_SIZE - 8 - tx_len
    if avail <= 0 { return 0 }
    let to_write = if len < avail { len } else { avail }
    let mut i: i64 = 0
    while i < to_write {
        volatile_write_u8(tx_buf + 8 + tx_len + i, volatile_read_u8(buf + i))
        i = i + 1
    }
    volatile_write_u64(tx_buf, tx_len + to_write)
    to_write
}

// O1.8: `netstat` command
@kernel fn cmd_netstat() {
    cprintln("Active sockets:", YELLOW_ON_BLACK)
    let mut i: i64 = 0
    let mut count: i64 = 0
    while i < SOCKET_MAX {
        let entry = SOCKET_TABLE + i * SOCKET_ENTRY_SIZE
        let state = volatile_read_u64(entry + SOCK_OFF_STATE)
        if state != SOCK_FREE {
            cprint("  [", WHITE_ON_BLACK)
            cprint_decimal(i, CYAN_ON_BLACK)
            cprint("] ", WHITE_ON_BLACK)
            // Type
            let stype = volatile_read_u64(entry + SOCK_OFF_TYPE)
            if stype == SOCK_STREAM { cprint("TCP ", WHITE_ON_BLACK) }
            else { cprint("UDP ", WHITE_ON_BLACK) }
            // Local port
            cprint(":", WHITE_ON_BLACK)
            cprint_decimal(volatile_read_u64(entry + SOCK_OFF_LOCAL_PORT), CYAN_ON_BLACK)
            cprint(" → ", WHITE_ON_BLACK)
            // Remote
            let rip = volatile_read_u64(entry + SOCK_OFF_REMOTE_IP)
            if rip != 0 {
                cprint_decimal((rip >> 24) & 0xFF, WHITE_ON_BLACK)
                cprint(".", WHITE_ON_BLACK)
                cprint_decimal((rip >> 16) & 0xFF, WHITE_ON_BLACK)
                cprint(".", WHITE_ON_BLACK)
                cprint_decimal((rip >> 8) & 0xFF, WHITE_ON_BLACK)
                cprint(".", WHITE_ON_BLACK)
                cprint_decimal(rip & 0xFF, WHITE_ON_BLACK)
            } else { cprint("*", WHITE_ON_BLACK) }
            cprint(":", WHITE_ON_BLACK)
            cprint_decimal(volatile_read_u64(entry + SOCK_OFF_REMOTE_PORT), WHITE_ON_BLACK)
            cprint(" ", WHITE_ON_BLACK)
            // State name
            if state == SOCK_CREATED { cprint("CREATED", WHITE_ON_BLACK) }
            else if state == SOCK_BOUND { cprint("BOUND", YELLOW_ON_BLACK) }
            else if state == SOCK_LISTEN { cprint("LISTEN", GREEN_ON_BLACK) }
            else if state == SOCK_CONNECTING { cprint("CONNECTING", YELLOW_ON_BLACK) }
            else if state == SOCK_ESTABLISHED { cprint("ESTABLISHED", GREEN_ON_BLACK) }
            else if state == SOCK_CLOSE_WAIT { cprint("CLOSE_WAIT", YELLOW_ON_BLACK) }
            else if state == SOCK_CLOSED { cprint("CLOSED", RED_ON_BLACK) }
            console_putchar(10, WHITE_ON_BLACK)
            count = count + 1
        }
        i = i + 1
    }
    if count == 0 { cprintln("  (no active sockets)", WHITE_ON_BLACK) }
}

// O1.9: TCP RST — reset connection
@kernel fn socket_reset(slot: i64) {
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_CLOSED)
    // Clear buffers
    let rx_buf = volatile_read_u64(entry + SOCK_OFF_RX_BUF)
    let tx_buf = volatile_read_u64(entry + SOCK_OFF_TX_BUF)
    if rx_buf != 0 { volatile_write_u64(rx_buf, 0) }
    if tx_buf != 0 { volatile_write_u64(tx_buf, 0) }
}

@kernel fn socket_close(slot: i64) {
    let entry = SOCKET_TABLE + slot * SOCKET_ENTRY_SIZE
    volatile_write_u64(entry + SOCK_OFF_STATE, SOCK_FREE)
    volatile_write_u64(entry + SOCK_OFF_LOCAL_PORT, 0)
    volatile_write_u64(entry + SOCK_OFF_REMOTE_IP, 0)
    volatile_write_u64(entry + SOCK_OFF_REMOTE_PORT, 0)
}

// ═══════════════════════════════════════════════
// HTTP Server (Sprint O2 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// HTTP request buffer at 0x990000 (4KB)
const HTTP_REQ_BUF: i64 = 0x990000
// HTTP response buffer at 0x991000 (8KB)
const HTTP_RESP_BUF: i64 = 0x991000
const HTTP_RESP_MAX: i64 = 8192
// HTTP server state at 0x993000
const HTTP_SERVER_PORT: i64 = 0x993000
const HTTP_SERVER_ACTIVE: i64 = 0x993008
const HTTP_REQ_COUNT: i64 = 0x993010

// O2.1: `httpd` command — start HTTP server on port 80
@kernel fn cmd_httpd() {
    let len = cmdbuf_len()
    let port: i64 = if len > 6 { volatile_read_u8(0x6F800 + 6) - 48 } else { 80 }
    let actual_port = if port > 0 && port < 10 { port * 1000 } else { 80 }

    volatile_write_u64(HTTP_SERVER_PORT, actual_port)
    volatile_write_u64(HTTP_SERVER_ACTIVE, 1)
    volatile_write_u64(HTTP_REQ_COUNT, 0)
    cprint("HTTP server started on port ", WHITE_ON_BLACK)
    cprint_decimal(actual_port, GREEN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprintln("  Serving files from ramfs", WHITE_ON_BLACK)
    cprintln("  Endpoints: /proc/version, /proc/uptime, static files", WHITE_ON_BLACK)
}

// O2.2: Parse HTTP request — extract method + path
// Returns path length in low 16 bits, method in high 16 bits (1=GET, 2=POST)
@kernel fn http_parse_request(buf: i64, len: i64) -> i64 {
    // Expect: "GET /path HTTP/1.1\r\n..."
    let method: i64 = if volatile_read_u8(buf) == 71 && volatile_read_u8(buf + 1) == 69 && volatile_read_u8(buf + 2) == 84 { 1 } // GET
    else if volatile_read_u8(buf) == 80 && volatile_read_u8(buf + 1) == 79 { 2 } // POST
    else { 0 }

    if method == 0 { return -1 }

    // Find path start (after "GET " or "POST ")
    let path_start = if method == 1 { 4 } else { 5 }
    // Extract path to HTTP_REQ_BUF + 256
    let path_buf = HTTP_REQ_BUF + 256
    let mut pi: i64 = 0
    let mut pos = path_start
    while pos < len && pi < 127 {
        let ch = volatile_read_u8(buf + pos)
        if ch == 32 || ch == 13 || ch == 10 { pos = len } // space or CR/LF
        else { volatile_write_u8(path_buf + pi, ch); pi = pi + 1; pos = pos + 1 }
    }
    volatile_write_u8(path_buf + pi, 0)
    (method << 16) | pi
}

// O2.3: Serve static file from ramfs
@kernel fn http_serve_file(path_buf: i64, resp_buf: i64) -> i64 {
    // Skip leading /
    let file_path = if volatile_read_u8(path_buf) == 47 { path_buf + 1 } else { path_buf }
    // Check for empty path → serve index
    if volatile_read_u8(file_path) == 0 {
        return http_write_response(resp_buf, 200, "text/html", "Welcome to FajarOS Nova HTTP Server!", 36)
    }
    let idx = ramfs_find_by_addr(file_path)
    if idx < 0 { return http_write_404(resp_buf) }
    let entry = ramfs_entry_addr(idx)
    let ftype = volatile_read(entry + 48)
    // O2.6: Directory listing
    if ftype == 2 { return http_write_dirlist(resp_buf, idx) }
    let size = volatile_read(entry + 32)
    let data_ptr = volatile_read(entry + 40)
    if data_ptr == 0 || size == 0 { return http_write_404(resp_buf) }
    http_write_response_data(resp_buf, 200, "text/plain", data_ptr, size)
}

// O2.4: Write HTTP response headers + body
@kernel fn http_write_response(buf: i64, status: i64, content_type: str, body: str, body_len: i64) -> i64 {
    let mut pos: i64 = 0
    // Status line
    pos = http_write_str(buf, pos, "HTTP/1.1 ")
    pos = http_write_decimal(buf, pos, status)
    pos = http_write_str(buf, pos, " OK\r\nContent-Type: ")
    pos = http_write_str(buf, pos, content_type)
    pos = http_write_str(buf, pos, "\r\nContent-Length: ")
    pos = http_write_decimal(buf, pos, body_len)
    pos = http_write_str(buf, pos, "\r\nConnection: close\r\n\r\n")
    pos = http_write_str(buf, pos, body)
    pos
}

@kernel fn http_write_response_data(buf: i64, status: i64, content_type: str, data: i64, data_len: i64) -> i64 {
    let mut pos: i64 = 0
    pos = http_write_str(buf, pos, "HTTP/1.1 ")
    pos = http_write_decimal(buf, pos, status)
    pos = http_write_str(buf, pos, " OK\r\nContent-Type: ")
    pos = http_write_str(buf, pos, content_type)
    pos = http_write_str(buf, pos, "\r\nContent-Length: ")
    pos = http_write_decimal(buf, pos, data_len)
    pos = http_write_str(buf, pos, "\r\nConnection: close\r\n\r\n")
    // Copy body data
    let mut i: i64 = 0
    while i < data_len && pos < HTTP_RESP_MAX {
        volatile_write_u8(buf + pos, volatile_read_u8(data + i))
        pos = pos + 1; i = i + 1
    }
    pos
}

// O2.5: 404 Not Found
@kernel fn http_write_404(buf: i64) -> i64 {
    let body = "404 Not Found"
    http_write_response(buf, 404, "text/plain", body, 13)
}

// O2.6: Directory listing as HTML
@kernel fn http_write_dirlist(buf: i64, dir_idx: i64) -> i64 {
    let mut pos: i64 = 0
    pos = http_write_str(buf, pos, "HTTP/1.1 200 OK\r\nContent-Type: text/html\r\nConnection: close\r\n\r\n")
    pos = http_write_str(buf, pos, "<html><body><h1>Directory Listing</h1><ul>")
    let count = volatile_read(FS_BASE)
    let mut i: i64 = 0
    while i < count {
        let entry = ramfs_entry_addr(i)
        let parent = volatile_read(entry + FS_OFF_PARENT)
        let ftype = volatile_read(entry + 48)
        if (parent == dir_idx || (dir_idx == 0 && parent == 0)) && ftype != 0 {
            pos = http_write_str(buf, pos, "<li>")
            let mut j: i64 = 0
            while j < 32 && pos < HTTP_RESP_MAX {
                let ch = volatile_read_u8(entry + j)
                if ch == 0 { j = 32 } else { volatile_write_u8(buf + pos, ch); pos = pos + 1; j = j + 1 }
            }
            pos = http_write_str(buf, pos, "</li>")
        }
        i = i + 1
    }
    pos = http_write_str(buf, pos, "</ul></body></html>")
    pos
}

// O2.7: /proc endpoint
@kernel fn http_serve_proc(path_buf: i64, resp_buf: i64) -> i64 {
    // /proc/version
    if volatile_read_u8(path_buf + 6) == 118 { // 'v'
        return http_write_response(resp_buf, 200, "application/json", "{\"kernel\":\"FajarOS Nova v1.3.0 Bastion\",\"arch\":\"x86_64\"}", 55)
    }
    // /proc/uptime
    if volatile_read_u8(path_buf + 6) == 117 { // 'u'
        let ticks = volatile_read_u64(0x6FE08)
        let secs = ticks / 100
        let mut body_buf: i64 = 0x993100
        let mut bpos: i64 = 0
        bpos = http_write_str(body_buf, bpos, "{\"uptime_seconds\":")
        bpos = http_write_decimal(body_buf, bpos, secs)
        bpos = http_write_str(body_buf, bpos, "}")
        volatile_write_u8(body_buf + bpos, 0)
        return http_write_response_data(resp_buf, 200, "application/json", body_buf, bpos)
    }
    http_write_404(resp_buf)
}

// O2.8: Log HTTP request to serial
@kernel fn http_log_request(method: i64, path_buf: i64, status: i64) {
    cprint("[HTTP] ", WHITE_ON_BLACK)
    if method == 1 { cprint("GET ", GREEN_ON_BLACK) }
    else { cprint("POST ", YELLOW_ON_BLACK) }
    let mut i: i64 = 0
    while i < 64 {
        let ch = volatile_read_u8(path_buf + i)
        if ch == 0 { i = 64 } else { console_putchar(ch, CYAN_ON_BLACK); i = i + 1 }
    }
    cprint(" → ", WHITE_ON_BLACK)
    cprint_decimal(status, if status == 200 { GREEN_ON_BLACK } else { RED_ON_BLACK })
    console_putchar(10, WHITE_ON_BLACK)
    let count = volatile_read_u64(HTTP_REQ_COUNT) + 1
    volatile_write_u64(HTTP_REQ_COUNT, count)
}

// O2.9: Handle single HTTP request
@kernel fn http_handle_request(req_buf: i64, req_len: i64) -> i64 {
    let parsed = http_parse_request(req_buf, req_len)
    if parsed < 0 { return http_write_response(HTTP_RESP_BUF, 400, "text/plain", "Bad Request", 11) }
    let method = (parsed >> 16) & 0xFFFF
    let path_buf = HTTP_REQ_BUF + 256

    let mut status: i64 = 200
    let resp_len: i64 = if volatile_read_u8(path_buf + 1) == 112 && volatile_read_u8(path_buf + 2) == 114 {
        // /proc/* endpoint
        http_serve_proc(path_buf, HTTP_RESP_BUF)
    } else {
        http_serve_file(path_buf, HTTP_RESP_BUF)
    }

    // Detect 404 from response
    if volatile_read_u8(HTTP_RESP_BUF + 9) == 52 { status = 404 } // '4' in "HTTP/1.1 4xx"
    http_log_request(method, path_buf, status)
    resp_len
}

// Helper: write string to buffer at offset, return new offset
@kernel fn http_write_str(buf: i64, offset: i64, s: str) -> i64 {
    let slen = str_len(s)
    let mut i: i64 = 0
    while i < slen && offset + i < HTTP_RESP_MAX {
        volatile_write_u8(buf + offset + i, str_byte_at(s, i))
        i = i + 1
    }
    offset + i
}

// Helper: write decimal number to buffer
@kernel fn http_write_decimal(buf: i64, offset: i64, num: i64) -> i64 {
    if num == 0 { volatile_write_u8(buf + offset, 48); return offset + 1 }
    let tmp_buf: i64 = 0x993080
    let mut n = num
    let mut digits: i64 = 0
    while n > 0 {
        volatile_write_u8(tmp_buf + digits, 48 + (n % 10))
        digits = digits + 1
        n = n / 10
    }
    // Reverse
    let mut i: i64 = 0
    while i < digits {
        volatile_write_u8(buf + offset + i, volatile_read_u8(tmp_buf + digits - 1 - i))
        i = i + 1
    }
    offset + digits
}

// ═══════════════════════════════════════════════
// GDB Remote Stub (Sprint P1 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// GDB uses COM2 (0x2F8) for remote debugging protocol
const GDB_COM2: i64 = 0x2F8
const GDB_COM2_LSR: i64 = 0x2FD

// GDB RSP packet buffer at 0x994000 (4KB)
const GDB_PKT_BUF: i64 = 0x994000
const GDB_RESP_BUF: i64 = 0x995000
const GDB_MAX_PKT: i64 = 2048

// GDB state at 0x996000
const GDB_STATE: i64 = 0x996000    // +0=active, +8=stepping, +16=bp_count
const GDB_BP_TABLE: i64 = 0x996100 // 16 breakpoints × 16B: +0=addr, +8=saved_byte

const GDB_BP_MAX: i64 = 16

// P1.1: GDB RSP packet parser
// RSP format: $<data>#<checksum>
// Returns packet data length, or -1 on error
@kernel fn gdb_parse_packet(buf: i64, raw_len: i64) -> i64 {
    // Find '$'
    let mut start: i64 = -1
    let mut i: i64 = 0
    while i < raw_len && start == -1 {
        if volatile_read_u8(buf + i) == 36 { start = i + 1 } // '$'
        i = i + 1
    }
    if start == -1 { return -1 }
    // Find '#'
    let mut end: i64 = -1
    i = start
    while i < raw_len && end == -1 {
        if volatile_read_u8(buf + i) == 35 { end = i } // '#'
        i = i + 1
    }
    if end == -1 { return -1 }
    // Verify checksum
    let mut sum: i64 = 0
    i = start
    while i < end { sum = (sum + volatile_read_u8(buf + i)) & 0xFF; i = i + 1 }
    // Read 2-digit hex checksum after '#'
    let h1 = gdb_hex_digit(volatile_read_u8(buf + end + 1))
    let h2 = gdb_hex_digit(volatile_read_u8(buf + end + 2))
    let expected = h1 * 16 + h2
    if sum != expected { return -2 } // checksum mismatch
    // Copy data to GDB_PKT_BUF (without $ and #xx)
    let data_len = end - start
    i = 0
    while i < data_len { volatile_write_u8(GDB_PKT_BUF + i, volatile_read_u8(buf + start + i)); i = i + 1 }
    volatile_write_u8(GDB_PKT_BUF + data_len, 0)
    data_len
}

@kernel fn gdb_hex_digit(ch: i64) -> i64 {
    if ch >= 48 && ch <= 57 { ch - 48 }        // '0'-'9'
    else if ch >= 97 && ch <= 102 { ch - 87 }   // 'a'-'f'
    else if ch >= 65 && ch <= 70 { ch - 55 }    // 'A'-'F'
    else { 0 }
}

// P1.2: Send GDB RSP response
@kernel fn gdb_send_packet(data: i64, len: i64) {
    // Send '+' (ACK)
    gdb_serial_write(43)
    // Send $data#checksum
    gdb_serial_write(36) // '$'
    let mut sum: i64 = 0
    let mut i: i64 = 0
    while i < len {
        let ch = volatile_read_u8(data + i)
        gdb_serial_write(ch)
        sum = (sum + ch) & 0xFF
        i = i + 1
    }
    gdb_serial_write(35) // '#'
    gdb_serial_write(gdb_hex_char((sum >> 4) & 0xF))
    gdb_serial_write(gdb_hex_char(sum & 0xF))
}

@kernel fn gdb_hex_char(val: i64) -> i64 {
    if val < 10 { 48 + val } else { 87 + val } // '0'-'9' or 'a'-'f'
}

@kernel fn gdb_serial_write(ch: i64) {
    // Wait TX ready on COM2
    while (volatile_read_u8(GDB_COM2_LSR) & 0x20) == 0 { }
    volatile_write_u8(GDB_COM2, ch)
}

// P1.2: '?' — halt reason (SIGTRAP = S05)
@kernel fn gdb_handle_halt_reason() {
    let resp = GDB_RESP_BUF
    volatile_write_u8(resp, 83) // 'S'
    volatile_write_u8(resp + 1, 48) // '0'
    volatile_write_u8(resp + 2, 53) // '5'
    gdb_send_packet(resp, 3)
}

// P1.3: 'g' — read all registers (16 GPRs + RIP + RFLAGS as hex)
@kernel fn gdb_handle_read_regs() {
    let resp = GDB_RESP_BUF
    let mut pos: i64 = 0
    // Read 16 registers from current process context frame
    let pid = volatile_read_u64(0x6FE00)
    let rsp = volatile_read(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_RSP)
    // 16 registers × 16 hex chars (8 bytes LE) = 256 chars
    let mut reg: i64 = 0
    while reg < 16 {
        let val = volatile_read_u64(rsp + reg * 8)
        pos = gdb_write_hex64(resp, pos, val)
        reg = reg + 1
    }
    gdb_send_packet(resp, pos)
}

// P1.5: 'm' — read memory (mADDR,LENGTH)
@kernel fn gdb_handle_read_mem(pkt: i64, len: i64) {
    // Parse addr,length from packet (after 'm')
    let mut addr: i64 = 0
    let mut mlen: i64 = 0
    let mut pos: i64 = 1 // skip 'm'
    // Parse hex address
    while pos < len && volatile_read_u8(pkt + pos) != 44 { // ','
        addr = addr * 16 + gdb_hex_digit(volatile_read_u8(pkt + pos))
        pos = pos + 1
    }
    pos = pos + 1 // skip ','
    // Parse hex length
    while pos < len {
        mlen = mlen * 16 + gdb_hex_digit(volatile_read_u8(pkt + pos))
        pos = pos + 1
    }
    // Read memory and send as hex
    let resp = GDB_RESP_BUF
    let mut rpos: i64 = 0
    let mut i: i64 = 0
    while i < mlen && rpos < GDB_MAX_PKT - 2 {
        let byte = volatile_read_u8(addr + i)
        volatile_write_u8(resp + rpos, gdb_hex_char((byte >> 4) & 0xF))
        volatile_write_u8(resp + rpos + 1, gdb_hex_char(byte & 0xF))
        rpos = rpos + 2
        i = i + 1
    }
    gdb_send_packet(resp, rpos)
}

// P1.7: 's' — single step (set TF in RFLAGS)
@kernel fn gdb_handle_step() {
    volatile_write_u64(GDB_STATE + 8, 1) // stepping = true
    let resp = GDB_RESP_BUF
    volatile_write_u8(resp, 83) // 'S'
    volatile_write_u8(resp + 1, 48) // '0'
    volatile_write_u8(resp + 2, 53) // '5'
    gdb_send_packet(resp, 3)
}

// P1.8: 'c' — continue
@kernel fn gdb_handle_continue() {
    volatile_write_u64(GDB_STATE + 8, 0) // stepping = false
    // Resume execution — GDB will get notified on next break/trap
}

// P1.9: 'Z0' — insert breakpoint (addr, kind)
@kernel fn gdb_insert_breakpoint(pkt: i64, len: i64) {
    // Parse: Z0,ADDR,KIND
    let mut addr: i64 = 0
    let mut pos: i64 = 3 // skip 'Z0,'
    while pos < len && volatile_read_u8(pkt + pos) != 44 {
        addr = addr * 16 + gdb_hex_digit(volatile_read_u8(pkt + pos))
        pos = pos + 1
    }
    // Find free breakpoint slot
    let bp_count = volatile_read_u64(GDB_STATE + 16)
    if bp_count >= GDB_BP_MAX { gdb_send_packet(GDB_RESP_BUF, 0); return }
    let bp = GDB_BP_TABLE + bp_count * 16
    volatile_write_u64(bp, addr)
    // Save original byte and replace with INT3 (0xCC)
    volatile_write_u64(bp + 8, volatile_read_u8(addr))
    volatile_write_u8(addr, 0xCC)
    volatile_write_u64(GDB_STATE + 16, bp_count + 1)
    // Send OK
    let resp = GDB_RESP_BUF
    volatile_write_u8(resp, 79) // 'O'
    volatile_write_u8(resp + 1, 75) // 'K'
    gdb_send_packet(resp, 2)
}

// 'z0' — remove breakpoint
@kernel fn gdb_remove_breakpoint(pkt: i64, len: i64) {
    let mut addr: i64 = 0
    let mut pos: i64 = 3
    while pos < len && volatile_read_u8(pkt + pos) != 44 {
        addr = addr * 16 + gdb_hex_digit(volatile_read_u8(pkt + pos))
        pos = pos + 1
    }
    // Find and remove breakpoint
    let bp_count = volatile_read_u64(GDB_STATE + 16)
    let mut i: i64 = 0
    while i < bp_count {
        let bp = GDB_BP_TABLE + i * 16
        if volatile_read_u64(bp) == addr {
            // Restore original byte
            volatile_write_u8(addr, volatile_read_u64(bp + 8))
            // Shift remaining breakpoints
            let mut j = i
            while j < bp_count - 1 {
                let src = GDB_BP_TABLE + (j + 1) * 16
                let dst = GDB_BP_TABLE + j * 16
                volatile_write_u64(dst, volatile_read_u64(src))
                volatile_write_u64(dst + 8, volatile_read_u64(src + 8))
                j = j + 1
            }
            volatile_write_u64(GDB_STATE + 16, bp_count - 1)
            let resp = GDB_RESP_BUF
            volatile_write_u8(resp, 79)
            volatile_write_u8(resp + 1, 75)
            gdb_send_packet(resp, 2)
            return
        }
        i = i + 1
    }
    gdb_send_packet(GDB_RESP_BUF, 0) // empty response = unsupported
}

// P1.10: Main GDB command dispatcher
@kernel fn gdb_dispatch(pkt: i64, len: i64) {
    let cmd = volatile_read_u8(pkt)
    if cmd == 63 { gdb_handle_halt_reason() }         // '?'
    else if cmd == 103 { gdb_handle_read_regs() }      // 'g'
    else if cmd == 109 { gdb_handle_read_mem(pkt, len) } // 'm'
    else if cmd == 115 { gdb_handle_step() }            // 's'
    else if cmd == 99 { gdb_handle_continue() }         // 'c'
    else if cmd == 90 { gdb_insert_breakpoint(pkt, len) } // 'Z'
    else if cmd == 122 { gdb_remove_breakpoint(pkt, len) } // 'z'
    else { gdb_send_packet(GDB_RESP_BUF, 0) }          // empty = unsupported
}

// Write 64-bit value as 16 hex chars (little-endian byte order for GDB)
@kernel fn gdb_write_hex64(buf: i64, offset: i64, val: i64) -> i64 {
    let mut pos = offset
    let mut i: i64 = 0
    while i < 8 {
        let byte = (val >> (i * 8)) & 0xFF
        volatile_write_u8(buf + pos, gdb_hex_char((byte >> 4) & 0xF))
        volatile_write_u8(buf + pos + 1, gdb_hex_char(byte & 0xF))
        pos = pos + 2
        i = i + 1
    }
    pos
}

// `gdb` shell command — enter debug mode
@kernel fn cmd_gdb() {
    volatile_write_u64(GDB_STATE, 1) // active
    volatile_write_u64(GDB_STATE + 8, 0) // not stepping
    volatile_write_u64(GDB_STATE + 16, 0) // 0 breakpoints
    cprintln("GDB remote stub active on COM2 (0x2F8)", GREEN_ON_BLACK)
    cprintln("  Connect: target remote :1234", WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// GDB Integration (Sprint P2 — v0.8 "Bastion")
// ═══════════════════════════════════════════════

// P2.1: QEMU GDB connection info
@kernel fn cmd_gdb_info() {
    cprintln("GDB Debug Info:", YELLOW_ON_BLACK)
    cprintln("  QEMU: qemu-system-x86_64 -s -S (port 1234)", WHITE_ON_BLACK)
    cprintln("  GDB:  target remote :1234", WHITE_ON_BLACK)
    cprintln("  Stub: COM2 (0x2F8), RSP protocol", WHITE_ON_BLACK)
    cprint("  Breakpoints: ", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(GDB_STATE + 16), CYAN_ON_BLACK)
    cprint("/", WHITE_ON_BLACK)
    cprint_decimal(GDB_BP_MAX, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Active: ", WHITE_ON_BLACK)
    if volatile_read_u64(GDB_STATE) == 1 { cprintln("yes", GREEN_ON_BLACK) }
    else { cprintln("no", WHITE_ON_BLACK) }
}

// P2.2: Symbol table — generate .sym file info for kernel functions
@kernel fn cmd_symbols() {
    cprintln("Kernel symbol map:", YELLOW_ON_BLACK)
    cprint("  kernel_main      = 0x", WHITE_ON_BLACK)
    cprint_hex(fn_addr("kernel_main"), 16, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  dispatch_command = 0x", WHITE_ON_BLACK)
    cprint_hex(fn_addr("dispatch_command"), 16, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  syscall_dispatch = 0x", WHITE_ON_BLACK)
    cprint_hex(fn_addr("syscall_dispatch"), 16, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  sys_fork         = 0x", WHITE_ON_BLACK)
    cprint_hex(fn_addr("sys_fork"), 16, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// P2.3: Process-aware debugging — qRcmd handler
@kernel fn gdb_handle_rcmd(pkt: i64, len: i64) {
    // qRcmd,<hex-encoded-command>
    // Decode hex command
    let cmd_buf: i64 = 0x996200
    let mut pos: i64 = 6 // skip "qRcmd,"
    let mut ci: i64 = 0
    while pos + 1 < len && ci < 63 {
        let h = gdb_hex_digit(volatile_read_u8(pkt + pos)) * 16 + gdb_hex_digit(volatile_read_u8(pkt + pos + 1))
        volatile_write_u8(cmd_buf + ci, h)
        ci = ci + 1
        pos = pos + 2
    }
    volatile_write_u8(cmd_buf + ci, 0)

    // Handle "info proc" — list processes
    if volatile_read_u8(cmd_buf) == 105 { // 'i' for "info"
        let resp = GDB_RESP_BUF
        let mut rpos: i64 = 0
        let mut pid: i64 = 0
        while pid < PROC_MAX {
            let state = volatile_read(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_STATE)
            if state != PROC_STATE_FREE {
                // Encode "PID N STATE\n" as hex
                rpos = gdb_encode_hex_byte(resp, rpos, 80) // 'P'
                rpos = gdb_encode_hex_byte(resp, rpos, 48 + pid) // digit
                rpos = gdb_encode_hex_byte(resp, rpos, 32) // space
                rpos = gdb_encode_hex_byte(resp, rpos, 48 + state)
                rpos = gdb_encode_hex_byte(resp, rpos, 10) // newline
            }
            pid = pid + 1
        }
        gdb_send_packet(resp, rpos)
        return
    }
    // Unknown command
    let resp = GDB_RESP_BUF
    volatile_write_u8(resp, 79) // 'O'
    volatile_write_u8(resp + 1, 75) // 'K'
    gdb_send_packet(resp, 2)
}

@kernel fn gdb_encode_hex_byte(buf: i64, pos: i64, byte: i64) -> i64 {
    volatile_write_u8(buf + pos, gdb_hex_char((byte >> 4) & 0xF))
    volatile_write_u8(buf + pos + 1, gdb_hex_char(byte & 0xF))
    pos + 2
}

// P2.4: Hardware watchpoints via DR0-DR3
const GDB_WP_MAX: i64 = 4
const GDB_WP_TABLE: i64 = 0x996300 // 4 watchpoints × 16B: +0=addr, +8=type(2=write,3=rw)

@kernel fn gdb_insert_watchpoint(pkt: i64, len: i64) {
    // Z2,ADDR,KIND (write watchpoint) or Z3,ADDR,KIND (r/w)
    let wp_type = volatile_read_u8(pkt + 1) - 48 // '2' or '3'
    let mut addr: i64 = 0
    let mut pos: i64 = 3
    while pos < len && volatile_read_u8(pkt + pos) != 44 {
        addr = addr * 16 + gdb_hex_digit(volatile_read_u8(pkt + pos))
        pos = pos + 1
    }
    // Find free DR register
    let mut dr: i64 = 0
    let mut found: i64 = -1
    while dr < GDB_WP_MAX && found == -1 {
        if volatile_read_u64(GDB_WP_TABLE + dr * 16) == 0 { found = dr }
        dr = dr + 1
    }
    if found == -1 { gdb_send_packet(GDB_RESP_BUF, 0); return }
    volatile_write_u64(GDB_WP_TABLE + found * 16, addr)
    volatile_write_u64(GDB_WP_TABLE + found * 16 + 8, wp_type)
    let resp = GDB_RESP_BUF
    volatile_write_u8(resp, 79)
    volatile_write_u8(resp + 1, 75)
    gdb_send_packet(resp, 2)
}

@kernel fn gdb_remove_watchpoint(pkt: i64, len: i64) {
    let mut addr: i64 = 0
    let mut pos: i64 = 3
    while pos < len && volatile_read_u8(pkt + pos) != 44 {
        addr = addr * 16 + gdb_hex_digit(volatile_read_u8(pkt + pos))
        pos = pos + 1
    }
    let mut i: i64 = 0
    while i < GDB_WP_MAX {
        if volatile_read_u64(GDB_WP_TABLE + i * 16) == addr {
            volatile_write_u64(GDB_WP_TABLE + i * 16, 0)
            volatile_write_u64(GDB_WP_TABLE + i * 16 + 8, 0)
            let resp = GDB_RESP_BUF
            volatile_write_u8(resp, 79)
            volatile_write_u8(resp + 1, 75)
            gdb_send_packet(resp, 2)
            return
        }
        i = i + 1
    }
    gdb_send_packet(GDB_RESP_BUF, 0)
}

// P2.5: Thread query — qfThreadInfo lists PIDs as GDB threads
@kernel fn gdb_handle_thread_info() {
    let resp = GDB_RESP_BUF
    let mut pos: i64 = 0
    volatile_write_u8(resp + pos, 109) // 'm' = more threads
    pos = pos + 1
    let mut first: i64 = 1
    let mut pid: i64 = 0
    while pid < PROC_MAX {
        let state = volatile_read(PROC_TABLE + pid * PROC_ENTRY_SIZE + PROC_OFF_STATE)
        if state != PROC_STATE_FREE {
            if first == 0 { volatile_write_u8(resp + pos, 44); pos = pos + 1 } // ','
            pos = gdb_write_hex_small(resp, pos, pid + 1) // thread IDs start at 1
            first = 0
        }
        pid = pid + 1
    }
    gdb_send_packet(resp, pos)
}

@kernel fn gdb_write_hex_small(buf: i64, pos: i64, val: i64) -> i64 {
    if val < 16 {
        volatile_write_u8(buf + pos, gdb_hex_char(val))
        pos + 1
    } else {
        volatile_write_u8(buf + pos, gdb_hex_char((val >> 4) & 0xF))
        volatile_write_u8(buf + pos + 1, gdb_hex_char(val & 0xF))
        pos + 2
    }
}

// P2.6: Memory map — qXfer:memory-map:read
@kernel fn gdb_handle_memory_map() {
    // Return XML memory map
    let resp = GDB_RESP_BUF
    let mut pos: i64 = 0
    volatile_write_u8(resp, 108) // 'l' = last chunk
    pos = 1
    pos = http_write_str(resp, pos, "<memory-map>")
    pos = http_write_str(resp, pos, "<memory type=\"ram\" start=\"0x100000\" length=\"0x7F00000\"/>")
    pos = http_write_str(resp, pos, "<memory type=\"ram\" start=\"0x2000000\" length=\"0x1000000\"/>")
    pos = http_write_str(resp, pos, "</memory-map>")
    gdb_send_packet(resp, pos)
}

// P2.8: Debug exception handlers (IDT vectors 1 and 3)
// Vector 1 = #DB (debug), Vector 3 = #BP (breakpoint)
// These are handled by the linker's ISR stubs
// When GDB is active, they should notify GDB instead of crashing

@kernel fn gdb_on_breakpoint() {
    // Called when INT3 (0xCC) is hit
    if volatile_read_u64(GDB_STATE) == 1 {
        gdb_handle_halt_reason() // Send S05 to GDB
    }
}

@kernel fn gdb_on_debug_trap() {
    // Called on single-step (#DB, TF=1)
    if volatile_read_u64(GDB_STATE) == 1 {
        volatile_write_u64(GDB_STATE + 8, 0) // clear stepping
        gdb_handle_halt_reason()
    }
}

// Enhanced gdb_dispatch with P2 commands
@kernel fn gdb_dispatch_v2(pkt: i64, len: i64) {
    let cmd = volatile_read_u8(pkt)
    if cmd == 63 { gdb_handle_halt_reason() }
    else if cmd == 103 { gdb_handle_read_regs() }
    else if cmd == 109 { gdb_handle_read_mem(pkt, len) }
    else if cmd == 115 { gdb_handle_step() }
    else if cmd == 99 { gdb_handle_continue() }
    else if cmd == 90 {
        let subcmd = volatile_read_u8(pkt + 1)
        if subcmd == 48 { gdb_insert_breakpoint(pkt, len) }      // Z0
        else if subcmd == 50 || subcmd == 51 { gdb_insert_watchpoint(pkt, len) } // Z2/Z3
        else { gdb_send_packet(GDB_RESP_BUF, 0) }
    }
    else if cmd == 122 {
        let subcmd = volatile_read_u8(pkt + 1)
        if subcmd == 48 { gdb_remove_breakpoint(pkt, len) }
        else if subcmd == 50 || subcmd == 51 { gdb_remove_watchpoint(pkt, len) }
        else { gdb_send_packet(GDB_RESP_BUF, 0) }
    }
    else if cmd == 113 { // 'q' query
        if volatile_read_u8(pkt + 1) == 102 { gdb_handle_thread_info() } // qfThreadInfo
        else if volatile_read_u8(pkt + 1) == 82 { gdb_handle_rcmd(pkt, len) } // qRcmd
        else if volatile_read_u8(pkt + 1) == 88 { gdb_handle_memory_map() } // qXfer
        else { gdb_send_packet(GDB_RESP_BUF, 0) }
    }
    else { gdb_send_packet(GDB_RESP_BUF, 0) }
}

// ═══════════════════════════════════════════════
// VirtIO-GPU Driver (Sprint R1 — v0.9 "Zenith")
// ═══════════════════════════════════════════════

// VirtIO-GPU PCI: vendor 0x1AF4, device 0x1050
const VIRTIO_GPU_VENDOR: i64 = 0x1AF4
const VIRTIO_GPU_DEVICE: i64 = 0x1050

// GPU state at 0x9A0000 (4KB)
const GPU_STATE: i64 = 0x9A0000
const GPU_OFF_BAR0: i64 = 0
const GPU_OFF_WIDTH: i64 = 8
const GPU_OFF_HEIGHT: i64 = 16
const GPU_OFF_ACTIVE: i64 = 24
const GPU_OFF_RESOURCE_ID: i64 = 32
const GPU_OFF_SCANOUT_ID: i64 = 40

// GPU framebuffer at 0x9A1000 (256KB — 800×600×4 = 1.83MB needs truncated, use 320×200×4 = 256KB)
const GPU_FB_BASE: i64 = 0x9A1000
const GPU_FB_WIDTH: i64 = 320
const GPU_FB_HEIGHT: i64 = 200
const GPU_FB_BPP: i64 = 4  // 32-bit RGBA
const GPU_FB_SIZE: i64 = 256000  // 320 × 200 × 4

// VirtIO-GPU command types
const VIRTIO_GPU_CMD_GET_DISPLAY_INFO: i64 = 0x0100
const VIRTIO_GPU_CMD_RESOURCE_CREATE_2D: i64 = 0x0101
const VIRTIO_GPU_CMD_RESOURCE_UNREF: i64 = 0x0102
const VIRTIO_GPU_CMD_SET_SCANOUT: i64 = 0x0103
const VIRTIO_GPU_CMD_RESOURCE_FLUSH: i64 = 0x0104
const VIRTIO_GPU_CMD_TRANSFER_TO_HOST_2D: i64 = 0x0105
const VIRTIO_GPU_CMD_RESOURCE_ATTACH_BACKING: i64 = 0x0106
const VIRTIO_GPU_RESP_OK_NODATA: i64 = 0x1100

// VirtIO-GPU control virtqueue at 0x9E0000 (16KB)
const GPU_CTRL_QUEUE: i64 = 0x9E0000
const GPU_CMD_BUF: i64 = 0x9E4000  // command buffer (4KB)
const GPU_RESP_BUFADDR: i64 = 0x9E5000  // response buffer (4KB)

// R1.1: Find VirtIO-GPU device on PCI bus
@kernel fn gpu_find_device() -> i64 {
    let mut dev: i64 = 0
    while dev < 32 {
        let id = pci_read32(0, dev, 0, 0)
        if id != 0xFFFFFFFF && id != 0 {
            let vendor = id & 0xFFFF
            let device_id = (id >> 16) & 0xFFFF
            if vendor == VIRTIO_GPU_VENDOR && device_id == VIRTIO_GPU_DEVICE { return dev }
        }
        dev = dev + 1
    }
    -1
}

// R1.2: Initialize VirtIO-GPU virtqueues
@kernel fn gpu_init() -> i64 {
    let dev = gpu_find_device()
    if dev < 0 {
        volatile_write_u64(GPU_STATE + GPU_OFF_ACTIVE, 0)
        return -1
    }
    // Read BAR0
    let bar0 = pci_read32(0, dev, 0, 0x10) & 0xFFFFFFF0
    volatile_write_u64(GPU_STATE + GPU_OFF_BAR0, bar0)
    // Enable bus master
    let cmd = pci_read32(0, dev, 0, 4)
    pci_write32(0, dev, 0, 4, cmd | 4)
    // Set default resolution
    volatile_write_u64(GPU_STATE + GPU_OFF_WIDTH, GPU_FB_WIDTH)
    volatile_write_u64(GPU_STATE + GPU_OFF_HEIGHT, GPU_FB_HEIGHT)
    volatile_write_u64(GPU_STATE + GPU_OFF_ACTIVE, 1)
    volatile_write_u64(GPU_STATE + GPU_OFF_RESOURCE_ID, 1)
    volatile_write_u64(GPU_STATE + GPU_OFF_SCANOUT_ID, 0)
    0
}

// R1.3: Create 2D resource (framebuffer)
@kernel fn gpu_resource_create_2d(resource_id: i64, width: i64, height: i64) {
    let cmd = GPU_CMD_BUF
    // VirtIO-GPU header: type(4B), flags(4B), fence_id(8B), ctx_id(4B), padding(4B) = 24B
    volatile_write_u32_le(cmd, VIRTIO_GPU_CMD_RESOURCE_CREATE_2D)
    volatile_write_u32_le(cmd + 4, 0) // flags
    volatile_write_u64(cmd + 8, 0)    // fence
    volatile_write_u32_le(cmd + 16, 0) // ctx
    volatile_write_u32_le(cmd + 20, 0) // padding
    // Resource create params: resource_id(4B), format(4B), width(4B), height(4B)
    volatile_write_u32_le(cmd + 24, resource_id)
    volatile_write_u32_le(cmd + 28, 1) // format = B8G8R8A8_UNORM
    volatile_write_u32_le(cmd + 32, width)
    volatile_write_u32_le(cmd + 36, height)
}

// R1.4: Attach backing store (host memory for framebuffer)
@kernel fn gpu_resource_attach_backing(resource_id: i64, addr: i64, length: i64) {
    let cmd = GPU_CMD_BUF
    volatile_write_u32_le(cmd, VIRTIO_GPU_CMD_RESOURCE_ATTACH_BACKING)
    volatile_write_u32_le(cmd + 4, 0)
    volatile_write_u64(cmd + 8, 0)
    volatile_write_u32_le(cmd + 16, 0)
    volatile_write_u32_le(cmd + 20, 0)
    // Attach params: resource_id(4B), nr_entries(4B)
    volatile_write_u32_le(cmd + 24, resource_id)
    volatile_write_u32_le(cmd + 28, 1) // 1 entry
    // Entry: addr(8B), length(4B), padding(4B)
    volatile_write_u64(cmd + 32, addr)
    volatile_write_u32_le(cmd + 40, length)
    volatile_write_u32_le(cmd + 44, 0)
}

// R1.5: Set scanout (display resource on screen)
@kernel fn gpu_set_scanout(scanout_id: i64, resource_id: i64, width: i64, height: i64) {
    let cmd = GPU_CMD_BUF
    volatile_write_u32_le(cmd, VIRTIO_GPU_CMD_SET_SCANOUT)
    volatile_write_u32_le(cmd + 4, 0)
    volatile_write_u64(cmd + 8, 0)
    volatile_write_u32_le(cmd + 16, 0)
    volatile_write_u32_le(cmd + 20, 0)
    // Scanout params: x, y, width, height, scanout_id, resource_id
    volatile_write_u32_le(cmd + 24, 0) // x
    volatile_write_u32_le(cmd + 28, 0) // y
    volatile_write_u32_le(cmd + 32, width)
    volatile_write_u32_le(cmd + 36, height)
    volatile_write_u32_le(cmd + 40, scanout_id)
    volatile_write_u32_le(cmd + 44, resource_id)
}

// R1.6: Transfer framebuffer data to host
@kernel fn gpu_transfer_to_host_2d(resource_id: i64, width: i64, height: i64) {
    let cmd = GPU_CMD_BUF
    volatile_write_u32_le(cmd, VIRTIO_GPU_CMD_TRANSFER_TO_HOST_2D)
    volatile_write_u32_le(cmd + 4, 0)
    volatile_write_u64(cmd + 8, 0)
    volatile_write_u32_le(cmd + 16, 0)
    volatile_write_u32_le(cmd + 20, 0)
    // Transfer: x, y, width, height, offset, resource_id, padding
    volatile_write_u32_le(cmd + 24, 0) // x
    volatile_write_u32_le(cmd + 28, 0) // y
    volatile_write_u32_le(cmd + 32, width)
    volatile_write_u32_le(cmd + 36, height)
    volatile_write_u64(cmd + 40, 0) // offset
    volatile_write_u32_le(cmd + 48, resource_id)
    volatile_write_u32_le(cmd + 52, 0)
}

// R1.7: Flush resource to display
@kernel fn gpu_resource_flush(resource_id: i64, width: i64, height: i64) {
    let cmd = GPU_CMD_BUF
    volatile_write_u32_le(cmd, VIRTIO_GPU_CMD_RESOURCE_FLUSH)
    volatile_write_u32_le(cmd + 4, 0)
    volatile_write_u64(cmd + 8, 0)
    volatile_write_u32_le(cmd + 16, 0)
    volatile_write_u32_le(cmd + 20, 0)
    // Flush: x, y, width, height, resource_id, padding
    volatile_write_u32_le(cmd + 24, 0)
    volatile_write_u32_le(cmd + 28, 0)
    volatile_write_u32_le(cmd + 32, width)
    volatile_write_u32_le(cmd + 36, height)
    volatile_write_u32_le(cmd + 40, resource_id)
    volatile_write_u32_le(cmd + 44, 0)
}

// R1.8: Framebuffer abstraction
@kernel fn gpu_draw_pixel(x: i64, y: i64, color: i64) {
    if x < 0 || x >= GPU_FB_WIDTH || y < 0 || y >= GPU_FB_HEIGHT { return }
    let offset = (y * GPU_FB_WIDTH + x) * GPU_FB_BPP
    volatile_write_u32_le(GPU_FB_BASE + offset, color)
}

@kernel fn gpu_fill_rect(x: i64, y: i64, w: i64, h: i64, color: i64) {
    let mut py = y
    while py < y + h && py < GPU_FB_HEIGHT {
        let mut px = x
        while px < x + w && px < GPU_FB_WIDTH {
            gpu_draw_pixel(px, py, color)
            px = px + 1
        }
        py = py + 1
    }
}

@kernel fn gpu_clear(color: i64) {
    gpu_fill_rect(0, 0, GPU_FB_WIDTH, GPU_FB_HEIGHT, color)
}

// Helper: write u32 little-endian to address
@kernel fn volatile_write_u32_le(addr: i64, val: i64) {
    volatile_write_u8(addr, val & 0xFF)
    volatile_write_u8(addr + 1, (val >> 8) & 0xFF)
    volatile_write_u8(addr + 2, (val >> 16) & 0xFF)
    volatile_write_u8(addr + 3, (val >> 24) & 0xFF)
}

// R1.9: `gpu` shell command
@kernel fn cmd_gpu_v1() {
    let active = volatile_read_u64(GPU_STATE + GPU_OFF_ACTIVE)
    if active == 0 {
        cprintln("No VirtIO-GPU detected", WHITE_ON_BLACK)
        cprintln("  Start QEMU with: -device virtio-gpu-pci", YELLOW_ON_BLACK)
        return
    }
    cprintln("VirtIO-GPU:", YELLOW_ON_BLACK)
    cprint("  BAR0: 0x", WHITE_ON_BLACK)
    cprint_hex(volatile_read_u64(GPU_STATE + GPU_OFF_BAR0), 8, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Resolution: ", WHITE_ON_BLACK)
    cprint_decimal(GPU_FB_WIDTH, CYAN_ON_BLACK)
    cprint("x", WHITE_ON_BLACK)
    cprint_decimal(GPU_FB_HEIGHT, CYAN_ON_BLACK)
    cprintln(" (32bpp RGBA)", WHITE_ON_BLACK)
    cprint("  Framebuffer: 0x", WHITE_ON_BLACK)
    cprint_hex(GPU_FB_BASE, 8, CYAN_ON_BLACK)
    cprint(" (", WHITE_ON_BLACK)
    cprint_decimal(GPU_FB_SIZE / 1024, CYAN_ON_BLACK)
    cprintln(" KB)", WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// GPU Compute Dispatch (Sprint R2 — v0.9 "Zenith")
// ═══════════════════════════════════════════════

// Compute buffer pool at 0x9F0000 (64KB — 16 buffers × 4KB each)
const COMPUTE_BUF_BASE: i64 = 0x9F0000
const COMPUTE_BUF_MAX: i64 = 16
const COMPUTE_BUF_SIZE: i64 = 4096

// Compute buffer metadata at 0x9EF000 (16 buffers × 32B)
// Per buffer: +0=active(i64), +8=rows(i64), +16=cols(i64), +24=dtype(i64: 0=f64, 1=i64)
const COMPUTE_META: i64 = 0x9EF000
const COMPUTE_META_SIZE: i64 = 32

// Compute kernel IDs
const KERNEL_MATMUL: i64 = 1
const KERNEL_VECADD: i64 = 2
const KERNEL_SCALE: i64 = 3
const KERNEL_RELU: i64 = 4

// New syscalls
const SYS_GPU_ALLOC: i64 = 32
const SYS_GPU_DISPATCH: i64 = 33

// R2.1: Allocate compute buffer
@kernel fn compute_buf_alloc(rows: i64, cols: i64, dtype: i64) -> i64 {
    let needed = rows * cols * 8
    if needed > COMPUTE_BUF_SIZE { return -1 }
    let mut slot: i64 = 0
    while slot < COMPUTE_BUF_MAX {
        let meta = COMPUTE_META + slot * COMPUTE_META_SIZE
        if volatile_read_u64(meta) == 0 {
            volatile_write_u64(meta, 1)       // active
            volatile_write_u64(meta + 8, rows)
            volatile_write_u64(meta + 16, cols)
            volatile_write_u64(meta + 24, dtype)
            // Zero the buffer
            let buf = COMPUTE_BUF_BASE + slot * COMPUTE_BUF_SIZE
            let mut i: i64 = 0
            while i < needed { volatile_write_u8(buf + i, 0); i = i + 1 }
            return slot
        }
        slot = slot + 1
    }
    -1
}

@kernel fn compute_buf_free(slot: i64) {
    if slot >= 0 && slot < COMPUTE_BUF_MAX {
        volatile_write_u64(COMPUTE_META + slot * COMPUTE_META_SIZE, 0)
    }
}

@kernel fn compute_buf_addr(slot: i64) -> i64 { COMPUTE_BUF_BASE + slot * COMPUTE_BUF_SIZE }

// R2.2: Matrix multiply kernel (CPU fallback)
// C[m×p] = A[m×n] × B[n×p]
@kernel fn compute_matmul(a_slot: i64, b_slot: i64, c_slot: i64) -> i64 {
    let a_meta = COMPUTE_META + a_slot * COMPUTE_META_SIZE
    let b_meta = COMPUTE_META + b_slot * COMPUTE_META_SIZE
    let m = volatile_read_u64(a_meta + 8)
    let n = volatile_read_u64(a_meta + 16)
    let bn = volatile_read_u64(b_meta + 8)
    let p = volatile_read_u64(b_meta + 16)
    if n != bn { return -1 } // dimension mismatch
    let a = compute_buf_addr(a_slot)
    let b = compute_buf_addr(b_slot)
    let c = compute_buf_addr(c_slot)
    // Set C metadata
    let c_meta = COMPUTE_META + c_slot * COMPUTE_META_SIZE
    volatile_write_u64(c_meta + 8, m)
    volatile_write_u64(c_meta + 16, p)
    // Naive O(n^3) matmul
    let mut i: i64 = 0
    while i < m {
        let mut j: i64 = 0
        while j < p {
            let mut sum: i64 = 0
            let mut k: i64 = 0
            while k < n {
                let av = volatile_read_u64(a + (i * n + k) * 8)
                let bv = volatile_read_u64(b + (k * p + j) * 8)
                sum = sum + av * bv
                k = k + 1
            }
            volatile_write_u64(c + (i * p + j) * 8, sum)
            j = j + 1
        }
        i = i + 1
    }
    0
}

// R2.3: Vector add kernel
@kernel fn compute_vecadd(a_slot: i64, b_slot: i64, c_slot: i64) -> i64 {
    let a_meta = COMPUTE_META + a_slot * COMPUTE_META_SIZE
    let rows = volatile_read_u64(a_meta + 8)
    let cols = volatile_read_u64(a_meta + 16)
    let total = rows * cols
    let a = compute_buf_addr(a_slot)
    let b = compute_buf_addr(b_slot)
    let c = compute_buf_addr(c_slot)
    let c_meta = COMPUTE_META + c_slot * COMPUTE_META_SIZE
    volatile_write_u64(c_meta + 8, rows)
    volatile_write_u64(c_meta + 16, cols)
    let mut i: i64 = 0
    while i < total {
        volatile_write_u64(c + i * 8, volatile_read_u64(a + i * 8) + volatile_read_u64(b + i * 8))
        i = i + 1
    }
    0
}

// R2.4: Tensor shape tracking
@kernel fn compute_get_shape(slot: i64, dim: i64) -> i64 {
    let meta = COMPUTE_META + slot * COMPUTE_META_SIZE
    if dim == 0 { volatile_read_u64(meta + 8) }  // rows
    else { volatile_read_u64(meta + 16) }          // cols
}

// R2.5: `tensor` command — create, fill, display
@kernel fn cmd_tensor_compute() {
    cprintln("Compute tensors:", YELLOW_ON_BLACK)
    // Create 4×4 identity matrix
    let a = compute_buf_alloc(4, 4, 1)
    if a < 0 { cprintln("  Alloc failed", RED_ON_BLACK); return }
    let buf = compute_buf_addr(a)
    // Set identity
    let mut i: i64 = 0
    while i < 4 { volatile_write_u64(buf + (i * 4 + i) * 8, 1); i = i + 1 }
    cprint("  Buffer ", WHITE_ON_BLACK)
    cprint_decimal(a, CYAN_ON_BLACK)
    cprintln(": 4x4 identity", WHITE_ON_BLACK)
    // Display first row
    cprint("  [", WHITE_ON_BLACK)
    i = 0
    while i < 4 {
        cprint_decimal(volatile_read_u64(buf + i * 8), CYAN_ON_BLACK)
        if i < 3 { cprint(", ", WHITE_ON_BLACK) }
        i = i + 1
    }
    cprintln(", ...]", WHITE_ON_BLACK)
    compute_buf_free(a)
}

// R2.6/R2.7: Syscalls for GPU compute
@kernel fn sys_gpu_alloc(rows: i64, cols: i64, dtype: i64) -> i64 {
    compute_buf_alloc(rows, cols, dtype)
}

@kernel fn sys_gpu_dispatch(kernel_id: i64, a: i64, b: i64, c: i64) -> i64 {
    if kernel_id == KERNEL_MATMUL { return compute_matmul(a, b, c) }
    if kernel_id == KERNEL_VECADD { return compute_vecadd(a, b, c) }
    -1
}

// R2.8: Benchmark matmul
@kernel fn cmd_gpubench() {
    cprintln("GPU Compute Benchmark:", YELLOW_ON_BLACK)
    let n: i64 = 8
    let a = compute_buf_alloc(n, n, 1)
    let b = compute_buf_alloc(n, n, 1)
    let c = compute_buf_alloc(n, n, 1)
    if a < 0 || b < 0 || c < 0 { cprintln("  Alloc failed", RED_ON_BLACK); return }
    // Fill A and B with simple values
    let mut i: i64 = 0
    while i < n * n {
        volatile_write_u64(compute_buf_addr(a) + i * 8, i + 1)
        volatile_write_u64(compute_buf_addr(b) + i * 8, 1)
        i = i + 1
    }
    let start = volatile_read_u64(0x6FE08)
    compute_matmul(a, b, c)
    let end = volatile_read_u64(0x6FE08)
    cprint("  ", WHITE_ON_BLACK)
    cprint_decimal(n, CYAN_ON_BLACK)
    cprint("x", WHITE_ON_BLACK)
    cprint_decimal(n, CYAN_ON_BLACK)
    cprint(" matmul: ", WHITE_ON_BLACK)
    cprint_decimal((end - start) * 10, CYAN_ON_BLACK)
    cprintln(" ms", WHITE_ON_BLACK)
    // Verify: first element of C = sum of first row of A = 1+2+...+n = n*(n+1)/2 * 1
    let c0 = volatile_read_u64(compute_buf_addr(c))
    cprint("  C[0,0] = ", WHITE_ON_BLACK)
    cprint_decimal(c0, CYAN_ON_BLACK)
    cprint(" (expected ", WHITE_ON_BLACK)
    cprint_decimal(n * (n + 1) / 2, CYAN_ON_BLACK)
    cprintln(")", WHITE_ON_BLACK)
    compute_buf_free(a)
    compute_buf_free(b)
    compute_buf_free(c)
}

// ═══════════════════════════════════════════════
// ext2-like Filesystem (Sprint S1 — v0.9 "Zenith")
// ═══════════════════════════════════════════════

// ext2 on-disk layout (simplified for Nova)
// Sector 0-1: boot (reserved)
// Sector 2-3: Superblock (1KB)
// Sector 4-7: Block bitmap (4 sectors = 2KB = 16K blocks trackable)
// Sector 8-11: Inode bitmap (4 sectors = 2KB = 16K inodes trackable)
// Sector 12-139: Inode table (128 sectors = 256 inodes × 128B each)
// Sector 140+: Data blocks (4KB each = 8 sectors per block)

const EXT2_SUPERBLOCK_SECTOR: i64 = 2
const EXT2_BLOCK_BITMAP_SECTOR: i64 = 4
const EXT2_INODE_BITMAP_SECTOR: i64 = 8
const EXT2_INODE_TABLE_SECTOR: i64 = 12
const EXT2_DATA_START_SECTOR: i64 = 140
const EXT2_BLOCK_SIZE: i64 = 4096
const EXT2_SECTORS_PER_BLOCK: i64 = 8
const EXT2_INODE_SIZE: i64 = 128
const EXT2_MAX_INODES: i64 = 256
const EXT2_MAX_BLOCKS: i64 = 16384

// Superblock fields (at sector 2, 1024 bytes)
const EXT2_SB_MAGIC: i64 = 0xEF53
const EXT2_SB_OFF_MAGIC: i64 = 56       // u16 magic at offset 56
const EXT2_SB_OFF_INODE_COUNT: i64 = 0  // u32
const EXT2_SB_OFF_BLOCK_COUNT: i64 = 4  // u32
const EXT2_SB_OFF_FREE_BLOCKS: i64 = 12 // u32
const EXT2_SB_OFF_FREE_INODES: i64 = 16 // u32
const EXT2_SB_OFF_BLOCK_SIZE: i64 = 24  // u32 (log2(block_size) - 10)
const EXT2_SB_OFF_FIRST_DATA: i64 = 20  // u32

// Inode fields (128 bytes each)
// +0: mode(u16), +2: uid(u16), +4: size(u32), +8: atime(u32),
// +12: ctime(u32), +16: mtime(u32), +20: dtime(u32), +24: gid(u16),
// +26: links_count(u16), +28: blocks(u32), +40: block[12](u32×12),
// +88: indirect(u32), +92: double_indirect(u32)
const EXT2_INO_OFF_MODE: i64 = 0
const EXT2_INO_OFF_UID: i64 = 2
const EXT2_INO_OFF_SIZE: i64 = 4
const EXT2_INO_OFF_GID: i64 = 24
const EXT2_INO_OFF_LINKS: i64 = 26
const EXT2_INO_OFF_BLOCKS: i64 = 28
const EXT2_INO_OFF_BLOCK0: i64 = 40  // first direct block pointer
const EXT2_INO_OFF_INDIRECT: i64 = 88

// ext2 state buffer at 0xA00000 (4KB scratch for NVMe I/O)
const EXT2_BUF: i64 = 0xA00000
const EXT2_STATE: i64 = 0xA01000  // +0=mounted(i64), +8=blk_dev(i64), +16=total_blocks, +24=free_blocks

// S1.1: Superblock read/write
@kernel fn ext2_read_superblock() -> i64 {
    let blk_dev = volatile_read_u64(EXT2_STATE + 8)
    let result = blk_read(blk_dev, EXT2_SUPERBLOCK_SECTOR, 2, EXT2_BUF) // read 2 sectors = 1KB
    if result < 0 { return -1 }
    // Check magic
    let magic = volatile_read_u8(EXT2_BUF + EXT2_SB_OFF_MAGIC) + volatile_read_u8(EXT2_BUF + EXT2_SB_OFF_MAGIC + 1) * 256
    if magic != EXT2_SB_MAGIC { return -2 }
    0
}

// S1.2: Inode table I/O
@kernel fn ext2_read_inode(inode_num: i64) -> i64 {
    if inode_num < 1 || inode_num > EXT2_MAX_INODES { return -1 }
    let idx = inode_num - 1  // inodes are 1-based
    let sector = EXT2_INODE_TABLE_SECTOR + (idx * EXT2_INODE_SIZE) / 512
    let offset_in_sector = (idx * EXT2_INODE_SIZE) % 512
    let result = blk_read(volatile_read_u64(EXT2_STATE + 8), sector, 1, EXT2_BUF)
    if result < 0 { return -1 }
    // Return address of inode data in buffer
    EXT2_BUF + offset_in_sector
}

// S1.5: Block allocator — find free block in bitmap
@kernel fn ext2_block_alloc() -> i64 {
    let blk_dev = volatile_read_u64(EXT2_STATE + 8)
    // Read block bitmap (4 sectors)
    let result = blk_read(blk_dev, EXT2_BLOCK_BITMAP_SECTOR, 4, EXT2_BUF)
    if result < 0 { return -1 }
    let mut byte: i64 = 0
    while byte < 2048 {
        let val = volatile_read_u8(EXT2_BUF + byte)
        if val != 0xFF {
            let mut bit: i64 = 0
            while bit < 8 {
                if (val & (1 << bit)) == 0 {
                    let block_num = byte * 8 + bit
                    // Mark as used
                    volatile_write_u8(EXT2_BUF + byte, val | (1 << bit))
                    blk_write(blk_dev, EXT2_BLOCK_BITMAP_SECTOR, 4, EXT2_BUF)
                    return block_num
                }
                bit = bit + 1
            }
        }
        byte = byte + 1
    }
    -1 // no free blocks
}

// S1.6: Inode allocator
@kernel fn ext2_inode_alloc() -> i64 {
    let blk_dev = volatile_read_u64(EXT2_STATE + 8)
    let result = blk_read(blk_dev, EXT2_INODE_BITMAP_SECTOR, 4, EXT2_BUF)
    if result < 0 { return -1 }
    let mut byte: i64 = 0
    while byte < 32 { // 256 inodes = 32 bytes
        let val = volatile_read_u8(EXT2_BUF + byte)
        if val != 0xFF {
            let mut bit: i64 = 0
            while bit < 8 {
                if (val & (1 << bit)) == 0 {
                    let inode_num = byte * 8 + bit + 1 // 1-based
                    volatile_write_u8(EXT2_BUF + byte, val | (1 << bit))
                    blk_write(blk_dev, EXT2_INODE_BITMAP_SECTOR, 4, EXT2_BUF)
                    return inode_num
                }
                bit = bit + 1
            }
        }
        byte = byte + 1
    }
    -1
}

// S1.7/S1.8: Read/write data block from NVMe
@kernel fn ext2_read_block(block_num: i64, buf: i64) -> i64 {
    let sector = EXT2_DATA_START_SECTOR + block_num * EXT2_SECTORS_PER_BLOCK
    blk_read(volatile_read_u64(EXT2_STATE + 8), sector, EXT2_SECTORS_PER_BLOCK, buf)
}

@kernel fn ext2_write_block(block_num: i64, buf: i64) -> i64 {
    let sector = EXT2_DATA_START_SECTOR + block_num * EXT2_SECTORS_PER_BLOCK
    blk_write(volatile_read_u64(EXT2_STATE + 8), sector, EXT2_SECTORS_PER_BLOCK, buf)
}

// S1.9: `mkfs.ext2` command — format NVMe with ext2
@kernel fn cmd_mkfs_ext2() {
    let len = cmdbuf_len()
    let blk_dev: i64 = if len > 10 { volatile_read_u8(0x6F800 + 10) - 48 } else { 0 }
    volatile_write_u64(EXT2_STATE + 8, blk_dev)
    cprintln("Formatting ext2...", YELLOW_ON_BLACK)

    // Write superblock
    let mut i: i64 = 0
    while i < 1024 { volatile_write_u8(EXT2_BUF + i, 0); i = i + 1 }
    // Set fields
    volatile_write_u32_le(EXT2_BUF + EXT2_SB_OFF_INODE_COUNT, EXT2_MAX_INODES)
    volatile_write_u32_le(EXT2_BUF + EXT2_SB_OFF_BLOCK_COUNT, EXT2_MAX_BLOCKS)
    volatile_write_u32_le(EXT2_BUF + EXT2_SB_OFF_FREE_BLOCKS, EXT2_MAX_BLOCKS - 1)
    volatile_write_u32_le(EXT2_BUF + EXT2_SB_OFF_FREE_INODES, EXT2_MAX_INODES - 1)
    volatile_write_u32_le(EXT2_BUF + EXT2_SB_OFF_FIRST_DATA, EXT2_DATA_START_SECTOR)
    volatile_write_u32_le(EXT2_BUF + EXT2_SB_OFF_BLOCK_SIZE, 2) // log2(4096)-10 = 2
    // Magic
    volatile_write_u8(EXT2_BUF + EXT2_SB_OFF_MAGIC, EXT2_SB_MAGIC & 0xFF)
    volatile_write_u8(EXT2_BUF + EXT2_SB_OFF_MAGIC + 1, (EXT2_SB_MAGIC >> 8) & 0xFF)
    blk_write(blk_dev, EXT2_SUPERBLOCK_SECTOR, 2, EXT2_BUF)

    // Clear bitmaps
    i = 0
    while i < 2048 { volatile_write_u8(EXT2_BUF + i, 0); i = i + 1 }
    blk_write(blk_dev, EXT2_BLOCK_BITMAP_SECTOR, 4, EXT2_BUF)
    blk_write(blk_dev, EXT2_INODE_BITMAP_SECTOR, 4, EXT2_BUF)

    // Create root inode (inode 2, standard ext2)
    i = 0
    while i < 512 { volatile_write_u8(EXT2_BUF + i, 0); i = i + 1 }
    // Mode: directory + 0755
    volatile_write_u8(EXT2_BUF + EXT2_INO_OFF_MODE, 0xED) // 0x41ED = dir + 0755
    volatile_write_u8(EXT2_BUF + EXT2_INO_OFF_MODE + 1, 0x41)
    volatile_write_u8(EXT2_BUF + EXT2_INO_OFF_LINKS, 2) // . and ..
    blk_write(blk_dev, EXT2_INODE_TABLE_SECTOR + 1, 1, EXT2_BUF) // inode 2 at offset 128

    // Mark inode 1 and 2 as used in bitmap
    volatile_read_u8(0) // dummy
    i = 0
    while i < 2048 { volatile_write_u8(EXT2_BUF + i, 0); i = i + 1 }
    volatile_write_u8(EXT2_BUF, 0x03) // inodes 1+2 used
    blk_write(blk_dev, EXT2_INODE_BITMAP_SECTOR, 4, EXT2_BUF)

    volatile_write_u64(EXT2_STATE, 1) // mounted
    volatile_write_u64(EXT2_STATE + 16, EXT2_MAX_BLOCKS)
    volatile_write_u64(EXT2_STATE + 24, EXT2_MAX_BLOCKS - 1)

    cprintln("ext2 formatted:", GREEN_ON_BLACK)
    cprint("  Inodes: ", WHITE_ON_BLACK); cprint_decimal(EXT2_MAX_INODES, CYAN_ON_BLACK); console_putchar(10, WHITE_ON_BLACK)
    cprint("  Blocks: ", WHITE_ON_BLACK); cprint_decimal(EXT2_MAX_BLOCKS, CYAN_ON_BLACK); console_putchar(10, WHITE_ON_BLACK)
    cprint("  Block size: ", WHITE_ON_BLACK); cprint_decimal(EXT2_BLOCK_SIZE, CYAN_ON_BLACK); cprintln(" bytes", WHITE_ON_BLACK)
    cprintln("  Root inode: 2", WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// ext2 Directory + File Ops (Sprint S2 — v0.9 "Zenith")
// ═══════════════════════════════════════════════

// Directory entry: inode(4B) + rec_len(2B) + name_len(1B) + file_type(1B) + name[248]
// Simplified: 8B inode + 8B name_len + name[112] = 128B per entry (fits 32 per block)
const EXT2_DIRENT_SIZE: i64 = 128
const EXT2_DIRENTS_PER_BLOCK: i64 = 32
const EXT2_ROOT_INODE: i64 = 2

// ext2 scratch buffer #2 at 0xA02000 (4KB for directory block I/O)
const EXT2_DIR_BUF: i64 = 0xA02000
// ext2 file data buffer at 0xA03000 (4KB)
const EXT2_FILE_BUF: i64 = 0xA03000

// S2.1: Directory entry format
// Each 128B: +0=inode(i64), +8=name_len(i64), +16=name[112]
@kernel fn ext2_dirent_inode(buf: i64, idx: i64) -> i64 {
    volatile_read_u64(buf + idx * EXT2_DIRENT_SIZE)
}

@kernel fn ext2_dirent_name_len(buf: i64, idx: i64) -> i64 {
    volatile_read_u64(buf + idx * EXT2_DIRENT_SIZE + 8)
}

@kernel fn ext2_dirent_set(buf: i64, idx: i64, inode: i64, name_addr: i64, name_len: i64) {
    let off = idx * EXT2_DIRENT_SIZE
    volatile_write_u64(buf + off, inode)
    volatile_write_u64(buf + off + 8, name_len)
    let mut i: i64 = 0
    while i < name_len && i < 112 {
        volatile_write_u8(buf + off + 16 + i, volatile_read_u8(name_addr + i))
        i = i + 1
    }
    volatile_write_u8(buf + off + 16 + name_len, 0)
}

// S2.3: ext2_lookup — find entry in directory
@kernel fn ext2_lookup(dir_inode: i64, name_addr: i64, name_len: i64) -> i64 {
    // Read inode to get block pointers
    let iaddr = ext2_read_inode(dir_inode)
    if iaddr < 0 { return -1 }
    // Read first direct block
    let block0 = volatile_read_u8(iaddr + EXT2_INO_OFF_BLOCK0) + volatile_read_u8(iaddr + EXT2_INO_OFF_BLOCK0 + 1) * 256
    if block0 == 0 { return -1 }
    let result = ext2_read_block(block0, EXT2_DIR_BUF)
    if result < 0 { return -1 }
    // Search directory entries
    let mut idx: i64 = 0
    while idx < EXT2_DIRENTS_PER_BLOCK {
        let dinode = ext2_dirent_inode(EXT2_DIR_BUF, idx)
        if dinode != 0 {
            let dlen = ext2_dirent_name_len(EXT2_DIR_BUF, idx)
            if dlen == name_len {
                let mut match_ok: i64 = 1
                let mut j: i64 = 0
                while j < name_len && match_ok == 1 {
                    if volatile_read_u8(EXT2_DIR_BUF + idx * EXT2_DIRENT_SIZE + 16 + j) != volatile_read_u8(name_addr + j) {
                        match_ok = 0
                    }
                    j = j + 1
                }
                if match_ok == 1 { return dinode }
            }
        }
        idx = idx + 1
    }
    -1 // not found
}

// S2.4: ext2_create — create new file in directory
@kernel fn ext2_create(dir_inode: i64, name_addr: i64, name_len: i64, mode: i64) -> i64 {
    // Allocate inode
    let new_inode = ext2_inode_alloc()
    if new_inode < 0 { return -1 }
    // Allocate data block for new file
    let new_block = ext2_block_alloc()
    if new_block < 0 { return -1 }
    // Initialize new inode
    let iaddr = ext2_read_inode(new_inode)
    if iaddr < 0 { return -1 }
    // Set mode + uid + size
    volatile_write_u8(iaddr + EXT2_INO_OFF_MODE, mode & 0xFF)
    volatile_write_u8(iaddr + EXT2_INO_OFF_MODE + 1, (mode >> 8) & 0xFF)
    volatile_write_u32_le(iaddr + EXT2_INO_OFF_SIZE, 0) // empty file
    volatile_write_u8(iaddr + EXT2_INO_OFF_LINKS, 1) // 1 link
    // Set first block pointer
    volatile_write_u8(iaddr + EXT2_INO_OFF_BLOCK0, new_block & 0xFF)
    volatile_write_u8(iaddr + EXT2_INO_OFF_BLOCK0 + 1, (new_block >> 8) & 0xFF)
    // Write inode back
    let isector = EXT2_INODE_TABLE_SECTOR + ((new_inode - 1) * EXT2_INODE_SIZE) / 512
    blk_write(volatile_read_u64(EXT2_STATE + 8), isector, 1, EXT2_BUF)
    // Add entry to parent directory
    let diaddr = ext2_read_inode(dir_inode)
    if diaddr < 0 { return -1 }
    let dblock = volatile_read_u8(diaddr + EXT2_INO_OFF_BLOCK0) + volatile_read_u8(diaddr + EXT2_INO_OFF_BLOCK0 + 1) * 256
    if dblock == 0 { return -1 }
    ext2_read_block(dblock, EXT2_DIR_BUF)
    // Find free slot
    let mut idx: i64 = 0
    let mut found: i64 = -1
    while idx < EXT2_DIRENTS_PER_BLOCK && found == -1 {
        if ext2_dirent_inode(EXT2_DIR_BUF, idx) == 0 { found = idx }
        idx = idx + 1
    }
    if found == -1 { return -1 }
    ext2_dirent_set(EXT2_DIR_BUF, found, new_inode, name_addr, name_len)
    ext2_write_block(dblock, EXT2_DIR_BUF)
    new_inode
}

// S2.5: ext2_read — read file data
@kernel fn ext2_read_file(inode_num: i64, buf: i64, max_len: i64) -> i64 {
    let iaddr = ext2_read_inode(inode_num)
    if iaddr < 0 { return -1 }
    let size = volatile_read_u8(iaddr + EXT2_INO_OFF_SIZE) +
               volatile_read_u8(iaddr + EXT2_INO_OFF_SIZE + 1) * 256 +
               volatile_read_u8(iaddr + EXT2_INO_OFF_SIZE + 2) * 65536
    let to_read = if max_len < size { max_len } else { size }
    let block0 = volatile_read_u8(iaddr + EXT2_INO_OFF_BLOCK0) + volatile_read_u8(iaddr + EXT2_INO_OFF_BLOCK0 + 1) * 256
    if block0 == 0 { return 0 }
    ext2_read_block(block0, EXT2_FILE_BUF)
    let mut i: i64 = 0
    while i < to_read { volatile_write_u8(buf + i, volatile_read_u8(EXT2_FILE_BUF + i)); i = i + 1 }
    to_read
}

// S2.6: ext2_write — write file data
@kernel fn ext2_write_file(inode_num: i64, data: i64, data_len: i64) -> i64 {
    let iaddr = ext2_read_inode(inode_num)
    if iaddr < 0 { return -1 }
    let block0 = volatile_read_u8(iaddr + EXT2_INO_OFF_BLOCK0) + volatile_read_u8(iaddr + EXT2_INO_OFF_BLOCK0 + 1) * 256
    if block0 == 0 { return -1 }
    // Write data to block
    let mut i: i64 = 0
    while i < data_len && i < EXT2_BLOCK_SIZE { volatile_write_u8(EXT2_FILE_BUF + i, volatile_read_u8(data + i)); i = i + 1 }
    ext2_write_block(block0, EXT2_FILE_BUF)
    // Update size in inode
    volatile_write_u32_le(iaddr + EXT2_INO_OFF_SIZE, data_len)
    let isector = EXT2_INODE_TABLE_SECTOR + ((inode_num - 1) * EXT2_INODE_SIZE) / 512
    blk_write(volatile_read_u64(EXT2_STATE + 8), isector, 1, EXT2_BUF)
    data_len
}

// S2.7: ext2_unlink — remove file from directory
@kernel fn ext2_unlink(dir_inode: i64, name_addr: i64, name_len: i64) -> i64 {
    let diaddr = ext2_read_inode(dir_inode)
    if diaddr < 0 { return -1 }
    let dblock = volatile_read_u8(diaddr + EXT2_INO_OFF_BLOCK0) + volatile_read_u8(diaddr + EXT2_INO_OFF_BLOCK0 + 1) * 256
    if dblock == 0 { return -1 }
    ext2_read_block(dblock, EXT2_DIR_BUF)
    let mut idx: i64 = 0
    while idx < EXT2_DIRENTS_PER_BLOCK {
        let dinode = ext2_dirent_inode(EXT2_DIR_BUF, idx)
        if dinode != 0 {
            let dlen = ext2_dirent_name_len(EXT2_DIR_BUF, idx)
            if dlen == name_len {
                let mut ok: i64 = 1
                let mut j: i64 = 0
                while j < name_len && ok == 1 {
                    if volatile_read_u8(EXT2_DIR_BUF + idx * EXT2_DIRENT_SIZE + 16 + j) != volatile_read_u8(name_addr + j) { ok = 0 }
                    j = j + 1
                }
                if ok == 1 {
                    // Clear directory entry
                    volatile_write_u64(EXT2_DIR_BUF + idx * EXT2_DIRENT_SIZE, 0)
                    ext2_write_block(dblock, EXT2_DIR_BUF)
                    // TODO: free inode + blocks
                    return 0
                }
            }
        }
        idx = idx + 1
    }
    -1
}

// S2.8: `mount /dev/nvme0 /mnt ext2`
@kernel fn cmd_mount_ext2() {
    let blk_dev: i64 = 0 // default NVMe
    volatile_write_u64(EXT2_STATE + 8, blk_dev)
    let result = ext2_read_superblock()
    if result < 0 {
        cprintln("ext2 mount failed (bad superblock)", RED_ON_BLACK)
        return
    }
    volatile_write_u64(EXT2_STATE, 1)
    cprintln("ext2 mounted on /mnt", GREEN_ON_BLACK)
}

// S2.9: VFS integration — ext2 as backend
@kernel fn ext2_vfs_stat(path_addr: i64, path_len: i64) -> i64 {
    if volatile_read_u64(EXT2_STATE) != 1 { return -1 }
    ext2_lookup(EXT2_ROOT_INODE, path_addr, path_len)
}

// `ext2ls` command — list root directory
@kernel fn cmd_ext2ls() {
    if volatile_read_u64(EXT2_STATE) != 1 { cprintln("ext2 not mounted", RED_ON_BLACK); return }
    cprintln("ext2 root directory:", YELLOW_ON_BLACK)
    let iaddr = ext2_read_inode(EXT2_ROOT_INODE)
    if iaddr < 0 { cprintln("  Cannot read root inode", RED_ON_BLACK); return }
    let block0 = volatile_read_u8(iaddr + EXT2_INO_OFF_BLOCK0) + volatile_read_u8(iaddr + EXT2_INO_OFF_BLOCK0 + 1) * 256
    if block0 == 0 { cprintln("  (empty)", WHITE_ON_BLACK); return }
    ext2_read_block(block0, EXT2_DIR_BUF)
    let mut idx: i64 = 0
    while idx < EXT2_DIRENTS_PER_BLOCK {
        let dinode = ext2_dirent_inode(EXT2_DIR_BUF, idx)
        if dinode != 0 {
            cprint("  inode=", WHITE_ON_BLACK)
            cprint_decimal(dinode, CYAN_ON_BLACK)
            cprint(" ", WHITE_ON_BLACK)
            let nlen = ext2_dirent_name_len(EXT2_DIR_BUF, idx)
            let mut j: i64 = 0
            while j < nlen {
                console_putchar(volatile_read_u8(EXT2_DIR_BUF + idx * EXT2_DIRENT_SIZE + 16 + j), GREEN_ON_BLACK)
                j = j + 1
            }
            console_putchar(10, WHITE_ON_BLACK)
        }
        idx = idx + 1
    }
}

// ═══════════════════════════════════════════════
// TCP State Machine (Sprint T1 — v0.9 "Zenith")
// ═══════════════════════════════════════════════

// TCP connection states (RFC 793)
const TCP_CLOSED: i64 = 0
const TCP_LISTEN: i64 = 1
const TCP_SYN_SENT: i64 = 2
const TCP_SYN_RCVD: i64 = 3
const TCP_ESTABLISHED: i64 = 4
const TCP_FIN_WAIT_1: i64 = 5
const TCP_FIN_WAIT_2: i64 = 6
const TCP_CLOSE_WAIT: i64 = 7
const TCP_CLOSING: i64 = 8
const TCP_LAST_ACK: i64 = 9
const TCP_TIME_WAIT: i64 = 10

// TCP flags
const TCP_FIN: i64 = 0x01
const TCP_SYN: i64 = 0x02
const TCP_RST: i64 = 0x04
const TCP_PSH: i64 = 0x08
const TCP_ACK: i64 = 0x10
const TCP_URG: i64 = 0x20

// TCP Control Block table at 0xA04000: 16 connections × 128B
const TCB_TABLE: i64 = 0xA04000
const TCB_MAX: i64 = 16
const TCB_SIZE: i64 = 128
// Per TCB:
const TCB_OFF_STATE: i64 = 0
const TCB_OFF_LOCAL_PORT: i64 = 8
const TCB_OFF_REMOTE_IP: i64 = 16
const TCB_OFF_REMOTE_PORT: i64 = 24
const TCB_OFF_SND_NXT: i64 = 32    // next sequence to send
const TCB_OFF_SND_UNA: i64 = 40    // oldest unacked sequence
const TCB_OFF_RCV_NXT: i64 = 48    // next expected receive seq
const TCB_OFF_WINDOW: i64 = 56     // receive window size
const TCB_OFF_TIMER: i64 = 64      // retransmit timer (tick)
const TCB_OFF_RETRIES: i64 = 72    // retransmission count
const TCB_OFF_SOCKET: i64 = 80     // associated socket slot
const TCB_OFF_RX_LEN: i64 = 88    // received data length
const TCB_OFF_TX_LEN: i64 = 96    // pending transmit length

// Retransmit timeout: 20 ticks = 200ms
const TCP_RTO: i64 = 20
const TCP_MAX_RETRIES: i64 = 5

// T1.1: TCB management
@kernel fn tcp_init() {
    let mut i: i64 = 0
    while i < TCB_MAX * TCB_SIZE { volatile_write_u8(TCB_TABLE + i, 0); i = i + 1 }
}

@kernel fn tcb_alloc() -> i64 {
    let mut i: i64 = 0
    while i < TCB_MAX {
        if volatile_read_u64(TCB_TABLE + i * TCB_SIZE + TCB_OFF_STATE) == TCP_CLOSED { return i }
        i = i + 1
    }
    -1
}

@kernel fn tcb_addr(idx: i64) -> i64 { TCB_TABLE + idx * TCB_SIZE }

@kernel fn tcb_get(idx: i64, field: i64) -> i64 { volatile_read_u64(tcb_addr(idx) + field) }
@kernel fn tcb_set(idx: i64, field: i64, val: i64) { volatile_write_u64(tcb_addr(idx) + field, val) }

// T1.2: TCP state name for display
@kernel fn tcp_state_name(state: i64) {
    if state == TCP_CLOSED { cprint("CLOSED", WHITE_ON_BLACK) }
    else if state == TCP_LISTEN { cprint("LISTEN", GREEN_ON_BLACK) }
    else if state == TCP_SYN_SENT { cprint("SYN_SENT", YELLOW_ON_BLACK) }
    else if state == TCP_SYN_RCVD { cprint("SYN_RCVD", YELLOW_ON_BLACK) }
    else if state == TCP_ESTABLISHED { cprint("ESTABLISHED", GREEN_ON_BLACK) }
    else if state == TCP_FIN_WAIT_1 { cprint("FIN_WAIT_1", YELLOW_ON_BLACK) }
    else if state == TCP_FIN_WAIT_2 { cprint("FIN_WAIT_2", YELLOW_ON_BLACK) }
    else if state == TCP_CLOSE_WAIT { cprint("CLOSE_WAIT", YELLOW_ON_BLACK) }
    else if state == TCP_CLOSING { cprint("CLOSING", YELLOW_ON_BLACK) }
    else if state == TCP_LAST_ACK { cprint("LAST_ACK", YELLOW_ON_BLACK) }
    else if state == TCP_TIME_WAIT { cprint("TIME_WAIT", YELLOW_ON_BLACK) }
    else { cprint("???", RED_ON_BLACK) }
}

// T1.3: Active open (client connect) — send SYN
@kernel fn tcp_connect(tcb: i64, remote_ip: i64, remote_port: i64, local_port: i64) -> i64 {
    tcb_set(tcb, TCB_OFF_LOCAL_PORT, local_port)
    tcb_set(tcb, TCB_OFF_REMOTE_IP, remote_ip)
    tcb_set(tcb, TCB_OFF_REMOTE_PORT, remote_port)
    let isn: i64 = volatile_read_u64(0x6FE08) * 1000 // initial sequence number from tick
    tcb_set(tcb, TCB_OFF_SND_NXT, isn + 1)
    tcb_set(tcb, TCB_OFF_SND_UNA, isn)
    tcb_set(tcb, TCB_OFF_WINDOW, 65535)
    tcb_set(tcb, TCB_OFF_STATE, TCP_SYN_SENT)
    tcb_set(tcb, TCB_OFF_TIMER, volatile_read_u64(0x6FE08) + TCP_RTO)
    tcb_set(tcb, TCB_OFF_RETRIES, 0)
    // Would send SYN packet here via virtio-net
    0
}

// T1.4: Passive open (server accept) — transition on SYN received
@kernel fn tcp_listen(tcb: i64, local_port: i64) -> i64 {
    tcb_set(tcb, TCB_OFF_LOCAL_PORT, local_port)
    tcb_set(tcb, TCB_OFF_STATE, TCP_LISTEN)
    tcb_set(tcb, TCB_OFF_WINDOW, 65535)
    0
}

@kernel fn tcp_on_syn_received(tcb: i64, remote_ip: i64, remote_port: i64, their_seq: i64) {
    tcb_set(tcb, TCB_OFF_REMOTE_IP, remote_ip)
    tcb_set(tcb, TCB_OFF_REMOTE_PORT, remote_port)
    tcb_set(tcb, TCB_OFF_RCV_NXT, their_seq + 1)
    let isn = volatile_read_u64(0x6FE08) * 1000
    tcb_set(tcb, TCB_OFF_SND_NXT, isn + 1)
    tcb_set(tcb, TCB_OFF_SND_UNA, isn)
    tcb_set(tcb, TCB_OFF_STATE, TCP_SYN_RCVD)
    // Would send SYN+ACK here
}

// T1.5: Data transfer (ESTABLISHED state)
@kernel fn tcp_on_data(tcb: i64, data_seq: i64, data_len: i64) {
    let expected = tcb_get(tcb, TCB_OFF_RCV_NXT)
    if data_seq == expected {
        tcb_set(tcb, TCB_OFF_RCV_NXT, expected + data_len)
        let rx_len = tcb_get(tcb, TCB_OFF_RX_LEN)
        tcb_set(tcb, TCB_OFF_RX_LEN, rx_len + data_len)
        // Would send ACK here
    }
    // Out-of-order: drop (simple implementation)
}

// T1.6: ACK processing
@kernel fn tcp_on_ack(tcb: i64, ack_num: i64) {
    let una = tcb_get(tcb, TCB_OFF_SND_UNA)
    if ack_num > una {
        tcb_set(tcb, TCB_OFF_SND_UNA, ack_num)
        // Reset retransmit timer
        tcb_set(tcb, TCB_OFF_TIMER, volatile_read_u64(0x6FE08) + TCP_RTO)
        tcb_set(tcb, TCB_OFF_RETRIES, 0)
    }
    // Handle state transitions on ACK
    let state = tcb_get(tcb, TCB_OFF_STATE)
    if state == TCP_SYN_SENT {
        // SYN+ACK received → ESTABLISHED
        tcb_set(tcb, TCB_OFF_STATE, TCP_ESTABLISHED)
    }
    if state == TCP_SYN_RCVD {
        // ACK of our SYN+ACK → ESTABLISHED
        tcb_set(tcb, TCB_OFF_STATE, TCP_ESTABLISHED)
    }
    if state == TCP_FIN_WAIT_1 {
        tcb_set(tcb, TCB_OFF_STATE, TCP_FIN_WAIT_2)
    }
    if state == TCP_LAST_ACK {
        tcb_set(tcb, TCB_OFF_STATE, TCP_CLOSED)
    }
}

// T1.7: FIN handshake — graceful close
@kernel fn tcp_close(tcb: i64) {
    let state = tcb_get(tcb, TCB_OFF_STATE)
    if state == TCP_ESTABLISHED {
        tcb_set(tcb, TCB_OFF_STATE, TCP_FIN_WAIT_1)
        // Would send FIN here
    }
    if state == TCP_CLOSE_WAIT {
        tcb_set(tcb, TCB_OFF_STATE, TCP_LAST_ACK)
        // Would send FIN here
    }
}

@kernel fn tcp_on_fin(tcb: i64) {
    let state = tcb_get(tcb, TCB_OFF_STATE)
    let rcv_nxt = tcb_get(tcb, TCB_OFF_RCV_NXT)
    tcb_set(tcb, TCB_OFF_RCV_NXT, rcv_nxt + 1) // FIN consumes 1 seq
    if state == TCP_ESTABLISHED {
        tcb_set(tcb, TCB_OFF_STATE, TCP_CLOSE_WAIT)
        // Would send ACK here
    }
    if state == TCP_FIN_WAIT_1 {
        tcb_set(tcb, TCB_OFF_STATE, TCP_CLOSING)
    }
    if state == TCP_FIN_WAIT_2 {
        tcb_set(tcb, TCB_OFF_STATE, TCP_TIME_WAIT)
    }
}

// T1.8: RST handling
@kernel fn tcp_reset(tcb: i64) {
    tcb_set(tcb, TCB_OFF_STATE, TCP_CLOSED)
    tcb_set(tcb, TCB_OFF_RX_LEN, 0)
    tcb_set(tcb, TCB_OFF_TX_LEN, 0)
}

// T1.9: Retransmission timer check (called periodically)
@kernel fn tcp_check_timers() {
    let now = volatile_read_u64(0x6FE08)
    let mut i: i64 = 0
    while i < TCB_MAX {
        let state = tcb_get(i, TCB_OFF_STATE)
        if state != TCP_CLOSED && state != TCP_LISTEN {
            let timer = tcb_get(i, TCB_OFF_TIMER)
            if timer > 0 && now >= timer {
                let retries = tcb_get(i, TCB_OFF_RETRIES)
                if retries >= TCP_MAX_RETRIES {
                    tcp_reset(i) // give up
                } else {
                    tcb_set(i, TCB_OFF_RETRIES, retries + 1)
                    tcb_set(i, TCB_OFF_TIMER, now + TCP_RTO)
                    // Would retransmit unacked data here
                }
            }
        }
        i = i + 1
    }
}

// `tcpstat` command — show TCP connections
@kernel fn cmd_tcpstat() {
    cprintln("TCP connections:", YELLOW_ON_BLACK)
    let mut i: i64 = 0
    let mut count: i64 = 0
    while i < TCB_MAX {
        let state = tcb_get(i, TCB_OFF_STATE)
        if state != TCP_CLOSED {
            cprint("  [", WHITE_ON_BLACK)
            cprint_decimal(i, CYAN_ON_BLACK)
            cprint("] :", WHITE_ON_BLACK)
            cprint_decimal(tcb_get(i, TCB_OFF_LOCAL_PORT), CYAN_ON_BLACK)
            cprint(" → :", WHITE_ON_BLACK)
            cprint_decimal(tcb_get(i, TCB_OFF_REMOTE_PORT), WHITE_ON_BLACK)
            cprint(" seq=", WHITE_ON_BLACK)
            cprint_decimal(tcb_get(i, TCB_OFF_SND_NXT), WHITE_ON_BLACK)
            cprint(" ack=", WHITE_ON_BLACK)
            cprint_decimal(tcb_get(i, TCB_OFF_RCV_NXT), WHITE_ON_BLACK)
            cprint(" ", WHITE_ON_BLACK)
            tcp_state_name(state)
            console_putchar(10, WHITE_ON_BLACK)
            count = count + 1
        }
        i = i + 1
    }
    if count == 0 { cprintln("  (none)", WHITE_ON_BLACK) }
}

// ═══════════════════════════════════════════════
// Network Services (Sprint T2 — v0.9 "Zenith")
// ═══════════════════════════════════════════════

// Network statistics at 0xA06000
const NET_STATS: i64 = 0xA06000
const NSTAT_RX_PACKETS: i64 = 0
const NSTAT_TX_PACKETS: i64 = 8
const NSTAT_RX_BYTES: i64 = 16
const NSTAT_TX_BYTES: i64 = 24
const NSTAT_ERRORS: i64 = 32
const NSTAT_DROPPED: i64 = 40
const NSTAT_TCP_CONNS: i64 = 48
const NSTAT_UDP_DGRAMS: i64 = 56

// ARP aging: max age = 300 ticks (30 seconds at 100Hz)
const ARP_MAX_AGE: i64 = 300
const ARP_MAX_ENTRIES: i64 = 16

// T2.1: TCP server multi-client (up to 4)
@kernel fn tcp_server_accept(listen_tcb: i64) -> i64 {
    let state = tcb_get(listen_tcb, TCB_OFF_STATE)
    if state != TCP_LISTEN { return -1 }
    // Allocate new TCB for accepted connection
    let new_tcb = tcb_alloc()
    if new_tcb < 0 { return -1 }
    tcb_set(new_tcb, TCB_OFF_LOCAL_PORT, tcb_get(listen_tcb, TCB_OFF_LOCAL_PORT))
    tcb_set(new_tcb, TCB_OFF_STATE, TCP_ESTABLISHED)
    tcb_set(new_tcb, TCB_OFF_WINDOW, 65535)
    let isn = volatile_read_u64(0x6FE08) * 1000
    tcb_set(new_tcb, TCB_OFF_SND_NXT, isn + 1)
    tcb_set(new_tcb, TCB_OFF_SND_UNA, isn)
    // Update stats
    let conns = volatile_read_u64(NET_STATS + NSTAT_TCP_CONNS)
    volatile_write_u64(NET_STATS + NSTAT_TCP_CONNS, conns + 1)
    new_tcb
}

// T2.2: UDP socket support
@kernel fn udp_send(local_port: i64, remote_ip: i64, remote_port: i64, data: i64, len: i64) -> i64 {
    // Build UDP header (8 bytes) + data
    let pkt: i64 = 0xA06100
    // Source port (2B)
    volatile_write_u8(pkt, (local_port >> 8) & 0xFF)
    volatile_write_u8(pkt + 1, local_port & 0xFF)
    // Dest port (2B)
    volatile_write_u8(pkt + 2, (remote_port >> 8) & 0xFF)
    volatile_write_u8(pkt + 3, remote_port & 0xFF)
    // Length (2B)
    let total = 8 + len
    volatile_write_u8(pkt + 4, (total >> 8) & 0xFF)
    volatile_write_u8(pkt + 5, total & 0xFF)
    // Checksum (0 = disabled)
    volatile_write_u8(pkt + 6, 0)
    volatile_write_u8(pkt + 7, 0)
    // Copy data
    let mut i: i64 = 0
    while i < len { volatile_write_u8(pkt + 8 + i, volatile_read_u8(data + i)); i = i + 1 }
    let dgrams = volatile_read_u64(NET_STATS + NSTAT_UDP_DGRAMS)
    volatile_write_u64(NET_STATS + NSTAT_UDP_DGRAMS, dgrams + 1)
    total
}

// T2.3: `telnet` command — simple TCP terminal client
@kernel fn cmd_telnet() {
    let len = cmdbuf_len()
    if len <= 7 { cprintln("Usage: telnet <ip> <port>", YELLOW_ON_BLACK); return }
    cprintln("Telnet client (simulated):", YELLOW_ON_BLACK)
    let tcb = tcb_alloc()
    if tcb < 0 { cprintln("  No free TCB", RED_ON_BLACK); return }
    // Parse IP and port from command (simplified: use defaults)
    tcp_connect(tcb, 0x0A000202, 23, 49200 + tcb) // 10.0.2.2:23
    cprint("  Connecting to 10.0.2.2:23 (TCB ", WHITE_ON_BLACK)
    cprint_decimal(tcb, CYAN_ON_BLACK)
    cprintln(")...", WHITE_ON_BLACK)
    cprint("  State: ", WHITE_ON_BLACK)
    tcp_state_name(tcb_get(tcb, TCB_OFF_STATE))
    console_putchar(10, WHITE_ON_BLACK)
}

// T2.4: Echo server — listen on port 7
@kernel fn cmd_echo_server() {
    cprintln("Echo server on port 7:", YELLOW_ON_BLACK)
    let tcb = tcb_alloc()
    if tcb < 0 { cprintln("  No free TCB", RED_ON_BLACK); return }
    tcp_listen(tcb, 7)
    cprint("  Listening on :7 (TCB ", WHITE_ON_BLACK)
    cprint_decimal(tcb, CYAN_ON_BLACK)
    cprintln(")", WHITE_ON_BLACK)
    cprint("  State: ", WHITE_ON_BLACK)
    tcp_state_name(tcb_get(tcb, TCB_OFF_STATE))
    console_putchar(10, WHITE_ON_BLACK)
}

// T2.5: DNS client v2 — with retry and timeout
@kernel fn dns_resolve_v2(name_addr: i64, name_len: i64) -> i64 {
    let mut retries: i64 = 0
    let max_retries: i64 = 3
    let mut result: i64 = -1
    while retries < max_retries && result < 0 {
        // Send DNS query via UDP to 10.0.2.3:53
        result = udp_send(53000 + retries, 0x0A000203, 53, name_addr, name_len)
        if result < 0 { retries = retries + 1 }
        else { result = 0 }
    }
    result
}

// T2.6: DHCP client v2 — with lease renewal
@kernel fn dhcp_renew() {
    cprint("[DHCP] Renewing lease at T=", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(0x6FE08), CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    // Would send DHCP Request to renew lease
}

// T2.7: Enhanced `ifconfig`
@kernel fn cmd_ifconfig_v2() {
    cprintln("Network interfaces:", YELLOW_ON_BLACK)
    cprint("  eth0: ", WHITE_ON_BLACK)
    // Read IP from net state
    let ip = net_state_read(16)
    if ip != 0 {
        cprint_decimal((ip >> 24) & 0xFF, CYAN_ON_BLACK); cprint(".", WHITE_ON_BLACK)
        cprint_decimal((ip >> 16) & 0xFF, CYAN_ON_BLACK); cprint(".", WHITE_ON_BLACK)
        cprint_decimal((ip >> 8) & 0xFF, CYAN_ON_BLACK); cprint(".", WHITE_ON_BLACK)
        cprint_decimal(ip & 0xFF, CYAN_ON_BLACK)
    } else { cprint("(no IP)", WHITE_ON_BLACK) }
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  RX: ", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_RX_PACKETS), CYAN_ON_BLACK)
    cprint(" pkts, ", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_RX_BYTES), CYAN_ON_BLACK)
    cprintln(" bytes", WHITE_ON_BLACK)
    cprint("  TX: ", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_TX_PACKETS), CYAN_ON_BLACK)
    cprint(" pkts, ", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_TX_BYTES), CYAN_ON_BLACK)
    cprintln(" bytes", WHITE_ON_BLACK)
    cprint("  Errors: ", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_ERRORS), WHITE_ON_BLACK)
    cprint("  Dropped: ", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_DROPPED), WHITE_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  TCP conns: ", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_TCP_CONNS), CYAN_ON_BLACK)
    cprint("  UDP dgrams: ", WHITE_ON_BLACK)
    cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_UDP_DGRAMS), CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// T2.8: ARP table with aging
@kernel fn arp_check_age() {
    let now = volatile_read_u64(0x6FE08)
    let arp_cache = 0x878000  // existing ARP cache address
    let mut i: i64 = 0
    while i < ARP_MAX_ENTRIES {
        let entry = arp_cache + i * 16
        let ip = volatile_read_u64(entry)
        if ip != 0 {
            let timestamp = volatile_read_u64(entry + 8) & 0xFFFFFFFF0000
            let age = now - (timestamp >> 16)
            if age > ARP_MAX_AGE {
                volatile_write_u64(entry, 0) // expire entry
                volatile_write_u64(entry + 8, 0)
            }
        }
        i = i + 1
    }
}

// T2.9: Network statistics
@kernel fn net_stats_init() {
    let mut i: i64 = 0
    while i < 64 { volatile_write_u8(NET_STATS + i, 0); i = i + 1 }
}

@kernel fn net_stat_inc(field: i64, amount: i64) {
    let val = volatile_read_u64(NET_STATS + field)
    volatile_write_u64(NET_STATS + field, val + amount)
}

@kernel fn cmd_netstat_v2() {
    cprintln("Network statistics:", YELLOW_ON_BLACK)
    cprint("  RX packets: ", WHITE_ON_BLACK); cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_RX_PACKETS), CYAN_ON_BLACK); console_putchar(10, WHITE_ON_BLACK)
    cprint("  TX packets: ", WHITE_ON_BLACK); cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_TX_PACKETS), CYAN_ON_BLACK); console_putchar(10, WHITE_ON_BLACK)
    cprint("  RX bytes:   ", WHITE_ON_BLACK); cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_RX_BYTES), CYAN_ON_BLACK); console_putchar(10, WHITE_ON_BLACK)
    cprint("  TX bytes:   ", WHITE_ON_BLACK); cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_TX_BYTES), CYAN_ON_BLACK); console_putchar(10, WHITE_ON_BLACK)
    cprint("  Errors:     ", WHITE_ON_BLACK); cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_ERRORS), WHITE_ON_BLACK); console_putchar(10, WHITE_ON_BLACK)
    cprint("  Dropped:    ", WHITE_ON_BLACK); cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_DROPPED), WHITE_ON_BLACK); console_putchar(10, WHITE_ON_BLACK)
    cprint("  TCP conns:  ", WHITE_ON_BLACK); cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_TCP_CONNS), CYAN_ON_BLACK); console_putchar(10, WHITE_ON_BLACK)
    cprint("  UDP dgrams: ", WHITE_ON_BLACK); cprint_decimal(volatile_read_u64(NET_STATS + NSTAT_UDP_DGRAMS), CYAN_ON_BLACK); console_putchar(10, WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Init System + Services (Sprint U1 — v0.9 "Zenith")
// ═══════════════════════════════════════════════

// Service table at 0x9B0000: 16 services × 64B
// Per service: +0=name[16], +16=pid(i64), +24=state(i64), +32=restart_policy(i64), +40=start_tick(i64), +48=restarts(i64), +56=enabled(i64)
const SVC_TABLE: i64 = 0x9B0000
const SVC_MAX: i64 = 16
const SVC_SIZE: i64 = 64
const SVC_OFF_NAME: i64 = 0
const SVC_OFF_PID: i64 = 16
const SVC_OFF_STATE: i64 = 24
const SVC_OFF_RESTART: i64 = 32
const SVC_OFF_START_TICK: i64 = 40
const SVC_OFF_RESTARTS: i64 = 48
const SVC_OFF_ENABLED: i64 = 56

// Service states
const SVC_STOPPED: i64 = 0
const SVC_RUNNING: i64 = 1
const SVC_FAILED: i64 = 2
const SVC_STARTING: i64 = 3

// Restart policies
const RESTART_NO: i64 = 0
const RESTART_ALWAYS: i64 = 1
const RESTART_ON_FAILURE: i64 = 2

// Runlevels
const RUNLEVEL_HALT: i64 = 0
const RUNLEVEL_SINGLE: i64 = 1
const RUNLEVEL_MULTI: i64 = 3
const RUNLEVEL_GRAPHICAL: i64 = 5

// Current runlevel at 0x9B1000
const CURRENT_RUNLEVEL: i64 = 0x9B1000

// U1.1: Init service table
@kernel fn svc_init() {
    let mut i: i64 = 0
    while i < SVC_MAX * SVC_SIZE { volatile_write_u8(SVC_TABLE + i, 0); i = i + 1 }
    volatile_write_u64(CURRENT_RUNLEVEL, RUNLEVEL_MULTI) // default: multi-user
}

// U1.2: Register a service
@kernel fn svc_register(name_addr: i64, name_len: i64, restart_policy: i64) -> i64 {
    let mut slot: i64 = -1
    let mut i: i64 = 0
    while i < SVC_MAX && slot == -1 {
        if volatile_read_u64(SVC_TABLE + i * SVC_SIZE + SVC_OFF_ENABLED) == 0 { slot = i }
        i = i + 1
    }
    if slot == -1 { return -1 }
    let entry = SVC_TABLE + slot * SVC_SIZE
    let mut ni: i64 = 0
    while ni < name_len && ni < 15 {
        volatile_write_u8(entry + SVC_OFF_NAME + ni, volatile_read_u8(name_addr + ni))
        ni = ni + 1
    }
    volatile_write_u8(entry + SVC_OFF_NAME + ni, 0)
    volatile_write_u64(entry + SVC_OFF_PID, 0)
    volatile_write_u64(entry + SVC_OFF_STATE, SVC_STOPPED)
    volatile_write_u64(entry + SVC_OFF_RESTART, restart_policy)
    volatile_write_u64(entry + SVC_OFF_RESTARTS, 0)
    volatile_write_u64(entry + SVC_OFF_ENABLED, 1)
    slot
}

// U1.3: `service start <name>`
@kernel fn cmd_service() {
    let len = cmdbuf_len()
    if len <= 8 { cprintln("Usage: service start|stop|status [name]", YELLOW_ON_BLACK); return }
    // Parse subcommand
    let c0 = volatile_read_u8(0x6F800 + 8)
    if c0 == 115 && volatile_read_u8(0x6F800 + 9) == 116 && volatile_read_u8(0x6F800 + 10) == 97 {
        // "start"
        if len > 14 { svc_start_by_name(14) }
        else { cprintln("Usage: service start <name>", YELLOW_ON_BLACK) }
    } else if c0 == 115 && volatile_read_u8(0x6F800 + 9) == 116 && volatile_read_u8(0x6F800 + 10) == 111 {
        // "stop"
        if len > 13 { svc_stop_by_name(13) }
        else { cprintln("Usage: service stop <name>", YELLOW_ON_BLACK) }
    } else if c0 == 115 && volatile_read_u8(0x6F800 + 9) == 116 && volatile_read_u8(0x6F800 + 10) == 97 && volatile_read_u8(0x6F800 + 11) == 116 {
        // "status"
        cmd_service_status()
    } else { cmd_service_status() }
}

@kernel fn svc_find(name_addr: i64, name_len: i64) -> i64 {
    let mut i: i64 = 0
    while i < SVC_MAX {
        let entry = SVC_TABLE + i * SVC_SIZE
        if volatile_read_u64(entry + SVC_OFF_ENABLED) == 1 {
            let mut ok: i64 = 1
            let mut j: i64 = 0
            while j < name_len && ok == 1 {
                if volatile_read_u8(entry + SVC_OFF_NAME + j) != volatile_read_u8(name_addr + j) { ok = 0 }
                j = j + 1
            }
            if ok == 1 && volatile_read_u8(entry + SVC_OFF_NAME + name_len) == 0 { return i }
        }
        i = i + 1
    }
    -1
}

@kernel fn svc_start_by_name(prefix: i64) {
    let name_buf: i64 = 0x9B1100
    let len = cmdbuf_len()
    let mut ni: i64 = 0
    let mut pos: i64 = prefix
    while pos < len && ni < 15 { volatile_write_u8(name_buf + ni, volatile_read_u8(0x6F800 + pos)); ni = ni + 1; pos = pos + 1 }
    volatile_write_u8(name_buf + ni, 0)
    let slot = svc_find(name_buf, ni)
    if slot < 0 {
        // Auto-register
        let ns = svc_register(name_buf, ni, RESTART_NO)
        if ns < 0 { cprintln("Cannot register service", RED_ON_BLACK); return }
        svc_start(ns)
    } else { svc_start(slot) }
}

@kernel fn svc_start(slot: i64) {
    let entry = SVC_TABLE + slot * SVC_SIZE
    volatile_write_u64(entry + SVC_OFF_STATE, SVC_RUNNING)
    volatile_write_u64(entry + SVC_OFF_START_TICK, volatile_read_u64(0x6FE08))
    cprint("[SVC] Started: ", WHITE_ON_BLACK)
    let mut i: i64 = 0
    while i < 15 { let ch = volatile_read_u8(entry + SVC_OFF_NAME + i); if ch == 0 { i = 15 } else { console_putchar(ch, GREEN_ON_BLACK); i = i + 1 } }
    console_putchar(10, WHITE_ON_BLACK)
}

// U1.4: `service stop <name>`
@kernel fn svc_stop_by_name(prefix: i64) {
    let name_buf: i64 = 0x9B1100
    let len = cmdbuf_len()
    let mut ni: i64 = 0
    let mut pos: i64 = prefix
    while pos < len && ni < 15 { volatile_write_u8(name_buf + ni, volatile_read_u8(0x6F800 + pos)); ni = ni + 1; pos = pos + 1 }
    volatile_write_u8(name_buf + ni, 0)
    let slot = svc_find(name_buf, ni)
    if slot < 0 { cprintln("Service not found", RED_ON_BLACK); return }
    svc_stop(slot)
}

@kernel fn svc_stop(slot: i64) {
    let entry = SVC_TABLE + slot * SVC_SIZE
    volatile_write_u64(entry + SVC_OFF_STATE, SVC_STOPPED)
    cprint("[SVC] Stopped: ", WHITE_ON_BLACK)
    let mut i: i64 = 0
    while i < 15 { let ch = volatile_read_u8(entry + SVC_OFF_NAME + i); if ch == 0 { i = 15 } else { console_putchar(ch, YELLOW_ON_BLACK); i = i + 1 } }
    console_putchar(10, WHITE_ON_BLACK)
}

// U1.5: `service status`
@kernel fn cmd_service_status() {
    cprintln("Services:", YELLOW_ON_BLACK)
    let mut i: i64 = 0
    let mut count: i64 = 0
    while i < SVC_MAX {
        let entry = SVC_TABLE + i * SVC_SIZE
        if volatile_read_u64(entry + SVC_OFF_ENABLED) == 1 {
            cprint("  ", WHITE_ON_BLACK)
            let mut j: i64 = 0
            while j < 15 { let ch = volatile_read_u8(entry + SVC_OFF_NAME + j); if ch == 0 { j = 15 } else { console_putchar(ch, WHITE_ON_BLACK); j = j + 1 } }
            cprint(": ", WHITE_ON_BLACK)
            let state = volatile_read_u64(entry + SVC_OFF_STATE)
            if state == SVC_RUNNING { cprint("running", GREEN_ON_BLACK) }
            else if state == SVC_STOPPED { cprint("stopped", WHITE_ON_BLACK) }
            else if state == SVC_FAILED { cprint("failed", RED_ON_BLACK) }
            else { cprint("starting", YELLOW_ON_BLACK) }
            let restarts = volatile_read_u64(entry + SVC_OFF_RESTARTS)
            if restarts > 0 {
                cprint(" (restarts: ", WHITE_ON_BLACK); cprint_decimal(restarts, CYAN_ON_BLACK); cprint(")", WHITE_ON_BLACK)
            }
            console_putchar(10, WHITE_ON_BLACK)
            count = count + 1
        }
        i = i + 1
    }
    if count == 0 { cprintln("  (no services)", WHITE_ON_BLACK) }
}

// U1.6: Auto-restart crashed services
@kernel fn svc_check_restart() {
    let mut i: i64 = 0
    while i < SVC_MAX {
        let entry = SVC_TABLE + i * SVC_SIZE
        if volatile_read_u64(entry + SVC_OFF_ENABLED) == 1 {
            let state = volatile_read_u64(entry + SVC_OFF_STATE)
            let policy = volatile_read_u64(entry + SVC_OFF_RESTART)
            if state == SVC_FAILED && (policy == RESTART_ALWAYS || policy == RESTART_ON_FAILURE) {
                let restarts = volatile_read_u64(entry + SVC_OFF_RESTARTS)
                volatile_write_u64(entry + SVC_OFF_RESTARTS, restarts + 1)
                svc_start(i)
            }
        }
        i = i + 1
    }
}

// U1.7: Runlevels
@kernel fn cmd_runlevel() {
    let rl = volatile_read_u64(CURRENT_RUNLEVEL)
    cprint("Current runlevel: ", WHITE_ON_BLACK)
    cprint_decimal(rl, CYAN_ON_BLACK)
    cprint(" (", WHITE_ON_BLACK)
    if rl == 0 { cprint("halt", RED_ON_BLACK) }
    else if rl == 1 { cprint("single-user", YELLOW_ON_BLACK) }
    else if rl == 3 { cprint("multi-user", GREEN_ON_BLACK) }
    else if rl == 5 { cprint("graphical", CYAN_ON_BLACK) }
    else { cprint("custom", WHITE_ON_BLACK) }
    cprintln(")", WHITE_ON_BLACK)
}

// U1.9: `init <level>` — switch runlevel
@kernel fn cmd_init_level() {
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: init <0|1|3|5>", YELLOW_ON_BLACK); return }
    let level = volatile_read_u8(0x6F800 + 5) - 48
    volatile_write_u64(CURRENT_RUNLEVEL, level)
    cprint("Switching to runlevel ", WHITE_ON_BLACK)
    cprint_decimal(level, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    if level == 0 { cprintln("Halting...", RED_ON_BLACK); shutdown_clean() }
}

// ═══════════════════════════════════════════════
// Daemon Infrastructure (Sprint U2 — v0.9 "Zenith")
// ═══════════════════════════════════════════════

// Kernel log ring buffer at 0x9B2000 (8KB)
const KLOG_BUF: i64 = 0x9B2000
const KLOG_SIZE: i64 = 8192
const KLOG_HEAD: i64 = 0x9B4000  // write position
const KLOG_COUNT: i64 = 0x9B4008 // total messages

// Syslog buffer at 0x9B5000 (8KB for /var/log/syslog)
const SYSLOG_BUF: i64 = 0x9B5000
const SYSLOG_SIZE: i64 = 8192
const SYSLOG_POS: i64 = 0x9B7000
const SYSLOG_MAX_ROTATE: i64 = 65536 // rotate at 64KB

// Crontab at 0x9B8000: 8 entries × 64B
const CRONTAB: i64 = 0x9B8000
const CRON_MAX: i64 = 8
const CRON_SIZE: i64 = 64
// Per entry: +0=minute(i64), +8=hour(i64), +16=interval_ticks(i64), +24=last_run(i64), +32=command[32]
const CRON_OFF_INTERVAL: i64 = 16
const CRON_OFF_LAST_RUN: i64 = 24
const CRON_OFF_CMD: i64 = 32
const CRON_OFF_ACTIVE: i64 = 56

// PID file directory at 0x9B9000 (16 services × 16B: name_hash + pid)
const PIDFILE_TABLE: i64 = 0x9B9000

// U2.1: Syslog — centralized logging
@kernel fn syslog_write(level: i64, msg: str) {
    let pos = volatile_read_u64(SYSLOG_POS)
    let mlen = str_len(msg)
    // Write timestamp
    let tick = volatile_read_u64(0x6FE08)
    let secs = tick / 100
    // Format: "[TICK] LEVEL: message\n"
    let mut wp = pos
    volatile_write_u8(SYSLOG_BUF + (wp % SYSLOG_SIZE), 91) // '['
    wp = wp + 1
    // Write seconds (simple: up to 5 digits)
    let mut tmp = secs
    let digit_buf: i64 = 0x9B7010
    let mut dc: i64 = 0
    if tmp == 0 { volatile_write_u8(digit_buf, 48); dc = 1 }
    else { while tmp > 0 { volatile_write_u8(digit_buf + dc, 48 + (tmp % 10)); dc = dc + 1; tmp = tmp / 10 } }
    let mut di = dc - 1
    while di >= 0 {
        volatile_write_u8(SYSLOG_BUF + (wp % SYSLOG_SIZE), volatile_read_u8(digit_buf + di))
        wp = wp + 1; di = di - 1
    }
    volatile_write_u8(SYSLOG_BUF + (wp % SYSLOG_SIZE), 93) // ']'
    wp = wp + 1
    volatile_write_u8(SYSLOG_BUF + (wp % SYSLOG_SIZE), 32) // ' '
    wp = wp + 1
    // Write message
    let mut i: i64 = 0
    while i < mlen {
        volatile_write_u8(SYSLOG_BUF + (wp % SYSLOG_SIZE), str_byte_at(msg, i))
        wp = wp + 1; i = i + 1
    }
    volatile_write_u8(SYSLOG_BUF + (wp % SYSLOG_SIZE), 10) // '\n'
    wp = wp + 1
    volatile_write_u64(SYSLOG_POS, wp)
    volatile_write_u64(KLOG_COUNT, volatile_read_u64(KLOG_COUNT) + 1)
}

// U2.2: crond — periodic task execution
@kernel fn cron_init() {
    let mut i: i64 = 0
    while i < CRON_MAX * CRON_SIZE { volatile_write_u8(CRONTAB + i, 0); i = i + 1 }
}

@kernel fn cron_add(interval_ticks: i64, cmd_addr: i64, cmd_len: i64) -> i64 {
    let mut slot: i64 = -1
    let mut i: i64 = 0
    while i < CRON_MAX && slot == -1 {
        if volatile_read_u64(CRONTAB + i * CRON_SIZE + CRON_OFF_ACTIVE) == 0 { slot = i }
        i = i + 1
    }
    if slot == -1 { return -1 }
    let entry = CRONTAB + slot * CRON_SIZE
    volatile_write_u64(entry + CRON_OFF_INTERVAL, interval_ticks)
    volatile_write_u64(entry + CRON_OFF_LAST_RUN, volatile_read_u64(0x6FE08))
    let cl = if cmd_len < 31 { cmd_len } else { 31 }
    let mut ci: i64 = 0
    while ci < cl { volatile_write_u8(entry + CRON_OFF_CMD + ci, volatile_read_u8(cmd_addr + ci)); ci = ci + 1 }
    volatile_write_u8(entry + CRON_OFF_CMD + cl, 0)
    volatile_write_u64(entry + CRON_OFF_ACTIVE, 1)
    slot
}

@kernel fn cron_check() {
    let now = volatile_read_u64(0x6FE08)
    let mut i: i64 = 0
    while i < CRON_MAX {
        let entry = CRONTAB + i * CRON_SIZE
        if volatile_read_u64(entry + CRON_OFF_ACTIVE) == 1 {
            let interval = volatile_read_u64(entry + CRON_OFF_INTERVAL)
            let last = volatile_read_u64(entry + CRON_OFF_LAST_RUN)
            if now - last >= interval {
                volatile_write_u64(entry + CRON_OFF_LAST_RUN, now)
                // Execute command
                let cmd = entry + CRON_OFF_CMD
                let mut cl: i64 = 0
                while cl < 31 && volatile_read_u8(cmd + cl) != 0 { cl = cl + 1 }
                shell_exec_from_buf(cmd, cl)
            }
        }
        i = i + 1
    }
}

// U2.3: Crontab command
@kernel fn cmd_crontab() {
    let len = cmdbuf_len()
    if len <= 8 {
        // List cron entries
        cprintln("Crontab:", YELLOW_ON_BLACK)
        let mut i: i64 = 0
        let mut count: i64 = 0
        while i < CRON_MAX {
            let entry = CRONTAB + i * CRON_SIZE
            if volatile_read_u64(entry + CRON_OFF_ACTIVE) == 1 {
                cprint("  [", WHITE_ON_BLACK); cprint_decimal(i, CYAN_ON_BLACK); cprint("] every ", WHITE_ON_BLACK)
                cprint_decimal(volatile_read_u64(entry + CRON_OFF_INTERVAL) / 100, CYAN_ON_BLACK)
                cprint("s: ", WHITE_ON_BLACK)
                let mut j: i64 = 0
                while j < 31 { let ch = volatile_read_u8(entry + CRON_OFF_CMD + j); if ch == 0 { j = 31 } else { console_putchar(ch, GREEN_ON_BLACK); j = j + 1 } }
                console_putchar(10, WHITE_ON_BLACK)
                count = count + 1
            }
            i = i + 1
        }
        if count == 0 { cprintln("  (empty)", WHITE_ON_BLACK) }
        return
    }
    // "crontab <interval_sec> <command>"
    cprintln("Use: crontab <sec> <cmd>", YELLOW_ON_BLACK)
}

// U2.5: PID files
@kernel fn pidfile_write(svc_slot: i64, pid: i64) {
    volatile_write_u64(PIDFILE_TABLE + svc_slot * 16, svc_slot + 1) // name hash (simplified)
    volatile_write_u64(PIDFILE_TABLE + svc_slot * 16 + 8, pid)
}

@kernel fn pidfile_read(svc_slot: i64) -> i64 {
    volatile_read_u64(PIDFILE_TABLE + svc_slot * 16 + 8)
}

// U2.6: `dmesg` — kernel message ring buffer
@kernel fn klog_write(msg: str) {
    let head = volatile_read_u64(KLOG_HEAD)
    let mlen = str_len(msg)
    let mut i: i64 = 0
    while i < mlen {
        volatile_write_u8(KLOG_BUF + ((head + i) % KLOG_SIZE), str_byte_at(msg, i))
        i = i + 1
    }
    volatile_write_u8(KLOG_BUF + ((head + mlen) % KLOG_SIZE), 10)
    volatile_write_u64(KLOG_HEAD, head + mlen + 1)
}

@kernel fn cmd_dmesg_v2() {
    cprintln("Kernel messages:", YELLOW_ON_BLACK)
    let head = volatile_read_u64(KLOG_HEAD)
    let start = if head > KLOG_SIZE { head - KLOG_SIZE } else { 0 }
    let mut pos = start
    while pos < head {
        let ch = volatile_read_u8(KLOG_BUF + (pos % KLOG_SIZE))
        console_putchar(ch, WHITE_ON_BLACK)
        pos = pos + 1
    }
    if head == 0 { cprintln("  (empty)", WHITE_ON_BLACK) }
}

// U2.7: Log rotation
@kernel fn syslog_check_rotate() {
    let pos = volatile_read_u64(SYSLOG_POS)
    if pos >= SYSLOG_MAX_ROTATE {
        // Rotate: keep last SYSLOG_SIZE bytes, reset position
        volatile_write_u64(SYSLOG_POS, 0)
        syslog_write(0, "Log rotated")
    }
}

// U2.8: `systemctl` alias
@kernel fn cmd_systemctl() { cmd_service() }

// U2.9: Shutdown sequence — stop services in reverse order
@kernel fn shutdown_services() {
    cprintln("[INIT] Stopping services...", YELLOW_ON_BLACK)
    let mut i = SVC_MAX - 1
    while i >= 0 {
        let entry = SVC_TABLE + i * SVC_SIZE
        if volatile_read_u64(entry + SVC_OFF_ENABLED) == 1 && volatile_read_u64(entry + SVC_OFF_STATE) == SVC_RUNNING {
            svc_stop(i)
        }
        i = i - 1
    }
    cprintln("[INIT] All services stopped", GREEN_ON_BLACK)
    syslog_write(0, "System shutdown")
    journal_commit()
    cprintln("[INIT] Filesystem synced", GREEN_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Package Manager (Sprint V1 — v0.9 "Zenith")
// ═══════════════════════════════════════════════

// Package database at 0x9C0000: 32 packages × 128B
// Per package: +0=name[24], +24=version[8], +32=state(i64: 0=none,1=installed,2=available),
//              +40=deps[32] (comma-sep dep names), +72=files_count(i64),
//              +80=size(i64), +88=checksum(i64), +96=description[32]
const PKG_DB: i64 = 0x9C0000
const PKG_MAX: i64 = 32
const PKG_SIZE: i64 = 128
const PKG_OFF_NAME: i64 = 0
const PKG_OFF_VERSION: i64 = 24
const PKG_OFF_STATE: i64 = 32
const PKG_OFF_DEPS: i64 = 40
const PKG_OFF_FILES: i64 = 72
const PKG_OFF_PKG_SIZE: i64 = 80
const PKG_OFF_CHECKSUM: i64 = 88
const PKG_OFF_DESC: i64 = 96

const PKG_NONE: i64 = 0
const PKG_INSTALLED: i64 = 1
const PKG_AVAILABLE: i64 = 2

// V1.1: Initialize package database
@kernel fn pkg_init() {
    let mut i: i64 = 0
    while i < PKG_MAX * PKG_SIZE { volatile_write_u8(PKG_DB + i, 0); i = i + 1 }
}

// V1.2: Find package by name
@kernel fn pkg_find(name_addr: i64, name_len: i64) -> i64 {
    let mut i: i64 = 0
    while i < PKG_MAX {
        let entry = PKG_DB + i * PKG_SIZE
        if volatile_read_u8(entry) != 0 {
            let mut ok: i64 = 1
            let mut j: i64 = 0
            while j < name_len && ok == 1 {
                if volatile_read_u8(entry + j) != volatile_read_u8(name_addr + j) { ok = 0 }
                j = j + 1
            }
            if ok == 1 && volatile_read_u8(entry + name_len) == 0 { return i }
        }
        i = i + 1
    }
    -1
}

// V1.3: `pkg install <name>`
@kernel fn cmd_pkg() {
    let len = cmdbuf_len()
    if len <= 4 { cprintln("Usage: pkg install|remove|list|search|info <name>", YELLOW_ON_BLACK); return }
    let c0 = volatile_read_u8(0x6F800 + 4)
    if c0 == 105 { cmd_pkg_install() }       // 'i' = install
    else if c0 == 114 { cmd_pkg_remove() }    // 'r' = remove
    else if c0 == 108 { cmd_pkg_list() }      // 'l' = list
    else if c0 == 115 { cmd_pkg_search() }    // 's' = search
    else if c0 == 105 { cmd_pkg_info() }      // 'i' = info (disambiguated below)
    else { cmd_pkg_list() }
}

@kernel fn cmd_pkg_install() {
    let len = cmdbuf_len()
    if len <= 12 { cprintln("Usage: pkg install <name>", YELLOW_ON_BLACK); return }
    let name_buf: i64 = 0x9C1000
    let mut ni: i64 = 0
    let mut pos: i64 = 12
    while pos < len && ni < 23 { volatile_write_u8(name_buf + ni, volatile_read_u8(0x6F800 + pos)); ni = ni + 1; pos = pos + 1 }
    volatile_write_u8(name_buf + ni, 0)
    // Check if already installed
    let existing = pkg_find(name_buf, ni)
    if existing >= 0 {
        let state = volatile_read_u64(PKG_DB + existing * PKG_SIZE + PKG_OFF_STATE)
        if state == PKG_INSTALLED { cprintln("Already installed", YELLOW_ON_BLACK); return }
    }
    // V1.7: Check dependencies (simplified)
    // In a real system, we'd resolve deps recursively
    // Allocate slot
    let mut slot: i64 = -1
    if existing >= 0 { slot = existing }
    else {
        let mut si: i64 = 0
        while si < PKG_MAX && slot == -1 {
            if volatile_read_u8(PKG_DB + si * PKG_SIZE) == 0 { slot = si }
            si = si + 1
        }
    }
    if slot == -1 { cprintln("Package database full", RED_ON_BLACK); return }
    let entry = PKG_DB + slot * PKG_SIZE
    // Write name
    let mut ci: i64 = 0
    while ci <= ni { volatile_write_u8(entry + PKG_OFF_NAME + ci, volatile_read_u8(name_buf + ci)); ci = ci + 1 }
    // Set version "1.0"
    volatile_write_u8(entry + PKG_OFF_VERSION, 49); volatile_write_u8(entry + PKG_OFF_VERSION + 1, 46)
    volatile_write_u8(entry + PKG_OFF_VERSION + 2, 48); volatile_write_u8(entry + PKG_OFF_VERSION + 3, 0)
    volatile_write_u64(entry + PKG_OFF_STATE, PKG_INSTALLED)
    // V1.8: Checksum (FNV hash of name)
    volatile_write_u64(entry + PKG_OFF_CHECKSUM, simple_hash(name_buf))
    volatile_write_u64(entry + PKG_OFF_FILES, 0)
    volatile_write_u64(entry + PKG_OFF_PKG_SIZE, 0)
    cprint("Installed: ", WHITE_ON_BLACK)
    ci = 0
    while ci < ni { console_putchar(volatile_read_u8(name_buf + ci), GREEN_ON_BLACK); ci = ci + 1 }
    cprintln(" (1.0)", WHITE_ON_BLACK)
}

// V1.4: `pkg remove <name>`
@kernel fn cmd_pkg_remove() {
    let len = cmdbuf_len()
    if len <= 11 { cprintln("Usage: pkg remove <name>", YELLOW_ON_BLACK); return }
    let name_buf: i64 = 0x9C1000
    let mut ni: i64 = 0
    let mut pos: i64 = 11
    while pos < len && ni < 23 { volatile_write_u8(name_buf + ni, volatile_read_u8(0x6F800 + pos)); ni = ni + 1; pos = pos + 1 }
    volatile_write_u8(name_buf + ni, 0)
    let slot = pkg_find(name_buf, ni)
    if slot < 0 { cprintln("Package not found", RED_ON_BLACK); return }
    let entry = PKG_DB + slot * PKG_SIZE
    if volatile_read_u64(entry + PKG_OFF_STATE) != PKG_INSTALLED { cprintln("Not installed", YELLOW_ON_BLACK); return }
    // Check if other packages depend on this
    // (simplified: skip dep check for now)
    volatile_write_u8(entry, 0) // clear name
    volatile_write_u64(entry + PKG_OFF_STATE, PKG_NONE)
    cprint("Removed: ", WHITE_ON_BLACK)
    let mut ci: i64 = 0
    while ci < ni { console_putchar(volatile_read_u8(name_buf + ci), YELLOW_ON_BLACK); ci = ci + 1 }
    console_putchar(10, WHITE_ON_BLACK)
}

// V1.5: `pkg list`
@kernel fn cmd_pkg_list() {
    cprintln("Installed packages:", YELLOW_ON_BLACK)
    let mut i: i64 = 0
    let mut count: i64 = 0
    while i < PKG_MAX {
        let entry = PKG_DB + i * PKG_SIZE
        if volatile_read_u64(entry + PKG_OFF_STATE) == PKG_INSTALLED {
            cprint("  ", WHITE_ON_BLACK)
            let mut j: i64 = 0
            while j < 24 { let ch = volatile_read_u8(entry + PKG_OFF_NAME + j); if ch == 0 { j = 24 } else { console_putchar(ch, GREEN_ON_BLACK); j = j + 1 } }
            cprint(" ", WHITE_ON_BLACK)
            j = 0
            while j < 8 { let ch = volatile_read_u8(entry + PKG_OFF_VERSION + j); if ch == 0 { j = 8 } else { console_putchar(ch, CYAN_ON_BLACK); j = j + 1 } }
            console_putchar(10, WHITE_ON_BLACK)
            count = count + 1
        }
        i = i + 1
    }
    if count == 0 { cprintln("  (none)", WHITE_ON_BLACK) }
    cprint("Total: ", WHITE_ON_BLACK); cprint_decimal(count, CYAN_ON_BLACK); cprintln(" packages", WHITE_ON_BLACK)
}

// V1.6: `pkg search <name>`
@kernel fn cmd_pkg_search() {
    let len = cmdbuf_len()
    if len <= 11 { cprintln("Usage: pkg search <query>", YELLOW_ON_BLACK); return }
    cprintln("Available packages:", YELLOW_ON_BLACK)
    // List built-in packages that can be installed
    cprintln("  core        - Essential commands (ls, cat, echo)", WHITE_ON_BLACK)
    cprintln("  net-tools   - Network utilities (ping, wget)", WHITE_ON_BLACK)
    cprintln("  dev-tools   - Developer tools (readelf, gdb)", WHITE_ON_BLACK)
    cprintln("  editors     - Text editor (ed-like)", WHITE_ON_BLACK)
    cprintln("  man         - Manual pages", WHITE_ON_BLACK)
}

// V1.9: `pkg info <name>`
@kernel fn cmd_pkg_info() {
    let len = cmdbuf_len()
    if len <= 9 { cprintln("Usage: pkg info <name>", YELLOW_ON_BLACK); return }
    let name_buf: i64 = 0x9C1000
    let mut ni: i64 = 0
    let mut pos: i64 = 9
    while pos < len && ni < 23 { volatile_write_u8(name_buf + ni, volatile_read_u8(0x6F800 + pos)); ni = ni + 1; pos = pos + 1 }
    volatile_write_u8(name_buf + ni, 0)
    let slot = pkg_find(name_buf, ni)
    if slot < 0 { cprintln("Package not found", RED_ON_BLACK); return }
    let entry = PKG_DB + slot * PKG_SIZE
    cprint("Name: ", WHITE_ON_BLACK)
    let mut j: i64 = 0
    while j < 24 { let ch = volatile_read_u8(entry + PKG_OFF_NAME + j); if ch == 0 { j = 24 } else { console_putchar(ch, GREEN_ON_BLACK); j = j + 1 } }
    console_putchar(10, WHITE_ON_BLACK)
    cprint("Version: ", WHITE_ON_BLACK)
    j = 0
    while j < 8 { let ch = volatile_read_u8(entry + PKG_OFF_VERSION + j); if ch == 0 { j = 8 } else { console_putchar(ch, CYAN_ON_BLACK); j = j + 1 } }
    console_putchar(10, WHITE_ON_BLACK)
    cprint("State: ", WHITE_ON_BLACK)
    let state = volatile_read_u64(entry + PKG_OFF_STATE)
    if state == PKG_INSTALLED { cprintln("installed", GREEN_ON_BLACK) }
    else { cprintln("available", WHITE_ON_BLACK) }
    cprint("Checksum: ", WHITE_ON_BLACK)
    cprint_hex(volatile_read_u64(entry + PKG_OFF_CHECKSUM), 8, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Standard Packages + Update (Sprint V2 — v0.9 "Zenith")
// ═══════════════════════════════════════════════

// Package registry (built-in available packages) at 0x9C2000: 8 entries × 64B
const PKG_REGISTRY: i64 = 0x9C2000
const PKG_REG_MAX: i64 = 8
const PKG_REG_SIZE: i64 = 64
// Per entry: +0=name[24], +24=version[8], +32=desc[24], +56=dep_count(i64)

// V2.1-V2.5: Register standard packages
@kernel fn pkg_registry_init() {
    let mut i: i64 = 0
    while i < PKG_REG_MAX * PKG_REG_SIZE { volatile_write_u8(PKG_REGISTRY + i, 0); i = i + 1 }
    // core
    pkg_reg_add(0, "core", "1.0", "Essential commands", 0)
    // net-tools
    pkg_reg_add(1, "net-tools", "1.0", "Network utilities", 0)
    // dev-tools
    pkg_reg_add(2, "dev-tools", "1.0", "Developer tools", 0)
    // editors
    pkg_reg_add(3, "editors", "1.0", "Text editor", 0)
    // man
    pkg_reg_add(4, "man", "1.0", "Manual pages", 0)
}

@kernel fn pkg_reg_add(slot: i64, name: str, version: str, desc: str, deps: i64) {
    let entry = PKG_REGISTRY + slot * PKG_REG_SIZE
    let nlen = str_len(name)
    let mut i: i64 = 0
    while i < nlen && i < 23 { volatile_write_u8(entry + i, str_byte_at(name, i)); i = i + 1 }
    volatile_write_u8(entry + i, 0)
    let vlen = str_len(version)
    i = 0
    while i < vlen && i < 7 { volatile_write_u8(entry + 24 + i, str_byte_at(version, i)); i = i + 1 }
    volatile_write_u8(entry + 24 + i, 0)
    let dlen = str_len(desc)
    i = 0
    while i < dlen && i < 23 { volatile_write_u8(entry + 32 + i, str_byte_at(desc, i)); i = i + 1 }
    volatile_write_u8(entry + 32 + i, 0)
    volatile_write_u64(entry + 56, deps)
}

// V2.6: Package manifest — /etc/packages.conf
@kernel fn cmd_pkg_manifest() {
    cprintln("Package manifest (/etc/packages.conf):", YELLOW_ON_BLACK)
    let mut i: i64 = 0
    while i < PKG_REG_MAX {
        let entry = PKG_REGISTRY + i * PKG_REG_SIZE
        if volatile_read_u8(entry) != 0 {
            cprint("  ", WHITE_ON_BLACK)
            let mut j: i64 = 0
            while j < 24 { let ch = volatile_read_u8(entry + j); if ch == 0 { j = 24 } else { console_putchar(ch, GREEN_ON_BLACK); j = j + 1 } }
            cprint(" ", WHITE_ON_BLACK)
            j = 0
            while j < 8 { let ch = volatile_read_u8(entry + 24 + j); if ch == 0 { j = 8 } else { console_putchar(ch, CYAN_ON_BLACK); j = j + 1 } }
            cprint(" — ", WHITE_ON_BLACK)
            j = 0
            while j < 24 { let ch = volatile_read_u8(entry + 32 + j); if ch == 0 { j = 24 } else { console_putchar(ch, WHITE_ON_BLACK); j = j + 1 } }
            console_putchar(10, WHITE_ON_BLACK)
        }
        i = i + 1
    }
}

// V2.7: `pkg update` — refresh registry
@kernel fn cmd_pkg_update() {
    cprintln("Updating package index...", YELLOW_ON_BLACK)
    pkg_registry_init()
    cprintln("Package index updated (5 packages available)", GREEN_ON_BLACK)
}

// V2.8: `pkg upgrade` — upgrade all installed
@kernel fn cmd_pkg_upgrade() {
    cprintln("Checking for upgrades...", YELLOW_ON_BLACK)
    let mut upgraded: i64 = 0
    let mut i: i64 = 0
    while i < PKG_MAX {
        let entry = PKG_DB + i * PKG_SIZE
        if volatile_read_u64(entry + PKG_OFF_STATE) == PKG_INSTALLED {
            // Check registry for newer version
            let name_buf: i64 = 0x9C1100
            let mut ni: i64 = 0
            while ni < 24 { let ch = volatile_read_u8(entry + PKG_OFF_NAME + ni); volatile_write_u8(name_buf + ni, ch); if ch == 0 { ni = 24 } else { ni = ni + 1 } }
            // Compare with registry (simplified: assume latest is always current)
            // In real system: semver compare
            cprint("  ", WHITE_ON_BLACK)
            let mut j: i64 = 0
            while j < 24 { let ch = volatile_read_u8(entry + PKG_OFF_NAME + j); if ch == 0 { j = 24 } else { console_putchar(ch, WHITE_ON_BLACK); j = j + 1 } }
            cprintln(": up to date", GREEN_ON_BLACK)
        }
        i = i + 1
    }
    if upgraded == 0 { cprintln("All packages up to date", GREEN_ON_BLACK) }
}

// V2.9: Version comparison (semver: major.minor)
@kernel fn pkg_version_compare(v1_major: i64, v1_minor: i64, v2_major: i64, v2_minor: i64) -> i64 {
    if v1_major > v2_major { 1 }
    else if v1_major < v2_major { -1 }
    else if v1_minor > v2_minor { 1 }
    else if v1_minor < v2_minor { -1 }
    else { 0 }
}

@kernel fn pkg_version_parse(entry: i64) -> i64 {
    // Parse "M.N" from version string, return packed major*100+minor
    let major = volatile_read_u8(entry + PKG_OFF_VERSION) - 48
    let minor = volatile_read_u8(entry + PKG_OFF_VERSION + 2) - 48
    major * 100 + minor
}

// ═══════════════════════════════════════════════
// Process Syscalls (Sprint G1-G3)
// ═══════════════════════════════════════════════

const SYS_FORK: i64 = 20      // fork() -> pid/0
const SYS_EXEC: i64 = 21      // exec(path, argv) -> (no return)
const SYS_WAITPID: i64 = 22   // waitpid(pid, status, opts) -> child_pid
const SYS_PIPE: i64 = 23      // pipe(fds_buf) -> 0
const SYS_KILL: i64 = 24      // kill(pid, signum) -> 0
const SYS_SIGNAL: i64 = 25    // signal(signum, handler) -> old_handler
const SYS_SETPGID: i64 = 26   // setpgid(pid, pgid) -> 0

// Process state constants
const PROC_STATE_FREE: i64 = 0
const PROC_STATE_READY: i64 = 1
const PROC_STATE_RUNNING: i64 = 2
const PROC_STATE_BLOCKED: i64 = 3
const PROC_STATE_ZOMBIE: i64 = 4

// Context frame: 15 GPRs + 5 IRETQ fields = 20 × 8 = 160 bytes
const CTX_FRAME_SIZE: i64 = 160
// GPR offsets from frame bottom (order: R15,R14,...,RBP,RDI,RSI,RDX,RCX,RBX,RAX,RIP,CS,RFLAGS,RSP,SS)
const CTX_OFF_RAX: i64 = 112   // RAX is 15th from bottom: 14*8=112
const CTX_OFF_RIP: i64 = 120   // RIP: 15*8=120

// SYS_FORK(20): create child process as copy of parent
@kernel fn sys_fork() -> i64 {
    let parent_pid = volatile_read_u64(0x6FE00)
    let parent_base = PROC_TABLE + parent_pid * PROC_ENTRY_SIZE

    // G1.1: Find free PID
    let mut child_pid: i64 = -1
    let mut i: i64 = 1
    while i < PROC_MAX && child_pid == -1 {
        if volatile_read(PROC_TABLE + i * PROC_ENTRY_SIZE + PROC_OFF_STATE) == PROC_STATE_FREE {
            child_pid = i
        }
        i = i + 1
    }
    if child_pid == -1 { return -1 } // no free PIDs

    // G1.2: Clone page tables (kernel entries + deep-copy user pages)
    let parent_cr3 = volatile_read(parent_base + PROC_OFF_CR3)
    let child_pml4 = fork_clone_page_tables(parent_cr3)
    if child_pml4 == -1 { return -1 }

    // G1.3: Copy FD table from parent to child
    fork_copy_fd_table(parent_pid, child_pid)
    fork_copy_uid(parent_pid, child_pid) // M3.7: inherit UID/GID

    // G1.4: Copy CWD, brk, and other proc fields
    let child_base = PROC_TABLE + child_pid * PROC_ENTRY_SIZE
    // Copy bytes 96-159 (brk, wake, cwd, etc.)
    let mut off: i64 = PROC_OFF_BRK
    while off < PROC_OFF_CWD + 32 {
        volatile_write_u8(child_base + off, volatile_read_u8(parent_base + off))
        off = off + 1
    }

    // G1.5: Build child kernel stack (copy parent's context frame)
    let child_kstack_base = KSTACK_BASE + child_pid * KSTACK_SIZE
    let child_kstack_top = child_kstack_base + KSTACK_SIZE - 16
    // Ensure kernel stack pages are mapped
    let mut pg: i64 = child_kstack_base
    while pg < child_kstack_base + KSTACK_SIZE {
        map_page(pg, pg, PAGE_PRESENT | PAGE_WRITABLE)
        frame_mark_used(pg / FRAME_SIZE)
        pg = pg + FRAME_SIZE
    }

    // Copy parent's saved context frame from parent kernel stack
    let parent_rsp = volatile_read(parent_base + PROC_OFF_RSP)
    let child_sp = child_kstack_top - CTX_FRAME_SIZE
    let mut ci: i64 = 0
    while ci < CTX_FRAME_SIZE {
        volatile_write_u8(child_sp + ci, volatile_read_u8(parent_rsp + ci))
        ci = ci + 1
    }

    // G1.7: Set child RAX=0 (fork returns 0 to child)
    // RAX is at frame_bottom + CTX_OFF_RAX
    volatile_write_u64(child_sp + CTX_OFF_RAX, 0)

    // G1.6: Set child process table entry
    volatile_write(child_base + PROC_OFF_STATE, PROC_STATE_READY)
    volatile_write(child_base + PROC_OFF_RSP, child_sp)
    volatile_write(child_base + PROC_OFF_ENTRY, volatile_read(parent_base + PROC_OFF_ENTRY))
    volatile_write(child_base + PROC_OFF_TICKS, 0)
    volatile_write(child_base + PROC_OFF_CR3, child_pml4)
    volatile_write(child_base + PROC_OFF_EXIT, 0)
    volatile_write(child_base + PROC_OFF_PPID, parent_pid)
    // Copy process name
    let mut ni: i64 = 0
    while ni < 16 {
        volatile_write_u8(child_base + PROC_OFF_NAME + ni, volatile_read_u8(parent_base + PROC_OFF_NAME + ni))
        ni = ni + 1
    }

    // Return child_pid to parent
    child_pid
}

// G1.2: Clone page tables — copy kernel entries, deep-copy user pages
@kernel fn fork_clone_page_tables(parent_pml4: i64) -> i64 {
    // Clone kernel PML4 first
    let child_pml4 = clone_kernel_pml4()
    if child_pml4 == -1 { return -1 }

    // Deep-copy user pages (PML4 entries where PAGE_USER is set)
    // Walk PML4 → PDPT → PD → PT for entries with PAGE_USER
    let mut pml4_idx: i64 = 0
    while pml4_idx < 512 {
        let pml4_entry = page_table_entry(parent_pml4, pml4_idx)
        if pml4_entry != 0 && (pml4_entry & PAGE_USER) != 0 {
            // This is a user-accessible entry — need to deep-copy the subtree
            let parent_pdpt = pml4_entry & 0xFFFFFFFFF000  // mask flags
            let child_pdpt = fork_copy_page_level(parent_pdpt, 3)
            if child_pdpt != -1 {
                page_table_set(child_pml4, pml4_idx, child_pdpt | (pml4_entry & 0xFFF))
            }
        }
        pml4_idx = pml4_idx + 1
    }

    child_pml4
}

// Deep-copy one level of page table hierarchy
// level: 3=PDPT, 2=PD, 1=PT
@kernel fn fork_copy_page_level(parent_table: i64, level: i64) -> i64 {
    let child_frame = frame_alloc()
    if child_frame == -1 { return -1 }
    let child_table = child_frame * FRAME_SIZE

    // Zero the new table
    let mut z: i64 = 0
    while z < 4096 { volatile_write_u8(child_table + z, 0); z = z + 1 }

    let mut idx: i64 = 0
    while idx < 512 {
        let entry = page_table_entry(parent_table, idx)
        if entry != 0 && (entry & PAGE_PRESENT) != 0 {
            if level == 1 {
                // L2.3: PT level — CoW share instead of deep-copy
                if (entry & PAGE_USER) != 0 {
                    // Share the page: mark parent read-only+CoW, child same
                    let phys = entry & 0xFFFFFFFFF000
                    let frame_idx = phys / FRAME_SIZE
                    let cow_flags = (entry & (0xFFF ^ PAGE_WRITABLE)) | PAGE_COW
                    // Mark parent as CoW (read-only)
                    page_table_set(parent_table, idx, phys | cow_flags)
                    // Child gets same mapping (CoW)
                    page_table_set(child_table, idx, phys | cow_flags)
                    // Set refcount
                    let rc = cow_refcount_get(frame_idx)
                    if rc == 0 { cow_refcount_set(frame_idx, 2) }
                    else { cow_refcount_inc(frame_idx) }
                } else {
                    // Kernel page at PT level — share directly
                    page_table_set(child_table, idx, entry)
                }
            } else {
                // Higher level: recurse
                if (entry & PAGE_USER) != 0 {
                    let subtable = entry & 0xFFFFFFFFF000
                    let child_subtable = fork_copy_page_level(subtable, level - 1)
                    if child_subtable != -1 {
                        page_table_set(child_table, idx, child_subtable | (entry & 0xFFF))
                    }
                } else {
                    // Kernel entry: share (don't deep-copy)
                    page_table_set(child_table, idx, entry)
                }
            }
        }
        idx = idx + 1
    }

    child_table
}

// G1.3: Copy FD table from parent to child (H1.9: pipe refcount increment)
@kernel fn fork_copy_fd_table(parent_pid: i64, child_pid: i64) {
    let mut fd: i64 = 0
    while fd < FD_MAX {
        let ftype = fd_v2_get_type(parent_pid, fd)
        let data = fd_v2_get_data(parent_pid, fd)
        fd_v2_set(child_pid, fd, ftype, data)
        // H1.9: Increment pipe refcounts on fork
        if ftype == FD_PIPE_READ {
            pipe_incref(data, 0) // is_writer=0
        }
        if ftype == FD_PIPE_WRITE {
            pipe_incref(data, 1) // is_writer=1
        }
        fd = fd + 1
    }
}

// G1.8: `sysfork` shell command (tests sys_fork syscall path)
@kernel fn cmd_sysfork_test() {
    cprintln("SysFork test:", YELLOW_ON_BLACK)
    cprintln("  Note: sys_fork() creates child with deep-copied page tables", WHITE_ON_BLACK)

    let child_pid = sys_fork()
    if child_pid < 0 {
        cprintln("  Fork failed: no free PIDs", RED_ON_BLACK)
    } else {
        cprint("  Forked child PID: ", WHITE_ON_BLACK)
        cprint_decimal(child_pid, GREEN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        cprint("  Child PPID: ", WHITE_ON_BLACK)
        let child_ppid = volatile_read(PROC_TABLE + child_pid * PROC_ENTRY_SIZE + PROC_OFF_PPID)
        cprint_decimal(child_ppid, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        cprint("  Child state: ", WHITE_ON_BLACK)
        let child_state = volatile_read(PROC_TABLE + child_pid * PROC_ENTRY_SIZE + PROC_OFF_STATE)
        cprint_decimal(child_state, CYAN_ON_BLACK)
        cprintln(" (1=READY)", WHITE_ON_BLACK)
    }
}

// ═══════════════════════════════════════════════
// SYS_EXEC (Sprint G2)
// ═══════════════════════════════════════════════

// ARGV_BUF at 0x8D6000: 8KB for argument passing
const ARGV_BUF: i64 = 0x8D6000
const ARGV_MAX: i64 = 16        // max 16 arguments
const ARGV_STR_SIZE: i64 = 256  // max 256 bytes per argument string

// SYS_EXEC(21): replace current process image with ELF from path
// path_addr: pointer to null-terminated filename string
// argv_addr: pointer to null-terminated argument list (0 = no args)
// Returns: does NOT return on success; returns -1 on failure
@kernel fn sys_exec(path_addr: i64, argv_addr: i64) -> i64 {
    let pid = volatile_read_u64(0x6FE00)
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE

    // G2.1: Find and load ELF file
    // Try ramfs first (for in-memory ELFs)
    let ramfs_idx = ramfs_find_by_addr(path_addr)
    let mut elf_loaded: i64 = 0

    if ramfs_idx >= 0 {
        // Load from ramfs into ELF_BUF
        let entry_addr = ramfs_entry_addr(ramfs_idx)
        let file_size = volatile_read(entry_addr + 32)
        let data_ptr = volatile_read(entry_addr + 40)
        if data_ptr == 0 || file_size == 0 { return -1 }
        // Copy to ELF_BUF
        let mut ci: i64 = 0
        while ci < file_size && ci < 0x10000 {
            volatile_write_u8(ELF_BUF + ci, volatile_read_u8(data_ptr + ci))
            ci = ci + 1
        }
        elf_loaded = file_size
    }

    // Try FAT32 if ramfs didn't find it
    if elf_loaded == 0 && fat32_state_read(0) == 1 {
        // Copy path to FAT32 name buffer
        let mut ni: i64 = 0
        while ni < 64 {
            let ch = volatile_read_u8(path_addr + ni)
            volatile_write_u8(FAT32_NAME_BUF + 256 + ni, ch)
            if ch == 0 { ni = 64 } else { ni = ni + 1 }
        }
        let root = fat32_state_read(48)
        let result = fat32_find_in_dir(root, FAT32_NAME_BUF + 256)
        if result != -1 {
            let shifted = result >> 32
            let file_cluster = shifted & 0x7FFFFFFF
            let file_size = result & 0xFFFFFFFF
            let bytes = fat32_read_file(file_cluster, file_size, ELF_BUF)
            if bytes > 0 { elf_loaded = bytes }
        }
    }

    if elf_loaded == 0 { return -1 } // file not found

    // Validate ELF
    let valid = elf_validate(ELF_BUF)
    if valid != 0 { return -1 }

    // G2.2: Free old user pages
    exec_free_user_pages(pid)

    // G2.3: Load new ELF segments
    let loaded = elf_load_segments(ELF_BUF, elf_loaded)
    if loaded == 0 { return -1 }

    let entry = elf_get_entry(ELF_BUF)

    // G2.4: Setup new user stack (64KB at ELF_STACK_TOP - 0x10000)
    let user_stack_base = ELF_STACK_TOP - 0x10000
    let mut pg: i64 = user_stack_base
    while pg < ELF_STACK_TOP {
        let frame = frame_alloc()
        if frame != -1 {
            map_page(pg, frame * FRAME_SIZE, PAGE_PRESENT | PAGE_WRITABLE | PAGE_USER)
        }
        pg = pg + FRAME_SIZE
    }

    // G2.5: Setup argv on user stack
    let user_rsp = exec_setup_argv(argv_addr)

    // G2.6: Reset close-on-exec FDs (close FDs 3+ for now)
    exec_reset_fds(pid)

    // G2.7: Reset signal handlers (future: clear signal table)
    // For now, nothing to reset — signal table not yet implemented

    // G2.8: Update process entry — rebuild context frame for Ring 3
    let kstack_top = KSTACK_BASE + pid * KSTACK_SIZE + KSTACK_SIZE - 16
    let mut sp = kstack_top

    // IRETQ frame for Ring 3
    sp = sp - 8; volatile_write_u64(sp, 0x1B)       // SS (user data RPL=3)
    sp = sp - 8; volatile_write_u64(sp, user_rsp)    // RSP (user stack)
    sp = sp - 8; volatile_write_u64(sp, 0x202)       // RFLAGS (IF=1)
    sp = sp - 8; volatile_write_u64(sp, 0x23)        // CS (user code RPL=3)
    sp = sp - 8; volatile_write_u64(sp, entry)        // RIP (ELF entry point)

    // 15 GPRs (zeroed — fresh start)
    let mut r: i64 = 0
    while r < 15 { sp = sp - 8; volatile_write_u64(sp, 0); r = r + 1 }

    // Update process table
    volatile_write(base + PROC_OFF_RSP, sp)
    volatile_write(base + PROC_OFF_ENTRY, entry)
    volatile_write(base + PROC_OFF_TICKS, 0)
    volatile_write(base + PROC_OFF_STATE, PROC_STATE_READY)
    // Reset heap break
    volatile_write_u64(base + PROC_OFF_BRK, 0)

    // exec never returns on success — the process will be scheduled
    // and resume at the new entry point via the timer ISR
    0
}

// G2.2: Free all user pages for a process (pages with PAGE_USER flag)
@kernel fn exec_free_user_pages(pid: i64) {
    // L2.1: Use CoW-aware page cleanup on exec
    // Release all CoW-tracked user pages (decrement refcounts)
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE
    let cr3 = volatile_read(base + PROC_OFF_CR3)
    if cr3 != 0 && cr3 != PML4_BASE {
        cow_release_pages(cr3)
    }
}

// G2.5: Setup argv on user stack, return adjusted RSP
@kernel fn exec_setup_argv(argv_addr: i64) -> i64 {
    let mut user_rsp = ELF_STACK_TOP - 8

    if argv_addr == 0 {
        // No arguments: argc=0, argv=NULL
        user_rsp = user_rsp - 8; volatile_write_u64(user_rsp, 0) // argv = NULL
        user_rsp = user_rsp - 8; volatile_write_u64(user_rsp, 0) // argc = 0
        return user_rsp
    }

    // Parse arguments from argv_addr (space-separated string or pointer array)
    // Simple: treat argv_addr as a space-separated string, copy to ARGV_BUF
    let mut argc: i64 = 0
    let mut pos: i64 = 0
    let mut arg_start: i64 = 0
    let mut in_arg: i64 = 0

    // First pass: count args and copy strings to ARGV_BUF
    let mut ch = volatile_read_u8(argv_addr + pos)
    while ch != 0 && argc < ARGV_MAX {
        if ch == 32 { // space
            if in_arg == 1 {
                // End of argument
                volatile_write_u8(ARGV_BUF + argc * ARGV_STR_SIZE + (pos - arg_start), 0)
                argc = argc + 1
                in_arg = 0
            }
        } else {
            if in_arg == 0 {
                arg_start = pos
                in_arg = 1
            }
            let offset = pos - arg_start
            if offset < ARGV_STR_SIZE - 1 {
                volatile_write_u8(ARGV_BUF + argc * ARGV_STR_SIZE + offset, ch)
            }
        }
        pos = pos + 1
        ch = volatile_read_u8(argv_addr + pos)
    }
    // Last arg
    if in_arg == 1 {
        volatile_write_u8(ARGV_BUF + argc * ARGV_STR_SIZE + (pos - arg_start), 0)
        argc = argc + 1
    }

    // Copy arg strings to user stack
    let mut arg_addrs: i64 = ARGV_BUF + ARGV_MAX * ARGV_STR_SIZE // temp storage for pointers
    let mut ai: i64 = 0
    while ai < argc {
        // Find string length
        let mut slen: i64 = 0
        while volatile_read_u8(ARGV_BUF + ai * ARGV_STR_SIZE + slen) != 0 { slen = slen + 1 }
        // Push string onto user stack
        user_rsp = user_rsp - (slen + 1)
        user_rsp = (user_rsp / 8) * 8 // 8-byte align
        let mut si: i64 = 0
        while si <= slen {
            volatile_write_u8(user_rsp + si, volatile_read_u8(ARGV_BUF + ai * ARGV_STR_SIZE + si))
            si = si + 1
        }
        // Store pointer
        volatile_write_u64(arg_addrs + ai * 8, user_rsp)
        ai = ai + 1
    }

    // Push NULL terminator for argv array
    user_rsp = user_rsp - 8; volatile_write_u64(user_rsp, 0)
    // Push argv pointers (reverse order so argv[0] is at lowest addr)
    let mut aj: i64 = argc - 1
    while aj >= 0 {
        user_rsp = user_rsp - 8
        volatile_write_u64(user_rsp, volatile_read_u64(arg_addrs + aj * 8))
        aj = aj - 1
    }
    let argv_base = user_rsp

    // Push argv pointer and argc (System V ABI: RDI=argc, RSI=argv)
    user_rsp = user_rsp - 8; volatile_write_u64(user_rsp, argv_base)
    user_rsp = user_rsp - 8; volatile_write_u64(user_rsp, argc)

    // Align to 16 bytes (System V ABI requirement)
    user_rsp = (user_rsp / 16) * 16 // 16-byte align (System V ABI)

    user_rsp
}

// G2.6: Reset FDs on exec (close non-stdio FDs)
@kernel fn exec_reset_fds(pid: i64) {
    // Keep FD 0 (stdin), 1 (stdout), 2 (stderr)
    // Close everything else (simple CLOEXEC behavior)
    let mut fd: i64 = 3
    while fd < FD_MAX {
        let ftype = fd_v2_get_type(pid, fd)
        if ftype != FD_CLOSED {
            fd_v2_set(pid, fd, FD_CLOSED, 0)
        }
        fd = fd + 1
    }
}

// ═══════════════════════════════════════════════
// SYS_WAITPID + Process Groups (Sprint G3)
// ═══════════════════════════════════════════════

// PROC_WAIT_TABLE at 0x8D2000: per-process wait state
// Per entry (16 bytes): +0=waiting_for_pid (i64), +8=options (i64)
const PROC_WAIT_TABLE: i64 = 0x8D2000
const WAIT_ENTRY_SIZE: i64 = 16

// waitpid options
const WNOHANG: i64 = 1

// Process group offset in proc table
const PROC_OFF_PGID: i64 = 120

// Exit status packing: bits 0-7 = signal, bits 8-15 = exit code
@kernel fn wait_pack_status(exit_code: i64, signal: i64) -> i64 {
    ((exit_code & 0xFF) << 8) | (signal & 0xFF)
}

@kernel fn wait_unpack_exit(status: i64) -> i64 {
    (status >> 8) & 0xFF
}

@kernel fn wait_unpack_signal(status: i64) -> i64 {
    status & 0xFF
}

// G3.1: SYS_WAITPID(22) — wait for child process
// pid: specific child PID, or -1 for any child
// status_addr: user buffer to write exit status (0 = don't write)
// options: WNOHANG (1) = return immediately if no child exited
@kernel fn sys_waitpid(pid: i64, status_addr: i64, options: i64) -> i64 {
    let parent_pid = volatile_read_u64(0x6FE00)

    // G3.4: Wait for any child (pid == -1)
    if pid == -1 {
        return waitpid_any(parent_pid, status_addr, options)
    }

    // Wait for specific child
    if pid < 1 || pid >= PROC_MAX { return -1 }
    let child_base = PROC_TABLE + pid * PROC_ENTRY_SIZE

    // Verify this is actually our child
    let child_ppid = volatile_read(child_base + PROC_OFF_PPID)
    if child_ppid != parent_pid { return -1 }

    let state = volatile_read(child_base + PROC_OFF_STATE)

    // G3.6: If child is ZOMBIE, reap immediately
    if state == PROC_STATE_ZOMBIE {
        let exit_code = volatile_read(child_base + PROC_OFF_EXIT)
        let status = wait_pack_status(exit_code, 0) // normal exit, signal=0
        if status_addr != 0 {
            volatile_write_u64(status_addr, status)
        }
        // Reap: free the slot
        volatile_write(child_base + PROC_OFF_STATE, PROC_STATE_FREE)
        volatile_write(child_base + PROC_OFF_TICKS, 0)
        volatile_write(child_base + PROC_OFF_ENTRY, 0)
        return pid
    }

    // G3.3: WNOHANG — return 0 if child hasn't exited yet
    if (options & WNOHANG) != 0 {
        return 0
    }

    // G3.2: Block parent until child exits
    // Store wait state and block
    volatile_write_u64(PROC_WAIT_TABLE + parent_pid * WAIT_ENTRY_SIZE, pid)
    volatile_write_u64(PROC_WAIT_TABLE + parent_pid * WAIT_ENTRY_SIZE + 8, options)
    volatile_write(PROC_TABLE + parent_pid * PROC_ENTRY_SIZE + PROC_OFF_STATE, PROC_STATE_BLOCKED)

    // The parent is now BLOCKED. When the child exits (process_exit_v2),
    // it will wake the parent by setting state=READY and storing the result.
    // For now, busy-wait fallback for PID 0 (shell doesn't get descheduled)
    if parent_pid == 0 {
        waitpid_busy_wait(pid, child_base, status_addr, parent_pid)
    } else {
        // For non-shell processes: the scheduler will resume us when child exits
        0
    }
}

// Busy-wait fallback for PID 0 (shell)
@kernel fn waitpid_busy_wait(pid: i64, child_base: i64, status_addr: i64, parent_pid: i64) -> i64 {
    waitpid_spin(child_base)
    let exit_code = volatile_read(child_base + PROC_OFF_EXIT)
    let status = wait_pack_status(exit_code, 0)
    waitpid_write_status(status_addr, status)
    waitpid_reap_child(child_base, parent_pid)
    pid
}

@kernel fn waitpid_spin(child_base: i64) {
    while volatile_read(child_base + PROC_OFF_STATE) != PROC_STATE_ZOMBIE { hlt() }
}

@kernel fn waitpid_reap_child(child_base: i64, parent_pid: i64) {
    volatile_write(child_base + PROC_OFF_STATE, PROC_STATE_FREE)
    volatile_write(child_base + PROC_OFF_TICKS, 0)
    volatile_write(child_base + PROC_OFF_ENTRY, 0)
    volatile_write(PROC_TABLE + parent_pid * PROC_ENTRY_SIZE + PROC_OFF_STATE, PROC_STATE_RUNNING)
}

@kernel fn waitpid_write_status(addr: i64, status: i64) {
    if addr != 0 { volatile_write_u64(addr, status) }
}

// G3.4: Wait for any child
@kernel fn waitpid_any(parent_pid: i64, status_addr: i64, options: i64) -> i64 {
    // Scan all PIDs for zombie children of this parent
    let mut i: i64 = 1
    while i < PROC_MAX {
        let child_base = PROC_TABLE + i * PROC_ENTRY_SIZE
        let child_ppid = volatile_read(child_base + PROC_OFF_PPID)
        let child_state = volatile_read(child_base + PROC_OFF_STATE)
        if child_ppid == parent_pid && child_state == PROC_STATE_ZOMBIE {
            let exit_code = volatile_read(child_base + PROC_OFF_EXIT)
            let status = wait_pack_status(exit_code, 0)
            if status_addr != 0 {
                volatile_write_u64(status_addr, status)
            }
            // Reap
            volatile_write(child_base + PROC_OFF_STATE, PROC_STATE_FREE)
            volatile_write(child_base + PROC_OFF_TICKS, 0)
            volatile_write(child_base + PROC_OFF_ENTRY, 0)
            return i
        }
        i = i + 1
    }

    // No zombie child found
    if (options & WNOHANG) != 0 { return 0 }

    // Check if we have any children at all
    let mut has_children: i64 = 0
    i = 1
    while i < PROC_MAX {
        let child_ppid = volatile_read(PROC_TABLE + i * PROC_ENTRY_SIZE + PROC_OFF_PPID)
        let child_state = volatile_read(PROC_TABLE + i * PROC_ENTRY_SIZE + PROC_OFF_STATE)
        if child_ppid == parent_pid && child_state != PROC_STATE_FREE { has_children = 1 }
        i = i + 1
    }
    if has_children == 0 { return -1 } // no children at all

    // Block and wait (same mechanism as specific pid)
    volatile_write_u64(PROC_WAIT_TABLE + parent_pid * WAIT_ENTRY_SIZE, -1)
    volatile_write(PROC_TABLE + parent_pid * PROC_ENTRY_SIZE + PROC_OFF_STATE, PROC_STATE_BLOCKED)
    0
}

// G3.7: Reparent orphaned children to init (PID 1)
@kernel fn reparent_children(exiting_pid: i64) {
    let mut i: i64 = 1
    while i < PROC_MAX {
        let child_base = PROC_TABLE + i * PROC_ENTRY_SIZE
        let child_ppid = volatile_read(child_base + PROC_OFF_PPID)
        let child_state = volatile_read(child_base + PROC_OFF_STATE)
        if child_ppid == exiting_pid && child_state != PROC_STATE_FREE {
            // Reparent to init (PID 1)
            volatile_write(child_base + PROC_OFF_PPID, 1)
            // If child is zombie, init will auto-reap
            if child_state == PROC_STATE_ZOMBIE {
                volatile_write(child_base + PROC_OFF_STATE, PROC_STATE_FREE)
                volatile_write(child_base + PROC_OFF_TICKS, 0)
            }
        }
        i = i + 1
    }
}

// Wake parent that is waiting in waitpid
@kernel fn wake_waiting_parent(child_pid: i64, exit_code: i64) {
    let child_base = PROC_TABLE + child_pid * PROC_ENTRY_SIZE
    let parent_pid = volatile_read(child_base + PROC_OFF_PPID)
    if parent_pid <= 0 || parent_pid >= PROC_MAX { return }

