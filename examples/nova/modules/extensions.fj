@kernel fn cmd_stat() {
    // stat <file>
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: stat <file>", YELLOW_ON_BLACK); return }
    let idx = ramfs_find_buf(5)
    if idx == -1 { cprintln("stat: not found", RED_ON_BLACK); return }
    let addr = ramfs_entry_addr(idx)
    let ftype = volatile_read(addr + 48)
    let size = volatile_read(addr + 32)
    let data_ptr = volatile_read(addr + 40)
    cprint("  File: ", WHITE_ON_BLACK)
    let mut j: i64 = 0
    while volatile_read_u8(addr + j) != 0 && j < 31 {
        console_putchar(volatile_read_u8(addr + j), CYAN_ON_BLACK)
        j = j + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Type: ", WHITE_ON_BLACK)
    if ftype == 1 { cprintln("regular file", WHITE_ON_BLACK) }
    else { cprintln("directory", CYAN_ON_BLACK) }
    cprint("  Size: ", WHITE_ON_BLACK)
    cprint_decimal(size, CYAN_ON_BLACK)
    cprintln(" bytes", WHITE_ON_BLACK)
    cprint("  Data: 0x", WHITE_ON_BLACK)
    cprint_hex(data_ptr, 8, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  Idx:  ", WHITE_ON_BLACK)
    cprint_decimal(idx, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

