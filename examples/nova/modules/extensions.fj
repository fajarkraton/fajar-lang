// ═══════════════════════════════════════════════
// Phase E — Preemptive Multitasking Scheduler
// ═══════════════════════════════════════════════

// ── E1.3: Context Frame Structure ──
// The timer ISR (linker assembly, vector 32 = IRQ0) saves this frame
// on the kernel stack every 10ms (100 Hz PIT). The scheduler then
// switches RSP to the next process and the pop+IRETQ restores it.
//
// Stack layout after timer ISR push (grows down):
//
// Offset  Register    Pushed by
// ──────  ────────    ─────────
// +0x98   SS          CPU (interrupt gate)
// +0x90   RSP         CPU (interrupt gate)
// +0x88   RFLAGS      CPU (interrupt gate)
// +0x80   CS          CPU (interrupt gate)
// +0x78   RIP         CPU (interrupt gate)
// +0x70   RAX         ISR (push rax)
// +0x68   RBX         ISR (push rbx)
// +0x60   RCX         ISR (push rcx)
// +0x58   RDX         ISR (push rdx)
// +0x50   RSI         ISR (push rsi)
// +0x48   RDI         ISR (push rdi)
// +0x40   RBP         ISR (push rbp)
// +0x38   R8          ISR (push r8)
// +0x30   R9          ISR (push r9)
// +0x28   R10         ISR (push r10)
// +0x20   R11         ISR (push r11)
// +0x18   R12         ISR (push r12)
// +0x10   R13         ISR (push r13)
// +0x08   R14         ISR (push r14)
// +0x00   R15         ISR (push r15) ← RSP points here
//
// Total frame: 20 × 8 = 160 bytes (0xA0)

const CTX_R15: i64 = 0
const CTX_R14: i64 = 8
const CTX_R13: i64 = 16
const CTX_R12: i64 = 24
const CTX_R11: i64 = 32
const CTX_R10: i64 = 40
const CTX_R9: i64 = 48
const CTX_R8: i64 = 56
const CTX_RBP: i64 = 64
const CTX_RDI: i64 = 72
const CTX_RSI: i64 = 80
const CTX_RDX: i64 = 88
const CTX_RCX: i64 = 96
const CTX_RBX: i64 = 104
const CTX_RAX: i64 = 112
const CTX_RIP: i64 = 120
const CTX_CS: i64 = 128
const CTX_RFLAGS: i64 = 136
const CTX_RSP: i64 = 144
const CTX_SS: i64 = 152
const CTX_FRAME_SIZE: i64 = 160

// ── E1.2: Per-Process Kernel Stack ──
// Each process gets 16KB kernel stack at KSTACK_BASE + pid * KSTACK_SIZE.
// The timer ISR saves the context frame on this stack, and
// TSS.RSP0 is updated on switch for Ring 3→0 transitions.
const KSTACK_BASE: i64 = 0x700000
const KSTACK_SIZE: i64 = 0x4000

// Process Table Layout (256 bytes per process, 16 PIDs)
const PROC_TABLE: i64 = 0x600000
const PROC_MAX: i64 = 16
const PROC_ENTRY_SIZE: i64 = 256
const PROC_OFF_STATE: i64 = 8
const PROC_OFF_RSP: i64 = 16
const PROC_OFF_ENTRY: i64 = 24
const PROC_OFF_TICKS: i64 = 32
const PROC_OFF_CR3: i64 = 40
const PROC_OFF_EXIT: i64 = 48
const PROC_OFF_PPID: i64 = 56
const PROC_OFF_NAME: i64 = 64

// ── Spawn: build fake interrupt frame on kernel stack ──
// When the scheduler switches to this process, the pop × 15 + IRETQ
// sequence will "return" to the entry point as if the process was
// interrupted mid-execution.

@kernel fn sched_spawn_kernel(entry_addr: i64) -> i64 {
    // Find free PID (skip PID 0 = kernel/shell)
    let mut pid: i64 = -1
    let mut i: i64 = 1
    while i < PROC_MAX && pid == -1 {
        if volatile_read(PROC_TABLE + i * PROC_ENTRY_SIZE + PROC_OFF_STATE) == 0 {
            pid = i
        }
        i = i + 1
    }
    if pid == -1 { return -1 }

    // E1.2: Allocate per-process kernel stack (16KB)
    let stack_base = KSTACK_BASE + pid * KSTACK_SIZE
    let stack_top = stack_base + KSTACK_SIZE - 16
    let mut pg: i64 = stack_base
    while pg < stack_base + KSTACK_SIZE {
        map_page(pg, pg, PAGE_PRESENT | PAGE_WRITABLE)
        frame_mark_used(pg / FRAME_SIZE)
        pg = pg + FRAME_SIZE
    }

    // E1.3: Build fake context frame on the stack
    let mut sp = stack_top

    // IRETQ frame (popped by CPU on IRETQ)
    sp = sp - 8; volatile_write_u64(sp, 0x10)       // SS (kernel data)
    sp = sp - 8; volatile_write_u64(sp, stack_top)   // RSP
    sp = sp - 8; volatile_write_u64(sp, 0x202)       // RFLAGS (IF=1)
    sp = sp - 8; volatile_write_u64(sp, 0x08)        // CS (kernel code)
    sp = sp - 8; volatile_write_u64(sp, entry_addr)  // RIP = entry point

    // 15 GPRs (popped by ISR restore sequence)
    sp = sp - 8; volatile_write_u64(sp, 0)   // RAX
    sp = sp - 8; volatile_write_u64(sp, 0)   // RBX
    sp = sp - 8; volatile_write_u64(sp, 0)   // RCX
    sp = sp - 8; volatile_write_u64(sp, 0)   // RDX
    sp = sp - 8; volatile_write_u64(sp, 0)   // RSI
    sp = sp - 8; volatile_write_u64(sp, 0)   // RDI
    sp = sp - 8; volatile_write_u64(sp, 0)   // RBP
    sp = sp - 8; volatile_write_u64(sp, 0)   // R8
    sp = sp - 8; volatile_write_u64(sp, 0)   // R9
    sp = sp - 8; volatile_write_u64(sp, 0)   // R10
    sp = sp - 8; volatile_write_u64(sp, 0)   // R11
    sp = sp - 8; volatile_write_u64(sp, 0)   // R12
    sp = sp - 8; volatile_write_u64(sp, 0)   // R13
    sp = sp - 8; volatile_write_u64(sp, 0)   // R14
    sp = sp - 8; volatile_write_u64(sp, 0)   // R15

    // Set process table entry
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE
    volatile_write(base + PROC_OFF_STATE, 1)    // state = READY
    volatile_write(base + PROC_OFF_RSP, sp)     // saved RSP → bottom of frame
    volatile_write(base + PROC_OFF_ENTRY, entry_addr)
    volatile_write(base + PROC_OFF_TICKS, 0)
    volatile_write(base + PROC_OFF_CR3, PML4_BASE)
    volatile_write(base + PROC_OFF_EXIT, 0)
    volatile_write(base + PROC_OFF_PPID, volatile_read(0x6FE00))

    pid
}

// ── E1.4: save_context ──
// Software context save for voluntary yield/sleep.
// (Hardware timer ISR handles preemptive save automatically via asm.)
@kernel fn save_context(pid: i64) {
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE
    // Save page table base (CR3)
    volatile_write(base + PROC_OFF_CR3, read_cr3())
    // RSP is saved by the timer ISR. For voluntary context switch,
    // the caller's return address is on the stack — the timer ISR
    // will save the full frame when it next fires.
    // Mark process as READY (not running)
    if volatile_read(base + PROC_OFF_STATE) == 2 {
        volatile_write(base + PROC_OFF_STATE, 1)  // RUNNING → READY
    }
}

// ── E1.5: restore_context ──
// Software context restore for manual process switch.
// After calling this + IRETQ, execution resumes at the process RIP.
@kernel fn restore_context(pid: i64) {
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE
    // Update current PID
    set_current_pid(pid)
    volatile_write(base + PROC_OFF_STATE, 2)  // state = RUNNING

    // Switch page table if different
    let saved_cr3 = volatile_read(base + PROC_OFF_CR3)
    if saved_cr3 != 0 && saved_cr3 != read_cr3() {
        write_cr3(saved_cr3)
    }

    // Update TSS.RSP0 for Ring 3→0 transitions
    let kstack_top = KSTACK_BASE + pid * KSTACK_SIZE + KSTACK_SIZE - 16
    volatile_write_u64(0x6FC04, kstack_top)
}

// ── E1.6: pick_next_process ──
// Round-robin scheduler: find next READY/RUNNING process after current.
@kernel fn pick_next_process() -> i64 {
    let current = volatile_read(0x6FE00)
    let mut next = current + 1
    let mut checked: i64 = 0
    while checked < PROC_MAX {
        if next >= PROC_MAX { next = 0 }
        let state = volatile_read(PROC_TABLE + next * PROC_ENTRY_SIZE + PROC_OFF_STATE)
        // Pick READY (1) or RUNNING (2) processes
        if state == 1 || state == 2 { return next }
        next = next + 1
        checked = checked + 1
    }
    current  // no other process → stay on current
}

// ── E1.7: Timer ISR integration ──
// The timer ISR (linker.rs __isr_timer, vector 32) does the following
// every 10ms (100 Hz PIT):
//   1. Push 15 GPRs (RAX..R15)
//   2. Increment __timer_ticks
//   3. Save current RSP + CR3 to process table [0x600000 + pid*256]
//   4. Round-robin: scan PIDs for next READY/RUNNING
//   5. Switch: mark old→READY, new→RUNNING, load RSP+CR3
//   6. Update TSS.RSP0 for new process
//   7. EOI to PIC (port 0x20)
//   8. Pop 15 GPRs + IRETQ
//
// This is fully automatic. Any process in READY state will be scheduled.

// ── Process exit (clean) ──
@kernel fn process_exit(exit_code: i64) {
    let pid = volatile_read(0x6FE00)
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE
    volatile_write(base + PROC_OFF_STATE, 4)   // state = ZOMBIE
    volatile_write(base + PROC_OFF_EXIT, exit_code)
    // Print exit message
    cprint("[PROC] PID ", WHITE_ON_BLACK)
    cprint_decimal(pid, CYAN_ON_BLACK)
    cprint(" exited (code ", WHITE_ON_BLACK)
    cprint_decimal(exit_code, CYAN_ON_BLACK)
    cprintln(")", WHITE_ON_BLACK)
    // Halt — scheduler will skip ZOMBIE processes
    while 1 == 1 { hlt() }
}

// ── Process cleanup (reap zombie) ──
@kernel fn process_reap(pid: i64) -> i64 {
    if pid < 1 || pid >= PROC_MAX { return -1 }
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE
    let state = volatile_read(base + PROC_OFF_STATE)
    if state != 4 { return -1 }  // not ZOMBIE
    let exit_code = volatile_read(base + PROC_OFF_EXIT)
    // Free the slot
    volatile_write(base + PROC_OFF_STATE, 0)  // FREE
    volatile_write(base + PROC_OFF_TICKS, 0)
    volatile_write(base + PROC_OFF_ENTRY, 0)
    exit_code
}

// ── E1.8: Enhanced spawn command ──
@kernel fn cmd_spawn() {
    let len = cmdbuf_len()
    if len <= 6 {
        cprintln("Usage: spawn <name>", YELLOW_ON_BLACK)
        cprintln("  Names: hello, counter, fib, test, init", WHITE_ON_BLACK)
        return
    }

    // Parse process name from command buffer (after "spawn ")
    let c0 = volatile_read_u8(0x6F800 + 6)
    let c1 = volatile_read_u8(0x6F800 + 7)
    let c2 = volatile_read_u8(0x6F800 + 8)
    let c3 = volatile_read_u8(0x6F800 + 9)
    let c4 = volatile_read_u8(0x6F800 + 10)

    // Match process name to entry point
    let mut entry_fn: i64 = 0

    // "hello" → hello_process
    if c0 == 104 && c1 == 101 && c2 == 108 && c3 == 108 && c4 == 111 {
        entry_fn = fn_addr("hello_process")
    }
    // "counter" → counter_process
    else if c0 == 99 && c1 == 111 && c2 == 117 && c3 == 110 && c4 == 116 {
        entry_fn = fn_addr("counter_process")
    }
    // "fib" → fibonacci_process
    else if c0 == 102 && c1 == 105 && c2 == 98 {
        entry_fn = fn_addr("fibonacci_process")
    }
    // "test" → sched_test_process
    else if c0 == 116 && c1 == 101 && c2 == 115 && c3 == 116 {
        entry_fn = fn_addr("sched_test_process")
    }
    // "init" → init_process
    else if c0 == 105 && c1 == 110 && c2 == 105 && c3 == 116 {
        entry_fn = fn_addr("init_process")
    }
    else {
        cprintln("spawn: unknown process name", RED_ON_BLACK)
        cprintln("  Available: hello, counter, fib, test, init", YELLOW_ON_BLACK)
        return
    }

    let pid = sched_spawn_kernel(entry_fn)
    if pid < 0 {
        cprintln("spawn: no free PIDs (max 16)", RED_ON_BLACK)
        return
    }

    // Copy process name to table
    let base = PROC_TABLE + pid * PROC_ENTRY_SIZE
    let mut j: i64 = 0
    while j < 16 && j + 6 < len {
        volatile_write_u8(base + PROC_OFF_NAME + j, volatile_read_u8(0x6F800 + 6 + j))
        j = j + 1
    }
    volatile_write_u8(base + PROC_OFF_NAME + j, 0)

    cprint("Spawned '", GREEN_ON_BLACK)
    j = 0
    while j < 16 {
        let ch = volatile_read_u8(base + PROC_OFF_NAME + j)
        if ch == 0 { j = 16 }  // break
        else { console_putchar(ch, GREEN_ON_BLACK); j = j + 1 }
    }
    cprint("' as PID ", GREEN_ON_BLACK)
    cprint_decimal(pid, CYAN_ON_BLACK)
    cprintln(" (preemptive)", WHITE_ON_BLACK)
}

// ── E1.9: Spawnable Process Functions ──

// hello_process: prints greeting, sleeps, exits cleanly
@kernel fn hello_process() {
    let pid = volatile_read(0x6FE00)
    cprint("[hello:PID ", CYAN_ON_BLACK)
    cprint_decimal(pid, CYAN_ON_BLACK)
    cprintln("] Hello from a preemptive process!", CYAN_ON_BLACK)

    // Sleep 1 second
    let target = read_timer_ticks() + 100
    while read_timer_ticks() < target {}

    cprint("[hello:PID ", CYAN_ON_BLACK)
    cprint_decimal(pid, CYAN_ON_BLACK)
    cprintln("] Goodbye!", CYAN_ON_BLACK)

    process_exit(0)
}

// counter_process: counts 1-10 with 500ms delays, demonstrates preemption
@kernel fn counter_process() {
    let pid = volatile_read(0x6FE00)
    cprint("[counter:PID ", GREEN_ON_BLACK)
    cprint_decimal(pid, GREEN_ON_BLACK)
    cprintln("] Starting count 1-10", GREEN_ON_BLACK)

    let mut count: i64 = 1
    while count <= 10 {
        cprint("[counter:PID ", GREEN_ON_BLACK)
        cprint_decimal(pid, GREEN_ON_BLACK)
        cprint("] ", GREEN_ON_BLACK)
        cprint_decimal(count, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)

        // Sleep 500ms (50 ticks at 100Hz) — timer preempts during this wait
        let target = read_timer_ticks() + 50
        while read_timer_ticks() < target {}

        count = count + 1
    }

    cprint("[counter:PID ", GREEN_ON_BLACK)
    cprint_decimal(pid, GREEN_ON_BLACK)
    cprintln("] Done!", GREEN_ON_BLACK)

    process_exit(0)
}

// fibonacci_process: computes fib(20), prints result
@kernel fn fibonacci_process() {
    let pid = volatile_read(0x6FE00)
    cprint("[fib:PID ", YELLOW_ON_BLACK)
    cprint_decimal(pid, YELLOW_ON_BLACK)
    cprintln("] Computing fibonacci(20)...", YELLOW_ON_BLACK)

    let result = fib_compute(20)

    cprint("[fib:PID ", YELLOW_ON_BLACK)
    cprint_decimal(pid, YELLOW_ON_BLACK)
    cprint("] fib(20) = ", YELLOW_ON_BLACK)
    cprint_decimal(result, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    process_exit(0)
}

@kernel fn fib_compute(n: i64) -> i64 {
    if n <= 1 { return n }
    let mut a: i64 = 0
    let mut b: i64 = 1
    let mut i: i64 = 2
    while i <= n {
        let tmp = a + b
        a = b
        b = tmp
        i = i + 1
    }
    b
}

// sched_test_process: original test — prints every 3 seconds, exits after 3 iterations
@kernel fn sched_test_process() {
    let pid = volatile_read(0x6FE00)
    let mut count: i64 = 0
    while count < 3 {
        let target = read_timer_ticks() + 300
        while read_timer_ticks() < target {}
        cprint("[test:PID ", WHITE_ON_BLACK)
        cprint_decimal(pid, CYAN_ON_BLACK)
        cprintln("] background process alive", WHITE_ON_BLACK)
        count = count + 1
    }
    cprint("[test:PID ", WHITE_ON_BLACK)
    cprint_decimal(pid, CYAN_ON_BLACK)
    cprintln("] exiting", WHITE_ON_BLACK)
    process_exit(0)
}

// ── E1.10: Preemption demo command ──
@kernel fn cmd_sched_demo() {
    cprintln("=== Preemptive Scheduler Demo ===", YELLOW_ON_BLACK)
    cprintln("Spawning 3 processes: hello + counter + fib", WHITE_ON_BLACK)
    cprintln("Watch them interleave via timer preemption (10ms quantum):", WHITE_ON_BLACK)
    cprintln("", WHITE_ON_BLACK)

    // Spawn all three
    let pid1 = sched_spawn_kernel(fn_addr("hello_process"))
    if pid1 > 0 {
        let base1 = PROC_TABLE + pid1 * PROC_ENTRY_SIZE
        volatile_write_u8(base1 + PROC_OFF_NAME, 104)  // 'h'
        volatile_write_u8(base1 + PROC_OFF_NAME + 1, 101) // 'e'
        volatile_write_u8(base1 + PROC_OFF_NAME + 2, 108) // 'l'
        volatile_write_u8(base1 + PROC_OFF_NAME + 3, 108) // 'l'
        volatile_write_u8(base1 + PROC_OFF_NAME + 4, 111) // 'o'
        volatile_write_u8(base1 + PROC_OFF_NAME + 5, 0)
        cprint("  Spawned hello as PID ", GREEN_ON_BLACK)
        cprint_decimal(pid1, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    }

    let pid2 = sched_spawn_kernel(fn_addr("counter_process"))
    if pid2 > 0 {
        let base2 = PROC_TABLE + pid2 * PROC_ENTRY_SIZE
        volatile_write_u8(base2 + PROC_OFF_NAME, 99)   // 'c'
        volatile_write_u8(base2 + PROC_OFF_NAME + 1, 111) // 'o'
        volatile_write_u8(base2 + PROC_OFF_NAME + 2, 117) // 'u'
        volatile_write_u8(base2 + PROC_OFF_NAME + 3, 110) // 'n'
        volatile_write_u8(base2 + PROC_OFF_NAME + 4, 116) // 't'
        volatile_write_u8(base2 + PROC_OFF_NAME + 5, 0)
        cprint("  Spawned counter as PID ", GREEN_ON_BLACK)
        cprint_decimal(pid2, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    }

    let pid3 = sched_spawn_kernel(fn_addr("fibonacci_process"))
    if pid3 > 0 {
        let base3 = PROC_TABLE + pid3 * PROC_ENTRY_SIZE
        volatile_write_u8(base3 + PROC_OFF_NAME, 102)  // 'f'
        volatile_write_u8(base3 + PROC_OFF_NAME + 1, 105) // 'i'
        volatile_write_u8(base3 + PROC_OFF_NAME + 2, 98)  // 'b'
        volatile_write_u8(base3 + PROC_OFF_NAME + 3, 0)
        cprint("  Spawned fib as PID ", GREEN_ON_BLACK)
        cprint_decimal(pid3, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    }

    cprintln("", WHITE_ON_BLACK)
    cprintln("Processes running. Use 'ps' to see status.", YELLOW_ON_BLACK)
    cprintln("Timer IRQ preempts every 10ms (100 Hz PIT).", WHITE_ON_BLACK)
}

@kernel fn cmd_wait() {
    // wait <pid> — wait for process (simulated)
    let len = cmdbuf_len()
    if len <= 5 { cprintln("Usage: wait <pid>", YELLOW_ON_BLACK); return }
    let mut pid: i64 = 0
    let mut i: i64 = 5
    while i < len {
        let ch = volatile_read_u8(0x6F800 + i)
        if ch >= 48 && ch <= 57 { pid = pid * 10 + (ch - 48) }
        i = i + 1
    }
    let base = 0x600000 + pid * 256
    let state = volatile_read(base + 8)
    if state == 0 {
        cprint("PID ", WHITE_ON_BLACK)
        cprint_decimal(pid, CYAN_ON_BLACK)
        cprintln(" already exited", WHITE_ON_BLACK)
    } else {
        cprint("Waiting for PID ", WHITE_ON_BLACK)
        cprint_decimal(pid, CYAN_ON_BLACK)
        cprintln("...", WHITE_ON_BLACK)
        // Simulate wait (busy-wait 1 second then mark dead)
        let target = read_timer_ticks() + 100
        while read_timer_ticks() < target {}
        volatile_write(base + 8, 0)
        cprint("PID ", GREEN_ON_BLACK)
        cprint_decimal(pid, GREEN_ON_BLACK)
        cprintln(" exited (0)", GREEN_ON_BLACK)
    }
}

@kernel fn cmd_nice_v1() {
    // nice — show/set process priority (simulated)
    cprintln("Priorities:", YELLOW_ON_BLACK)
    cprintln("  PID 0: priority 0 (kernel)", WHITE_ON_BLACK)
    let mut i: i64 = 1
    while i < 16 {
        let base = 0x600000 + i * 256
        if volatile_read(base + 8) != 0 {
            cprint("  PID ", WHITE_ON_BLACK)
            cprint_decimal(i, CYAN_ON_BLACK)
            cprintln(": priority 20 (normal)", WHITE_ON_BLACK)
        }
        i = i + 1
    }
}

@kernel fn cmd_demo() {
    // demo — run interactive OS demo
    cprintln("=== FajarOS Nova Demo ===", WHITE_ON_BLUE)
    cprintln("", WHITE_ON_BLACK)

    // 1. File operations
    cprintln("[1/5] File System Demo:", YELLOW_ON_BLACK)
    ramfs_write_file("demo.txt", "Hello from FajarOS Nova!", 24)
    cprint("  Created demo.txt: ", WHITE_ON_BLACK)
    // Read it back
    let idx = ramfs_find("demo.txt")
    if idx >= 0 {
        let addr = ramfs_entry_addr(idx)
        let size = volatile_read(addr + 32)
        let data = volatile_read(addr + 40)
        let mut i: i64 = 0
        while i < size { console_putchar(volatile_read_u8(data + i), GREEN_ON_BLACK); i = i + 1 }
        console_putchar(10, WHITE_ON_BLACK)
    }

    // 2. Process demo
    cprintln("[2/5] Process Demo:", YELLOW_ON_BLACK)
    let mut pid: i64 = 1
    while pid < 4 {
        let base = 0x600000 + pid * 256
        if volatile_read(base + 8) == 0 {
            volatile_write(base + 8, 1)
            volatile_write(base + 32, read_timer_ticks() % 1000)
        }
        pid = pid + 1
    }
    cprintln("  Spawned 3 demo processes (PID 1-3)", GREEN_ON_BLACK)

    // 3. Math demo
    cprintln("[3/5] Math Demo:", YELLOW_ON_BLACK)
    cprint("  fib(20) = ", WHITE_ON_BLACK)
    let mut a: i64 = 0
    let mut b: i64 = 1
    let mut n: i64 = 0
    while n < 20 { let tmp = a + b; a = b; b = tmp; n = n + 1 }
    cprint_decimal(b, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
    cprint("  factors(360) = ", WHITE_ON_BLACK)
    let mut val: i64 = 360
    let mut d: i64 = 2
    while d * d <= val {
        while val % d == 0 { cprint_decimal(d, CYAN_ON_BLACK); cprint(" ", WHITE_ON_BLACK); val = val / d }
        d = d + 1
    }
    if val > 1 { cprint_decimal(val, CYAN_ON_BLACK) }
    console_putchar(10, WHITE_ON_BLACK)

    // 4. Hardware info
    cprintln("[4/5] Hardware:", YELLOW_ON_BLACK)
    let rsdp = acpi_find_rsdp()
    if rsdp != 0 {
        cprint("  CPUs: ", WHITE_ON_BLACK)
        cprint_decimal(acpi_get_cpu_count(rsdp), CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    }
    cprint("  PCI devices: ", WHITE_ON_BLACK)
    let mut pci_count: i64 = 0
    let mut dev: i64 = 0
    while dev < 32 {
        let id = pci_read32(0, dev, 0, 0)
        if id != 0xFFFFFFFF && id != 0 { pci_count = pci_count + 1 }
        dev = dev + 1
    }
    cprint_decimal(pci_count, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    // 5. Benchmark
    cprintln("[5/5] Benchmark:", YELLOW_ON_BLACK)
    let t0 = rdtsc()
    let mut sum: i64 = 0
    let mut k: i64 = 0
    while k < 1000000 { sum = sum + k; k = k + 1 }
    let t1 = rdtsc()
    cprint("  1M loop: ", WHITE_ON_BLACK)
    cprint_decimal((t1 - t0) / 1000, CYAN_ON_BLACK)
    cprintln("K cycles", WHITE_ON_BLACK)

    cprintln("", WHITE_ON_BLACK)
    cprintln("Demo complete! Type 'help' for all commands.", GREEN_ON_BLACK)
}

@kernel fn cmd_neofetch() {
    // neofetch — system info with ASCII art
    cprintln("", WHITE_ON_BLACK)
    // Left side: ASCII logo, Right side: info
    cprint("  ####  ##   ", CYAN_ON_BLACK)
    cprintln("OS:      FajarOS Nova v1.0.0", WHITE_ON_BLACK)
    cprint("  #     # #  ", CYAN_ON_BLACK)
    cprintln("Kernel:  x86_64 bare-metal", WHITE_ON_BLACK)
    cprint("  ###  ##### ", CYAN_ON_BLACK)
    cprintln("Lang:    Fajar Lang (fj)", WHITE_ON_BLACK)
    cprint("  #    #   # ", CYAN_ON_BLACK)
    cprint("Uptime:  ", WHITE_ON_BLACK)
    let ticks = read_timer_ticks()
    cprint_decimal(ticks / 100, CYAN_ON_BLACK)
    cprintln("s", WHITE_ON_BLACK)
    cprint("  #    #   # ", CYAN_ON_BLACK)
    cprint("Shell:   fjsh (", WHITE_ON_BLACK)
    cprintln("100 commands)", WHITE_ON_BLACK)
    cprint("             ", CYAN_ON_BLACK)
    cprintln("Memory:  128 MB", WHITE_ON_BLACK)
    cprint("             ", CYAN_ON_BLACK)
    cprint("CPU:     ", WHITE_ON_BLACK)
    let rsdp = acpi_find_rsdp()
    if rsdp != 0 { cprint_decimal(acpi_get_cpu_count(rsdp), CYAN_ON_BLACK) }
    else { console_putchar(49, CYAN_ON_BLACK) }
    cprintln(" core(s)", WHITE_ON_BLACK)
    cprint("             ", CYAN_ON_BLACK)
    cprintln("Display: VGA 80x25 text", WHITE_ON_BLACK)
    cprint("             ", CYAN_ON_BLACK)
    cprintln("Timer:   PIT 100 Hz", WHITE_ON_BLACK)
    // Color blocks
    cprint("  ", WHITE_ON_BLACK)
    let mut c: i64 = 0
    while c < 8 {
        console_putchar(32, c * 16 + 15)
        console_putchar(32, c * 16 + 15)
        console_putchar(32, c * 16 + 15)
        c = c + 1
    }
    console_putchar(10, WHITE_ON_BLACK)
    cprintln("", WHITE_ON_BLACK)
}

// ═══════════════════════════════════════════════
// Command Dispatcher
// ═══════════════════════════════════════════════

@kernel fn buf_eq4(a: i64, b: i64, c: i64, d: i64) -> i64 {
    let r0 = volatile_read_u8(0x6F800)
    let r1 = volatile_read_u8(0x6F801)
    let r2 = volatile_read_u8(0x6F802)
    let r3 = volatile_read_u8(0x6F803)
    if r0 == a && r1 == b && r2 == c && r3 == d { 1 } else { 0 }
}

@kernel fn dispatch_command() {
    let len = cmdbuf_len()
    let mut handled: i64 = 0

    // === Original 15 commands ===
    // help (104,101,108,112)
    if len == 4 && buf_eq4(104, 101, 108, 112) == 1 { cmd_help(); handled = 1 }
    // clear (99,108,101,97,114)
    if handled == 0 && len == 5 && buf_eq4(99, 108, 101, 97) == 1 && volatile_read_u8(0x6F804) == 114 { cmd_clear(); handled = 1 }
    // uname (117,110,97,109,101)
    if handled == 0 && len == 5 && buf_eq4(117, 110, 97, 109) == 1 && volatile_read_u8(0x6F804) == 101 { cmd_uname(); handled = 1 }
    // uptime (117,112,116,105,109,101)
    if handled == 0 && len == 6 && buf_eq4(117, 112, 116, 105) == 1 { cmd_uptime(); handled = 1 }
    // cpuinfo
