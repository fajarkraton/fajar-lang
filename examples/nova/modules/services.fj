@kernel fn cmd_version() {
    cprintln("FajarOS Nova v1.0.0 \"Nova\"", WHITE_ON_BLUE)
    cprintln("  Kernel:   x86_64 bare-metal", WHITE_ON_BLACK)
    cprintln("  Language: 100% Fajar Lang", WHITE_ON_BLACK)
    cprintln("  Compiler: Fajar Lang + Cranelift", WHITE_ON_BLACK)
    cprintln("  Boot:     Multiboot2 (GRUB2)", WHITE_ON_BLACK)
    cprintln("  Paging:   128MB identity (2MB pages)", WHITE_ON_BLACK)
    cprintln("  Timer:    PIT 100Hz preemptive", WHITE_ON_BLACK)
    cprintln("  Shell:    100 commands", WHITE_ON_BLACK)
    cprintln("  Author:   Fajar (TaxPrime/PrimeCore.id)", WHITE_ON_BLACK)
    cprintln("  Built with Claude Opus 4.6", CYAN_ON_BLACK)
}

@kernel fn cmd_uname() {
    cprintln("FajarOS Nova v1.0.0 x86_64 (Fajar Lang)", CYAN_ON_BLACK)
}

@kernel fn cmd_uptime() {
    cprint("Uptime: ", WHITE_ON_BLACK)
    let ticks = read_timer_ticks()
    cprint_decimal(ticks, CYAN_ON_BLACK)
    cprint(" ticks (", WHITE_ON_BLACK)
    cprint_decimal(ticks / 100, CYAN_ON_BLACK)
    cprintln(" seconds)", WHITE_ON_BLACK)
}

@kernel fn cmd_cpuinfo() {
    let ecx1 = cpuid_ecx(1)
    let edx1 = cpuid_edx(1)
    let ebx7 = cpuid_ebx(7)
    cprintln("CPU Features:", YELLOW_ON_BLACK)
    if (edx1 & (1 << 0)) != 0 { cprintln("  FPU", WHITE_ON_BLACK) }
    if (edx1 & (1 << 25)) != 0 { cprintln("  SSE", WHITE_ON_BLACK) }
    if (edx1 & (1 << 26)) != 0 { cprintln("  SSE2", WHITE_ON_BLACK) }
    if (ecx1 & (1 << 20)) != 0 { cprintln("  SSE4.2", WHITE_ON_BLACK) }
    if (ecx1 & (1 << 28)) != 0 { cprintln("  AVX", WHITE_ON_BLACK) }
    if (ebx7 & (1 << 5)) != 0 { cprintln("  AVX2", WHITE_ON_BLACK) }
    if (edx1 & (1 << 9)) != 0 { cprintln("  APIC", WHITE_ON_BLACK) }
}

@kernel fn cmd_meminfo() {
    cprintln("Memory:", YELLOW_ON_BLACK)
    cprintln("  Total mapped: 128 MB (identity)", WHITE_ON_BLACK)
    cprintln("  Kernel:  0x100000 (1 MB)", WHITE_ON_BLACK)
    cprintln("  Heap:    0x400000 - 0x7000000 (108 MB)", WHITE_ON_BLACK)
    cprintln("  Stack:   0x7F00000 (127 MB)", WHITE_ON_BLACK)
    cprintln("  ProcTbl: 0x600000 (4 KB)", WHITE_ON_BLACK)
}

@kernel fn pci_class_name(class: i64, subclass: i64) {
    if class == 0x00 { cprint("Legacy", WHITE_ON_BLACK) }
    else if class == 0x01 {
        cprint("Storage", WHITE_ON_BLACK)
        if subclass == 0x01 { cprint("/IDE", CYAN_ON_BLACK) }
        else if subclass == 0x06 { cprint("/SATA", CYAN_ON_BLACK) }
        else if subclass == 0x08 { cprint("/NVMe", GREEN_ON_BLACK) }
    }
    else if class == 0x02 {
        cprint("Network", WHITE_ON_BLACK)
        if subclass == 0x00 { cprint("/Ethernet", CYAN_ON_BLACK) }
        else if subclass == 0x80 { cprint("/Other", CYAN_ON_BLACK) }
    }
    else if class == 0x03 {
        cprint("Display", WHITE_ON_BLACK)
        if subclass == 0x00 { cprint("/VGA", CYAN_ON_BLACK) }
        else if subclass == 0x02 { cprint("/3D", CYAN_ON_BLACK) }
    }
    else if class == 0x04 { cprint("Multimedia", WHITE_ON_BLACK) }
    else if class == 0x05 { cprint("Memory", WHITE_ON_BLACK) }
    else if class == 0x06 {
        cprint("Bridge", WHITE_ON_BLACK)
        if subclass == 0x00 { cprint("/Host", CYAN_ON_BLACK) }
        else if subclass == 0x01 { cprint("/ISA", CYAN_ON_BLACK) }
        else if subclass == 0x04 { cprint("/PCI", CYAN_ON_BLACK) }
    }
    else if class == 0x07 { cprint("Serial", WHITE_ON_BLACK) }
    else if class == 0x08 { cprint("System", WHITE_ON_BLACK) }
    else if class == 0x0C {
        cprint("Serial Bus", WHITE_ON_BLACK)
        if subclass == 0x03 { cprint("/USB", CYAN_ON_BLACK) }
    }
    else { cprint("Unknown", WHITE_ON_BLACK) }
}

@kernel fn cmd_lspci() {
    cprintln("PCI Devices:", YELLOW_ON_BLACK)
    let mut dev: i64 = 0
    let mut found: i64 = 0
    while dev < 32 {
        let id = pci_read32(0, dev, 0, 0)
        if id != 0xFFFFFFFF && id != 0 {
            cprint("  ", WHITE_ON_BLACK)
            cprint_hex(id & 0xFFFF, 4, CYAN_ON_BLACK)
            console_putchar(58, WHITE_ON_BLACK)
            cprint_hex((id >> 16) & 0xFFFF, 4, CYAN_ON_BLACK)
            let cl = pci_read32(0, dev, 0, 8)
            let class = (cl >> 24) & 0xFF
            let subclass = (cl >> 16) & 0xFF
            cprint(" ", WHITE_ON_BLACK)
            pci_class_name(class, subclass)
            console_putchar(10, WHITE_ON_BLACK)
            found = found + 1
        }
        dev = dev + 1
    }
    cprint("Total: ", GREEN_ON_BLACK)
    cprint_decimal(found, GREEN_ON_BLACK)
    cprintln(" devices", GREEN_ON_BLACK)
}

@kernel fn cmd_lspci_v() {
    // lspci -v — verbose with BAR info
    cprintln("PCI Devices (verbose):", YELLOW_ON_BLACK)
    let mut dev: i64 = 0
    while dev < 32 {
        let id = pci_read32(0, dev, 0, 0)
        if id != 0xFFFFFFFF && id != 0 {
            let cl = pci_read32(0, dev, 0, 8)
            let class = (cl >> 24) & 0xFF
            let subclass = (cl >> 16) & 0xFF
            cprint("  Dev ", WHITE_ON_BLACK)
            cprint_decimal(dev, CYAN_ON_BLACK)
            cprint(": ", WHITE_ON_BLACK)
            cprint_hex(id & 0xFFFF, 4, CYAN_ON_BLACK)
            console_putchar(58, WHITE_ON_BLACK)
            cprint_hex((id >> 16) & 0xFFFF, 4, CYAN_ON_BLACK)
            cprint(" ", WHITE_ON_BLACK)
            pci_class_name(class, subclass)
            console_putchar(10, WHITE_ON_BLACK)
            // Read BARs (offset 0x10-0x24, 6 BARs)
            let mut bar: i64 = 0
            while bar < 6 {
                let bar_val = pci_read32(0, dev, 0, 0x10 + bar * 4)
                if bar_val != 0 {
                    cprint("    BAR", WHITE_ON_BLACK)
                    cprint_decimal(bar, WHITE_ON_BLACK)
                    cprint(": 0x", WHITE_ON_BLACK)
                    cprint_hex(bar_val, 8, CYAN_ON_BLACK)
                    if (bar_val & 1) == 1 {
                        cprint(" (I/O port ", YELLOW_ON_BLACK)
                        cprint_hex(bar_val & 0xFFFFFFFC, 4, YELLOW_ON_BLACK)
                        cprintln(")", WHITE_ON_BLACK)
                    } else {
                        let bar_type = (bar_val >> 1) & 3
                        if bar_type == 0 { cprint(" (MMIO 32-bit)", YELLOW_ON_BLACK) }
                        else if bar_type == 2 { cprint(" (MMIO 64-bit)", YELLOW_ON_BLACK) }
                        console_putchar(10, WHITE_ON_BLACK)
                    }
                }
                bar = bar + 1
            }
            // Read interrupt line
            let int_reg = pci_read32(0, dev, 0, 0x3C)
            let irq = int_reg & 0xFF
            if irq != 0 && irq != 0xFF {
                cprint("    IRQ: ", WHITE_ON_BLACK)
                cprint_decimal(irq, CYAN_ON_BLACK)
                console_putchar(10, WHITE_ON_BLACK)
            }
        }
        dev = dev + 1
    }
}

// ═══════════════════════════════════════════════
// Slab Allocator (Phase 2 Sprint 6)
// Pre-sized caches: 32, 64, 128, 256, 512, 1024
// Each slab: bitmap + objects at fixed addresses
// ═══════════════════════════════════════════════

const SLAB_BASE: i64 = 0x590000
const SLAB_SIZES: i64 = 6  // 32, 64, 128, 256, 512, 1024

@kernel fn slab_init() {
    // Initialize slab metadata at SLAB_BASE
    // Each slab: offset +0: object_size, +8: capacity, +16: used, +24: bitmap_addr, +32: data_addr
    let mut i: i64 = 0
    let sizes: [i64; 6] = [32, 64, 128, 256, 512, 1024]
    let mut data_off: i64 = SLAB_BASE + 256  // data starts after metadata
    while i < SLAB_SIZES {
        let meta = SLAB_BASE + i * 40
        let obj_size = sizes[i]
        let capacity = 4096 / obj_size  // one page worth
        volatile_write(meta, obj_size)
        volatile_write(meta + 8, capacity)
        volatile_write(meta + 16, 0)      // used = 0
        volatile_write(meta + 24, data_off) // bitmap
        volatile_write(meta + 32, data_off + capacity) // data
        // Clear bitmap
        let mut j: i64 = 0
        while j < capacity { volatile_write_u8(data_off + j, 0); j = j + 1 }
        data_off = data_off + capacity + capacity * obj_size
        i = i + 1
    }
}

@kernel fn slab_alloc(size: i64) -> i64 {
    // Find smallest slab that fits
    let sizes: [i64; 6] = [32, 64, 128, 256, 512, 1024]
    let mut i: i64 = 0
    while i < SLAB_SIZES {
        if sizes[i] >= size {
            let meta = SLAB_BASE + i * 40
            let capacity = volatile_read(meta + 8)
            let used = volatile_read(meta + 16)
            if used < capacity {
                let bitmap = volatile_read(meta + 24)
                let data = volatile_read(meta + 32)
                // Find free slot
                let mut j: i64 = 0
                while j < capacity {
                    if volatile_read_u8(bitmap + j) == 0 {
                        volatile_write_u8(bitmap + j, 1)
                        volatile_write(meta + 16, used + 1)
                        return data + j * sizes[i]
                    }
                    j = j + 1
                }
            }
        }
        i = i + 1
    }
    -1  // No suitable slab
}

@kernel fn slab_free(ptr: i64, size: i64) {
    let sizes: [i64; 6] = [32, 64, 128, 256, 512, 1024]
    let mut i: i64 = 0
    while i < SLAB_SIZES {
        if sizes[i] >= size {
            let meta = SLAB_BASE + i * 40
            let data = volatile_read(meta + 32)
            let bitmap = volatile_read(meta + 24)
            let slot = (ptr - data) / sizes[i]
            if slot >= 0 && slot < volatile_read(meta + 8) {
                volatile_write_u8(bitmap + slot, 0)
                let used = volatile_read(meta + 16)
                if used > 0 { volatile_write(meta + 16, used - 1) }
            }
            return
        }
        i = i + 1
    }
}

@kernel fn cmd_slab() {
    cprintln("Slab Allocator:", YELLOW_ON_BLACK)
    let sizes: [i64; 6] = [32, 64, 128, 256, 512, 1024]
    let mut i: i64 = 0
    while i < SLAB_SIZES {
        let meta = SLAB_BASE + i * 40
        let obj_size = volatile_read(meta)
        let capacity = volatile_read(meta + 8)
        let used = volatile_read(meta + 16)
        cprint("  ", WHITE_ON_BLACK)
        cprint_decimal(obj_size, CYAN_ON_BLACK)
        cprint("B: ", WHITE_ON_BLACK)
        cprint_decimal(used, WHITE_ON_BLACK)
        cprint("/", WHITE_ON_BLACK)
        cprint_decimal(capacity, WHITE_ON_BLACK)
        cprintln(" used", WHITE_ON_BLACK)
        i = i + 1
    }
}

// ═══════════════════════════════════════════════
