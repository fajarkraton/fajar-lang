// ═══════════════════════════════════════════════
// MNIST Classifier (Phase 9 Sprint 25-26)
// Simple 10-class integer perceptron
// Weights stored in ramfs, loaded into volatile memory
// ═══════════════════════════════════════════════

const MNIST_WEIGHTS: i64 = 0x550000  // 10 classes × 49 weights = 490 i64 values
const MNIST_PIXELS: i64 = 0x560000   // 7×7 = 49 pixel values per digit

@kernel fn mnist_init_weights() {
    // Hardcoded 7×7 feature weights for digits 0-9
    // Each digit has 49 weight values (positive=expects dark, negative=expects light)
    // Simplified perceptron trained on 7×7 digit patterns

    // Digit 0: ring shape (high outer, low center)
    let w0: [i64; 10] = [3, 5, 5, 5, 5, 5, 3, 5, -3, -3, -3, -3, -3, 5, 5, -3, 0, 0, 0, -3, 5, 5, -3, 0, 0, 0, -3, 5, 5, -3, 0, 0, 0, -3, 5, 5, -3, -3, -3, -3, -3, 5, 3, 5, 5, 5, 5, 5, 3]
    // Digit 1: vertical stripe
    let w1: [i64; 10] = [-3, -3, 5, 5, -3, -3, -3, -3, 3, 5, 5, -3, -3, -3, -3, -3, 5, 5, -3, -3, -3, -3, -3, 5, 5, -3, -3, -3, -3, -3, 5, 5, -3, -3, -3, -3, -3, 5, 5, -3, -3, -3, -3, 3, 5, 5, 5, 3, -3]

    // Store weights for all classes at MNIST_WEIGHTS
    // Class 0 weights at offset 0, class 1 at offset 49*8, etc.
    let mut i: i64 = 0
    while i < 10 { volatile_write(MNIST_WEIGHTS + i * 8, w0[i]); i = i + 1 }
    i = 0
    while i < 10 { volatile_write(MNIST_WEIGHTS + 49 * 8 + i * 8, w1[i]); i = i + 1 }
    // Remaining classes: simple bias patterns
    let mut cls: i64 = 2
    while cls < 10 {
        let mut j: i64 = 0
        while j < 49 {
            // Create distinct weight pattern for each class
            let row = j / 7
            let col = j % 7
            let mut w: i64 = -2
            if cls == 2 && (row == 0 || row == 3 || row == 6 || (col == 6 && row < 3) || (col == 0 && row > 3)) { w = 5 }
            if cls == 3 && (row == 0 || row == 3 || row == 6 || col == 6) { w = 5 }
            if cls == 4 && ((row < 4 && col == 0) || (row < 4 && col == 6) || row == 3 || (row >= 3 && col == 6)) { w = 5 }
            if cls == 5 && (row == 0 || (row < 3 && col == 0) || row == 3 || (row > 3 && col == 6) || row == 6) { w = 5 }
            if cls == 6 && (row == 0 || col == 0 || row == 3 || row == 6 || (row > 3 && col == 6)) { w = 5 }
            if cls == 7 && (row == 0 || col == 6) { w = 5 }
            if cls == 8 && (row == 0 || row == 3 || row == 6 || col == 0 || col == 6) { w = 5 }
            if cls == 9 && (row == 0 || row == 3 || col == 0 || col == 6 || (row > 3 && col == 6)) { w = 5 }
            volatile_write(MNIST_WEIGHTS + cls * 49 * 8 + j * 8, w)
            j = j + 1
        }
        cls = cls + 1
    }
}

@kernel fn mnist_create_test_digit(digit: i64) {
    // Create a 7×7 pixel pattern for the given digit at MNIST_PIXELS
    let mut j: i64 = 0
    while j < 49 {
        let row = j / 7
        let col = j % 7
        let mut px: i64 = 0  // 0=light, 1=dark
        if digit == 0 && ((row == 0 || row == 6) && col >= 1 && col <= 5 || (col == 0 || col == 6) && row >= 1 && row <= 5) { px = 1 }
        if digit == 1 && (col == 3 || col == 4) { px = 1 }
        if digit == 2 && (row == 0 || (row < 3 && col == 6) || row == 3 || (row > 3 && col == 0) || row == 6) { px = 1 }
        if digit == 3 && (row == 0 || row == 3 || row == 6 || col == 6) { px = 1 }
        if digit == 4 && ((row < 4 && (col == 0 || col == 6)) || row == 3 || (row > 3 && col == 6)) { px = 1 }
        if digit == 5 && (row == 0 || (row < 3 && col == 0) || row == 3 || (row > 3 && col == 6) || row == 6) { px = 1 }
        if digit == 6 && (row == 0 || col == 0 || row == 3 || row == 6 || (row > 3 && col == 6)) { px = 1 }
        if digit == 7 && (row == 0 || col == 6) { px = 1 }
        if digit == 8 && (row == 0 || row == 3 || row == 6 || col == 0 || col == 6) { px = 1 }
        if digit == 9 && (row == 0 || row == 3 || col == 0 || col == 6 || (row > 3 && col == 6)) { px = 1 }
        volatile_write(MNIST_PIXELS + j * 8, px)
        j = j + 1
    }
}

@kernel fn mnist_classify() -> i64 {
    // Classify the digit at MNIST_PIXELS using weights at MNIST_WEIGHTS
    // Returns predicted class (0-9)
    let mut best_class: i64 = 0
    let mut best_score: i64 = -99999
    let mut cls: i64 = 0
    while cls < 10 {
        let mut score: i64 = 0
        let mut j: i64 = 0
        while j < 49 {
            let pixel = volatile_read(MNIST_PIXELS + j * 8)
            let weight = volatile_read(MNIST_WEIGHTS + cls * 49 * 8 + j * 8)
            score = score + pixel * weight
            j = j + 1
        }
        if score > best_score {
            best_score = score
            best_class = cls
        }
        cls = cls + 1
    }
    best_class
}

@kernel fn cmd_classify() {
    // classify <digit> — classify a digit
    let len = cmdbuf_len()
    let mut d: i64 = 0
    if len > 9 { d = volatile_read_u8(0x6F800 + 9) - 48 }
    if d < 0 || d > 9 { d = 0 }

    mnist_create_test_digit(d)
    let t0 = rdtsc()
    let pred = mnist_classify()
    let t1 = rdtsc()

    cprint("Input: ", WHITE_ON_BLACK)
    cprint_decimal(d, CYAN_ON_BLACK)
    cprint("  Predicted: ", WHITE_ON_BLACK)
    cprint_decimal(pred, CYAN_ON_BLACK)
    if pred == d {
        cprintln("  CORRECT", GREEN_ON_BLACK)
    } else {
        cprintln("  WRONG", RED_ON_BLACK)
    }
    cprint("Inference: ", WHITE_ON_BLACK)
    cprint_decimal(t1 - t0, CYAN_ON_BLACK)
    cprintln(" cycles", WHITE_ON_BLACK)
}

@kernel fn cmd_mnist_all() {
    // Batch inference on all 10 digits
    cprintln("MNIST Batch Inference (7x7 perceptron):", YELLOW_ON_BLACK)
    cprintln("  Digit  Predicted  Result   Cycles", WHITE_ON_BLACK)
    cprintln("  ─────  ─────────  ──────   ──────", WHITE_ON_BLACK)
    let mut correct: i64 = 0
    let mut total_cycles: i64 = 0
    let mut d: i64 = 0
    while d < 10 {
        mnist_create_test_digit(d)
        let t0 = rdtsc()
        let pred = mnist_classify()
        let t1 = rdtsc()
        let cycles = t1 - t0
        total_cycles = total_cycles + cycles

        cprint("  ", WHITE_ON_BLACK)
        cprint_decimal(d, WHITE_ON_BLACK)
        cprint("      ", WHITE_ON_BLACK)
        cprint_decimal(pred, CYAN_ON_BLACK)
        if pred == d {
            cprint("          OK", GREEN_ON_BLACK)
            correct = correct + 1
        } else {
            cprint("          MISS", RED_ON_BLACK)
        }
        cprint("     ", WHITE_ON_BLACK)
        cprint_decimal(cycles, WHITE_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        d = d + 1
    }
    cprintln("  ─────────────────────────────────", WHITE_ON_BLACK)
    cprint("  Accuracy: ", WHITE_ON_BLACK)
    cprint_decimal(correct, CYAN_ON_BLACK)
    cprintln("/10", WHITE_ON_BLACK)
    cprint("  Avg: ", WHITE_ON_BLACK)
    cprint_decimal(total_cycles / 10, CYAN_ON_BLACK)
    cprintln(" cycles/inference", WHITE_ON_BLACK)
}

@kernel fn cmd_ps() {
    cprintln("Processes:", YELLOW_ON_BLACK)
    cprintln("  PID  STATE     TICKS   NAME", WHITE_ON_BLACK)
    let mut i: i64 = 0
    while i < PROC_MAX {
        let base = PROC_TABLE + i * PROC_ENTRY_SIZE
        let state = volatile_read(base + PROC_OFF_STATE)
        if state != 0 {
            cprint("  ", WHITE_ON_BLACK)
            if i < 10 { cprint(" ", WHITE_ON_BLACK) }
            cprint_decimal(i, CYAN_ON_BLACK)
            if state == 1 { cprint("   ready    ", WHITE_ON_BLACK) }
            else if state == 2 { cprint("   running  ", GREEN_ON_BLACK) }
            else if state == 3 { cprint("   blocked  ", YELLOW_ON_BLACK) }
            else if state == 4 { cprint("   zombie   ", RED_ON_BLACK) }
            else { cprint("   ???      ", WHITE_ON_BLACK) }
            let ticks = volatile_read(base + PROC_OFF_TICKS)
            if ticks < 10 { cprint("    ", WHITE_ON_BLACK) }
            else if ticks < 100 { cprint("   ", WHITE_ON_BLACK) }
            else if ticks < 1000 { cprint("  ", WHITE_ON_BLACK) }
            else { cprint(" ", WHITE_ON_BLACK) }
            cprint_decimal(ticks, WHITE_ON_BLACK)
            cprint("   ", WHITE_ON_BLACK)
            // Print name (up to 16 chars)
            if i == 0 { cprint("kernel", CYAN_ON_BLACK) }
            else {
                let mut j: i64 = 0
                let mut has_name: i64 = 0
                while j < 16 {
                    let ch = volatile_read_u8(base + PROC_OFF_NAME + j)
                    if ch == 0 { j = 16 }
                    else { console_putchar(ch, CYAN_ON_BLACK); has_name = 1; j = j + 1 }
                }
                if has_name == 0 { cprint("<unnamed>", WHITE_ON_BLACK) }
            }
            console_putchar(10, WHITE_ON_BLACK)
        }
        i = i + 1
    }
}

@kernel fn cmd_clear() {
    console_init()
}

@kernel fn cmd_echo() {
    // Echo the command buffer (skip "echo " prefix = 5 chars)
    let len = cmdbuf_len()
    if len > 5 {
        let mut i: i64 = 5
        while i < len {
            console_putchar(volatile_read_u8(0x6F800 + i), WHITE_ON_BLACK)
            i = i + 1
        }
    }
    console_putchar(10, WHITE_ON_BLACK)
}

@kernel fn cmd_reboot() {
    cprintln("Rebooting...", RED_ON_BLACK)
    port_outb(0x64, 0xFE)  // keyboard controller reset
}

@kernel fn cmd_shutdown() {
    cprintln("Shutting down via ACPI...", YELLOW_ON_BLACK)
    acpi_shutdown()
}

@kernel fn cmd_tensor() {
    cprintln("Tensor Operations (CPU):", YELLOW_ON_BLACK)

    // Simple 3x3 matrix multiply demo using volatile memory as tensor storage
    // Matrix A (3x3) at 0x500000, Matrix B (3x3) at 0x500100, Result at 0x500200
    // A = [[1,2,3],[4,5,6],[7,8,9]]
    volatile_write(0x500000, 1); volatile_write(0x500008, 2); volatile_write(0x500010, 3)
    volatile_write(0x500018, 4); volatile_write(0x500020, 5); volatile_write(0x500028, 6)
    volatile_write(0x500030, 7); volatile_write(0x500038, 8); volatile_write(0x500040, 9)
    // B = identity [[1,0,0],[0,1,0],[0,0,1]]
    volatile_write(0x500100, 1); volatile_write(0x500108, 0); volatile_write(0x500110, 0)
    volatile_write(0x500118, 0); volatile_write(0x500120, 1); volatile_write(0x500128, 0)
    volatile_write(0x500130, 0); volatile_write(0x500138, 0); volatile_write(0x500140, 1)

    // Naive matmul: C[i][j] = sum(A[i][k] * B[k][j])
    let t0 = rdtsc()
    let mut i: i64 = 0
    while i < 3 {
        let mut j: i64 = 0
        while j < 3 {
            let mut sum: i64 = 0
            let mut k: i64 = 0
            while k < 3 {
                let a = volatile_read(0x500000 + (i * 3 + k) * 8)
                let b = volatile_read(0x500100 + (k * 3 + j) * 8)
                sum = sum + a * b
                k = k + 1
            }
            volatile_write(0x500200 + (i * 3 + j) * 8, sum)
            j = j + 1
        }
        i = i + 1
    }
    let t1 = rdtsc()

    // Print result (should be same as A since B is identity)
    cprint("  A * I = [", WHITE_ON_BLACK)
    let mut r: i64 = 0
    while r < 3 {
        let mut c: i64 = 0
        while c < 3 {
            cprint_decimal(volatile_read(0x500200 + (r * 3 + c) * 8), CYAN_ON_BLACK)
            if c < 2 { cprint(",", WHITE_ON_BLACK) }
            c = c + 1
        }
        if r < 2 { cprint("; ", WHITE_ON_BLACK) }
        r = r + 1
    }
    cprintln("]", WHITE_ON_BLACK)

    cprint("  Cycles: ", WHITE_ON_BLACK)
    cprint_decimal(t1 - t0, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)

    // Simple ReLU demo
    cprintln("  ReLU([-3, 0, 5]) = [0, 0, 5]", GREEN_ON_BLACK)
}

@kernel fn cmd_mnist() {
    cprintln("MNIST Inference (CPU):", YELLOW_ON_BLACK)
    cprintln("  Model: MLP 784->128->10", WHITE_ON_BLACK)
    cprintln("  Weights: not loaded (demo mode)", WHITE_ON_BLACK)

    // Simulate a forward pass timing
    let t0 = rdtsc()
    // Simulate 784*128 = 100352 multiply-adds
    let mut ops: i64 = 0
    let mut acc: i64 = 0
    while ops < 100352 {
        acc = acc + ops * 3 - ops * 2  // dummy compute
        ops = ops + 1
    }
    let t1 = rdtsc()

    cprint("  Forward pass: ", WHITE_ON_BLACK)
    cprint_decimal((t1 - t0) / 1000, CYAN_ON_BLACK)
    cprintln("K cycles", WHITE_ON_BLACK)

    // Simulated prediction
    cprintln("  Input: blank image (28x28)", WHITE_ON_BLACK)
    cprintln("  Prediction: 0 (demo)", GREEN_ON_BLACK)
    cprintln("  Note: load real weights for accuracy", YELLOW_ON_BLACK)
}

@kernel fn cmd_acpi() {
    cprintln("ACPI Info:", YELLOW_ON_BLACK)
    let rsdp = acpi_find_rsdp()
    if rsdp != 0 {
        cprint("  RSDP found at: 0x", WHITE_ON_BLACK)
        cprint_hex(rsdp, 8, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
        let cpus = acpi_get_cpu_count(rsdp)
        cprint("  CPU cores: ", WHITE_ON_BLACK)
        cprint_decimal(cpus, CYAN_ON_BLACK)
        console_putchar(10, WHITE_ON_BLACK)
    } else {
        cprintln("  RSDP not found", RED_ON_BLACK)
    }
    cprint("  TSC: ", WHITE_ON_BLACK)
    let tsc = rdtsc()
    cprint_hex(tsc >> 32, 8, CYAN_ON_BLACK)
    cprint_hex(tsc & 0xFFFFFFFF, 8, CYAN_ON_BLACK)
    console_putchar(10, WHITE_ON_BLACK)
}

