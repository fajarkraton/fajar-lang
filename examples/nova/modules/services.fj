        cprintln("    ##  ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("   ###  ", WHITE_ON_BLACK)
    } else if n == 4 {
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  ##### ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
    } else if n == 5 {
        cprintln("  ##### ", WHITE_ON_BLACK)
        cprintln("  #     ", WHITE_ON_BLACK)
        cprintln("  ####  ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("   ###  ", WHITE_ON_BLACK)
    } else if n == 6 {
        cprintln("   ###  ", WHITE_ON_BLACK)
        cprintln("  #     ", WHITE_ON_BLACK)
        cprintln("  ####  ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("  #   # ", WHITE_ON_BLACK)
        cprintln("   ###  ", WHITE_ON_BLACK)
    } else if n == 7 {
        cprintln("  ##### ", WHITE_ON_BLACK)
        cprintln("      # ", WHITE_ON_BLACK)
        cprintln("     #  ", WHITE_ON_BLACK)
        cprintln("    #   ", WHITE_ON_BLACK)
