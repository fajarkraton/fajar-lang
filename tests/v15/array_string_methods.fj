// Test array methods
let mut arr = [1, 2, 3, 4, 5]

// pop
let last = arr.pop()
println(f"pop: {last}")
assert_eq(last, 5)

// push
let arr2 = [10, 20].push(30)
println(f"push: {arr2}")

// insert
let arr3 = [1, 3, 4].insert(1, 2)
println(f"insert: {arr3}")
assert_eq(arr3[1], 2)

// remove
let arr4 = [1, 2, 3, 4].remove(1)
println(f"remove: {arr4}")
assert_eq(arr4[1], 3)

// index_of
let idx = [10, 20, 30, 40].index_of(30)
println(f"index_of 30: {idx}")
assert_eq(idx, 2)

// sort, reverse, contains
let sorted = [5, 1, 3].sort()
assert_eq(sorted[0], 1)
assert_eq(sorted[2], 5)

let rev = [1, 2, 3].reverse()
assert_eq(rev[0], 3)

assert([1, 2, 3].contains(2))

// sum, min, max
let s = [1, 2, 3, 4].sum()
assert_eq(s, 10)

// String methods
let text = "hello world"
assert_eq(text.to_upper(), "HELLO WORLD")
assert_eq(text.to_lower(), "hello world")

let chars = "abc".chars()
assert_eq(len(chars), 3)

let rep = "ha".repeat(3)
assert_eq(rep, "hahaha")

// Array concat (V16 feature)
let c = [1, 2] + [3, 4]
assert_eq(len(c), 4)
assert_eq(c[2], 3)

println("PASS: all array & string methods")
