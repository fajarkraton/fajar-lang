// Test array destructuring
match [1, 2, 3, 4, 5] {
    [first, second, ..rest] => {
        println(f"first={first}, second={second}, rest={rest}")
        assert_eq(first, 1)
        assert_eq(second, 2)
        assert_eq(len(rest), 3)
        assert_eq(rest[0], 3)
    }
    _ => println("no match")
}

// Test binding pattern
match 42 {
    n @ 1..100 => {
        println(f"matched n={n} in range 1..100")
        assert_eq(n, 42)
    }
    _ => println("no match")
}

// Combine: array + binding
match [10, 20, 30] {
    [x, ..tail] => {
        println(f"head={x}, tail={tail}")
        assert_eq(x, 10)
        assert_eq(len(tail), 2)
    }
    _ => println("no match")
}

println("PASS: array destructure + @ binding")
