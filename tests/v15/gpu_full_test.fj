// V16 G1: Full @gpu Context Rules Test Suite

// G1.1: @gpu blocks raw pointers — tested via fj check (analyzer error)
// G1.2: @gpu blocks syscalls — tested via fj check (analyzer error)

// G1.3: @gpu allows tensor ops
@gpu fn gpu_tensor_test() -> f64 {
    let t = zeros(2, 2)
    let o = ones(2, 2)
    1.0
}
assert_eq(gpu_tensor_test(), 1.0)

// G1.4: @gpu allows math builtins
@gpu fn gpu_math_test(x: f64) -> f64 {
    sin(x) + cos(x) + sqrt(abs(x))
}
let m = gpu_math_test(1.0)
println(f"GPU math: {m}")

// G1.5: @gpu blocks file I/O — tested via fj check (analyzer error)

// G1.7: @gpu allows shared memory (mock in interpreter)
@gpu fn gpu_shared_test() -> i64 {
    // In real GPU, this would use __shared__ memory
    // In interpreter, it's just a local variable
    let shared_val = 42
    shared_val
}
assert_eq(gpu_shared_test(), 42)

// G1.8: @gpu thread indexing
@gpu fn gpu_thread_test() -> i64 {
    let tid = thread_idx(0)
    let bid = block_idx()
    let bdim = block_dim(0)
    let gdim = grid_dim()
    // In interpreter: all return mock values (0, 0, 1, 1)
    tid + bid + bdim + gdim
}
let thread_result = gpu_thread_test()
println(f"GPU thread: tid+bid+bdim+gdim = {thread_result}")
assert_eq(thread_result, 2) // 0 + 0 + 1 + 1

// G1.9: @device can call @gpu
@gpu fn gpu_compute(a: f64, b: f64) -> f64 {
    a * b
}

@device fn device_uses_gpu() -> f64 {
    gpu_compute(3.0, 4.0)
}

let d = device_uses_gpu()
assert_eq(d, 12.0)

// G1.10: Comprehensive @gpu test
@gpu fn gpu_full(x: f64, y: f64) -> f64 {
    let mag = sqrt(x * x + y * y)
    let angle = sin(x) + cos(y)
    gpu_sync()
    mag + angle
}

let full = gpu_full(3.0, 4.0)
println(f"GPU full compute: {full}")

println("PASS: G1 full @gpu test suite (10 tests)")
