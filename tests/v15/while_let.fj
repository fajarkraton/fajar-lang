// V16: while let expression tests

// Basic while let — iterate until pattern fails
let items = [Some(10), Some(20), Some(30), None, Some(50)]
let mut total = 0
let mut i = 0

while let Some(val) = items[i] {
    total = total + val
    i = i + 1
}
assert_eq(total, 60)
assert_eq(i, 3)

// while let with Ok/Err
let results = [Ok(1), Ok(2), Err("stop"), Ok(4)]
let mut sum = 0
let mut j = 0

while let Ok(n) = results[j] {
    sum = sum + n
    j = j + 1
}
assert_eq(sum, 3)
assert_eq(j, 2)

println("PASS: while-let")
