// V16 X1: REPL Features — Tests features that work in both REPL and script mode
//
// All features here work identically in:
//   fj repl          (interactive REPL)
//   fj run file.fj   (script mode)
//
// The REPL provides additional conveniences like multi-line editing,
// history, and tab completion via the LSP server.

// ── X1.1: Expression evaluation ──
// In REPL, bare expressions print their value. In script mode, we verify via assert.
let a = 2 + 3 * 4
assert_eq(a, 14)

let b = (2 + 3) * 4
assert_eq(b, 20)

let c = 10 % 3
assert_eq(c, 1)

let d = 2 ** 10
assert_eq(d, 1024)

// ── X1.2: Variable shadowing ──
// REPL often re-binds variables — shadowing must work
let x = 10
assert_eq(x, 10)

let x = 20
assert_eq(x, 20)

let x = "now a string"
assert_eq(x, "now a string")

let x = [1, 2, 3]
assert_eq(len(x), 3)

// ── X1.3: Function definition and redefinition ──
// In REPL, users often redefine functions to fix mistakes
fn greet(name: str) -> str {
    f"Hello, {name}!"
}
let g1 = greet("World")
assert_eq(g1, "Hello, World!")

// Redefine with different body
fn greet(name: str) -> str {
    f"Hi, {name}!"
}
let g2 = greet("World")
assert_eq(g2, "Hi, World!")

// ── X1.4: F-string interpolation (all types) ──
let int_val = 42
let float_val = 3.14
let str_val = "fajar"
let bool_val = true

assert_eq(f"int: {int_val}", "int: 42")
assert_eq(f"float: {float_val}", "float: 3.14")
assert_eq(f"str: {str_val}", "str: fajar")
assert_eq(f"bool: {bool_val}", "bool: true")

// Expressions inside f-strings
assert_eq(f"sum: {2 + 3}", "sum: 5")
assert_eq(f"len: {len([1, 2, 3])}", "len: 3")

// ── X1.5: Closure definition and invocation ──
let double = |x| x * 2
assert_eq(double(5), 10)

let add = |a, b| a + b
assert_eq(add(3, 4), 7)

// Closure with capture
let factor = 10
let scale = |x| x * factor
assert_eq(scale(5), 50)

// ── X1.6: Inline struct and enum usage ──
struct Point { x: f64, y: f64 }
let p = Point { x: 1.0, y: 2.0 }
assert_eq(p.x, 1.0)
assert_eq(p.y, 2.0)

let opt = Some(42)
let val = match opt {
    Some(v) => v
    None => 0
}
assert_eq(val, 42)

// ── X1.7: Multi-line expressions ──
// In REPL, these span multiple lines with auto-continuation
let result = if true {
    let inner = 10
    inner * 2
} else {
    0
}
assert_eq(result, 20)

let matched = match "hello" {
    "hello" => 1
    "world" => 2
    _ => 0
}
assert_eq(matched, 1)

// ── X1.8: Type introspection with type_of ──
assert_eq(type_of(42), "i64")
assert_eq(type_of(3.14), "f64")
assert_eq(type_of("hello"), "str")
assert_eq(type_of(true), "bool")
assert_eq(type_of([1, 2, 3]), "array")
assert_eq(type_of(Some(1)), "enum")

// ── X1.9: Chained method calls ──
let nums = [5, 3, 1, 4, 2]
let sorted = nums.sort()
assert_eq(sorted[0], 1)
assert_eq(sorted[4], 5)

let doubled = [1, 2, 3].map(|x| x * 2)
assert_eq(doubled[0], 2)
assert_eq(doubled[1], 4)
assert_eq(doubled[2], 6)

let evens = [1, 2, 3, 4, 5, 6].filter(|x| x % 2 == 0)
assert_eq(len(evens), 3)

// ── X1.10: Error handling in REPL ──
// REPL shows errors without crashing — verify graceful handling
let safe_result = match "abc".parse_int() {
    Ok(n) => n
    Err(_) => -1
}
assert_eq(safe_result, -1)

if let Ok(n) = "123".parse_int() {
    assert_eq(n, 123)
} else {
    panic("should parse")
}

println("PASS: X1 REPL features (10 tests)")
